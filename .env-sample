# Copy to `.env` and adjust as needed. Compose loads `.env` automatically.

# Host port the container is published on. The container always listens on 8080 internally.
HOST_PORT=8080

# Standard ASP.NET Core environment. Use `Development` locally for verbose errors.
ASPNETCORE_ENVIRONMENT=Production

# Shared admin password for the /admin section. Auth lands in milestone 6 — for
# milestone 3 this can be left empty. In production prefer ADMIN_PASSWORD_FILE
# (mounted as a docker secret) so the value never appears in `docker inspect`.
ADMIN_PASSWORD=
