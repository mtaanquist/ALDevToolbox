# Copy to `.env` and adjust as needed. Compose loads `.env` automatically.

# --- App ---------------------------------------------------------------------

# Host port the published container listens on. The container always binds 8080
# internally — only the host-side mapping is configurable.
HOST_PORT=8080

# Standard ASP.NET Core environment. Use `Development` locally for verbose
# errors; leave as `Production` for any real deployment.
ASPNETCORE_ENVIRONMENT=Production

# --- Database ----------------------------------------------------------------

# Credentials for the bundled Postgres service. The app connection string in
# compose.yml is assembled from these three values, so change them in one place
# and both sides stay in sync. Override before first boot — once the pg-data
# volume is initialised, changing these here won't rotate the existing role.
POSTGRES_USER=aldevtoolbox
POSTGRES_PASSWORD=aldevtoolbox
POSTGRES_DB=aldevtoolbox

# --- Bootstrap admin ---------------------------------------------------------

# On a fresh database the app provisions one SiteAdmin account from these two
# variables and stamps it onto the singleton system org. Leave blank after the
# first boot — they're ignored once a SiteAdmin exists. Promote further admins
# from /site-admin/users.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# --- Email (SMTP) ------------------------------------------------------------

# SMTP is normally configured at runtime from /site-admin/settings (stored in
# the database, password encrypted with the Data Protection key ring). These
# env vars are a fallback used when no DB row is set yet — handy for a fresh
# deployment that wants email working before the first SiteAdmin signs in.
#
# Configuring SMTP does more than send notifications: it switches /signup into
# the email-first VERIFIED flow (the visitor must confirm a one-time link or
# code before an account is created). With no SMTP configured, /signup falls
# back to the legacy single-form signup with no email verification.
#
# SMTP_PASSWORD_FILE is a path to a file containing the password (Docker-secret
# style), not the password itself. Leave the whole block unset to keep email off.
#SMTP_HOST=
#SMTP_PORT=587
#SMTP_USER=
#SMTP_PASSWORD_FILE=
#SMTP_FROM=
#SMTP_USE_STARTTLS=true

# --- Passkeys (WebAuthn) -----------------------------------------------------

# Set both to expose passkey sign-in. Leave RP id blank in dev / behind an
# unstable hostname — the /account UI hides the passkeys section and the
# server refuses to start ceremonies when RpId is unset, so it's safe to
# defer until you have a real hostname.
#
# - RP id must be a registrable suffix of the hostname the browser sees
#   (e.g. `aldevtoolbox.example.com`, NOT `https://…` and NOT a path).
# - Origins is a comma-separated list of full `https://host` values the
#   server will accept; pass at least the public hostname, plus any extra
#   origins users will reach the app through (admin subdomain, staging).
AUTH_WEBAUTHN_RP_ID=
AUTH_WEBAUTHN_ORIGINS=
