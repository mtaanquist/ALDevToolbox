<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <BlazorDisableThrowNavigationException>true</BlazorDisableThrowNavigationException>
  </PropertyGroup>

  <ItemGroup>
    <EmbeddedResource Include="Resources/logo.png" LogicalName="ALDevToolbox.Resources.logo.png" />
    <EmbeddedResource Include="Resources/Company.ruleset.json" LogicalName="ALDevToolbox.Resources.Company.ruleset.json" />
    <EmbeddedResource Include="Resources/al.gitignore" LogicalName="ALDevToolbox.Resources.al.gitignore" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Lucide.Blazor" Version="0.0.38" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="10.*">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="Microsoft.EntityFrameworkCore.Sqlite" Version="10.*" />
    <PackageReference Include="Tomlyn" Version="2.3.2" />
  </ItemGroup>

</Project>
