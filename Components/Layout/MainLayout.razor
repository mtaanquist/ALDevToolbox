@inherits LayoutComponentBase
@using Lucide.Blazor.Components

<div class="app-shell">
    <header class="top-bar">
        <div class="top-bar__brand">
            <Icon Name="hammer" Css="brand-icon" Width="20" Height="20" />
            <span class="brand-name">AL Dev Toolbox</span>
        </div>
        <div class="top-bar__user">
            <ThemeToggle />
            <AuthorizeView>
                <Authorized>
                    <span class="signed-in-as">
                        Signed in as <strong>@context.User.Identity?.Name</strong>
                    </span>
                    <form method="post" action="/auth/logout" class="signout-form">
                        <AntiforgeryToken />
                        <button type="submit" class="signin-link signin-link--button">Sign out</button>
                    </form>
                </Authorized>
                <NotAuthorized>
                    <a href="/login" class="signin-link">
                        <Icon Name="log-in" Width="14" Height="14" />
                        <span>Sign in</span>
                    </a>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </header>

    <aside class="sidebar">
        <NavMenu />
    </aside>

    <main class="content">
        @Body
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">×</span>
</div>
