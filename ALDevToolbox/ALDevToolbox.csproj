<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <BlazorDisableThrowNavigationException>true</BlazorDisableThrowNavigationException>
  </PropertyGroup>

  <ItemGroup>
    <!-- The ruleset and .gitignore template stay as embedded resources: they
         are per-deployment policy rather than per-org config and don't have a
         clear customisation story yet (see milestones.md). The logo moved into
         Templates.seed/organization-defaults/ at M14 and is now stored per-org
         in the organization_assets table. -->
    <EmbeddedResource Include="Resources/Company.ruleset.json" LogicalName="ALDevToolbox.Resources.Company.ruleset.json" />
    <EmbeddedResource Include="Resources/al.gitignore" LogicalName="ALDevToolbox.Resources.al.gitignore" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="BCrypt.Net-Next" Version="4.0.3" />
    <PackageReference Include="Lucide.Blazor" Version="0.0.38" />
    <PackageReference Include="MailKit" Version="4.7.1.1" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="10.*">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="Microsoft.EntityFrameworkCore.Sqlite" Version="10.*" />
    <PackageReference Include="Tomlyn" Version="2.3.2" />
  </ItemGroup>

</Project>
