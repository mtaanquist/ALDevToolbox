@inherits LayoutComponentBase
@using System.Security.Claims
@using ALDevToolbox.Services
@inject OrganizationConfigService Config

<div class="app-shell">
    <header class="top-bar">
        <div class="top-bar__brand">
            <Icon Name="hammer" Css="brand-icon" Width="20" Height="20" />
            <span class="brand-name">AL Dev Toolbox</span>
        </div>
        <div class="top-bar__user">
            <ThemeToggle />
            <AuthorizeView>
                <Authorized>
                    @{
                        // Prefer the live (cached) name so a rename via
                        // /admin/configuration/identity takes effect for every
                        // active circuit without forcing a re-login. Fall back
                        // to the org_name claim if the live lookup hasn't
                        // completed yet, so the first prerender frame still
                        // shows something useful.
                        var orgName = !string.IsNullOrEmpty(_liveOrgName)
                            ? _liveOrgName
                            : context.User.FindFirst("org_name")?.Value;
                        var roles = context.User.FindAll(ClaimTypes.Role).Select(c => c.Value).ToList();
                        var role = roles.Contains("SiteAdmin") ? "Site admin"
                            : roles.Contains("Admin") ? "Admin"
                            : roles.FirstOrDefault();
                        var name = context.User.Identity?.Name;
                    }
                    <a href="/account" class="user-button" title="Manage your account">
                        <span class="user-button__name">@name</span>
                        @if (!string.IsNullOrEmpty(orgName))
                        {
                            <span class="user-button__org">(@orgName)</span>
                        }
                        @if (!string.IsNullOrEmpty(role))
                        {
                            <span class="user-button__role" title="@role">@role</span>
                        }
                    </a>
                    <form method="post" action="/auth/logout" class="signout-form">
                        <AntiforgeryToken />
                        <button type="submit" class="user-button" title="Sign out">
                            <Icon Name="log-out" Width="14" Height="14" Css="user-button__icon" />
                        </button>
                    </form>
                </Authorized>
                <NotAuthorized>
                    <a href="/login" class="signin-link signin-link--icon" aria-label="Sign in" title="Sign in">
                        <Icon Name="log-in" Width="16" Height="16" />
                    </a>
                    <a href="/signup" class="signin-link" aria-label="Sign up" title="Sign up">Sign up</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </header>

    <aside class="sidebar">
        <NavMenu />
    </aside>

    <main class="content">
        @Body
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">×</span>
</div>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthStateTask { get; set; }

    private string? _liveOrgName;

    protected override async Task OnInitializedAsync()
    {
        if (AuthStateTask is null) return;
        var state = await AuthStateTask;
        var orgIdClaim = state.User.FindFirst(HttpOrganizationContext.OrganizationIdClaim)?.Value;
        if (int.TryParse(orgIdClaim, out var orgId))
        {
            _liveOrgName = await Config.GetOrganizationNameAsync(orgId);
        }
    }
}
