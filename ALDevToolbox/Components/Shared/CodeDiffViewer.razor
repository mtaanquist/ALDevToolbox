@using ALDevToolbox.Services

@*
    Side-by-side diff renderer. Computes the per-side line decorations from
    BaseAppDiffResult and hands them to two CodeViewer instances. CodeMirror
    handles line numbers, syntax highlighting, and folding; the colour bands
    on added / removed / modified lines come from .cm-line--diff-* rules in
    app.css.

    "Imaginary" diff rows (DiffPlex padding so both sides align) carry no
    actual text in CodeMirror — they would skew the line numbers. We drop
    them when reconstructing the doc, then translate the surviving diff
    classes into 1-based line decorations.
*@

<div class="code-diff" role="region" aria-label="@AriaLabel">
    <div class="code-diff__pane">
        <header class="code-diff__pane-header">@LeftLabel</header>
        <CodeViewer Content="_leftText" Language="@Language" LineClasses="_leftClasses" />
    </div>
    <div class="code-diff__pane">
        <header class="code-diff__pane-header">@RightLabel</header>
        <CodeViewer Content="_rightText" Language="@Language" LineClasses="_rightClasses" />
    </div>
</div>

@code {
    [Parameter, EditorRequired] public BaseAppDiffResult Diff { get; set; } = default!;
    [Parameter] public string LeftLabel { get; set; } = "Before";
    [Parameter] public string RightLabel { get; set; } = "After";
    [Parameter] public string AriaLabel { get; set; } = "Side-by-side diff";
    [Parameter] public string Language { get; set; } = "al";

    private string _leftText = string.Empty;
    private string _rightText = string.Empty;
    private Dictionary<int, string>? _leftClasses;
    private Dictionary<int, string>? _rightClasses;

    protected override void OnParametersSet()
    {
        (_leftText, _leftClasses) = Project(Diff.Left, mutationClass: "cm-line--diff-removed");
        (_rightText, _rightClasses) = Project(Diff.Right, mutationClass: "cm-line--diff-added");
    }

    private static (string text, Dictionary<int, string> classes) Project(
        IReadOnlyList<BaseAppDiffLine> rows, string mutationClass)
    {
        var sb = new System.Text.StringBuilder();
        var classes = new Dictionary<int, string>();
        var lineNo = 0;
        for (var i = 0; i < rows.Count; i++)
        {
            var row = rows[i];
            // Imaginary rows are padding to align the two sides; they have
            // no source representation, so we drop them. The mirrored CodeViewer
            // on the other pane already shows the "real" line.
            if (row.Change == BaseAppDiffChange.Imaginary) continue;

            lineNo++;
            if (lineNo > 1) sb.Append('\n');
            sb.Append(row.Text ?? string.Empty);

            var cls = row.Change switch
            {
                BaseAppDiffChange.Inserted => mutationClass,
                BaseAppDiffChange.Deleted => mutationClass,
                BaseAppDiffChange.Modified => "cm-line--diff-modified",
                _ => null,
            };
            if (cls is not null) classes[lineNo] = cls;
        }
        return (sb.ToString(), classes);
    }
}
