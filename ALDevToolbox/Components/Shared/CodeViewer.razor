@inject IJSRuntime JS
@inject NavigationManager Nav
@implements IAsyncDisposable

@*
    Read-only CodeMirror 6 viewer. Mounts the same /code-editor.js module the
    TOML editor uses (Admin/AdminTemplateEdit, Admin/AdminConfigurationWorkspace)
    via its mountReadOnly export.

    Carries the Object Explorer click-to-find gesture: pass Declarations and
    the component decorates each declaration name with a hoverable class
    plus a right-click "Find references" menu. The Razor side handles the
    navigation via NavigationManager (no SymbolReferences URL leakage into JS).
*@

<div class="code-viewer-host @(Fluid ? "code-viewer-host--fluid" : null)" @ref="_container"></div>

@code {
    /// <summary>The source text to render. Re-passing this prop after mount calls <c>setValue</c>.</summary>
    [Parameter, EditorRequired] public string Content { get; set; } = string.Empty;

    /// <summary>Language mode for highlighting (<c>al</c>, <c>toml</c>, <c>json</c>, or empty).</summary>
    [Parameter] public string Language { get; set; } = "al";

    /// <summary>Optional per-line CSS classes keyed by 1-based line number (diff highlighting).</summary>
    [Parameter] public IReadOnlyDictionary<int, string>? LineClasses { get; set; }

    /// <summary>
    /// Optional declaration ranges. When supplied (and <see cref="OnFindReferences"/>
    /// is set), the viewer draws a faint underline on each declaration name and
    /// shows a "Find references" menu on right-click.
    /// </summary>
    [Parameter] public IReadOnlyList<CodeViewerDeclaration>? Declarations { get; set; }

    /// <summary>
    /// Optional resolvable-token ranges. Cosmetic-only ranges that get a faint
    /// underline so users see which call sites have a jump target; the actual
    /// resolution still happens server-side on Cmd/Ctrl-click.
    /// </summary>
    [Parameter] public IReadOnlyList<CodeViewerResolvable>? Resolvables { get; set; }

    /// <summary>Invoked from the right-click menu when the user picks "Find references".</summary>
    [Parameter] public EventCallback<long> OnFindReferences { get; set; }

    /// <summary>
    /// Invoked when the user Cmd/Ctrl-clicks a token in the viewer. The
    /// callback receives a 1-based <c>(line, column)</c> pair; the page
    /// resolves the click against the symbol tables and navigates.
    /// </summary>
    [Parameter] public EventCallback<CodeViewerClick> OnGoToDefinition { get; set; }

    /// <summary>
    /// Invoked when the user picks "Find in this file" from the right-click
    /// menu. The callback receives the click position; the page extracts the
    /// word and runs the in-file occurrence search.
    /// </summary>
    [Parameter] public EventCallback<CodeViewerClick> OnFindInFile { get; set; }

    /// <summary>
    /// Optional 1-based line number to scroll to (and flash) after mount.
    /// FileViewer reads this from the URL's <c>#L&lt;n&gt;</c> fragment.
    /// </summary>
    [Parameter] public int? ScrollToLine { get; set; }

    /// <summary>
    /// Monotonic token that the parent bumps each time it wants the viewer to
    /// re-scroll to <see cref="ScrollToLine"/>. Without it, clicking the same
    /// reference twice (or clicking the line you're already on) is a no-op
    /// — the line value didn't change so the viewer thought there was
    /// nothing to do.
    /// </summary>
    [Parameter] public int ScrollSequence { get; set; }

    /// <summary>
    /// When true, the editor grows to fit its content height instead of
    /// scrolling internally — the page scrolls instead. Used by the
    /// single-file viewer so long files extend the page and the
    /// inspector panel can sticky-follow. The side-by-side diff leaves
    /// it false so both panes share an aligned, bounded scroll context.
    /// </summary>
    [Parameter] public bool Fluid { get; set; }

    private ElementReference _container;
    private IJSObjectReference? _module;
    private int _editorId;
    private string? _mountedContent;
    private int _mountedScrollSequence = -1;
    private DotNetObjectReference<CodeViewerCallbacks>? _callbacks;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _module = await JS.InvokeAsync<IJSObjectReference>("import", "/code-editor.js");
            _callbacks = DotNetObjectReference.Create(new CodeViewerCallbacks(this));

            var options = new
            {
                lineDecorations = LineClasses is null
                    ? null
                    : LineClasses.ToDictionary(kvp => kvp.Key.ToString(), kvp => kvp.Value),
                declarations = Declarations?.Select(d => new
                {
                    line = d.Line,
                    columnStart = d.ColumnStart,
                    columnEnd = d.ColumnEnd,
                    symbolId = d.SymbolId,
                    kind = d.Kind,
                    name = d.Name,
                }).ToArray(),
                resolvables = Resolvables?.Select(r => new
                {
                    line = r.Line,
                    columnStart = r.ColumnStart,
                    columnEnd = r.ColumnEnd,
                }).ToArray(),
                // Pass the .NET reference when either gesture is wired up.
                // Right-click only fires when declarations exist, but
                // Cmd/Ctrl-click is meaningful even without a symbol index.
                dotNetRef = (Declarations is { Count: > 0 } || OnGoToDefinition.HasDelegate)
                    ? _callbacks : null,
                scrollToLine = ScrollToLine,
            };

            _editorId = await _module.InvokeAsync<int>(
                "mountReadOnly", _container, Content ?? string.Empty, Language, options);
            _mountedContent = Content;
            _mountedScrollSequence = ScrollSequence;
            return;
        }

        if (_module is null || _editorId == 0) return;

        if (!string.Equals(_mountedContent, Content, StringComparison.Ordinal))
        {
            await _module.InvokeVoidAsync("setValue", _editorId, Content ?? string.Empty);
            _mountedContent = Content;
        }

        // Re-scroll whenever the parent bumps the sequence — covers both
        // "go to definition lands inside the current file" and "user clicks
        // the same outline / reference link again after scrolling away".
        // Stamp _mountedScrollSequence *before* the await so a follow-up
        // render (e.g. from the explicit-then-auto StateHasChanged pair
        // a parent fires for one user click) doesn't queue a second
        // identical scrollToLine while this one is still in flight.
        if (ScrollToLine is { } line && line >= 1 && _mountedScrollSequence != ScrollSequence)
        {
            _mountedScrollSequence = ScrollSequence;
            await _module.InvokeVoidAsync("scrollToLine", _editorId, line, true);
        }
    }

    internal async Task TriggerFindReferencesAsync(long symbolId)
    {
        if (OnFindReferences.HasDelegate)
        {
            await OnFindReferences.InvokeAsync(symbolId);
        }
    }

    internal async Task TriggerGoToDefinitionAsync(int line, int column)
    {
        if (OnGoToDefinition.HasDelegate)
        {
            await OnGoToDefinition.InvokeAsync(new CodeViewerClick(line, column));
        }
    }

    internal async Task TriggerFindInFileAsync(int line, int column)
    {
        if (OnFindInFile.HasDelegate)
        {
            await OnFindInFile.InvokeAsync(new CodeViewerClick(line, column));
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null && _editorId != 0)
        {
            try { await _module.InvokeVoidAsync("dispose", _editorId); }
            catch (JSDisconnectedException) { }
            catch (TaskCanceledException) { }
        }
        if (_module is not null)
        {
            try { await _module.DisposeAsync(); }
            catch (JSDisconnectedException) { }
            catch (TaskCanceledException) { }
        }
        _callbacks?.Dispose();
    }
}
