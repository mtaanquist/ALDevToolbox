@rendermode InteractiveServer
@inject ALDevToolbox.Services.ObjectExplorer.DeliveryService Deliveries
@inject ILogger<ReleaseBuildDialog> Log
@using ALDevToolbox.Domain.ValueObjects
@using ALDevToolbox.Domain.ValueObjects.ObjectExplorer
@using ALDevToolbox.Domain.Entities.ObjectExplorer

@*
    Release a build through a release pipeline: pick which successful build to publish
    (defaults to the latest), pick when (prefilled to the next opening of the target
    environment's update window, or now if it has none), confirm a Production target,
    and release. "Release now" runs immediately; a future time is enqueued by the
    DeliveryScheduler when due. Picking a time outside the window is allowed but
    recorded. Times are shown in the customer's timezone. Opened imperatively; raises
    OnReleased with the new delivery id. See .design/saas-delivery.md.

    Named user: a BC consultant publishing a finished build to a customer environment.
*@

@if (_open)
{
    <div class="confirm-modal" role="dialog" aria-modal="true" aria-labelledby="rb-title"
         tabindex="-1" @onkeydown="OnKeyDown" @ref="_root">
        <div class="confirm-modal__backdrop" @onclick="Cancel" aria-hidden="true"></div>
        <div class="confirm-modal__panel" @onclick:stopPropagation>
            <h2 id="rb-title" class="confirm-modal__title">Release to @_envName</h2>

            <p class="confirm-modal__message">
                Uploads the build's apps to <b>@_envName</b> and installs them. Installs use
                <b>@_versionMode</b>@(_schemaSyncMode == SchemaSyncMode.ForceSync ? ", with Force Sync (which can drop columns)" : "").
            </p>

            <div class="pe-field">
                <label class="field__label" for="rb-build">Build to release</label>
                <select id="rb-build" class="field__input" @bind="_buildId" disabled="@_releasing">
                    @foreach (var b in _builds)
                    {
                        <option value="@b.Id">@b.Label</option>
                    }
                </select>
                <small class="muted">The latest successful build is selected. Older successful builds are available too.</small>
            </div>

            <div class="pe-field">
                <label class="field__label" for="rb-when">When</label>
                <div class="rb-when-row">
                    <input id="rb-when" type="datetime-local" class="field__input" @bind="_scheduledLocal" @bind:event="oninput" disabled="@_releasing" />
                    <button type="button" class="btn btn--sm" @onclick="SetNow" disabled="@_releasing">Now</button>
                </div>
                <small class="muted">
                    Time is in the customer's timezone (@_tzLabel).
                    @if (_hasWindow)
                    {
                        <text> Update window @WindowLabel; prefilled to its next opening.</text>
                    }
                </small>
                @if (_hasWindow && IsOutsideWindow)
                {
                    <small class="rb-outside"><Icon Name="triangle-alert" Width="13" Height="13" />Outside the update window — this will be recorded on the delivery.</small>
                }
                @if (SecretWarning is { } secretWarn)
                {
                    <small class="rb-outside"><Icon Name="triangle-alert" Width="13" Height="13" />@secretWarn</small>
                }
            </div>

            @if (_isProduction)
            {
                <label class="rpe-confirm">
                    <input type="checkbox" checked="@_prodAck"
                           @onchange="e => _prodAck = (bool)(e.Value ?? false)" disabled="@_releasing" />
                    @if (_envNameIsProduction)
                    {
                        <span>I understand this installs the apps into the live <b>Production</b> environment.</span>
                    }
                    else
                    {
                        <span>I understand this installs the apps into <b>@_envName</b>, a live <b>Production</b> environment.</span>
                    }
                </label>
            }

            @if (_error is { } err)
            {
                <p class="art-fail" role="alert">@err</p>
            }

            <div class="confirm-modal__actions">
                <button type="button" class="btn" @onclick="Cancel" disabled="@_releasing">Cancel</button>
                <button type="button" class="btn btn--primary" @onclick="ReleaseAsync" disabled="@(!CanRelease)">
                    <Icon Name="send" Width="14" Height="14" />
                    <span>@(_releasing ? "Releasing..." : IsImmediate ? "Release now" : "Schedule release")</span>
                </button>
            </div>
        </div>
    </div>
}

@code {
    /// <summary>Raised with the new delivery's id once the release is queued/scheduled.</summary>
    [Parameter] public EventCallback<int> OnReleased { get; set; }

    private bool _open;
    private bool _focusPending;
    private ElementReference _root;
    private int _releasePipelineId;
    private string _envName = string.Empty;
    private bool _isProduction;
    private bool _envNameIsProduction;
    private string _versionMode = string.Empty;
    private string _schemaSyncMode = string.Empty;
    private List<ReleasableBuildOption> _builds = new();
    private int _buildId;
    private bool _prodAck;
    private bool _releasing;
    private string? _error;

    // Scheduling: the picker value is a wall-clock in the project's timezone.
    private TimeZoneInfo _tz = TimeZoneInfo.Utc;
    private string _tzLabel = "UTC";
    private TimeOnly? _winStart;
    private TimeOnly? _winEnd;
    private bool _hasWindow;
    private DateTime _scheduledLocal; // Unspecified kind = customer-tz wall-clock
    private DateTime? _secretExpiresAt; // UTC instant the BC client secret lapses, if known

    private string WindowLabel => _hasWindow ? $"{_winStart:HH:mm}–{_winEnd:HH:mm}" : "";

    /// <summary>The picked customer-tz wall-clock as a UTC instant.</summary>
    private DateTime ScheduledUtc => TimeZoneInfo.ConvertTimeToUtc(DateTime.SpecifyKind(_scheduledLocal, DateTimeKind.Unspecified), _tz);

    /// <summary>True when the picked time is now or in the past (a "release now").</summary>
    private bool IsImmediate => ScheduledUtc <= DateTime.UtcNow.AddMinutes(1);

    private bool IsOutsideWindow =>
        UpdateWindow.IsConfigured(_winStart, _winEnd) && !UpdateWindow.IsWithin(_winStart, _winEnd, _tz, ScheduledUtc);

    /// <summary>
    /// Warn-but-allow: the release runs under the customer's S2S secret, which fails once
    /// it expires. Flag it at scheduling time (the run itself hard-fails with the same
    /// advice) so a consultant rotates it first. Already-lapsed and scheduled-past-expiry
    /// are distinct messages. See .design/saas-delivery.md ("Expired-secret behaviour").
    /// </summary>
    private string? SecretWarning
    {
        get
        {
            if (_secretExpiresAt is not { } expiry) return null;
            if (expiry <= DateTime.UtcNow)
            {
                return "The Business Central client secret has expired. Rotate it in Entra and re-enter it on the project's Business Central page before this can install.";
            }
            if (ScheduledUtc > expiry)
            {
                var localExpiry = TimeZoneInfo.ConvertTimeFromUtc(DateTime.SpecifyKind(expiry, DateTimeKind.Utc), _tz);
                return $"The Business Central client secret expires {localExpiry:yyyy-MM-dd}. This release is scheduled after that and will fail unless the secret is rotated first.";
            }
            return null;
        }
    }

    private bool CanRelease =>
        !_releasing && _buildId != 0 && _builds.Count > 0 && (!_isProduction || _prodAck);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_focusPending && _open)
        {
            _focusPending = false;
            try { await _root.FocusAsync(); }
            catch { /* detached */ }
        }
    }

    /// <summary>
    /// Opens the dialog for a release pipeline. <paramref name="builds"/> must be its
    /// successful builds (newest first). <paramref name="timeZone"/> is the project's
    /// IANA tz; <paramref name="windowStart"/>/<paramref name="windowEnd"/> the target
    /// environment's update window (both null = none).
    /// </summary>
    public Task OpenAsync(int releasePipelineId, string envName, string envType, string versionMode, string schemaSyncMode,
        IReadOnlyList<ReleasableBuildOption> builds, string? timeZone, TimeOnly? windowStart, TimeOnly? windowEnd,
        DateTime? secretExpiresAt = null)
    {
        _releasePipelineId = releasePipelineId;
        _secretExpiresAt = secretExpiresAt;
        _envName = envName;
        _isProduction = string.Equals(envType, "Production", StringComparison.OrdinalIgnoreCase);
        _envNameIsProduction = string.Equals(envName, "Production", StringComparison.OrdinalIgnoreCase);
        _versionMode = versionMode;
        _schemaSyncMode = schemaSyncMode;
        _builds = builds.ToList();
        _buildId = _builds.Count > 0 ? _builds[0].Id : 0;
        _prodAck = false;
        _error = null;
        _releasing = false;

        _tz = UpdateWindow.ResolveTimeZone(timeZone);
        _tzLabel = string.IsNullOrWhiteSpace(timeZone) ? "UTC" : timeZone!;
        _winStart = windowStart;
        _winEnd = windowEnd;
        _hasWindow = UpdateWindow.IsConfigured(windowStart, windowEnd);

        // Prefill to the next opening of the window (or now if there's none), expressed
        // as a customer-tz wall-clock for the datetime-local input.
        var prefillUtc = UpdateWindow.NextOpeningUtc(windowStart, windowEnd, _tz, DateTime.UtcNow);
        _scheduledLocal = Trim(TimeZoneInfo.ConvertTimeFromUtc(prefillUtc, _tz));

        _open = true;
        _focusPending = true;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private void SetNow() => _scheduledLocal = Trim(TimeZoneInfo.ConvertTimeFromUtc(DateTime.UtcNow, _tz));

    /// <summary>Drop seconds so the value round-trips cleanly through datetime-local (minute precision).</summary>
    private static DateTime Trim(DateTime d) => new(d.Year, d.Month, d.Day, d.Hour, d.Minute, 0, DateTimeKind.Unspecified);

    private void Cancel()
    {
        if (_releasing) return;
        _open = false;
    }

    private void OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key is "Escape" or "Esc") Cancel();
    }

    private async Task ReleaseAsync()
    {
        if (!CanRelease) return;
        _releasing = true;
        _error = null;
        try
        {
            var deliveryId = await Deliveries.ScheduleDeliveryAsync(_releasePipelineId, _buildId, ScheduledUtc);
            _open = false;
            await OnReleased.InvokeAsync(deliveryId);
        }
        catch (PlanValidationException ex)
        {
            _error = ex.Errors.Values.FirstOrDefault() ?? "Couldn't start the release.";
        }
        catch (ProjectAccessDeniedException)
        {
            _error = "Only the project owner or an admin can release this project's builds.";
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Failed to start release for pipeline {ReleasePipelineId}.", _releasePipelineId);
            _error = "Couldn't start the release.";
        }
        finally
        {
            _releasing = false;
        }
    }

    /// <summary>A successful build offered in the picker.</summary>
    public sealed record ReleasableBuildOption(int Id, string Label);
}
