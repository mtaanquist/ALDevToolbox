@rendermode InteractiveServer
@inject ALDevToolbox.Services.ObjectExplorer.DeliveryService Deliveries
@inject ILogger<ReleaseBuildDialog> Log
@using ALDevToolbox.Domain.ValueObjects
@using ALDevToolbox.Domain.Entities.ObjectExplorer

@*
    Release a build through a release pipeline: pick which successful build to publish
    (defaults to the latest), confirm a Production target, and start the delivery now.
    There's no scheduling in this slice — "Release now" runs immediately via the worker.
    Opened imperatively; raises OnReleased with the new delivery id. See
    .design/saas-delivery.md ("Schedule a release").

    Named user: a BC consultant publishing a finished build to a customer environment.
*@

@if (_open)
{
    <div class="confirm-modal" role="dialog" aria-modal="true" aria-labelledby="rb-title"
         tabindex="-1" @onkeydown="OnKeyDown" @ref="_root">
        <div class="confirm-modal__backdrop" @onclick="Cancel" aria-hidden="true"></div>
        <div class="confirm-modal__panel" @onclick:stopPropagation>
            <h2 id="rb-title" class="confirm-modal__title">Release to @_envName</h2>

            <p class="confirm-modal__message">
                This uploads the build's apps to <b>@_envName</b> and installs them now. Installs use
                <b>@_versionMode</b>@(_schemaSyncMode == SchemaSyncMode.ForceSync ? ", with Force Sync (which can drop columns)" : "").
            </p>

            <div class="pe-field">
                <label class="field__label" for="rb-build">Build to release</label>
                <select id="rb-build" class="field__input" @bind="_buildId" disabled="@_releasing">
                    @foreach (var b in _builds)
                    {
                        <option value="@b.Id">@b.Label</option>
                    }
                </select>
                <small class="muted">The latest successful build is selected. Older successful builds are available too.</small>
            </div>

            @if (_isProduction)
            {
                <label class="rpe-confirm">
                    <input type="checkbox" checked="@_prodAck"
                           @onchange="e => _prodAck = (bool)(e.Value ?? false)" disabled="@_releasing" />
                    @if (_envNameIsProduction)
                    {
                        <span>I understand this installs the apps into the live <b>Production</b> environment now.</span>
                    }
                    else
                    {
                        <span>I understand this installs the apps into <b>@_envName</b>, a live <b>Production</b> environment, now.</span>
                    }
                </label>
            }

            @if (_error is { } err)
            {
                <p class="art-fail" role="alert">@err</p>
            }

            <div class="confirm-modal__actions">
                <button type="button" class="btn" @onclick="Cancel" disabled="@_releasing">Cancel</button>
                <button type="button" class="btn btn--primary" @onclick="ReleaseAsync" disabled="@(!CanRelease)">
                    <Icon Name="send" Width="14" Height="14" />
                    <span>@(_releasing ? "Releasing..." : "Release now")</span>
                </button>
            </div>
        </div>
    </div>
}

@code {
    /// <summary>Raised with the new delivery's id once the release is queued.</summary>
    [Parameter] public EventCallback<int> OnReleased { get; set; }

    private bool _open;
    private bool _focusPending;
    private ElementReference _root;
    private int _releasePipelineId;
    private string _envName = string.Empty;
    private bool _isProduction;
    private bool _envNameIsProduction;
    private string _versionMode = string.Empty;
    private string _schemaSyncMode = string.Empty;
    private List<ReleasableBuildOption> _builds = new();
    private int _buildId;
    private bool _prodAck;
    private bool _releasing;
    private string? _error;

    private bool CanRelease =>
        !_releasing && _buildId != 0 && _builds.Count > 0 && (!_isProduction || _prodAck);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_focusPending && _open)
        {
            _focusPending = false;
            try { await _root.FocusAsync(); }
            catch { /* detached */ }
        }
    }

    /// <summary>Opens the dialog for a release pipeline. <paramref name="builds"/> must be its successful builds, newest first.</summary>
    public Task OpenAsync(int releasePipelineId, string envName, string envType, string versionMode, string schemaSyncMode,
        IReadOnlyList<ReleasableBuildOption> builds)
    {
        _releasePipelineId = releasePipelineId;
        _envName = envName;
        _isProduction = string.Equals(envType, "Production", StringComparison.OrdinalIgnoreCase);
        _envNameIsProduction = string.Equals(envName, "Production", StringComparison.OrdinalIgnoreCase);
        _versionMode = versionMode;
        _schemaSyncMode = schemaSyncMode;
        _builds = builds.ToList();
        _buildId = _builds.Count > 0 ? _builds[0].Id : 0;
        _prodAck = false;
        _error = null;
        _releasing = false;
        _open = true;
        _focusPending = true;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private void Cancel()
    {
        if (_releasing) return;
        _open = false;
    }

    private void OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key is "Escape" or "Esc") Cancel();
    }

    private async Task ReleaseAsync()
    {
        if (!CanRelease) return;
        _releasing = true;
        _error = null;
        try
        {
            var deliveryId = await Deliveries.ReleaseBuildNowAsync(_releasePipelineId, _buildId);
            _open = false;
            await OnReleased.InvokeAsync(deliveryId);
        }
        catch (PlanValidationException ex)
        {
            _error = ex.Errors.Values.FirstOrDefault() ?? "Couldn't start the release.";
        }
        catch (ProjectAccessDeniedException)
        {
            _error = "Only the project owner or an admin can release this project's builds.";
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Failed to start release for pipeline {ReleasePipelineId}.", _releasePipelineId);
            _error = "Couldn't start the release.";
        }
        finally
        {
            _releasing = false;
        }
    }

    /// <summary>A successful build offered in the picker.</summary>
    public sealed record ReleasableBuildOption(int Id, string Label);
}
