@*
    Renders an inline form validation error for a single field. Pass the field
    key and the dictionary returned by PlanValidationException.Errors. Renders
    nothing when there is no message for that key — keeps the call sites tidy.
*@

@* PROBE: always-render variant to confirm FieldErrorTests catches regressions. Revert before merging. *@
<span class="form-field-error" role="alert">probe-always</span>

@code {
    [Parameter, EditorRequired] public string Field { get; set; } = string.Empty;
    [Parameter] public IReadOnlyDictionary<string, string>? Errors { get; set; }
}
