@inject NavigationManager Nav

@code {
    /// <summary>
    /// Used by <see cref="Routes"/>'s <c>NotAuthorized</c> slot. Sends the user
    /// to /login with a return URL so the post-sign-in redirect can drop them
    /// back where they were trying to go.
    /// </summary>
    protected override void OnInitialized()
    {
        var current = new Uri(Nav.Uri);
        var returnPath = current.PathAndQuery;
        var qs = string.IsNullOrEmpty(returnPath) || returnPath == "/"
            ? string.Empty
            : $"?return={Uri.EscapeDataString(returnPath)}";
        Nav.NavigateTo($"/login{qs}", forceLoad: true);
    }
}
