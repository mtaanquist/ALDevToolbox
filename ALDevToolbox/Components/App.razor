@inject IHttpContextAccessor Http
@inject ALDevToolbox.Services.CacheBust Bust
<!DOCTYPE html>
@* data-theme is rendered server-side from the aldt-theme cookie so Blazor's
   enhanced-navigation diff sees a value matching what the client already has
   on <html> and leaves it alone. Without the cookie, the response would have
   no attribute and the diff would strip it on every nav, visibly flipping
   the page to the OS default. The inline FOUC script handles cookie-less
   first visits; theme.js writes the cookie alongside localStorage on click. *@
<html lang="en" data-theme="@ServerTheme">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    @* Synchronously honour the persisted theme choice before the CSS files
       load, so users who picked dark don't see a light flash on cold loads. *@
    <script>
        (function () {
            try {
                var t = localStorage.getItem("aldt-theme");
                if (t === "light" || t === "dark") {
                    document.documentElement.setAttribute("data-theme", t);
                }
            } catch (e) { /* private mode etc. — fall through to system pref */ }
        })();
    </script>
    @* CSS is split across four topic files (base, auth, tools, admin) so each
       surface can be edited without scrolling through 5k lines. Load order is
       deliberate: base owns shared shell + form fundamentals, then auth, then
       tools, and admin last so admin-specific rules win on ties. *@
    <link rel="stylesheet" href="@Assets["base.css"]" />
    <link rel="stylesheet" href="@Assets["auth.css"]" />
    <link rel="stylesheet" href="@Assets["tools.css"]" />
    <link rel="stylesheet" href="@Assets["admin.css"]" />
    <link rel="stylesheet" href="@Assets["ALDevToolbox.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/svg+xml" href="favicon.svg" />
    <HeadOutlet />
</head>

<body>
    <Routes />
    <ReconnectModal />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script src="@Assets["theme.js"]"></script>
    <script src="@Assets["generate.js"]"></script>
    <script src="@Assets["uncontrolled-input.js"]"></script>
    <script src="@Assets["js/webauthn.js"]"></script>
    @*
        Object Explorer source viewer's client glue.
        Loaded at the shell level (not on the source-viewer page itself)
        because Blazor's enhanced-navigation diff doesn't execute
        <script> tags that appear in page responses — confirmed by the
        network tab on a fresh navigation. With the script in the shell
        it loads once per session; the module's MutationObserver waits
        for .source-viewer to appear in the DOM and runs init() only
        when needed, so non-source-viewer pages pay nothing.

        ?v=token cache-buster comes from CacheBust (singleton, GUID
        prefix per process start) so deploys invalidate cleanly; the
        module forwards the same token to its dynamic import of
        /code-editor.js via import.meta.url.
    *@
    <script type="module" src="/source-viewer.js?v=@Bust.Token"></script>
</body>

</html>

@code {
    private string? ServerTheme
    {
        get
        {
            var cookie = Http.HttpContext?.Request.Cookies["aldt-theme"];
            return cookie is "light" or "dark" ? cookie : null;
        }
    }
}
