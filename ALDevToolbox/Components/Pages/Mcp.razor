@page "/tools/mcp"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@using ALDevToolbox.Services
@using ALDevToolbox.Services.Mcp
@using ALDevToolbox.Components.Shared
@inject IMcpAvailability McpAvailability
@inject IHttpContextAccessor Http
@inject IJSRuntime JS
@inject NavigationManager Nav

<PageTitle>MCP · AL Dev Toolbox</PageTitle>

<div class="admin-page mcp-page">
    <header class="admin-page__header">
        <div>
            <h1>Model Context Protocol</h1>
            <p class="muted">
                Connect an AI agent - Claude (web, mobile, desktop), Cursor, VS Code's Copilot
                agent mode, Claude Code - to AL Dev Toolbox so it can list templates, generate
                workspaces, query the Object Explorer, and search the cookbook on your
                behalf. For the Claude.ai web and mobile flow, see
                <a href="/docs/mcp">Connect an AI assistant</a> - no token needed.
            </p>
        </div>
    </header>

    @if (_loading)
    {
        <p class="muted">Loading...</p>
    }
    else if (!_mcpEnabled)
    {
        <p class="form-info" role="status">
            MCP isn't switched on for this site. Ask a site administrator to enable it.
        </p>
    }
    else
    {
        <section class="admin-section mcp-step">
            <div class="mcp-step__heading">
                <span class="mcp-step__number" aria-hidden="true">1</span>
                <h2>Choose how the agent authenticates</h2>
            </div>
            <p class="muted">
                Pick whichever credential matches your client. Both produce a
                Bearer token that the agent sends with every MCP request.
            </p>
            <div class="mcp-step__choice">
                <div class="mcp-step__choice-card">
                    <div class="mcp-step__choice-heading">
                        <Icon Name="key-round" Width="18" Height="18" />
                        <h3>Personal access token</h3>
                    </div>
                    <p class="muted">
                        Quickest to set up. Works in any MCP-aware client that
                        supports Bearer auth (VS Code, Claude Desktop, Cursor,
                        Claude Code). Tokens act as you - same organisation,
                        same role - and the full value is shown only once when
                        you create it.
                    </p>
                    <div class="mcp-step__actions">
                        <a class="btn btn--primary" href="/account?section=ai">
                            <Icon Name="key-round" Width="16" Height="16" />
                            <span>Manage access tokens</span>
                        </a>
                    </div>
                </div>

                <div class="mcp-step__choice-divider" aria-hidden="true">
                    <span>OR</span>
                </div>

                <div class="mcp-step__choice-card">
                    <div class="mcp-step__choice-heading">
                        <Icon Name="plug" Width="18" Height="18" />
                        <h3>OAuth connector</h3>
                    </div>
                    <p class="muted">
                        For clients that prefer a per-org consented connection -
                        Claude.ai web and mobile add the server as a Custom
                        Connector and use the OAuth flow. Manage which
                        assistants are connected from the Account page.
                    </p>
                    <div class="mcp-step__actions">
                        <a class="btn btn--primary" href="/account?section=ai">
                            <Icon Name="plug" Width="16" Height="16" />
                            <span>Connected assistants</span>
                        </a>
                        <a class="btn" href="/docs/mcp">
                            <Icon Name="book-open" Width="16" Height="16" />
                            <span>Claude.ai walk-through</span>
                        </a>
                    </div>
                </div>
            </div>
        </section>

        <section class="admin-section mcp-step">
            <div class="mcp-step__heading">
                <span class="mcp-step__number" aria-hidden="true">2</span>
                <h2>Add the server to your AI client</h2>
            </div>
            <p class="muted">
                Your server URL is <code>@_serverUrl</code>. Replace
                <code>${TOKEN}</code> in the snippet below with the personal
                access token from step 1, or the OAuth access token issued
                by the connected-assistants flow.
            </p>
            <div class="mcp-tabs" role="tablist">
                @foreach (var tab in Tabs)
                {
                    <button type="button" role="tab"
                            class="mcp-tab @(tab == _selectedTab ? "mcp-tab--active" : "")"
                            @onclick="() => Select(tab)">
                        @tab
                    </button>
                }
            </div>
            <pre class="mcp-snippet"><code>@CurrentSnippet</code></pre>
            <div class="mcp-step__actions">
                <button type="button" class="btn btn--sm" @onclick="CopySnippetAsync">
                    <Icon Name="copy" Width="14" Height="14" />
                    <span>@(_copied ? "Copied" : "Copy snippet")</span>
                </button>
            </div>
            <p class="muted mcp-step__hint">@CurrentHint</p>
        </section>

        <section class="admin-section mcp-step">
            <div class="mcp-step__heading">
                <span class="mcp-step__number" aria-hidden="true">3</span>
                <h2>Try it</h2>
            </div>
            <p class="muted">
                Once the agent is connected, try one of these prompts to see what it can do:
            </p>
            <ul class="mcp-prompts">
                <li>"Make a new workspace for CRONUS using the default template."</li>
                <li>"Which procedures touch the No. field on Sales Line in BC 28.1?"</li>
                <li>"Walk me through what happens when you post a sales order in BC 28.1."</li>
                <li>"Find me a snippet for posting validation overrides."</li>
            </ul>

            <h3 class="mcp-tools__heading">Tools the agent has</h3>
            <table class="data-table mcp-tools">
                <thead>
                    <tr><th>Tool</th><th>What it does</th></tr>
                </thead>
                <tbody>
                    <tr><td><code>list_templates</code></td><td>Lists workspace templates for your organisation.</td></tr>
                    <tr><td><code>list_modules</code></td><td>Lists optional modules available to add to a workspace.</td></tr>
                    <tr><td><code>list_well_known_dependencies</code></td><td>Lists the BC dependency catalogue.</td></tr>
                    <tr><td><code>generate_workspace</code></td><td>Generates a new workspace ZIP (returned inline as base64).</td></tr>
                    <tr><td><code>generate_extension</code></td><td>Generates a standalone extension ZIP.</td></tr>
                    <tr><td><code>list_releases</code></td><td>Lists BC releases ingested in Object Explorer.</td></tr>
                    <tr><td><code>search_objects</code></td><td>Searches a release for AL objects (tables, pages, codeunits, ...).</td></tr>
                    <tr><td><code>search_procedures</code></td><td>Searches a release for procedures by name.</td></tr>
                    <tr><td><code>search_content</code></td><td>Searches AL source content across a release.</td></tr>
                    <tr><td><code>find_references</code></td><td>Finds every place that touches a specific table, field, or procedure.</td></tr>
                    <tr><td><code>get_object_outline</code></td><td>Returns an object's procedures, triggers, and fields with their symbol ids.</td></tr>
                    <tr><td><code>get_procedure_source</code></td><td>Returns the AL source of one procedure body (capped at 200 lines).</td></tr>
                    <tr><td><code>list_procedure_calls</code></td><td>Returns the outgoing calls and field accesses from inside one procedure body - for tracing call chains.</td></tr>
                    <tr><td><code>search_snippets</code></td><td>Searches your organisation's snippet library.</td></tr>
                    <tr><td><code>get_snippet</code></td><td>Returns the full file content of one snippet.</td></tr>
                </tbody>
            </table>
        </section>

        <section class="admin-section mcp-step mcp-step--troubleshooting">
            <div class="mcp-step__heading">
                <h2>Troubleshooting</h2>
            </div>
            <dl class="mcp-troubleshoot">
                <dt>The server doesn't show up in my client.</dt>
                <dd>
                    Confirm the URL is reachable from your machine and that you saved your
                    client's config file in the right place. VS Code needs Copilot agent mode
                    enabled; Claude Desktop needs a restart after editing the config.
                </dd>

                <dt>401 Unauthorized.</dt>
                <dd>
                    The token is missing, expired, or revoked. Issue a fresh one and
                    update your client's config.
                </dd>

                <dt>404 Not Found.</dt>
                <dd>
                    A site administrator has turned MCP off, or the URL is wrong.
                    Refresh this page - if you see the warning at the top, MCP is off.
                </dd>
            </dl>
        </section>
    }
</div>

@code {
    private static readonly string[] Tabs = new[] { "VS Code", "Claude Desktop", "Cursor", "Claude Code" };

    private bool _loading = true;
    private bool _mcpEnabled;
    private string _serverUrl = string.Empty;
    private string _selectedTab = "VS Code";
    private bool _copied;

    protected override void OnInitialized()
    {
        _mcpEnabled = McpAvailability.IsEnabled;
        var ctx = Http.HttpContext;
        if (ctx is not null)
        {
            _serverUrl = $"{ctx.Request.Scheme}://{ctx.Request.Host}/mcp";
        }
        else
        {
            // OnInitialized after the SSR pass - fall back to the URL the
            // page itself is on so the snippet still has a sensible default.
            var uri = new Uri(Nav.Uri);
            _serverUrl = $"{uri.Scheme}://{uri.Authority}/mcp";
        }
        _loading = false;
    }

    private void Select(string tab)
    {
        _selectedTab = tab;
        _copied = false;
    }

    private async Task CopySnippetAsync()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", CurrentSnippet);
        _copied = true;
    }

    private string CurrentSnippet => _selectedTab switch
    {
        "Claude Desktop" => ClaudeDesktopSnippet(_serverUrl),
        "Cursor" => CursorSnippet(_serverUrl),
        "Claude Code" => ClaudeCodeSnippet(_serverUrl),
        _ => VsCodeSnippet(_serverUrl),
    };

    private string CurrentHint => _selectedTab switch
    {
        "VS Code" => "Save this to your workspace's .vscode/mcp.json and reload. Requires GitHub Copilot agent mode.",
        "Claude Desktop" => "Add to claude_desktop_config.json (Settings → Developer → Edit Config) and restart the app.",
        "Cursor" => "Add to ~/.cursor/mcp.json (or Cursor Settings → MCP). Cursor will reload the server automatically.",
        "Claude Code" => "Run the command in any project directory; Claude Code stores the config in .claude/.",
        _ => string.Empty,
    };

    private static string VsCodeSnippet(string url) => $$"""
        {
          "servers": {
            "aldevtoolbox": {
              "type": "http",
              "url": "{{url}}",
              "headers": {
                "Authorization": "Bearer ${TOKEN}"
              }
            }
          }
        }
        """;

    private static string ClaudeDesktopSnippet(string url) => $$"""
        {
          "mcpServers": {
            "aldevtoolbox": {
              "type": "http",
              "url": "{{url}}",
              "headers": {
                "Authorization": "Bearer ${TOKEN}"
              }
            }
          }
        }
        """;

    private static string CursorSnippet(string url) => $$"""
        {
          "mcpServers": {
            "aldevtoolbox": {
              "url": "{{url}}",
              "headers": {
                "Authorization": "Bearer ${TOKEN}"
              }
            }
          }
        }
        """;

    private static string ClaudeCodeSnippet(string url) =>
        $"claude mcp add aldevtoolbox \\\n  --transport http \\\n  --url {url} \\\n  --header \"Authorization: Bearer ${{TOKEN}}\"";
}
