@page "/cookbook/suggest"
@attribute [Authorize]
@rendermode InteractiveServer
@inject RecipeSuggestionService Suggestions
@inject ApplicationVersionService ApplicationVersions
@inject NavigationManager Nav
@inject ILogger<SuggestRecipe> Log
@using ALDevToolbox.Domain.Entities
@using ALDevToolbox.Domain.ValueObjects

<PageTitle>Suggest a recipe · AL Dev Toolbox</PageTitle>

<div class="admin-page">
    <header class="admin-page__header">
        <div>
            <h1>Suggest a recipe</h1>
            <p class="muted">
                Submit a reusable AL recipe for an admin to review. Pick a type
                (Snippet, Pattern, or Module), give it a clear title and
                description, comma-separate the search keywords, and add one or
                more files. Each file may live in a folder (set its
                <strong>Folder</strong> field) — the ZIP download preserves the
                folder structure.
            </p>
        </div>
        <div class="admin-page__header-actions">
            <a class="btn btn--sm" href="/cookbook">
                <Icon Name="arrow-left" Width="14" Height="14" />
                <span>Back to cookbook</span>
            </a>
            @if (!_submitted)
            {
                <button type="button" class="btn btn--sm btn--primary" @onclick="SubmitAsync" disabled="@_busy">
                    <Icon Name="send" Width="14" Height="14" />
                    <span>@(_busy ? "Submitting…" : "Submit for review")</span>
                </button>
            }
        </div>
    </header>

    @if (_submitted)
    {
        <p class="form-success" role="status">
            Thanks — your suggestion is pending review. An admin will approve
            or reject it shortly.
        </p>
        <a class="btn" href="/cookbook">Back to cookbook</a>
    }
    else
    {
        <section class="admin-section">
            <h2>Details</h2>
            <div class="form-grid form-grid--narrow">
                <section class="form-section">
                    <label class="section-label" for="recipe-title">Title</label>
                    <input id="recipe-title" type="text" maxlength="200"
                           @bind="_title" @bind:event="oninput"
                           placeholder="e.g. Doc. Attachment List Factbox for an unsupported table" />
                    <FieldError Field="Title" Errors="_errors" />
                </section>

                <section class="form-section">
                    <label class="section-label" for="recipe-type">Type</label>
                    <select id="recipe-type" @bind="_type">
                        <option value="@RecipeType.Snippet">Snippet — small, one or two files</option>
                        <option value="@RecipeType.Pattern">Pattern — a few related files</option>
                        <option value="@RecipeType.Module">Module — near-complete feature</option>
                    </select>
                    <FieldError Field="Type" Errors="_errors" />
                </section>

                <section class="form-section">
                    <label class="section-label" for="recipe-description">Description</label>
                    <textarea id="recipe-description" rows="4" maxlength="2000"
                              @bind="_description" @bind:event="oninput"
                              placeholder="What does this recipe do, and when would you use it?"></textarea>
                    <FieldError Field="Description" Errors="_errors" />
                </section>

                <section class="form-section">
                    <label class="section-label" for="recipe-keywords">Keywords</label>
                    <input id="recipe-keywords" type="text" maxlength="500"
                           @bind="_keywords" @bind:event="oninput"
                           placeholder="space-separated; wrap a phrase in quotes, e.g. &quot;document attachments&quot; factbox subscriber" />
                    <small class="muted">
                        Separate tags with spaces or commas. Wrap a multi-word tag in
                        double quotes to keep it as one — e.g.
                        <code>"document attachments"</code>.
                    </small>
                    <FieldError Field="Keywords" Errors="_errors" />
                </section>

                <section class="form-section">
                    <label class="section-label" for="recipe-min-version">Minimum BC application version (optional)</label>
                    <select id="recipe-min-version" @bind="_minimumApplicationVersionId">
                        <option value="">No minimum</option>
                        @foreach (var v in _applicationVersions)
                        {
                            <option value="@v.Id">@v.Name (@v.Application)</option>
                        }
                    </select>
                    <small class="muted">
                        Pick the lowest BC release this recipe compiles against. Shown as a
                        badge on the published recipe.
                    </small>
                    <FieldError Field="MinimumApplicationVersionId" Errors="_errors" />
                </section>

                <section class="form-section">
                    <label class="section-label" for="recipe-instructions">Instructions (optional, Markdown)</label>
                    <textarea id="recipe-instructions" rows="6" maxlength="10000"
                              @bind="_instructions" @bind:event="oninput"
                              placeholder="Where should the recipient put this? Anything to add to a permission set or setup table? Markdown is rendered on the published page."></textarea>
                    <FieldError Field="Instructions" Errors="_errors" />
                </section>
            </div>
        </section>

        <section class="admin-section">
            <h2>Files</h2>
            <p class="muted">
                Each file becomes one AL object. The optional <strong>Folder</strong>
                field puts the file inside that directory of the ZIP — leave it
                blank for files at the root.
            </p>
            <RecipeFileEditor Files="_files" Errors="_errors" />
        </section>

        @if (_lastError is not null)
        {
            <p class="form-error" role="alert">@_lastError</p>
        }
    }
</div>

@code {
    private string _title = string.Empty;
    private string _description = string.Empty;
    private string _keywords = string.Empty;
    private string _instructions = string.Empty;
    private RecipeType _type = RecipeType.Snippet;
    private string _minimumApplicationVersionId = string.Empty;
    private List<ApplicationVersion> _applicationVersions = new();
    private List<RecipeFileEditor.EditableFile> _files = new() { new RecipeFileEditor.EditableFile() };
    private IReadOnlyDictionary<string, string>? _errors;
    private string? _lastError;
    private bool _busy;
    private bool _submitted;

    protected override async Task OnInitializedAsync()
    {
        _applicationVersions = await ApplicationVersions.GetActiveAsync();
    }

    private async Task SubmitAsync()
    {
        if (_busy) return;
        _busy = true;
        _errors = null;
        _lastError = null;
        try
        {
            var input = new RecipeSuggestionInput(
                _title,
                _description,
                _keywords,
                _type,
                _files.Select(f => new RecipeFileInput(f.FileName, f.Content, f.RelativePath)).ToList(),
                Instructions: _instructions,
                MinimumApplicationVersionId: int.TryParse(_minimumApplicationVersionId, out var avId) ? avId : null);
            await Suggestions.SubmitAsync(input);
            _submitted = true;
        }
        catch (PlanValidationException ex)
        {
            _errors = ex.Errors;
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Failed to submit recipe suggestion.");
            _lastError = "An unexpected error occurred. Your suggestion was not saved.";
        }
        finally
        {
            _busy = false;
        }
    }
}
