@page "/site-admin/settings"
@attribute [Authorize(Roles = HttpOrganizationContext.SiteAdminRole)]
@inject NavigationManager Nav

@*
    Bare-route redirect for the Settings sidebar entry. The settings page
    is now split into per-section pill-tab routes; SMTP is the most
    common edit (and shows the running-mail-config status), so it's the
    default tab.

    Query parameters are forwarded so existing per-section endpoints can
    keep redirecting back to /site-admin/settings?... and still land on a
    real tab.
*@

@code {
    [SupplyParameterFromQuery(Name = "ok")] public string? Ok { get; set; }
    [SupplyParameterFromQuery(Name = "msg")] public string? Msg { get; set; }
    [SupplyParameterFromQuery(Name = "test")] public string? Test { get; set; }

    protected override void OnInitialized()
    {
        // Pick the tab that matches the legacy success/error code so
        // SMTP-related redirects land on the SMTP tab, off-site on the
        // off-site tab, etc. Anything else falls back to SMTP.
        var (tab, query) = Resolve();
        Nav.NavigateTo(tab + query, replace: true);
    }

    private (string Tab, string Query) Resolve()
    {
        var parts = new List<string>(3);
        if (!string.IsNullOrEmpty(Ok)) parts.Add("ok=" + Uri.EscapeDataString(Ok));
        if (!string.IsNullOrEmpty(Msg)) parts.Add("msg=" + Uri.EscapeDataString(Msg));
        if (!string.IsNullOrEmpty(Test)) parts.Add("test=" + Uri.EscapeDataString(Test));
        var query = parts.Count == 0 ? string.Empty : "?" + string.Join("&", parts);

        var tab = (Ok, Test) switch
        {
            ("offsite-saved", _) => "/site-admin/settings/offsite",
            (_, not null) => "/site-admin/settings/offsite",
            ("test-sent", _) => "/site-admin/settings/smtp",
            _ => "/site-admin/settings/smtp",
        };
        return (tab, query);
    }
}
