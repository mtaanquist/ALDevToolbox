@page "/site-admin/audit/{id:int}/diff"
@attribute [Authorize(Roles = HttpOrganizationContext.SiteAdminRole)]
@inject AppDbContext Db
@using ALDevToolbox.Data
@using ALDevToolbox.Domain.Entities
@using Microsoft.EntityFrameworkCore

@*
    SiteAdmin version of the audit-diff page. The org filter is bypassed via
    IgnoreQueryFilters() because the SiteAdmin audit search spans every
    organisation; see SiteAdminService.SearchAuditAsync.
*@

<PageTitle>Audit change · Site administration · AL Dev Toolbox</PageTitle>

<div class="admin-page audit-page">
    <header class="admin-page__header">
        <div>
            <h1>Audit change (cross-organisation)</h1>
            <p class="muted">
                Side-by-side comparison of the row's state before and after this
                audit entry. The "after" snapshot comes from the next change to
                the same entity in the same organisation.
            </p>
        </div>
        <a class="btn btn--sm" href="/site-admin/audit">
            <Icon Name="arrow-left" Width="14" Height="14" />
            <span>Back to audit search</span>
        </a>
    </header>

    @if (_entry is null)
    {
        <p class="muted">Loading…</p>
    }
    else if (_notFound)
    {
        <p class="muted">No audit entry with id <code>@Id</code>.</p>
    }
    else
    {
        <dl class="audit-diff__meta">
            <div><dt>When (UTC)</dt><dd>@_entry.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</dd></div>
            <div><dt>Who</dt><dd>@_entry.ChangedBy</dd></div>
            <div><dt>Organisation</dt><dd>@(_organizationName ?? "—")</dd></div>
            <div><dt>Entity</dt><dd>@_entry.EntityType <code>#@_entry.EntityId</code></dd></div>
            <div><dt>Action</dt><dd><span class="audit-action audit-action--@_entry.Action.ToString().ToLowerInvariant()">@_entry.Action</span></dd></div>
        </dl>

        <AuditDiffViewer
            BeforeJson="@_beforeJson"
            AfterJson="@_afterJson"
            BeforeLabel="@_beforeLabel"
            AfterLabel="@_afterLabel" />
    }
</div>

@code {
    [Parameter] public int Id { get; set; }

    private AuditLogEntry? _entry;
    private string? _organizationName;
    private bool _notFound;
    private string? _beforeJson;
    private string? _afterJson;
    private string? _beforeLabel;
    private string? _afterLabel;

    protected override async Task OnInitializedAsync()
    {
        var entry = await Db.AuditLog
            .IgnoreQueryFilters()
            .AsNoTracking()
            .Include(e => e.Organization)
            .FirstOrDefaultAsync(e => e.Id == Id);
        if (entry is null)
        {
            _notFound = true;
            _entry = new AuditLogEntry();
            return;
        }
        _entry = entry;
        _organizationName = entry.Organization?.Name;
        _beforeJson = entry.SnapshotJson;
        _beforeLabel = entry.Action == AuditAction.Created
            ? "no prior state (created)"
            : entry.Timestamp.ToString("yyyy-MM-dd HH:mm:ss");

        var next = await Db.AuditLog
            .IgnoreQueryFilters()
            .AsNoTracking()
            .Where(e => e.EntityType == entry.EntityType
                        && e.EntityId == entry.EntityId
                        && e.OrganizationId == entry.OrganizationId
                        && (e.Timestamp > entry.Timestamp
                            || (e.Timestamp == entry.Timestamp && e.Id > entry.Id)))
            .OrderBy(e => e.Timestamp)
            .ThenBy(e => e.Id)
            .FirstOrDefaultAsync();

        if (next is not null)
        {
            _afterJson = next.SnapshotJson;
            _afterLabel = next.Timestamp.ToString("yyyy-MM-dd HH:mm:ss");
        }
        else if (entry.Action == AuditAction.Deleted)
        {
            _afterJson = null;
            _afterLabel = "deleted (no later state)";
        }
        else
        {
            _afterJson = null;
            _afterLabel = "no later audit entry recorded yet";
        }
    }
}
