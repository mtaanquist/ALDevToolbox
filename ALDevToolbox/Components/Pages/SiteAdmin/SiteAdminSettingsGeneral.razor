@page "/site-admin/settings/general"
@attribute [Authorize(Roles = HttpOrganizationContext.SiteAdminRole)]
@using ALDevToolbox.Services
@inject SystemSettingsService Settings

<PageTitle>Site Admin · Banner &amp; signup · AL Dev Toolbox</PageTitle>

<div class="admin-page">
    <SiteAdminSettingsHeader ActiveTab="SiteAdminSettingsHeader.Tab.General">
        <Actions>
            <button type="submit" form="settings-general-form" class="btn btn--sm btn--primary">
                <Icon Name="save" Width="14" Height="14" />
                <span>Save</span>
            </button>
        </Actions>
    </SiteAdminSettingsHeader>

    @if (!string.IsNullOrEmpty(Message))
    {
        <p class="form-error" role="alert">@Message</p>
    }
    @if (Ok == "saved")
    {
        <p class="form-info" role="status">Settings saved.</p>
    }

    @if (_view is null)
    {
        <p class="muted">Loading…</p>
    }
    else
    {
        <form method="post" action="/site-admin/settings/general/save" class="admin-form" id="settings-general-form">
            <AntiforgeryToken />
            <label>
                System banner
                <textarea name="BannerText" rows="2" maxlength="500"
                          placeholder="Optional notice shown at the top of every page.">@_view.BannerText</textarea>
            </label>
            <label class="checkbox-label">
                <input type="checkbox" name="DefaultSignupAutoApprove" value="true"
                       checked="@_view.DefaultSignupAutoApprove" />
                Auto-approve signups into existing organisations (skip admin review)
            </label>
        </form>

        <p class="muted">Last updated: @_view.UpdatedAt.ToString("yyyy-MM-dd HH:mm 'UTC'")</p>
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "msg")] public string? Message { get; set; }
    [SupplyParameterFromQuery(Name = "ok")] public string? Ok { get; set; }

    private SystemSettingsView? _view;

    protected override async Task OnInitializedAsync()
    {
        _view = await Settings.GetViewAsync();
    }
}
