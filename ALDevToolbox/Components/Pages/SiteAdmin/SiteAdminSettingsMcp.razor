@page "/site-admin/settings/mcp"
@attribute [Authorize(Roles = HttpOrganizationContext.SiteAdminRole)]
@inject NavigationManager Nav

@*
    The MCP toggle moved into the unified Tools tab. This legacy route just
    forwards there so old bookmarks and links keep working.
*@

@code {
    protected override void OnInitialized() =>
        Nav.NavigateTo("/site-admin/settings/tools", replace: true);
}
