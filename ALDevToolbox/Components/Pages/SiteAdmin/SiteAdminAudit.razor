@page "/site-admin/audit"
@attribute [Authorize(Roles = HttpOrganizationContext.SiteAdminRole)]
@using ALDevToolbox.Domain.Entities
@using ALDevToolbox.Services
@using static ALDevToolbox.Components.Shared.AdminPageHelpers
@inject SiteAdminService SiteAdmin

<PageTitle>Audit log · Site administration · AL Dev Toolbox</PageTitle>

<div class="admin-page audit-page">
    <header class="admin-page__header">
        <div>
            <h1>Audit log</h1>
            <p class="muted">
                Cross-organisation audit search. Filters are optional; an
                unfiltered search returns the most recent activity across
                every organisation.
            </p>
        </div>
    </header>

    @*
        Filters apply on change rather than waiting for a submit button:
        selects and date pickers fire change events synchronously, and the
        Actor text input submits on Enter or when it loses focus. Keeping
        the form GET-based preserves bookmarkable URLs and uses the same
        SupplyParameterFromQuery wiring as before.
    *@
    <form method="get" action="/site-admin/audit" class="admin-filter-form" onchange="this.submit()">
        <label>
            Entity type
            <select name="entityType">
                <option value="">Any</option>
                @foreach (var type in Enum.GetValues<AuditEntityType>())
                {
                    <option value="@type" selected="@(EntityType == type.ToString())">@type</option>
                }
            </select>
        </label>
        <label>
            Organisation
            <select name="organizationId">
                <option value="">Any</option>
                @if (_orgs is not null)
                {
                    @foreach (var o in _orgs)
                    {
                        <option value="@o.Id" selected="@(OrganizationId == o.Id)">@o.Name</option>
                    }
                }
            </select>
        </label>
        <label>
            Actor contains
            <input type="text" name="actor" value="@Actor" placeholder="email or full name" />
        </label>
        <label>
            From (UTC)
            <input type="datetime-local" name="from" value="@FromUtc" />
        </label>
        <label>
            To (UTC)
            <input type="datetime-local" name="to" value="@ToUtc" />
        </label>
    </form>

    @if (_rows is null)
    {
        <p class="muted">Loading…</p>
    }
    else if (_rows.Count == 0)
    {
        <p class="muted">No audit entries match the current filters.</p>
    }
    else
    {
        <table class="data-table audit-table">
            <thead>
                <tr>
                    <th>When (UTC)</th>
                    <th>Who</th>
                    <th>Org</th>
                    <th>Entity</th>
                    <th>Id</th>
                    <th>Action</th>
                    <th>Snapshot</th>
                    <th class="data-table__actions"></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var e in _rows)
            {
                <tr>
                    <td><time datetime="@e.Timestamp.ToString("O")">@e.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</time></td>
                    <td>@e.ChangedBy</td>
                    <td>@(e.OrganizationName ?? "—")</td>
                    <td>@e.EntityType</td>
                    <td><code>@e.EntityId</code></td>
                    <td><span class="audit-action audit-action--@e.Action.ToString().ToLowerInvariant()">@e.Action</span></td>
                    <td>
                        @if (string.IsNullOrEmpty(e.SnapshotJson))
                        {
                            <span class="muted">—</span>
                        }
                        else
                        {
                            <details>
                                <summary>Show JSON</summary>
                                <pre class="audit-snapshot"><code>@PrettyJson(e.SnapshotJson)</code></pre>
                            </details>
                        }
                    </td>
                    <td class="data-table__actions">
                        <a class="btn btn--sm" href="@($"/site-admin/audit/{e.Id}/diff")"
                           title="Compare this row's snapshot against the next change to the same entity">
                            <Icon Name="diff" Width="14" Height="14" />
                            <span>View change</span>
                        </a>
                    </td>
                </tr>
            }
            </tbody>
        </table>

        @if (_total > PageSize)
        {
            <nav class="audit-pager" aria-label="Audit pagination">
                @if (_page > 1)
                {
                    <a class="btn btn--sm" href="@PageUrl(_page - 1)">Previous</a>
                }
                else
                {
                    <span class="btn btn--sm" aria-disabled="true">Previous</span>
                }
                <span class="muted">Page @_page of @TotalPages · @_total entries</span>
                @if (_page < TotalPages)
                {
                    <a class="btn btn--sm" href="@PageUrl(_page + 1)">Next</a>
                }
                else
                {
                    <span class="btn btn--sm" aria-disabled="true">Next</span>
                }
            </nav>
        }
    }
</div>

@code {
    private const int PageSize = 100;

    [SupplyParameterFromQuery(Name = "entityType")] public string? EntityType { get; set; }
    [SupplyParameterFromQuery(Name = "organizationId")] public int? OrganizationId { get; set; }
    [SupplyParameterFromQuery(Name = "actor")] public string? Actor { get; set; }
    [SupplyParameterFromQuery(Name = "from")] public string? FromUtc { get; set; }
    [SupplyParameterFromQuery(Name = "to")] public string? ToUtc { get; set; }
    [SupplyParameterFromQuery(Name = "page")] public int? Page { get; set; }

    private List<SiteAdminAuditRow>? _rows;
    private List<Organization>? _orgs;
    private int _total;
    private int _page = 1;

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(_total / (double)PageSize));

    protected override async Task OnInitializedAsync()
    {
        _orgs = await SiteAdmin.ListOrganizationsAsync();
        _page = Page is int p && p > 1 ? p : 1;
        AuditEntityType? entity = Enum.TryParse<AuditEntityType>(EntityType, out var et) ? et : null;
        DateTime? from = DateTime.TryParse(FromUtc, out var f) ? DateTime.SpecifyKind(f, DateTimeKind.Utc) : null;
        DateTime? to = DateTime.TryParse(ToUtc, out var t) ? DateTime.SpecifyKind(t, DateTimeKind.Utc) : null;
        var result = await SiteAdmin.SearchAuditAsync(
            entity, OrganizationId, Actor, from, to,
            skip: (_page - 1) * PageSize, take: PageSize);
        _rows = result.Rows.ToList();
        _total = result.Total;
    }

    /// <summary>
    /// Builds a page link that carries over the current filters — the page is
    /// static SSR, so pagination is plain bookmarkable anchors rather than
    /// interactive button handlers, matching the GET filter form above.
    /// </summary>
    private string PageUrl(int page)
    {
        var query = new List<string>();
        if (!string.IsNullOrEmpty(EntityType)) query.Add($"entityType={Uri.EscapeDataString(EntityType)}");
        if (OrganizationId is int oid) query.Add($"organizationId={oid}");
        if (!string.IsNullOrEmpty(Actor)) query.Add($"actor={Uri.EscapeDataString(Actor)}");
        if (!string.IsNullOrEmpty(FromUtc)) query.Add($"from={Uri.EscapeDataString(FromUtc)}");
        if (!string.IsNullOrEmpty(ToUtc)) query.Add($"to={Uri.EscapeDataString(ToUtc)}");
        query.Add($"page={page}");
        return "/site-admin/audit?" + string.Join("&", query);
    }
}
