@page "/login/magic"

<PageTitle>Sign in with a magic link · AL Dev Toolbox</PageTitle>

<div class="login-page">
    <h1>Sign in</h1>
    <p class="caption muted">
        We'll email you a single-use sign-in link, valid for 15 minutes. No
        password needed. We always show the same confirmation, whether or not
        the email matches an account.
    </p>

    <nav class="tab-bar tab-bar--auth" aria-label="Sign-in method">
        <a href="/login" class="tab">Password</a>
        <a href="/login/magic" class="tab active">Magic link</a>
    </nav>

    @if (Error == "not-configured")
    {
        <p class="form-error" role="alert">
            Magic-link sign-in isn't available on this site. Use your password
            to sign in instead.
        </p>
    }
    @if (Ok == "1")
    {
        <p class="form-success" role="status">If that email matches an account, you'll receive a sign-in link shortly.</p>
    }

    <form method="post" action="/auth/login/magic" class="form-grid login-form">
        <AntiforgeryToken />
        <section class="form-section">
            <label class="section-label" for="ml-email">Email</label>
            <input id="ml-email" type="email" name="Email" required autofocus autocomplete="username" />
        </section>
        <div class="login-form__actions">
            <button type="submit" class="btn btn--primary">
                <Icon Name="mail" Width="16" Height="16" />
                <span>Send sign-in link</span>
            </button>
        </div>
    </form>
</div>

@code {
    [SupplyParameterFromQuery(Name = "err")] public string? Error { get; set; }
    [SupplyParameterFromQuery(Name = "ok")] public string? Ok { get; set; }
}
