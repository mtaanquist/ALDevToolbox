@page "/account/repository-tokens"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@using ALDevToolbox.Domain.ValueObjects
@using ALDevToolbox.Services
@using ALDevToolbox.Services.Account
@inject OrganizationConfigService Config
@inject UserRepositoryTokenService Tokens
@inject ILogger<RepositoryTokens> Log

@*
    A user's own Git repository Personal Access Tokens, one per provider the org
    allows. Builds clone repositories as the user who starts them, using these
    tokens — so a build fails for whoever lacks access rather than leaning on a
    shared org credential. See .design/artifacts.md.
*@

<PageTitle>Repository tokens · AL Dev Toolbox</PageTitle>

<div class="account-page">
    <header class="page-header">
        <h1>Repository tokens</h1>
        <p class="muted">
            To build a project's solution, the toolbox clones its repositories as
            <strong>you</strong>. Store a Personal Access Token for each Git host you
            build from — it's kept encrypted, only ever used to clone, and never shown
            again. A build you start fails if your token can't reach one of its repos.
        </p>
    </header>

    @if (_loading)
    {
        <p class="muted">Loading…</p>
    }
    else if (_providers.Count == 0)
    {
        <p class="muted">
            Your organisation hasn't enabled any source-control providers yet. An
            administrator sets these under Administration → Repositories.
        </p>
    }
    else
    {
        @if (!string.IsNullOrEmpty(_okMessage))
        {
            <p class="form-success" role="status">@_okMessage</p>
        }
        @if (!string.IsNullOrEmpty(_errMessage))
        {
            <div class="form-error" role="alert"><p>@_errMessage</p></div>
        }

        <section class="account-section">
            <div class="form-grid form-grid--narrow">
                @foreach (var p in _providers)
                {
                    var f = _fields[p];
                    <section class="form-section">
                        <label class="section-label" for="@($"tok-{p}")">
                            @p.DisplayName() token
                            @if (f.HasToken)
                            {
                                <span class="muted">· a token is stored@(f.LastUsedAt is { } lu ? $", last used {lu:yyyy-MM-dd}" : "")</span>
                            }
                        </label>
                        <input id="@($"tok-{p}")" type="password" class="input" autocomplete="off"
                               placeholder="@(f.HasToken ? "•••••••• (leave blank to keep)" : Placeholder(p))"
                               @bind="f.NewValue" disabled="@(_saving || f.Clear)" />
                        @if (f.HasToken)
                        {
                            <label class="section-label section-label--inline">
                                <input type="checkbox" @bind="f.Clear" disabled="@_saving" />
                                <span>Remove the stored token</span>
                            </label>
                        }
                        <small class="muted">@ScopeHint(p)</small>
                    </section>
                }

                <section class="form-section form-section--actions">
                    <button type="button" class="btn btn--primary" @onclick="SaveAsync" disabled="@_saving">
                        <Icon Name="save" Width="14" Height="14" />
                        <span>@(_saving ? "Saving…" : "Save changes")</span>
                    </button>
                </section>
            </div>
        </section>
    }

    <p class="muted"><a href="/account">← Back to account</a></p>
</div>

@code {
    private bool _loading = true;
    private bool _saving;
    private string? _okMessage;
    private string? _errMessage;

    private List<RepositoryProvider> _providers = new();
    private readonly Dictionary<RepositoryProvider, TokenField> _fields = new();

    private sealed class TokenField
    {
        public bool HasToken { get; set; }
        public DateTime? LastUsedAt { get; set; }
        public string? NewValue { get; set; }
        public bool Clear { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
        _loading = false;
    }

    private async Task ReloadAsync()
    {
        _providers = (await Config.GetAllowedProvidersAsync()).ToList();
        var status = await Tokens.GetTokenStatusAsync();
        _fields.Clear();
        foreach (var p in _providers)
        {
            status.TryGetValue(p, out var s);
            _fields[p] = new TokenField
            {
                HasToken = s is not null,
                LastUsedAt = s?.LastUsedAt,
            };
        }
    }

    private async Task SaveAsync()
    {
        if (_saving) return;
        _saving = true;
        _okMessage = _errMessage = null;
        try
        {
            foreach (var p in _providers)
            {
                var f = _fields[p];
                if (f.Clear || !string.IsNullOrWhiteSpace(f.NewValue))
                {
                    await Tokens.SaveTokenAsync(p, f.NewValue, f.Clear);
                }
            }
            await ReloadAsync();
            _okMessage = "Repository tokens saved.";
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Failed to save repository tokens.");
            _errMessage = "An unexpected error occurred. The change was not saved.";
        }
        finally
        {
            _saving = false;
        }
    }

    private static string Placeholder(RepositoryProvider p) => p switch
    {
        RepositoryProvider.GitHub => "Paste a GitHub PAT",
        RepositoryProvider.AzureDevOps => "Paste an Azure DevOps PAT",
        _ => "Paste a token",
    };

    private static string ScopeHint(RepositoryProvider p) => p switch
    {
        RepositoryProvider.GitHub => "Needs repo (read) scope. Used for repositories on github.com.",
        RepositoryProvider.AzureDevOps => "Needs Code (Read) scope. Used for repositories on dev.azure.com.",
        _ => string.Empty,
    };
}
