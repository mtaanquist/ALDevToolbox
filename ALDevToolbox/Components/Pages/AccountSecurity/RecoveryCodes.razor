@page "/account/2fa/recovery-codes"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@implements IDisposable
@using ALDevToolbox.Endpoints
@using Microsoft.AspNetCore.DataProtection
@inject IHttpContextAccessor Http
@inject IDataProtectionProvider Protection
@inject NavigationManager Nav
@inject PersistentComponentState PersistentState

<PageTitle>Recovery codes · AL Dev Toolbox</PageTitle>

<div class="account-page">
    <header class="page-header">
        <h1>Save your recovery codes</h1>
        <p class="muted">
            Store these somewhere safe - a password manager, an encrypted note, or paper. Each code works
            <strong>once</strong>. Use them to sign in when your authenticator isn't available.
        </p>
    </header>

    @if (_codes.Length == 0)
    {
        <p class="form-error" role="alert">
            Recovery codes can only be shown immediately after generation. <a href="/account?section=security">Go back</a>
            and re-generate from the security section if you missed them.
        </p>
    }
    else
    {
        <section class="account-section">
            <pre class="recovery-codes">@_codesText</pre>
            <div class="account-actions">
                <button type="button" class="btn" @onclick="DownloadAsync">
                    <Icon Name="download" Width="14" Height="14" />
                    <span>Download as .txt</span>
                </button>
                <a class="btn btn--primary" href="/account?section=security">I've saved them</a>
            </div>
        </section>
    }
</div>

<style>
    .recovery-codes {
        background: var(--bg);
        border: 1px solid var(--border);
        padding: 16px;
        font-family: var(--mono);
        font-size: 14px;
        letter-spacing: 0.08em;
        line-height: 1.6;
    }
</style>

@code {
    [Inject] IJSRuntime JS { get; set; } = default!;

    private const string StateKey = "recoveryCodes";

    private string[] _codes = Array.Empty<string>();
    private string _codesText = string.Empty;
    private PersistingComponentStateSubscription _persistingSubscription;

    protected override void OnInitialized()
    {
        // Two render passes happen under InteractiveServer with prerender:
        // the SSR pass reads + clears the one-shot cookie, then the
        // interactive circuit re-runs OnInitialized with the cookie
        // already consumed. Without bridging the gap, the second pass
        // sees nothing and renders the "can only be shown immediately"
        // error over the codes the user briefly saw. PersistentComponentState
        // carries the codes across the boundary. See issue #177.
        if (PersistentState.TryTakeFromJson<string[]>(StateKey, out var restored) && restored is { Length: > 0 })
        {
            ApplyCodes(restored);
            return;
        }

        var ctx = Http.HttpContext;
        if (ctx is null) return;
        var codes = EndpointHelpers.ReadAndClearOneShotRecoveryCodesCookie(ctx, Protection);
        if (codes is null) return;
        ApplyCodes(codes);
        _persistingSubscription = PersistentState.RegisterOnPersisting(() =>
        {
            PersistentState.PersistAsJson(StateKey, _codes);
            return Task.CompletedTask;
        });
    }

    private void ApplyCodes(string[] codes)
    {
        _codes = codes;
        _codesText = string.Join('\n', _codes);
    }

    public void Dispose() => _persistingSubscription.Dispose();

    private async Task DownloadAsync()
    {
        var name = $"aldt-recovery-codes-{DateTime.UtcNow:yyyyMMdd}.txt";
        await JS.InvokeVoidAsync("aldtDownload.text", name, _codesText);
    }
}
