@page "/account/oauth-clients"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@using ALDevToolbox.Components.Shared
@using ALDevToolbox.Services
@using ALDevToolbox.Services.OAuth
@inject OAuthClientAdminService Clients
@inject IOrganizationContext Org

<PageTitle>Connected assistants · AL Dev Toolbox</PageTitle>

<div class="account-page">
    <header class="page-header">
        <h1>Connected assistants</h1>
        <p class="muted">
            AI assistants that signed in to AL Dev Toolbox on your behalf via the
            <em>Connect with AL Dev Toolbox</em> button — typically Claude on the web or mobile.
            Revoking access here signs the assistant out and forces it to ask for permission
            again the next time it connects. To remove a Personal Access Token paste-in
            credential instead, see <a href="/account/access-tokens">Personal access tokens</a>.
        </p>
    </header>

    @if (!string.IsNullOrEmpty(Error))
    {
        <p class="form-error" role="alert">@Error</p>
    }
    @if (Ok == "revoked")
    {
        <p class="form-success" role="status">Access revoked.</p>
    }

    <section class="account-section">
        <h2>Your connected assistants</h2>
        @if (_clients is null)
        {
            <p class="muted">Loading…</p>
        }
        else if (_clients.Count == 0)
        {
            <p class="muted">
                You haven't connected any AI assistants yet. Adding AL Dev Toolbox as a
                connector in Claude (or another assistant that supports it) opens a permission
                screen — once you click <strong>Allow</strong>, the connection shows up here.
            </p>
        }
        else
        {
            var now = DateTime.UtcNow;
            var active = _clients.Where(c => c.RevokedAt is null).ToList();
            var inactive = _clients.Where(c => c.RevokedAt is not null).ToList();

            if (active.Count == 0)
            {
                <p class="muted">No active connections.</p>
            }
            else
            {
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Assistant</th>
                            <th>Permissions</th>
                            <th>Approved</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in active)
                        {
                            <tr>
                                <td>
                                    @c.DisplayName
                                    @if (c.RedirectHosts.Count > 0)
                                    {
                                        <div class="muted small">@string.Join(", ", c.RedirectHosts)</div>
                                    }
                                </td>
                                <td class="muted">@HumanScopes(c.Scopes)</td>
                                <td class="muted">@c.GrantedAt.ToString("yyyy-MM-dd")</td>
                                <td class="row-actions">
                                    <button type="button" class="btn btn--sm btn--danger" @onclick="() => RevokeAsync(c.ConsentId)">
                                        Revoke
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }

            if (inactive.Count > 0)
            {
                <details class="inactive-tokens">
                    <summary>Show @inactive.Count revoked @(inactive.Count == 1 ? "connection" : "connections")</summary>
                    <p class="muted">
                        Kept around so audit log entries still resolve. The assistant cannot reach AL Dev Toolbox unless it reconnects.
                    </p>
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Assistant</th>
                                <th>Permissions</th>
                                <th>Approved</th>
                                <th>Revoked</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in inactive)
                            {
                                <tr>
                                    <td>@c.DisplayName</td>
                                    <td class="muted">@HumanScopes(c.Scopes)</td>
                                    <td class="muted">@c.GrantedAt.ToString("yyyy-MM-dd")</td>
                                    <td class="muted">@(c.RevokedAt?.ToString("yyyy-MM-dd") ?? "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </details>
            }
        }
    </section>

    <p class="muted"><a href="/account">← Back to account</a></p>
</div>

@code {
    [SupplyParameterFromQuery(Name = "err")] public string? Error { get; set; }
    [SupplyParameterFromQuery(Name = "ok")] public string? Ok { get; set; }

    private IReadOnlyList<ConnectedClient>? _clients;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        var userId = Org.CurrentUserId;
        if (userId is null) return;
        _clients = await Clients.ListForUserAsync(userId.Value);
    }

    private async Task RevokeAsync(int consentId)
    {
        var userId = Org.CurrentUserId;
        if (userId is null) return;
        await Clients.RevokeConsentAsync(consentId, userId.Value);
        await LoadAsync();
        Ok = "revoked";
    }

    private static string HumanScopes(string scopes)
    {
        var parts = scopes.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        var labels = parts.Select(s => s switch
        {
            "mcp" => "use AL Dev Toolbox tools",
            "offline_access" => "stay signed in",
            _ => s,
        });
        return string.Join(", ", labels);
    }
}
