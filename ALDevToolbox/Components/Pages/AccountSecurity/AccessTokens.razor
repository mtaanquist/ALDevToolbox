@page "/account/access-tokens"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@using ALDevToolbox.Data
@using ALDevToolbox.Domain.Entities
@using ALDevToolbox.Services
@using ALDevToolbox.Components.Shared
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db
@inject IOrganizationContext Org

<PageTitle>Personal access tokens · AL Dev Toolbox</PageTitle>

<div class="account-page">
    <header class="page-header">
        <h1>Personal access tokens</h1>
        <p class="muted">
            Use a token to connect AI agents (Claude Desktop, Cursor, VS Code Copilot, Claude Code)
            to the MCP server. Tokens act as you — same organisation, same role — but never expire
            a browser session and aren't covered by your two-factor settings.
            Treat them like passwords.
            <a href="/docs/mcp-clients">How to configure each client</a>.
        </p>
    </header>

    @if (!string.IsNullOrEmpty(Error))
    {
        <p class="form-error" role="alert">@Error</p>
    }
    @if (Ok == "revoked")
    {
        <p class="form-success" role="status">Token revoked.</p>
    }

    <section class="account-section">
        <h2>Create a token</h2>
        <form method="post" action="/auth/account/access-tokens/create" class="form-grid form-grid--narrow">
            <AntiforgeryToken />
            <section class="form-section">
                <label class="section-label" for="pat-name">Name</label>
                <input id="pat-name" type="text" name="Name" required minlength="1" maxlength="80"
                       placeholder="e.g. Cursor on laptop" />
                <small class="muted">A label that helps you remember where this token is used.</small>
            </section>
            <section class="form-section">
                <label class="section-label" for="pat-ttl">Expires in</label>
                <select id="pat-ttl" name="TtlDays">
                    <option value="30">30 days</option>
                    <option value="90" selected>90 days</option>
                    <option value="180">180 days</option>
                    <option value="365">1 year</option>
                    <option value="0">No expiry</option>
                </select>
                <small class="muted">You can revoke a token at any time.</small>
            </section>
            <button type="submit" class="btn btn--primary">
                <Icon Name="key-round" Width="16" Height="16" />
                <span>Create token</span>
            </button>
        </form>
    </section>

    <section class="account-section">
        <h2>Your tokens</h2>
        @if (_tokens is null)
        {
            <p class="muted">Loading…</p>
        }
        else if (_tokens.Count == 0)
        {
            <p class="muted">You haven't created any tokens yet.</p>
        }
        else
        {
            var now = DateTime.UtcNow;
            var active = _tokens.Where(t => IsActiveAt(t, now)).ToList();
            var inactive = _tokens.Where(t => !IsActiveAt(t, now)).ToList();

            @if (active.Count == 0)
            {
                <p class="muted">No active tokens.</p>
            }
            else
            {
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Prefix</th>
                            <th>Created</th>
                            <th>Last used</th>
                            <th>Expires</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in active)
                        {
                            <tr>
                                <td>@t.Name</td>
                                <td class="muted"><code>@t.TokenPrefix…</code></td>
                                <td class="muted">@t.CreatedAt.ToString("yyyy-MM-dd")</td>
                                <td class="muted">@(t.LastUsedAt?.ToString("yyyy-MM-dd HH:mm 'UTC'") ?? "—")</td>
                                <td class="muted">@(t.ExpiresAt?.ToString("yyyy-MM-dd") ?? "Never")</td>
                                <td class="row-actions">
                                    <form method="post" action="/auth/account/access-tokens/@t.Id/revoke" style="display:inline">
                                        <AntiforgeryToken />
                                        <button type="submit" class="btn btn--sm btn--danger">Revoke</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }

            @if (inactive.Count > 0)
            {
                <details class="inactive-tokens">
                    <summary>Show @inactive.Count revoked or expired @(inactive.Count == 1 ? "token" : "tokens")</summary>
                    <p class="muted">
                        Kept around so audit log entries that reference these tokens still resolve.
                        They can't be used to sign in.
                    </p>
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Prefix</th>
                                <th>Created</th>
                                <th>Last used</th>
                                <th>Expires</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var t in inactive)
                            {
                                var status = StatusFor(t, now);
                                <tr>
                                    <td>@t.Name</td>
                                    <td class="muted"><code>@t.TokenPrefix…</code></td>
                                    <td class="muted">@t.CreatedAt.ToString("yyyy-MM-dd")</td>
                                    <td class="muted">@(t.LastUsedAt?.ToString("yyyy-MM-dd HH:mm 'UTC'") ?? "—")</td>
                                    <td class="muted">@(t.ExpiresAt?.ToString("yyyy-MM-dd") ?? "Never")</td>
                                    <td><span class="status-pill @(status.Css)">@status.Label</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </details>
            }
        }
    </section>

    <p class="muted"><a href="/account">← Back to account</a></p>
</div>

@code {
    [SupplyParameterFromQuery(Name = "err")] public string? Error { get; set; }
    [SupplyParameterFromQuery(Name = "ok")] public string? Ok { get; set; }

    private IReadOnlyList<PersonalAccessToken>? _tokens;

    protected override async Task OnInitializedAsync()
    {
        var userId = Org.CurrentUserId;
        if (userId is null) return;
        _tokens = await Db.PersonalAccessTokens
            .Where(p => p.UserId == userId.Value)
            .OrderByDescending(p => p.CreatedAt)
            .AsNoTracking()
            .ToListAsync();
    }

    /// <summary>
    /// Active = not revoked and not yet past expiry. Revoked tokens and
    /// expired-but-not-revoked tokens both fall to the inactive bucket
    /// the UI folds behind a "Show revoked or expired" toggle.
    /// </summary>
    private static bool IsActiveAt(PersonalAccessToken t, DateTime now)
        => t.RevokedAt is null && (t.ExpiresAt is null || t.ExpiresAt > now);

    private static (string Label, string Css) StatusFor(PersonalAccessToken t, DateTime now)
    {
        if (t.RevokedAt is not null) return ("Revoked", "status-pill--muted");
        if (t.ExpiresAt is { } exp && exp <= now) return ("Expired", "status-pill--muted");
        return ("Active", "");
    }
}
