@page "/signup"
@inject IEmailService Email
@using ALDevToolbox.Services

<PageTitle>Sign up · AL Dev Toolbox</PageTitle>

<div class="login-page">
    <h1>Sign up</h1>

    @if (Error == "invalid" && !string.IsNullOrEmpty(Field))
    {
        <p class="form-error" role="alert"><strong>@Field:</strong> @Message</p>
    }
    else if (Error == "verify-invalid")
    {
        <p class="form-error" role="alert">That verification link or code is no longer valid. Start again below to get a fresh one.</p>
    }
    else if (Error == "code-invalid")
    {
        <p class="form-error" role="alert">That code didn't match. Check the email and try again, or request a new one.</p>
    }
    @if (Ok == "pending")
    {
        <p class="form-success" role="status">Signup recorded. The organisation's admin will be in touch when they approve.</p>
    }
    else if (Ok == "check-email")
    {
        <p class="form-success" role="status">
            If that address can sign up, we've sent it a verification link and code. Click the link in the
            email, or enter the code below. The link and code expire in 30 minutes.
        </p>
    }

    @if (_smtpConfigured)
    {
        <p class="caption muted">
            Enter your email to get started. We'll send you a verification link and code; once you've
            confirmed the address you'll choose a password and finish signing up.
        </p>

        <form method="post" action="/auth/signup/start" class="form-grid login-form">
            <AntiforgeryToken />
            <section class="form-section">
                <label class="section-label" for="su-email">Email</label>
                <input id="su-email" type="email" name="Email" value="@EmailValue" required autofocus autocomplete="username" />
            </section>
            <button type="submit" class="btn">
                <Icon Name="user-plus" Width="16" Height="16" />
                <span>Send verification email</span>
            </button>
        </form>

        <details class="signup-code" open="@(Ok == "check-email" || Error == "code-invalid")">
            <summary>Already have a code?</summary>
            <form method="post" action="/auth/signup/verify-code" class="form-grid login-form">
                <AntiforgeryToken />
                <section class="form-section">
                    <label class="section-label" for="su-code-email">Email</label>
                    <input id="su-code-email" type="email" name="Email" value="@EmailValue" required autocomplete="username" />
                </section>
                <section class="form-section">
                    <label class="section-label" for="su-code">Verification code</label>
                    <input id="su-code" type="text" name="Code" inputmode="numeric" pattern="[0-9]{6}" maxlength="6"
                           required autocomplete="one-time-code" placeholder="6-digit code" />
                </section>
                <button type="submit" class="btn">
                    <Icon Name="check" Width="16" Height="16" />
                    <span>Verify code</span>
                </button>
            </form>
        </details>
    }
    else
    {
        <p class="caption muted">
            If your email domain is already linked to an organisation, we'll route
            you to it automatically. Otherwise, either join an existing
            organisation by its short ID (an admin there will approve you), or
            leave the short ID blank and pick a name to start a brand-new
            organisation. New organisations are activated straight away — you'll
            be signed in as their first admin.
        </p>

        <form method="post" action="/auth/signup" class="form-grid login-form">
            <AntiforgeryToken />

            <section class="form-section">
                <label class="section-label" for="su-email">Email</label>
                <input id="su-email" type="email" name="Email" required autofocus autocomplete="username" />
            </section>

            <section class="form-section">
                <label class="section-label" for="su-display">Display name</label>
                <input id="su-display" type="text" name="DisplayName" required minlength="2" maxlength="80" placeholder="e.g. Bob — Engineering" />
            </section>

            <section class="form-section">
                <label class="section-label" for="su-password">Password</label>
                <input id="su-password" type="password" name="Password" required minlength="12" autocomplete="new-password" />
                <small class="muted">At least 12 characters. Length beats classes.</small>
            </section>

            <section class="form-section">
                <label class="section-label" for="su-org-name">Organisation name</label>
                <input id="su-org-name" type="text" name="OrganizationName" minlength="2" maxlength="80" placeholder="e.g. Acme" />
                <small class="muted">Required when you're creating a new organisation. Ignored if you're joining an existing one.</small>
            </section>

            <section class="form-section">
                <label class="section-label" for="su-org">Organisation short ID (optional)</label>
                <input id="su-org" type="text" name="OrganizationSlug" pattern="[a-z0-9-]*" maxlength="64" placeholder="e.g. acme" />
                <small class="muted">The short, lowercase ID of the organisation you'd like to join. Leave blank to start a new one with the name above.</small>
            </section>

            <button type="submit" class="btn">
                <Icon Name="user-plus" Width="16" Height="16" />
                <span>Sign up</span>
            </button>
        </form>
    }

    <p class="caption muted">Already have an account? <a href="/login">Sign in</a>.</p>
</div>

@code {
    [SupplyParameterFromQuery(Name = "err")] public string? Error { get; set; }
    [SupplyParameterFromQuery(Name = "ok")] public string? Ok { get; set; }
    [SupplyParameterFromQuery(Name = "field")] public string? Field { get; set; }
    [SupplyParameterFromQuery(Name = "msg")] public string? Message { get; set; }
    [SupplyParameterFromQuery(Name = "email")] public string? EmailValue { get; set; }

    private bool _smtpConfigured;

    protected override async Task OnInitializedAsync()
    {
        _smtpConfigured = await Email.IsConfiguredAsync();
    }
}
