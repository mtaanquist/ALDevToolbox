@page "/cookbook"
@attribute [Authorize]
@rendermode InteractiveServer
@implements IDisposable
@inject RecipeService Recipes
@inject NavigationManager Nav
@using ALDevToolbox.Domain.Entities
@using ALDevToolbox.Domain.ValueObjects

<PageTitle>Cookbook · AL Dev Toolbox</PageTitle>

<div class="cookbook">
    <div class="cb-head">
        <div>
            <h1>Cookbook</h1>
            <p class="sub">
                Reusable AL recipes — from one-file snippets to almost-complete
                modules. Search by title, description, or keywords; open one to
                view its files and copy them into your project.
            </p>
        </div>
        <a class="btn" href="/cookbook/suggest">
            <Icon Name="lightbulb" Width="16" Height="16" />
            <span>Suggest a recipe</span>
        </a>
    </div>

    <div class="cb-toolbar">
        <div class="cb-search">
            <Icon Name="search" Width="17" Height="17" />
            <input type="search"
                   class="input"
                   placeholder="Search the cookbook…"
                   value="@_query"
                   @oninput="OnQueryChanged"
                   aria-label="Search the cookbook" />
        </div>
        <div class="cb-pills" role="group" aria-label="Filter by type">
            @foreach (var option in _typeOptions)
            {
                var active = _typeFilter == option.Value;
                <button type="button"
                        class="cb-pill @(active ? "on" : "")"
                        @onclick="() => SetTypeFilter(option.Value)"
                        aria-pressed="@(active ? "true" : "false")">
                    @option.Label
                </button>
            }
        </div>
        <label class="cb-toggle">
            <input type="checkbox" @bind="_includeDeprecated" @bind:after="ReloadAsync" />
            <span class="cbx-box"><Icon Name="check" Width="12" Height="12" /></span>
            Include deprecated
        </label>
    </div>

    @if (_results is null)
    {
        <p class="muted">Loading…</p>
    }
    else
    {
        var rows = ApplyTypeFilter(_results);
        if (rows.Count == 0)
        {
            var emptyOrg = string.IsNullOrWhiteSpace(_query) && _typeFilter is null && !_includeDeprecated;
            <div class="rel-empty">
                <div class="rel-empty-ico"><Icon Name="@(emptyOrg ? "lightbulb" : "search")" Width="24" Height="24" /></div>
                <div class="rel-empty-h">@(emptyOrg ? "No recipes yet" : "No recipes match")</div>
                <p class="rel-empty-p">
                    @if (emptyOrg)
                    {
                        <text>No recipes in this organisation yet. If you have a useful AL pattern to share, click <strong>Suggest a recipe</strong> — an admin will review and publish it.</text>
                    }
                    else
                    {
                        <text>Try a different keyword or clear the type filter.</text>
                    }
                </p>
            </div>
        }
        else
        {
            <div class="cb-grid">
                @foreach (var s in rows)
                {
                    var tags = SplitKeywords(s.Keywords);
                    var fileCount = _fileCounts.GetValueOrDefault(s.Id);
                    <a class="recipe-card" href="@($"/cookbook/{s.Id}")">
                        <div class="rcd-top">
                            <RecipeTypeBadge Type="s.Type" />
                            <span class="rcd-min">
                                @if (s.Deprecated)
                                {
                                    <span class="rcd-deprecated">Deprecated</span>
                                }
                                else if (s.MinimumApplicationVersion is { } minV)
                                {
                                    <Icon Name="tag" Width="12" Height="12" />
                                    <span>Min: @minV.Name</span>
                                }
                            </span>
                        </div>
                        <h3>@s.Title</h3>
                        <p class="rcd-desc">@s.Description</p>
                        @if (tags.Count > 0)
                        {
                            <div class="rcd-tags">
                                @foreach (var tag in tags.Take(6))
                                {
                                    <span class="rcd-tag">@tag</span>
                                }
                                @if (tags.Count > 6)
                                {
                                    <span class="rcd-tag more">+@(tags.Count - 6)</span>
                                }
                            </div>
                        }
                        <div class="rcd-foot">
                            <span class="rcd-files">
                                <Icon Name="file-code" Width="14" Height="14" />
                                <span>@fileCount file@(fileCount == 1 ? "" : "s")</span>
                            </span>
                            <span class="rcd-open">View recipe<Icon Name="arrow-right" Width="14" Height="14" /></span>
                        </div>
                    </a>
                }
            </div>
        }
    }
</div>

@code {
    private string _query = string.Empty;
    private bool _includeDeprecated;
    private RecipeType? _typeFilter;
    private List<Recipe>? _results;
    private Dictionary<int, int> _fileCounts = new();
    private CancellationTokenSource? _debounce;

    private readonly (string Label, RecipeType? Value)[] _typeOptions =
    {
        ("All", (RecipeType?)null),
        ("Snippet", RecipeType.Snippet),
        ("Pattern", RecipeType.Pattern),
        ("Module", RecipeType.Module),
    };

    private static List<string> SplitKeywords(string? keywords) =>
        string.IsNullOrWhiteSpace(keywords)
            ? new List<string>()
            : keywords.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();

    protected override async Task OnInitializedAsync()
    {
        _fileCounts = await Recipes.GetFileCountsAsync();
        await ReloadAsync();
    }

    private void OnQueryChanged(ChangeEventArgs e)
    {
        _query = e.Value?.ToString() ?? string.Empty;
        DebouncedReload();
    }

    private void DebouncedReload()
    {
        _debounce?.Cancel();
        _debounce?.Dispose();
        _debounce = new CancellationTokenSource();
        var token = _debounce.Token;
        _ = Task.Run(async () =>
        {
            try
            {
                await Task.Delay(200, token);
                if (token.IsCancellationRequested) return;
                await InvokeAsync(ReloadAsync);
            }
            catch (TaskCanceledException) { }
        });
    }

    private async Task ReloadAsync()
    {
        _results = await Recipes.SearchAsync(_query, _includeDeprecated);
        StateHasChanged();
    }

    private void SetTypeFilter(RecipeType? value)
    {
        _typeFilter = value;
    }

    private List<Recipe> ApplyTypeFilter(List<Recipe> rows) =>
        _typeFilter is null ? rows : rows.Where(r => r.Type == _typeFilter).ToList();

    public void Dispose()
    {
        _debounce?.Cancel();
        _debounce?.Dispose();
    }
}
