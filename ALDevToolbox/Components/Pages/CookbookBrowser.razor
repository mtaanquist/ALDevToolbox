@page "/cookbook"
@attribute [Authorize]
@rendermode InteractiveServer
@implements IDisposable
@inject RecipeService Recipes
@inject NavigationManager Nav
@using ALDevToolbox.Domain.Entities
@using ALDevToolbox.Domain.ValueObjects

<PageTitle>Cookbook · AL Dev Toolbox</PageTitle>

<div class="snippets-browser">
    <header class="admin-page__header">
        <div>
            <h1>Cookbook</h1>
            <p class="muted">
                Reusable AL recipes — from one-file snippets to almost-complete
                modules. Search by title, description, or keywords; open one to
                view its files and copy them into your project.
            </p>
        </div>
        <a class="btn" href="/cookbook/suggest">
            <Icon Name="lightbulb" Width="16" Height="16" />
            <span>Suggest a recipe</span>
        </a>
    </header>

    <div class="snippets-browser__toolbar">
        <div class="admin-search-form snippets-browser__search">
            <input type="search"
                   class="admin-search-input"
                   placeholder="Search the cookbook…"
                   value="@_query"
                   @oninput="OnQueryChanged"
                   aria-label="Search the cookbook" />
            <button type="button" class="btn btn--icon" @onclick="ReloadAsync" aria-label="Search" title="Search">
                <Icon Name="search" Width="14" Height="14" />
            </button>
        </div>
        <div class="snippets-browser__chips" role="group" aria-label="Filter by type">
            @foreach (var option in _typeOptions)
            {
                var isActive = _typeFilter == option.Value;
                <button type="button"
                        class="btn @(isActive ? "btn--primary" : null)"
                        @onclick="() => SetTypeFilter(option.Value)"
                        aria-pressed="@(isActive ? "true" : "false")">
                    @option.Label
                </button>
            }
        </div>
        <label class="check-row">
            <input type="checkbox" @bind="_includeDeprecated" @bind:after="ReloadAsync" />
            <span>Include deprecated</span>
        </label>
    </div>

    @if (_results is null)
    {
        <p class="muted">Loading…</p>
    }
    else
    {
        var rows = ApplyTypeFilter(_results);
        if (rows.Count == 0)
        {
            @if (string.IsNullOrWhiteSpace(_query) && _typeFilter is null)
            {
                <p class="muted">
                    No recipes in this organisation yet. If you have a useful AL
                    pattern to share, click <strong>Suggest a recipe</strong> — an
                    admin will review and publish it.
                </p>
            }
            else if (_typeFilter is not null && string.IsNullOrWhiteSpace(_query))
            {
                <p class="muted">No <strong>@_typeFilter</strong> recipes in this organisation yet.</p>
            }
            else
            {
                <p class="muted">No recipes match "<strong>@_query</strong>".</p>
            }
        }
        else
        {
            <ul class="snippet-list">
                @foreach (var s in rows)
                {
                    <li class="snippet-card">
                        <a class="snippet-card__title" href="@($"/cookbook/{s.Id}")">@s.Title</a>
                        <span class="snippet-card__badge" title="Recipe type">@s.Type</span>
                        @if (s.Deprecated)
                        {
                            <span class="snippet-card__badge">Deprecated</span>
                        }
                        @if (s.MinimumApplicationVersion is { } minV)
                        {
                            <span class="snippet-card__badge" title="Minimum BC application version">
                                Min: @minV.Name
                            </span>
                        }
                        <p class="snippet-card__description">@s.Description</p>
                        @if (!string.IsNullOrWhiteSpace(s.Keywords))
                        {
                            <div class="snippet-card__keywords">
                                @foreach (var kw in s.Keywords.Split(' ', StringSplitOptions.RemoveEmptyEntries))
                                {
                                    <span class="snippet-card__keyword">@kw</span>
                                }
                            </div>
                        }
                    </li>
                }
            </ul>
        }
    }
</div>

@code {
    private string _query = string.Empty;
    private bool _includeDeprecated;
    private RecipeType? _typeFilter;
    private List<Recipe>? _results;
    private CancellationTokenSource? _debounce;

    private readonly (string Label, RecipeType? Value)[] _typeOptions =
    {
        ("All", (RecipeType?)null),
        ("Snippet", RecipeType.Snippet),
        ("Pattern", RecipeType.Pattern),
        ("Module", RecipeType.Module),
    };

    protected override Task OnInitializedAsync() => ReloadAsync();

    private void OnQueryChanged(ChangeEventArgs e)
    {
        _query = e.Value?.ToString() ?? string.Empty;
        DebouncedReload();
    }

    private void DebouncedReload()
    {
        _debounce?.Cancel();
        _debounce?.Dispose();
        _debounce = new CancellationTokenSource();
        var token = _debounce.Token;
        _ = Task.Run(async () =>
        {
            try
            {
                await Task.Delay(200, token);
                if (token.IsCancellationRequested) return;
                await InvokeAsync(ReloadAsync);
            }
            catch (TaskCanceledException) { }
        });
    }

    private async Task ReloadAsync()
    {
        _results = await Recipes.SearchAsync(_query, _includeDeprecated);
        StateHasChanged();
    }

    private void SetTypeFilter(RecipeType? value)
    {
        _typeFilter = value;
    }

    private List<Recipe> ApplyTypeFilter(List<Recipe> rows) =>
        _typeFilter is null ? rows : rows.Where(r => r.Type == _typeFilter).ToList();

    public void Dispose()
    {
        _debounce?.Cancel();
        _debounce?.Dispose();
    }
}
