@page "/Error"
@using System.Diagnostics

<PageTitle>Something went wrong · AL Dev Toolbox</PageTitle>

<div class="login-page">
    <h1>Something went wrong</h1>
    <p class="muted">
        Sorry — we hit an error processing your request. Try again in a
        moment. If the problem keeps happening, share the reference below
        with your administrator.
    </p>

    @if (ShowRequestId)
    {
        <p class="muted">
            Reference: <code>@RequestId</code>
        </p>
    }
</div>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
