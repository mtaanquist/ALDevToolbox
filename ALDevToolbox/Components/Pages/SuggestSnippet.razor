@page "/snippets/suggest"
@attribute [Authorize]
@rendermode InteractiveServer
@inject SnippetSuggestionService Suggestions
@inject NavigationManager Nav
@inject ILogger<SuggestSnippet> Log
@using ALDevToolbox.Domain.ValueObjects

<PageTitle>Suggest a snippet · AL Dev Toolbox</PageTitle>

<div class="admin-page">
    <a class="btn btn--sm" href="/snippets">
        <Icon Name="arrow-left" Width="14" Height="14" />
        <span>Back to snippets</span>
    </a>

    <h1>Suggest a snippet</h1>
    <p class="muted">
        Submit a reusable AL pattern for an admin to review. Include a clear
        title, a description of what the pattern is for, search keywords, and
        one or more files (each one becomes a separate AL object).
    </p>

    @if (_submitted)
    {
        <p class="form-success" role="status">
            Thanks — your suggestion is pending review. An admin will approve
            or reject it shortly.
        </p>
        <a class="btn" href="/snippets">Back to snippets</a>
    }
    else
    {
        <section class="form-section">
            <label class="section-label" for="snippet-title">Title</label>
            <input id="snippet-title" type="text" maxlength="200"
                   @bind="_title" @bind:event="oninput"
                   placeholder="e.g. Doc. Attachment List Factbox for an unsupported table" />
            <FieldError Field="Title" Errors="_errors" />
        </section>

        <section class="form-section">
            <label class="section-label" for="snippet-description">Description</label>
            <textarea id="snippet-description" rows="4" maxlength="2000"
                      @bind="_description" @bind:event="oninput"
                      placeholder="What does this snippet do, and when would you use it?"></textarea>
            <FieldError Field="Description" Errors="_errors" />
        </section>

        <section class="form-section">
            <label class="section-label" for="snippet-keywords">Keywords</label>
            <input id="snippet-keywords" type="text" maxlength="500"
                   @bind="_keywords" @bind:event="oninput"
                   placeholder="space-separated, e.g. factbox attachment subscriber" />
            <FieldError Field="Keywords" Errors="_errors" />
        </section>

        <section class="form-section">
            <h2>Files</h2>
            <p class="muted">Each file becomes one AL object. Use the file name (e.g. <code>MyPageExt.al</code>) the recipient should save it as.</p>
            <SnippetFileEditor Files="_files" Errors="_errors" />
        </section>

        @if (_lastError is not null)
        {
            <p class="form-error" role="alert">@_lastError</p>
        }

        <div class="form-actions">
            <button type="button" class="btn btn--primary" @onclick="SubmitAsync" disabled="@_busy">
                <Icon Name="send" Width="16" Height="16" />
                <span>Submit for review</span>
            </button>
        </div>
    }
</div>

@code {
    private string _title = string.Empty;
    private string _description = string.Empty;
    private string _keywords = string.Empty;
    private List<SnippetFileEditor.EditableFile> _files = new() { new SnippetFileEditor.EditableFile() };
    private IReadOnlyDictionary<string, string>? _errors;
    private string? _lastError;
    private bool _busy;
    private bool _submitted;

    private async Task SubmitAsync()
    {
        if (_busy) return;
        _busy = true;
        _errors = null;
        _lastError = null;
        try
        {
            var input = new SnippetSuggestionInput(
                _title,
                _description,
                _keywords,
                _files.Select(f => new SnippetFileInput(f.FileName, f.Content)).ToList());
            await Suggestions.SubmitAsync(input);
            _submitted = true;
        }
        catch (PlanValidationException ex)
        {
            _errors = ex.Errors;
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Failed to submit snippet suggestion.");
            _lastError = "An unexpected error occurred. Your suggestion was not saved.";
        }
        finally
        {
            _busy = false;
        }
    }
}
