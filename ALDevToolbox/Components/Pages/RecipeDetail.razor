@page "/cookbook/{Id:int}"
@attribute [Authorize]
@rendermode InteractiveServer
@implements IDisposable
@inject RecipeService Recipes
@inject MarkdownRenderer Markdown
@inject IJSRuntime JS
@using ALDevToolbox.Domain.Entities
@using ALDevToolbox.Services.Cookbook

<PageTitle>@(_recipe?.Title ?? "Recipe") · AL Dev Toolbox</PageTitle>

<div class="recipe-detail">
    <div class="rd-topbar">
        <a class="btn" href="/cookbook">
            <Icon Name="arrow-left" Width="14" Height="14" />
            <span>Back to cookbook</span>
        </a>
    </div>

    @if (_loaded && _recipe is null)
    {
        <p class="form-error" role="alert">Recipe not found.</p>
    }
    else if (_recipe is null)
    {
        <p class="muted">Loading…</p>
    }
    else
    {
        var tags = SplitKeywords(_recipe.Keywords);
        <div class="rd-grid">
            <div class="rd-main">
                <div class="rd-head">
                    <div class="rd-badges">
                        <RecipeTypeBadge Type="_recipe.Type" />
                        @if (_recipe.Deprecated)
                        {
                            <span class="rd-deprecated">Deprecated</span>
                        }
                        @if (_recipe.MinimumApplicationVersion is { } minV)
                        {
                            <span class="rd-min">
                                <Icon Name="tag" Width="13" Height="13" />
                                <span>Min: @minV.Name <span class="mono">(@minV.Application)</span></span>
                            </span>
                        }
                    </div>
                    <h1>@_recipe.Title</h1>
                    <p class="rd-desc">@_recipe.Description</p>
                    @if (tags.Count > 0)
                    {
                        <div class="rd-tags">
                            @foreach (var tag in tags)
                            {
                                <span class="rcd-tag">@tag</span>
                            }
                        </div>
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(_recipe.Instructions))
                {
                    <section class="rd-instructions">
                        <div class="rd-files-h"><span class="cap-label">Instructions</span></div>
                        <div class="rd-instructions-body">
                            @Markdown.Render(_recipe.Instructions)
                        </div>
                    </section>
                }

                <div class="rd-files-h">
                    <span class="cap-label">Files</span>
                    <span class="rd-files-n">@_recipe.Files.Count file@(_recipe.Files.Count == 1 ? "" : "s")</span>
                </div>

                @if (_recipe.Files.Count == 0)
                {
                    <p class="muted">No files attached.</p>
                }
                else
                {
                    @foreach (var file in _recipe.Files)
                    {
                        var path = DisplayPath(file);
                        var anchor = AnchorFor(path);
                        var collapsed = _collapsed.Contains(path);
                        var lines = SplitLines(file.Content);
                        <div id="@anchor" class="codeblock @(collapsed ? "collapsed" : "")">
                            <div class="cb-bar">
                                <button type="button" class="cb-name"
                                        aria-expanded="@((!collapsed).ToString().ToLowerInvariant())"
                                        aria-controls="@($"{anchor}-body")"
                                        @onclick="() => ToggleCollapsed(path)">
                                    <span class="chev"><Icon Name="chevron-down" Width="15" Height="15" /></span>
                                    <Icon Name="file-code" Width="15" Height="15" />
                                    <span class="mono">@path</span>
                                    <span class="cb-lines">@lines.Length lines</span>
                                </button>
                                <button type="button" class="cb-copy" @onclick="() => CopyAsync(file.Content, path)">
                                    <Icon Name="copy" Width="14" Height="14" />
                                    <span>Copy</span>
                                </button>
                            </div>
                            @if (!collapsed)
                            {
                                <div class="cb-body" id="@($"{anchor}-body")">
                                    <pre><code>@for (var li = 0; li < lines.Length; li++)
{<span class="cl"><span class="cl-n">@(li + 1)</span><span class="cl-c">@if (lines[li].Length == 0){<text>&#8203;</text>}else{@foreach (var tok in AlSyntaxHighlighter.TokenizeLine(lines[li])){<span class="tok-@tok.Cls">@tok.Text</span>}}</span></span>}</code></pre>
                                </div>
                            }
                        </div>
                    }
                }
            </div>

            <aside class="rd-rail">
                <div class="card">
                    <div class="card-head"><span class="cap-label">Files</span></div>
                    <div class="rail-files">
                        @foreach (var file in _recipe.Files)
                        {
                            var path = DisplayPath(file);
                            var anchor = AnchorFor(path);
                            <a class="rail-file @(_active == path ? "on" : "")"
                               href="@($"#{anchor}")"
                               @onclick="() => SelectFile(path)"
                               @onclick:preventDefault="false">
                                <Icon Name="file-code" Width="14" Height="14" />
                                <span class="rf-name">@path</span>
                            </a>
                        }
                    </div>
                </div>
                <div class="rd-meta">
                    <div class="rdm-row"><span>Type</span><RecipeTypeBadge Type="_recipe.Type" /></div>
                    <div class="rdm-row">
                        <span>Min. version</span>
                        <b class="mono">@(_recipe.MinimumApplicationVersion?.Application ?? "—")</b>
                    </div>
                    @if (_recipe.EstimatedValueHours is { } hours)
                    {
                        <div class="rdm-row" title="Estimated implementation time this recipe saves — a customer should be billed at least this much.">
                            <span>Est. value</span><b>@FormatHours(hours)</b>
                        </div>
                    }
                    <div class="rdm-row"><span>Files</span><b>@_recipe.Files.Count</b></div>
                    @if (_recipe.Files.Count > 0)
                    {
                        <button type="button" class="btn btn--primary rd-download" @onclick="OpenDownloadModal"
                                title="Download all files in this recipe as a ZIP archive (folders preserved)">
                            <Icon Name="download" Width="15" Height="15" />
                            <span>Download all</span>
                        </button>
                    }
                </div>
            </aside>
        </div>
    }
</div>

<div class="toast @(_toast is null ? "" : "show")" role="status" aria-live="polite">
    @if (_toast is not null)
    {
        <Icon Name="circle-check" Width="16" Height="16" />
        <span>@_toast</span>
    }
</div>

@if (_showDownloadModal)
{
    <div class="confirm-modal" role="dialog" aria-modal="true" aria-labelledby="dl-modal-title"
         @onkeydown="OnDownloadKeyDown">
        <div class="confirm-modal__backdrop" @onclick="CloseDownloadModal" aria-hidden="true"></div>
        <div class="confirm-modal__panel" @onclick:stopPropagation>
            <h2 id="dl-modal-title" class="confirm-modal__title">Download recipe</h2>
            <p class="confirm-modal__message">
                Which customer is this being applied to? We record it so that, if a
                bug turns up in this recipe, we know where a fix needs to land.
            </p>
            <div class="form-section">
                <label class="section-label" for="dl-customer">Customer</label>
                <input id="dl-customer" type="text" list="dl-customers" maxlength="200"
                       @bind="_customerName" @bind:event="oninput"
                       placeholder="e.g. Acme A/S" autofocus />
                <datalist id="dl-customers">
                    @foreach (var name in _customerSuggestions)
                    {
                        <option value="@name" />
                    }
                </datalist>
            </div>
            <div class="confirm-modal__actions">
                <button type="button" class="btn" @onclick="CloseDownloadModal">Cancel</button>
                <button type="button" class="btn btn--primary" @onclick="ConfirmDownloadAsync"
                        disabled="@string.IsNullOrWhiteSpace(_customerName)">
                    <Icon Name="download" Width="14" Height="14" />
                    <span>Download</span>
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private Recipe? _recipe;
    private bool _loaded;
    private string? _active;
    private string? _toast;
    private CancellationTokenSource? _toastTimer;
    private readonly HashSet<string> _collapsed = new(StringComparer.Ordinal);
    private bool _showDownloadModal;
    private string _customerName = string.Empty;
    private List<string> _customerSuggestions = new();

    protected override async Task OnInitializedAsync()
    {
        _recipe = await Recipes.GetAsync(Id);
        _loaded = true;
        _active = _recipe?.Files.Count > 0 ? DisplayPath(_recipe.Files[0]) : null;
    }

    /// <summary>Formats the estimated-value hours compactly, e.g. <c>8 h</c> or <c>2.5 h</c>.</summary>
    private static string FormatHours(decimal hours) => $"{hours.ToString("0.##")} h";

    private async Task OpenDownloadModal()
    {
        _customerName = string.Empty;
        // Refresh suggestions each open so a customer named in this session shows up.
        _customerSuggestions = await Recipes.GetCustomerNamesAsync();
        _showDownloadModal = true;
    }

    private void CloseDownloadModal() => _showDownloadModal = false;

    private void OnDownloadKeyDown(KeyboardEventArgs e)
    {
        if (e.Key is "Escape" or "Esc") CloseDownloadModal();
    }

    /// <summary>
    /// Hands the download off to the ZIP endpoint with the customer name as a
    /// query value. The endpoint records the download and streams an
    /// attachment, so navigating to it downloads the file without leaving the
    /// page — hence <c>location.assign</c> rather than a Blazor navigation.
    /// </summary>
    private async Task ConfirmDownloadAsync()
    {
        if (_recipe is null || string.IsNullOrWhiteSpace(_customerName)) return;
        var url = $"/api/cookbook/{_recipe.Id}/download?customer={Uri.EscapeDataString(_customerName.Trim())}";
        _showDownloadModal = false;
        await JS.InvokeVoidAsync("location.assign", url);
    }

    private static string DisplayPath(RecipeFile file) =>
        string.IsNullOrEmpty(file.RelativePath) ? file.FileName : file.RelativePath + "/" + file.FileName;

    private static string[] SplitLines(string content) =>
        content.Replace("\r\n", "\n").Replace('\r', '\n').Split('\n');

    private static List<string> SplitKeywords(string? keywords) =>
        string.IsNullOrWhiteSpace(keywords)
            ? new List<string>()
            : keywords.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();

    private void ToggleCollapsed(string path)
    {
        if (!_collapsed.Add(path))
        {
            _collapsed.Remove(path);
        }
    }

    /// <summary>Rail click: mark the file active and ensure its block is expanded
    /// so the hash-scroll lands on visible content.</summary>
    private void SelectFile(string path)
    {
        _active = path;
        _collapsed.Remove(path);
    }

    private static string AnchorFor(string path)
    {
        var sb = new System.Text.StringBuilder("recipe-file-");
        foreach (var c in path)
        {
            sb.Append(char.IsLetterOrDigit(c) ? char.ToLowerInvariant(c) : '-');
        }
        return sb.ToString().TrimEnd('-');
    }

    private async Task CopyAsync(string content, string path)
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", content);
            ShowToast($"Copied {path}");
        }
        catch
        {
            // Clipboard write can fail (insecure context, denied permission) —
            // the code is still selectable, so surface nothing.
        }
    }

    private void ShowToast(string message)
    {
        _toast = message;
        _toastTimer?.Cancel();
        _toastTimer?.Dispose();
        _toastTimer = new CancellationTokenSource();
        var token = _toastTimer.Token;
        _ = Task.Run(async () =>
        {
            try
            {
                await Task.Delay(1900, token);
                if (token.IsCancellationRequested) return;
                await InvokeAsync(() =>
                {
                    _toast = null;
                    StateHasChanged();
                });
            }
            catch (TaskCanceledException) { }
        });
    }

    public void Dispose()
    {
        _toastTimer?.Cancel();
        _toastTimer?.Dispose();
    }
}
