@page "/cookbook/{Id:int}"
@attribute [Authorize]
@rendermode InteractiveServer
@implements IDisposable
@inject RecipeService Recipes
@inject MarkdownRenderer Markdown
@inject IJSRuntime JS
@using ALDevToolbox.Domain.Entities

<PageTitle>@(_recipe?.Title ?? "Recipe") · AL Dev Toolbox</PageTitle>

<div class="snippet-detail @(HasOutline ? "snippet-detail--with-outline" : null)">
    <div class="snippet-detail__main">
        <div class="snippet-detail__topbar">
            <a class="btn btn--sm" href="/cookbook">
                <Icon Name="arrow-left" Width="14" Height="14" />
                <span>Back to cookbook</span>
            </a>
            @if (_recipe is not null && _recipe.Files.Count > 0)
            {
                <a class="btn btn--sm" href="@($"/api/cookbook/{_recipe.Id}/download")"
                   title="Download all files in this recipe as a ZIP archive (folders preserved)">
                    <Icon Name="download" Width="14" Height="14" />
                    <span>Download all</span>
                </a>
            }
        </div>

        @if (_loaded && _recipe is null)
        {
            <p class="form-error" role="alert">Recipe not found.</p>
        }
        else if (_recipe is null)
        {
            <p class="muted">Loading…</p>
        }
        else
        {
            <header class="snippet-detail__header">
                <h1>@_recipe.Title</h1>
                <span class="snippet-card__badge" title="Recipe type">@_recipe.Type</span>
                @if (_recipe.Deprecated)
                {
                    <span class="snippet-card__badge">Deprecated</span>
                }
                @if (_recipe.MinimumApplicationVersion is { } minV)
                {
                    <span class="snippet-card__badge" title="Minimum BC application version this recipe targets">
                        Min: @minV.Name (@minV.Application)
                    </span>
                }
            </header>
            <p class="snippet-detail__description">@_recipe.Description</p>
            @if (!string.IsNullOrWhiteSpace(_recipe.Keywords))
            {
                <div class="snippet-card__keywords">
                    @foreach (var kw in _recipe.Keywords.Split(' ', StringSplitOptions.RemoveEmptyEntries))
                    {
                        <span class="snippet-card__keyword">@kw</span>
                    }
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(_recipe.Instructions))
            {
                <section class="snippet-detail__instructions">
                    <h2>Instructions</h2>
                    <div class="snippet-detail__instructions-body">
                        @Markdown.Render(_recipe.Instructions)
                    </div>
                </section>
            }

            <h2>Files</h2>
            @if (_recipe.Files.Count == 0)
            {
                <p class="muted">No files attached.</p>
            }
            else
            {
                <ol class="snippet-detail__files">
                    @foreach (var file in _recipe.Files)
                    {
                        var displayPath = DisplayPath(file);
                        var anchor = AnchorFor(displayPath);
                        var isCollapsed = _collapsed.Contains(displayPath);
                        <li id="@anchor" class="snippet-file-view @(isCollapsed ? "snippet-file-view--collapsed" : null)">
                            <div class="snippet-file-view__header">
                                <button type="button"
                                        class="snippet-file-view__toggle"
                                        aria-expanded="@((!isCollapsed).ToString().ToLowerInvariant())"
                                        aria-controls="@($"{anchor}-content")"
                                        @onclick="() => ToggleCollapsed(displayPath)">
                                    <Icon Name="@(isCollapsed ? "chevron-right" : "chevron-down")" Width="14" Height="14" />
                                    <code>@displayPath</code>
                                </button>
                                <button type="button" class="btn btn--sm" @onclick="() => CopyAsync(file.Content, displayPath)">
                                    <Icon Name="copy" Width="14" Height="14" />
                                    <span>@(IsJustCopied(displayPath) ? "Copied!" : "Copy")</span>
                                </button>
                            </div>
                            <pre id="@($"{anchor}-content")" class="snippet-file-view__content"><code>@file.Content</code></pre>
                        </li>
                    }
                </ol>
            }
        }
    </div>

    @if (HasOutline)
    {
        <aside class="snippet-outline" aria-label="Files in this recipe">
            <div class="snippet-outline__inner">
                <h2 class="snippet-outline__title">Files</h2>
                <ul class="snippet-outline__list">
                    @foreach (var file in _recipe!.Files)
                    {
                        var displayPath = DisplayPath(file);
                        var anchor = AnchorFor(displayPath);
                        <li>
                            <a class="snippet-outline__link"
                               href="@($"#{anchor}")"
                               @onclick="() => ExpandForJump(displayPath)"
                               @onclick:preventDefault="false">@displayPath</a>
                        </li>
                    }
                </ul>
            </div>
        </aside>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }

    private Recipe? _recipe;
    private bool _loaded;
    private string? _justCopied;
    private CancellationTokenSource? _copyTimer;
    private readonly HashSet<string> _collapsed = new(StringComparer.Ordinal);

    private bool HasOutline => _recipe is not null && _recipe.Files.Count > 1;

    protected override async Task OnInitializedAsync()
    {
        _recipe = await Recipes.GetAsync(Id);
        _loaded = true;
    }

    private static string DisplayPath(RecipeFile file) =>
        string.IsNullOrEmpty(file.RelativePath) ? file.FileName : file.RelativePath + "/" + file.FileName;

    private bool IsJustCopied(string path) => _justCopied == path;

    private void ToggleCollapsed(string path)
    {
        if (!_collapsed.Add(path))
        {
            _collapsed.Remove(path);
        }
    }

    /// <summary>
    /// When the user clicks an aside link, expand the target file (if
    /// collapsed) so the browser's hash-scroll lands on visible content
    /// instead of a collapsed stub.
    /// </summary>
    private void ExpandForJump(string path) => _collapsed.Remove(path);

    private static string AnchorFor(string path)
    {
        var sb = new System.Text.StringBuilder("recipe-file-");
        foreach (var c in path)
        {
            sb.Append(char.IsLetterOrDigit(c) ? char.ToLowerInvariant(c) : '-');
        }
        return sb.ToString().TrimEnd('-');
    }

    private async Task CopyAsync(string content, string path)
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", content);
            _justCopied = path;
            _copyTimer?.Cancel();
            _copyTimer?.Dispose();
            _copyTimer = new CancellationTokenSource();
            var token = _copyTimer.Token;
            _ = Task.Run(async () =>
            {
                try
                {
                    await Task.Delay(1500, token);
                    if (token.IsCancellationRequested) return;
                    await InvokeAsync(() =>
                    {
                        _justCopied = null;
                        StateHasChanged();
                    });
                }
                catch (TaskCanceledException) { }
            });
        }
        catch
        {
            // Clipboard write can fail (insecure context, denied permission).
            // Surface nothing — the textarea is still selectable.
        }
    }

    public void Dispose()
    {
        _copyTimer?.Cancel();
        _copyTimer?.Dispose();
    }
}
