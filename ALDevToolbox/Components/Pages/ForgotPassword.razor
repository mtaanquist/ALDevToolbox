@page "/forgot-password"
@using Lucide.Blazor.Components

<PageTitle>Forgot password · AL Dev Toolbox</PageTitle>

<div class="login-page">
    <h1>Forgot password</h1>
    <p class="caption muted">
        Enter your email and we'll send you a single-use reset link, valid for
        one hour. We always show the same confirmation regardless of whether
        the email is in our database.
    </p>

    @if (Error == "not-configured")
    {
        <p class="form-error" role="alert">
            Email is not configured on this server, so password resets aren't
            currently working. Ask an admin to set up SMTP or contact them
            directly.
        </p>
    }
    @if (Ok == "1")
    {
        <p class="form-success" role="status">If that email exists in our database, you'll receive a reset link shortly.</p>
    }

    <form method="post" action="/auth/forgot-password" class="form-grid login-form">
        <AntiforgeryToken />
        <section class="form-section">
            <label class="section-label" for="fp-email">Email</label>
            <input id="fp-email" type="email" name="Email" required autofocus autocomplete="username" />
        </section>
        <button type="submit" class="btn">
            <Icon Name="mail" Width="16" Height="16" />
            <span>Send reset link</span>
        </button>
    </form>
</div>

@code {
    [SupplyParameterFromQuery(Name = "err")] public string? Error { get; set; }
    [SupplyParameterFromQuery(Name = "ok")] public string? Ok { get; set; }
}
