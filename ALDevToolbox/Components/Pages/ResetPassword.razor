@page "/reset-password"

<PageTitle>Reset password · AL Dev Toolbox</PageTitle>

<div class="login-page">
    <h1>Reset password</h1>

    @if (string.IsNullOrEmpty(Token))
    {
        <p class="form-error" role="alert">This page needs a token. Use the link from the password-reset email.</p>
    }
    else
    {
        @if (Error is not null && Message is not null)
        {
            <p class="form-error" role="alert"><strong>@Error:</strong> @Message</p>
        }
        <form method="post" action="/auth/reset-password" class="form-grid login-form">
            <AntiforgeryToken />
            <input type="hidden" name="Token" value="@Token" />

            <section class="form-section">
                <label class="section-label" for="rp-password">New password</label>
                <input id="rp-password" type="password" name="Password" required minlength="12" autofocus autocomplete="new-password" />
                <small class="muted">At least 12 characters.</small>
            </section>

            <button type="submit" class="btn">
                <Icon Name="key-round" Width="16" Height="16" />
                <span>Update password</span>
            </button>
        </form>
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "token")] public string? Token { get; set; }
    [SupplyParameterFromQuery(Name = "err")] public string? Error { get; set; }
    [SupplyParameterFromQuery(Name = "msg")] public string? Message { get; set; }
}
