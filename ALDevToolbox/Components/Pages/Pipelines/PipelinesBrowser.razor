@page "/pipelines"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@inject ALDevToolbox.Services.ObjectExplorer.ArtifactService Artifacts
@inject ALDevToolbox.Services.ObjectExplorer.ProjectService Projects
@inject NavigationManager Nav
@inject IHttpContextAccessor Http
@using ALDevToolbox.Services.ObjectExplorer

@*
    The Pipelines landing: every pipeline across the org's projects, with its latest
    build at a glance and a one-click download of its latest successful build. A
    pipeline is a named build flow under a project (a project can have several, each
    compiling a different set of extensions). Open one for its build history, run a
    build, or edit which extensions it compiles. Any signed-in user can browse and
    download. See .design/artifacts.md.

    Named user: a BC developer who needs the latest compiled .app for a customer
    environment. New pipelines are created here (pick a project) or from a project.
*@

<PageTitle>Pipelines · AL Dev Toolbox</PageTitle>

<div class="art-page">
    <div class="art-head">
        <div class="ah-text">
            <h1>Pipelines</h1>
            <p class="sub">
                A pipeline compiles a chosen set of a project's extensions into downloadable
                <span class="nowrap"><code>.app</code> files</span> — make one per environment
                (Production, Test, ...).
            </p>
        </div>
        @if (_projectOptions.Count > 0)
        {
            <button type="button" class="btn btn--primary" @onclick="NewPipelineAsync">
                <Icon Name="plus" Width="16" Height="16" />
                <span>New pipeline</span>
            </button>
        }
        else
        {
            <a class="btn btn--primary" href="/projects/new">
                <Icon Name="plus" Width="16" Height="16" />
                <span>New project</span>
            </a>
        }
    </div>

    @if (_rows is null)
    {
        <p class="muted">Loading...</p>
    }
    else if (_totalCount == 0)
    {
        <div class="rel-empty">
            <Icon Name="box" Width="30" Height="30" Css="rel-empty-ico" />
            <div class="rel-empty-h">No pipelines yet</div>
            @if (_projectOptions.Count > 0)
            {
                <p class="rel-empty-p">
                    A pipeline picks which of a project's extensions to compile. Create one to
                    start producing downloadable <code>.app</code> files.
                </p>
                <button type="button" class="btn btn--primary" @onclick="NewPipelineAsync">
                    <Icon Name="plus" Width="16" Height="16" />
                    <span>New pipeline</span>
                </button>
            }
            else
            {
                <p class="rel-empty-p">
                    Pipelines belong to a project (a customer). Create a project and point it at the
                    repositories that make up its solution, then add a pipeline.
                </p>
                <a class="btn btn--primary" href="/projects/new">
                    <Icon Name="plus" Width="16" Height="16" />
                    <span>New project</span>
                </a>
            }
        </div>
    }
    else
    {
        <form method="get" class="art-toolbar" role="search">
            <div class="art-search">
                <Icon Name="search" Width="17" Height="17" />
                <input type="search" name="q" value="@_search" class="input"
                       placeholder="Search pipelines by name, project, or owner..."
                       aria-label="Search pipelines" />
            </div>
            @if (!string.IsNullOrEmpty(_search))
            {
                <a class="btn btn--sm" href="/pipelines">Clear</a>
            }
            else
            {
                <span class="tb-sort">Sorted by <b>project</b></span>
            }
        </form>

        <div class="art-count">
            <b>@_totalCount</b> <span>pipeline@(_totalCount == 1 ? "" : "s")</span>
            @if (_buildingCount > 0)
            {
                <span class="sep">·</span>
                <b>@_buildingCount</b> <span>building now</span>
            }
            @if (_failedCount > 0)
            {
                <span class="sep">·</span>
                <b>@_failedCount</b> <span>need@(_failedCount == 1 ? "s" : "") attention</span>
            }
            @if (!string.IsNullOrEmpty(_search))
            {
                <span class="sep">·</span>
                <span>showing</span> <b>@_rows.Count</b> <span>match@(_rows.Count == 1 ? "" : "es")</span>
            }
        </div>

        @if (_rows.Count == 0)
        {
            <p class="muted">
                No pipelines match "<strong>@_search</strong>". <a href="/pipelines">Clear the search</a>.
            </p>
        }
        else
        {
            <div class="art-list">
                <div class="alr lean head">
                    <div>Pipeline</div>
                    <div>Latest build</div>
                    <div>Status</div>
                    <div>When</div>
                    <div class="h-blank"></div>
                </div>

                @foreach (var p in _rows)
                {
                    var sb = p.LatestSuccessfulBuildId;
                    var failedLatest = p.Latest?.Status == "failed";
                    <div class="alr lean proj">
                        <div class="al-proj">
                            <span class="al-pico"><Icon Name="git-branch" Width="18" Height="18" /></span>
                            <div class="al-ptext">
                                <a class="al-pname al-rowlink" href="@($"/pipelines/{p.Id}")">@p.Name</a>
                                <div class="al-pmeta">
                                    <a class="al-rowlink" href="@($"/projects/{p.ProjectId}")"><Icon Name="folder-git-2" Width="12" Height="12" />@p.ProjectName</a>
                                    @if (p.OwnerName is { } owner)
                                    {
                                        <span class="dotsep"></span>
                                        <span class="al-avatar">@Initials(owner)</span>
                                        <span>@owner</span>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="al-build">
                            @if (p.Latest is { } b)
                            {
                                @if (!string.IsNullOrEmpty(b.CommitShort))
                                {
                                    <span class="al-commit"><Icon Name="git-commit-vertical" Width="13" Height="13" />@b.CommitShort</span>
                                }
                                <span class="al-bmeta">
                                    @if (!string.IsNullOrEmpty(b.Branch))
                                    {
                                        <span class="br"><Icon Name="git-branch" Width="12" Height="12" />@b.Branch</span>
                                    }
                                    <span class="al-ver">@(string.IsNullOrEmpty(b.BcVersion) ? "BC —" : $"BC {b.BcVersion}")</span>
                                </span>
                            }
                            else
                            {
                                <span class="muted">No builds yet</span>
                            }
                        </div>

                        <div>
                            @if (p.Latest is { } st)
                            {
                                <BuildStatusPill Status="@st.Status" />
                            }
                            else
                            {
                                <span class="muted">—</span>
                            }
                        </div>

                        <div class="al-date">
                            @if (p.Latest is { } w)
                            {
                                <span title="@AbsoluteWhen(w)">@Verb(w.Status) @TimeAgo(w.FinishedAt ?? w.StartedAt)</span>
                            }
                            else
                            {
                                <span>—</span>
                            }
                        </div>

                        <div class="al-act">
                            <details class="ra__menu">
                                <summary class="ra__solo" title="More actions" aria-label="More actions" aria-haspopup="menu">
                                    <Icon Name="ellipsis-vertical" Width="17" Height="17" />
                                </summary>
                                <div class="ra__pop" role="menu">
                                    <a class="ra__item" href="@($"/pipelines/{p.Id}")" role="menuitem">
                                        <Icon Name="package" Width="15" Height="15" />
                                        <span>View builds</span>
                                    </a>
                                    @if (sb is { } good2)
                                    {
                                        <a class="ra__item" href="@($"/artifacts/build/{good2}/all")" role="menuitem">
                                            <Icon Name="archive" Width="15" Height="15" />
                                            <span>@(failedLatest ? "Download last good build" : "Download all deliverables")</span>
                                        </a>
                                    }
                                    <a class="ra__item" href="@($"/projects/{p.ProjectId}")" role="menuitem">
                                        <Icon Name="folder-git-2" Width="15" Height="15" />
                                        <span>Project settings</span>
                                    </a>
                                    <div class="ra__divider"></div>
                                    <button type="button" class="ra__item" data-copy-url="@($"/pipelines/{p.Id}")" role="menuitem">
                                        <Icon Name="copy" Width="15" Height="15" />
                                        <span data-copy-label>Copy link</span>
                                    </button>
                                </div>
                            </details>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>

<PipelineEditorDialog @ref="_editor" OnSaved="OnPipelineCreatedAsync" />

@code {
    private List<PipelineArtifactsRow>? _rows;
    private List<PipelineProjectOption> _projectOptions = new();
    private int _totalCount;
    private int _buildingCount;
    private int _failedCount;
    private string _search = string.Empty;

    private PipelineEditorDialog? _editor;

    protected override async Task OnInitializedAsync()
    {
        _search = Http.HttpContext?.Request.Query["q"].ToString().Trim() ?? string.Empty;

        var projects = await Projects.ListProjectsAsync();
        _projectOptions = projects.Select(p => new PipelineProjectOption(p.Id, p.Name)).ToList();

        var all = await Artifacts.ListPipelinesAsync();
        _totalCount = all.Count;
        _buildingCount = all.Count(p => p.Latest?.Status is "building" or "queued");
        _failedCount = all.Count(p => p.Latest?.Status == "failed");
        _rows = string.IsNullOrEmpty(_search) ? all : await Artifacts.ListPipelinesAsync(_search);
    }

    private async Task NewPipelineAsync()
    {
        if (_editor is null || _projectOptions.Count == 0) return;
        await _editor.OpenForCreateAsync(_projectOptions);
    }

    private void OnPipelineCreatedAsync(int pipelineId) => Nav.NavigateTo($"/pipelines/{pipelineId}");

    private static string Verb(string status) => status switch
    {
        "ready" => "Built",
        "failed" => "Failed",
        "building" => "Started",
        _ => "Queued",
    };

    /// <summary>The full local timestamp, shown as a hover title behind the relative "when".</summary>
    private static string AbsoluteWhen(BuildSummary b) =>
        (b.FinishedAt ?? b.StartedAt).ToString("yyyy-MM-dd HH:mm");

    /// <summary>A compact relative time ("2 days ago", "4 minutes ago") matching the build history.</summary>
    private static string TimeAgo(DateTime utc)
    {
        var span = DateTime.UtcNow - utc;
        if (span < TimeSpan.Zero) span = TimeSpan.Zero;
        return span switch
        {
            { TotalSeconds: < 60 } => "just now",
            { TotalMinutes: < 60 } => Plural((int)span.TotalMinutes, "minute"),
            { TotalHours: < 24 } => Plural((int)span.TotalHours, "hour"),
            { TotalDays: < 7 } => Plural((int)span.TotalDays, "day"),
            { TotalDays: < 30 } => Plural((int)(span.TotalDays / 7), "week"),
            { TotalDays: < 365 } => Plural((int)(span.TotalDays / 30), "month"),
            _ => Plural((int)(span.TotalDays / 365), "year"),
        };

        static string Plural(int n, string unit) => $"{n} {unit}{(n == 1 ? "" : "s")} ago";
    }

    /// <summary>Two-letter avatar initials from an owner's display name.</summary>
    private static string Initials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length == 0) return "?";
        var first = char.ToUpperInvariant(parts[0][0]);
        return parts.Length > 1 ? $"{first}{char.ToUpperInvariant(parts[^1][0])}" : first.ToString();
    }
}
