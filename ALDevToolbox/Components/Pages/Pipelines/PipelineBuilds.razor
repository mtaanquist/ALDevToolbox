@page "/pipelines/{ProjectId:int}"
@page "/artifacts/{ProjectId:int}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject ALDevToolbox.Services.ObjectExplorer.ArtifactService Artifacts
@inject ALDevToolbox.Services.ObjectExplorer.ProjectService Projects
@inject ALDevToolbox.Services.ObjectExplorer.ProjectBuildImporter Builds
@inject ALDevToolbox.Services.ObjectExplorer.ProjectBuildService BuildService
@inject NavigationManager Nav
@inject ILogger<PipelineBuilds> Log
@using ALDevToolbox.Services.ObjectExplorer
@using ALDevToolbox.Domain.ValueObjects

@*
    One project's builds: a "New build" action that discovers the project's
    extensions live and lets the user pick which to compile, the latest build's
    deliverables (download each .app or all at once), the changelog since the last
    successful build, the full build history, the raw build log, and a project-scoped
    Compare that diffs two of this project's builds in the Object Explorer. The only
    path into a build's objects is the "Explore objects" deep-link here — project
    builds aren't listed in the Object Explorer's global release list. While a build
    is in flight the page polls so the status flips Building -> Ready live. The
    /artifacts/{id} route is kept as an alias. See .design/artifacts.md.

    Named user: a BC consultant cutting a customer build who wants to leave a legacy
    app out. Primary action: New build. Repo editing and project deletion live in the
    Projects tool (/projects/{id}) — this page links there.
*@

<PageTitle>@(_header?.Name ?? "Builds") · Pipelines · AL Dev Toolbox</PageTitle>

<div class="art-page art-detail">
    @if (_loading)
    {
        <p class="muted">Loading...</p>
    }
    else if (_notFound)
    {
        <p class="muted">This project doesn't exist. <a href="/pipelines">Back to pipelines</a>.</p>
    }
    else
    {
        <div class="det-bc">
            <a href="/pipelines"><Icon Name="arrow-left" Width="14" Height="14" />Pipelines</a>
            <span>/</span>
            <span class="cur">@_header!.Name</span>
        </div>

        <div class="det-head">
            <div class="det-id">
                <span class="det-pico"><Icon Name="package" Width="26" Height="26" /></span>
                <div class="det-title">
                    <h1>@_header.Name</h1>
                    <div class="det-sub">
                        @if (_header.OwnerName is { } owner)
                        {
                            <span class="meta"><span class="av">@Initials(owner)</span>@owner</span>
                            <span class="dotsep"></span>
                        }
                        <span class="meta"><Icon Name="history" Width="14" Height="14" />@_builds.Count build@(_builds.Count == 1 ? "" : "s")</span>
                        @if (_latest is { BcVersion: { Length: > 0 } bc })
                        {
                            <span class="dotsep"></span>
                            <span class="meta"><Icon Name="box" Width="14" Height="14" />BC @bc</span>
                        }
                    </div>
                </div>
            </div>
            <div class="det-actions">
                @if (_canManage)
                {
                    <button type="button" class="btn btn--primary" @onclick="OpenNewBuildAsync" disabled="@_showNewBuild">
                        <Icon Name="hammer" Width="15" Height="15" />
                        <span>New build</span>
                    </button>
                }
                @if (_latest is not null && _latestDetail is { Artifacts.Count: > 0 })
                {
                    <a class="btn" href="@($"/artifacts/build/{_latest.Id}/all")">
                        <Icon Name="archive" Width="15" Height="15" />
                        <span>Download all</span>
                    </a>
                }
            </div>
        </div>

        @if (_showNewBuild)
        {
            <div class="confirm-modal" role="dialog" aria-modal="true" aria-labelledby="nb-title"
                 tabindex="-1" @onkeydown="OnModalKeyDown">
                <div class="confirm-modal__backdrop" @onclick="CloseNewBuild" aria-hidden="true"></div>
                <div class="confirm-modal__panel confirm-modal__panel--wide" @onclick:stopPropagation>
                    <h2 id="nb-title" class="confirm-modal__title">New build</h2>

                    @if (_discovering)
                    {
                        <p class="confirm-modal__message nb-status">
                            <span class="nb-spin" aria-hidden="true"></span>
                            Discovering extensions in the project's repositories...
                        </p>
                    }
                    else if (_discoverError is { } de)
                    {
                        <p class="art-fail" role="alert">@de</p>
                        @* Most discovery failures are auth-related, so offer the
                           recovery route directly rather than only naming it. *@
                        <a class="btn btn--sm" href="/account/repository-tokens">
                            <Icon Name="key-round" Width="14" Height="14" />
                            <span>Manage repository tokens</span>
                        </a>
                    }
                    else if (_extensions is { Count: > 0 })
                    {
                        <p class="confirm-modal__message">
                            Choose the extensions to compile. Leave out legacy apps you no longer build.
                        </p>
                        <div class="nb-list">
                            @foreach (var ext in _extensions)
                            {
                                <label class="nb-row">
                                    <input type="checkbox" checked="@IsSelected(ext.AppId)"
                                           @onchange="e => ToggleExtension(ext.AppId, (bool)(e.Value ?? false))" />
                                    <span class="nb-main">
                                        <span class="nb-name">@ext.Name</span>
                                        <span class="nb-meta">@ExtensionMeta(ext)</span>
                                    </span>
                                </label>
                            }
                        </div>
                        <div class="nb-foot">
                            <button type="button" class="nb-linkbtn" @onclick="SelectAll">Select all</button>
                            <span class="nb-sep">·</span>
                            <button type="button" class="nb-linkbtn" @onclick="SelectNone">Clear</button>
                            <span class="nb-count">@_selected.Count of @_extensions.Count selected</span>
                        </div>
                    }
                    else
                    {
                        <p class="confirm-modal__message">
                            No extensions found in this project's repositories. A build needs at least one
                            folder with an <code>app.json</code> outside test folders. Check the repositories
                            in project setup.
                        </p>
                    }

                    @if (_newBuildError is { } nbe)
                    {
                        <p class="art-fail" role="alert">@nbe</p>
                    }

                    <div class="confirm-modal__actions">
                        <button type="button" class="btn" @onclick="CloseNewBuild" disabled="@_starting">Cancel</button>
                        <button type="button" class="btn btn--primary" @onclick="StartBuildAsync"
                                disabled="@(_discovering || _starting || _extensions is not { Count: > 0 } || _selected.Count == 0)">
                            <Icon Name="hammer" Width="14" Height="14" />
                            <span>@(_starting ? "Starting..." : "Build")</span>
                        </button>
                    </div>
                </div>
            </div>
        }

        @if (_builds.Count == 0)
        {
            <div class="rel-empty">
                <Icon Name="box" Width="30" Height="30" Css="rel-empty-ico" />
                <div class="rel-empty-h">No builds yet</div>
                @if (_canManage)
                {
                    <p class="rel-empty-p">
                        No builds yet. Start one to pick which extensions to compile — the resulting
                        <code>.app</code> files show up here to download. You'll need a repository token
                        for each repository; set them up under Account → Repository tokens.
                    </p>
                    <a class="btn" href="@($"/projects/{ProjectId}")">
                        <Icon Name="settings" Width="16" Height="16" />
                        <span>Open project setup</span>
                    </a>
                }
                else
                {
                    <p class="rel-empty-p">
                        The owner hasn't built this project yet. Once they do, its compiled
                        <code>.app</code> files show up here to download.
                    </p>
                }
            </div>
        }
        else
        {
            <div class="det-grid">
                @* ── Main column ──────────────────────────────────────────── *@
                <div class="det-col">

                    @* ── Latest build hero ─────────────────────────────── *@
                    <section class="det-card hero">
                        <div class="dc-head">
                            <span class="dc-t"><Icon Name="box" Width="14" Height="14" />Latest build</span>
                            <BuildStatusPill Status="@_latest!.Status" />
                        </div>
                        <div class="dc-body">
                            <div class="lb-top">
                                @{ var heroCommit = _latestDetail?.RepoCommits.FirstOrDefault()?.CommitHash; }
                                @if (!string.IsNullOrEmpty(heroCommit))
                                {
                                    <span class="lb-commit"><Icon Name="git-commit-vertical" Width="15" Height="15" />@Short(heroCommit)</span>
                                }
                                @if (!string.IsNullOrEmpty(_latest.Branch))
                                {
                                    <span class="lb-branch"><Icon Name="git-branch" Width="13" Height="13" />@_latest.Branch</span>
                                }
                                @if (!string.IsNullOrEmpty(_latest.BcVersion))
                                {
                                    <span class="lb-ver">BC @_latest.BcVersion</span>
                                }
                                <span class="lb-when" title="@StartedTitle(_latest)">@StartedLine(_latest)</span>
                            </div>

                            @if (_inFlight)
                            {
                                <p class="muted art-app__meta">This updates automatically as the build progresses.</p>
                            }

                            @if (_latest.Status == "failed")
                            {
                                <p class="art-fail">@(_latest.FailureMessage ?? "The build failed. See the build log below.")</p>
                            }
                            else if (_latestDetail is { Artifacts.Count: > 0 })
                            {
                                <div class="lb-deliv">
                                    <span class="lbd-label">Deliverables · @_latestDetail.Artifacts.Count app@(_latestDetail.Artifacts.Count == 1 ? "" : "s") · @FormatBytes(_latestDetail.Artifacts.Sum(a => a.SizeBytes))</span>
                                </div>
                                <div class="app-list">
                                    @foreach (var a in _latestDetail.Artifacts)
                                    {
                                        <div class="app-row">
                                            <span class="app-ico"><Icon Name="file-text" Width="15" Height="15" /></span>
                                            <div>
                                                <div class="app-name">@a.FileName</div>
                                                <div class="app-pub">@a.AppName · v@(a.AppVersion)@(a.RuntimeVersion is { } rt ? $" · runtime {rt}" : "")</div>
                                            </div>
                                            <span class="app-size">@FormatBytes(a.SizeBytes)</span>
                                            <a class="btn btn--sm" href="@($"/artifacts/build/{_latest.Id}/app/{a.Id}")" aria-label="@($"Download {a.FileName}")">
                                                <Icon Name="download" Width="14" Height="14" />
                                                <span>Download</span>
                                            </a>
                                        </div>
                                    }
                                </div>
                            }
                            else if (_latest.Status is "queued" or "building")
                            {
                                <p class="muted">Building... the compiled files will appear here when it finishes.</p>
                            }
                            else
                            {
                                <p class="muted">This build produced no downloadable files.</p>
                            }

                            @if (_latestDetail?.ReleaseId is { } relId)
                            {
                                <div class="lb-explore">
                                    <a class="btn btn--sm" href="@($"/object-explorer/release/{relId}")">
                                        <Icon Name="package" Width="14" Height="14" />
                                        <span>Explore objects</span>
                                    </a>
                                </div>
                            }

                            @if (_latestDetail is { Changelog.Count: > 0 })
                            {
                                <div class="chg">
                                    <div class="chg-h">Changes since the last successful build</div>
                                    @foreach (var group in _latestDetail.Changelog)
                                    {
                                        <div class="chg-repo">
                                            <div class="cr-name"><Icon Name="folder-git-2" Width="12" Height="12" />@group.RepoName</div>
                                            <ul>
                                                @foreach (var c in group.Commits)
                                                {
                                                    @if (string.IsNullOrEmpty(c.ShortHash))
                                                    {
                                                        <li class="chg-note">@c.Message</li>
                                                    }
                                                    else
                                                    {
                                                        <li>@c.Message <span class="sha">@c.ShortHash</span></li>
                                                    }
                                                }
                                            </ul>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </section>

                    @* ── Build history ─────────────────────────────────── *@
                    <section class="det-card">
                        <div class="dc-head">
                            <span class="dc-t"><Icon Name="history" Width="14" Height="14" />Build history</span>
                            <span class="al-date">newest first</span>
                        </div>
                        <div class="hist-list">
                            @foreach (var b in _builds)
                            {
                                <div class="hist-row">
                                    <div class="hist-rail"><span class="hdot @b.Status"></span></div>
                                    <div>
                                        <div class="hist-commit">@(b.HeadCommitShort ?? "—")</div>
                                        <div class="hist-msg">
                                            @if (!string.IsNullOrEmpty(b.HeadCommitMessage))
                                            {
                                                <span>@b.HeadCommitMessage</span>
                                                @if (b.CommitCount > 1)
                                                {
                                                    <span class="hist-more">+@(b.CommitCount - 1) more</span>
                                                }
                                            }
                                            else if (b.Status == "failed" && !string.IsNullOrEmpty(b.FailureMessage))
                                            {
                                                <span class="hist-fail">@b.FailureMessage</span>
                                            }
                                            else if (!string.IsNullOrEmpty(b.Branch))
                                            {
                                                <span>@b.Branch</span>
                                            }
                                            else
                                            {
                                                <span class="hist-none">No commit details</span>
                                            }
                                        </div>
                                    </div>
                                    <div><BuildStatusPill Status="@b.Status" /></div>
                                    <div class="hist-when">@TimeAgo(b.FinishedAt ?? b.StartedAt)</div>
                                    <div class="hist-act">
                                        @if (b.Status == "failed")
                                        {
                                            <a class="btn btn--sm" href="@($"/artifacts/build/{b.Id}/log")">
                                                <Icon Name="file-text" Width="13" Height="13" />
                                                <span>Logs</span>
                                            </a>
                                        }
                                        else if (b.ArtifactCount > 0)
                                        {
                                            <span class="hist-apps">@b.ArtifactCount app@(b.ArtifactCount == 1 ? "" : "s")</span>
                                            <a class="btn btn--sm" href="@($"/artifacts/build/{b.Id}/all")" aria-label="@($"Download {b.ArtifactCount} apps as a zip")">
                                                <Icon Name="download" Width="13" Height="13" />
                                                <span>.zip</span>
                                            </a>
                                        }
                                        else if (b.Status is "queued" or "building")
                                        {
                                            <span class="hist-apps">Building...</span>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </section>

                    @* ── Build log ─────────────────────────────────────── *@
                    @if (_latestDetail is { Logs.Count: > 0 })
                    {
                        var logCommit = LatestCommitShort();
                        var logRepo = LatestSingleRepoName();
                        <section class="det-card">
                            <div class="dc-head">
                                <span class="dc-t"><Icon Name="file-text" Width="14" Height="14" />Build log</span>
                                <span class="al-date">@(logCommit is { } lc ? $"{lc} · {LogStatusWord()}" : LogStatusWord())</span>
                            </div>
                            <div class="dc-body">
                                <div class="logbox">
                                    <div class="logbox-h">
                                        <span class="lh-l">
                                            @if (logCommit is { } lc2)
                                            {
                                                <Icon Name="git-commit-vertical" Width="13" Height="13" />
                                                <span class="sha">@lc2</span>
                                            }
                                            @if (logRepo is { } rn)
                                            {
                                                <span>· @rn</span>
                                            }
                                        </span>
                                        <a class="btn btn--sm btn--ghost" href="@($"/artifacts/build/{_latest.Id}/log")">
                                            <Icon Name="download" Width="13" Height="13" />
                                            <span>Raw log</span>
                                        </a>
                                    </div>
                                    <pre>@RenderLog(_latestDetail)</pre>
                                </div>
                            </div>
                        </section>
                    }
                </div>

                @* ── Side rail ────────────────────────────────────────────── *@
                <div class="det-col">
                    <section class="det-card">
                        <div class="dc-head"><span class="dc-t"><Icon Name="folder-git-2" Width="14" Height="14" />Project</span></div>
                        <div class="dc-body">
                            <div class="pj-meta">
                                <div class="pj-row">
                                    <span class="pj-k">Owner</span>
                                    <span class="pj-v">
                                        @if (_header.OwnerName is { } o)
                                        {
                                            <span class="av sm">@Initials(o)</span><span>@o</span>
                                        }
                                        else
                                        {
                                            <span>—</span>
                                        }
                                    </span>
                                </div>
                                <div class="pj-row">
                                    <span class="pj-k">Builds</span>
                                    <span class="pj-v">@_builds.Count</span>
                                </div>
                                @if (_latest is { BcVersion: { Length: > 0 } railBc })
                                {
                                    <div class="pj-row">
                                        <span class="pj-k">Latest BC</span>
                                        <span class="pj-v mono">@railBc</span>
                                    </div>
                                }
                            </div>
                            <a class="pj-link" href="@($"/projects/{ProjectId}")">
                                <Icon Name="settings" Width="15" Height="15" />
                                <span>Edit project settings</span>
                                <Icon Name="external-link" Width="14" Height="14" />
                            </a>
                        </div>
                    </section>

                    @if (_latestDetail is { RepoCommits.Count: > 0 })
                    {
                        <section class="det-card">
                            <div class="dc-head"><span class="dc-t"><Icon Name="folder-git-2" Width="14" Height="14" />Repositories</span></div>
                            <div class="dc-body">
                                <div class="repo-list">
                                    @foreach (var rc in _latestDetail.RepoCommits)
                                    {
                                        <div class="repo-row">
                                            <span class="repo-ico"><Icon Name="folder-git-2" Width="15" Height="15" /></span>
                                            <div class="repo-main">
                                                <div class="repo-name">@rc.RepoName</div>
                                                <div class="repo-meta"><Icon Name="git-commit-vertical" Width="11" Height="11" />@Short(rc.CommitHash)@(string.IsNullOrEmpty(_latest.Branch) ? "" : $" · {_latest.Branch}")</div>
                                            </div>
                                            @if (!string.IsNullOrEmpty(rc.RepoUrl))
                                            {
                                                <a class="repo-link" href="@rc.RepoUrl" target="_blank" rel="noopener noreferrer" aria-label="@($"Open {rc.RepoName} repository")">
                                                    <Icon Name="external-link" Width="15" Height="15" />
                                                </a>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        </section>
                    }

                    @if (_comparable.Count >= 2)
                    {
                        <section class="det-card">
                            <div class="dc-head"><span class="dc-t"><Icon Name="git-compare" Width="14" Height="14" />Compare builds</span></div>
                            <div class="dc-body">
                                <p class="muted art-app__meta">Diff the objects of two of this project's builds in the Object Explorer.</p>
                                <div class="cmp-row">
                                    <select class="input" @bind="_compareLeft" aria-label="First build">
                                        @foreach (var c in _comparable)
                                        {
                                            <option value="@c.ReleaseId">@BuildLabel(c)</option>
                                        }
                                    </select>
                                    <span class="cmp-vs">vs</span>
                                    <select class="input" @bind="_compareRight" aria-label="Second build">
                                        @foreach (var c in _comparable)
                                        {
                                            <option value="@c.ReleaseId">@BuildLabel(c)</option>
                                        }
                                    </select>
                                    <button type="button" class="btn btn--sm cmp-go" @onclick="CompareAsync" disabled="@(_compareLeft == _compareRight)">
                                        <Icon Name="git-compare" Width="14" Height="14" />
                                        <span>Compare</span>
                                    </button>
                                </div>
                            </div>
                        </section>
                    }
                </div>
            </div>
        }
    }
</div>

@code {
    [Parameter] public int ProjectId { get; set; }

    private bool _loading = true;
    private bool _notFound;
    private bool _inFlight;
    private bool _canManage;

    // New-build dialog state: discovery runs in-request (a shallow clone), then the
    // user picks extensions from the checklist before the build is queued.
    private bool _showNewBuild;
    private bool _discovering;
    private bool _starting;
    private string? _discoverError;
    private string? _newBuildError;
    private List<DiscoveredExtension>? _extensions;
    private HashSet<string> _selected = new(StringComparer.Ordinal);

    private ProjectHeader? _header;
    private List<BuildRow> _builds = new();
    private BuildRow? _latest;
    private BuildDetail? _latestDetail;
    private List<ComparableBuildRow> _comparable = new();
    private int _compareLeft;
    private int _compareRight;

    private PeriodicTimer? _poll;
    private CancellationTokenSource? _pollCts;
    private static readonly TimeSpan PollInterval = TimeSpan.FromSeconds(2.5);

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        _loading = false;
        if (_inFlight) StartPoll();
    }

    private async Task LoadAsync()
    {
        _header = await Artifacts.GetProjectHeaderAsync(ProjectId);
        if (_header is null) { _notFound = true; return; }
        _canManage = await Projects.CanManageAsync(ProjectId);

        _builds = await Artifacts.ListBuildsAsync(ProjectId);
        _latest = _builds.FirstOrDefault();
        _latestDetail = _latest is null ? null : await Artifacts.GetBuildDetailAsync(_latest.Id);
        _comparable = await Artifacts.ListComparableBuildsAsync(ProjectId);
        if (_comparable.Count >= 2)
        {
            _compareLeft = _comparable[0].ReleaseId;
            _compareRight = _comparable[1].ReleaseId;
        }
        _inFlight = await Artifacts.HasBuildInFlightAsync(ProjectId);
    }

    private void CompareAsync()
    {
        if (_compareLeft == _compareRight) return;
        Nav.NavigateTo($"/object-explorer/release/{_compareLeft}?scope=Compare&right={_compareRight}");
    }

    /// <summary>
    /// Opens the "New build" dialog and runs live discovery — a shallow clone of the
    /// project's repositories to list their extensions — so the user can pick which to
    /// compile. Owner/admin-only (gated by <see cref="ProjectService.CanManageAsync"/>
    /// for visibility, re-checked in <see cref="ProjectBuildService.DiscoverExtensionsAsync"/>).
    /// A discovery failure (no token, clone error, no app.json) shows inline.
    /// </summary>
    private async Task OpenNewBuildAsync()
    {
        _showNewBuild = true;
        _discovering = true;
        _discoverError = null;
        _newBuildError = null;
        _extensions = null;
        _selected = new(StringComparer.Ordinal);
        try
        {
            var found = await BuildService.DiscoverExtensionsAsync(ProjectId);
            _extensions = found.ToList();
            // Default to every extension selected — the common case is "build it all".
            _selected = found.Select(e => ProjectBuildService.NormalizeAppId(e.AppId)).ToHashSet(StringComparer.Ordinal);
        }
        catch (PlanValidationException ex)
        {
            _discoverError = ex.Errors.Values.FirstOrDefault() ?? "Couldn't discover the project's extensions.";
        }
        catch (ProjectAccessDeniedException)
        {
            _discoverError = "Only the project owner or an admin can build this project.";
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Extension discovery failed for project {ProjectId}.", ProjectId);
            _discoverError = "Couldn't discover the project's extensions. Check the repositories and your repository tokens, then try again.";
        }
        finally
        {
            _discovering = false;
        }
    }

    private void CloseNewBuild()
    {
        if (_starting) return;
        _showNewBuild = false;
    }

    private void OnModalKeyDown(KeyboardEventArgs e)
    {
        if (e.Key is "Escape" or "Esc") CloseNewBuild();
    }

    private bool IsSelected(string appId) => _selected.Contains(ProjectBuildService.NormalizeAppId(appId));

    private void ToggleExtension(string appId, bool isChecked)
    {
        var key = ProjectBuildService.NormalizeAppId(appId);
        if (isChecked) _selected.Add(key);
        else _selected.Remove(key);
    }

    private void SelectAll()
    {
        if (_extensions is null) return;
        _selected = _extensions.Select(e => ProjectBuildService.NormalizeAppId(e.AppId)).ToHashSet(StringComparer.Ordinal);
    }

    private void SelectNone() => _selected = new(StringComparer.Ordinal);

    private static string ExtensionMeta(DiscoveredExtension e)
    {
        var pub = string.IsNullOrWhiteSpace(e.Publisher) ? "" : $"{e.Publisher} · ";
        return $"{pub}v{e.Version} · {e.RepoDisplayName}";
    }

    /// <summary>
    /// Queues a build of the picked extensions. When every extension is selected the
    /// selection is passed as <c>null</c> ("build everything"), so an app added to a
    /// repo after discovery is still built. The build lands queued; LoadAsync picks it
    /// up and the status poll drives Building -> Ready live. Re-checked in
    /// <see cref="ProjectBuildImporter.StartBuildAsync"/>. See .design/artifacts.md.
    /// </summary>
    private async Task StartBuildAsync()
    {
        if (_starting || _extensions is not { Count: > 0 } || _selected.Count == 0) return;
        _starting = true;
        _newBuildError = null;
        try
        {
            var picked = _extensions
                .Where(e => _selected.Contains(ProjectBuildService.NormalizeAppId(e.AppId)))
                .Select(e => e.AppId)
                .ToList();
            // All selected == build everything; null lets the worker compile whatever
            // it finds (including apps added since discovery).
            var selection = picked.Count == _extensions.Count ? null : picked;

            await Builds.StartBuildAsync(ProjectId, selection);
            _showNewBuild = false;
            await LoadAsync();
            if (_inFlight) StartPoll();
        }
        catch (PlanValidationException ex)
        {
            _newBuildError = ex.Errors.Values.FirstOrDefault() ?? "Could not start the build.";
        }
        catch (ProjectAccessDeniedException)
        {
            _newBuildError = "Only the project owner or an admin can build this project.";
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Failed to start build for project {ProjectId}.", ProjectId);
            _newBuildError = "Could not start the build.";
        }
        finally
        {
            _starting = false;
        }
    }

    private void StartPoll()
    {
        if (_poll is not null) return;
        _pollCts = new CancellationTokenSource();
        _poll = new PeriodicTimer(PollInterval);
        _ = PollLoopAsync(_poll, _pollCts.Token);
    }

    private async Task PollLoopAsync(PeriodicTimer timer, CancellationToken token)
    {
        try
        {
            while (await timer.WaitForNextTickAsync(token))
            {
                await LoadAsync();
                await InvokeAsync(StateHasChanged);
                if (!_inFlight) break;
            }
        }
        catch (OperationCanceledException) { /* circuit tearing down */ }
        catch (Exception ex)
        {
            Log.LogError(ex, "Build-status poll failed for project {ProjectId}.", ProjectId);
        }
        finally
        {
            StopPoll();
        }
    }

    private void StopPoll()
    {
        _poll?.Dispose();
        _poll = null;
        _pollCts?.Cancel();
        _pollCts?.Dispose();
        _pollCts = null;
    }

    /// <summary>The hero's relative build time ("Built 2 days ago"); the exact timestamp + who is the hover title.</summary>
    private static string StartedLine(BuildRow b)
    {
        var ago = TimeAgo(b.FinishedAt ?? b.StartedAt);
        return b.Status switch
        {
            "ready" => $"Built {ago}",
            "failed" => $"Failed {ago}",
            _ => $"Started {TimeAgo(b.StartedAt)}",
        };
    }

    private static string StartedTitle(BuildRow b)
    {
        var when = (b.FinishedAt ?? b.StartedAt).ToString("yyyy-MM-dd HH:mm");
        var who = b.StartedByName is { } n ? $" by {n}" : "";
        return $"{when}{who}";
    }

    /// <summary>A compact relative time ("2 days ago", "3 weeks ago") for the build history.</summary>
    private static string TimeAgo(DateTime utc)
    {
        var span = DateTime.UtcNow - utc;
        if (span < TimeSpan.Zero) span = TimeSpan.Zero;
        return span switch
        {
            { TotalSeconds: < 60 } => "just now",
            { TotalMinutes: < 60 } => Plural((int)span.TotalMinutes, "minute"),
            { TotalHours: < 24 } => Plural((int)span.TotalHours, "hour"),
            { TotalDays: < 7 } => Plural((int)span.TotalDays, "day"),
            { TotalDays: < 30 } => Plural((int)(span.TotalDays / 7), "week"),
            { TotalDays: < 365 } => Plural((int)(span.TotalDays / 30), "month"),
            _ => Plural((int)(span.TotalDays / 365), "year"),
        };

        static string Plural(int n, string unit) => $"{n} {unit}{(n == 1 ? "" : "s")} ago";
    }

    private static string BuildLabel(ComparableBuildRow c) =>
        $"{c.StartedAt:yyyy-MM-dd HH:mm}{(string.IsNullOrEmpty(c.BcVersion) ? "" : $" · BC {c.BcVersion}")}";

    private static string Short(string hash) => hash.Length > 7 ? hash[..7] : hash;

    /// <summary>
    /// The captured log as colourised lines for the terminal view. Each line is
    /// HTML-encoded, then wrapped in a span whose class drives the colour
    /// (<c>l-err</c>/<c>l-warn</c>/<c>l-ok</c>/<c>l-dim</c>); ordinary output gets no
    /// class and inherits the box colour. The classification is a cheap heuristic on
    /// the compiler's own line prefixes — cosmetic emphasis, not a parser. The
    /// "Raw log" download stays the source of truth.
    /// </summary>
    private static MarkupString RenderLog(BuildDetail d)
    {
        var spans = new List<string>();
        foreach (var section in d.Logs)
        {
            spans.Add($"<span class=\"l-dim\">=== {System.Net.WebUtility.HtmlEncode(section.Section)} ===</span>");
            var lines = section.Content.Replace("\r\n", "\n").Replace('\r', '\n').Split('\n');
            foreach (var line in lines)
            {
                var cls = ClassifyLogLine(line);
                var text = System.Net.WebUtility.HtmlEncode(line);
                spans.Add(cls is null ? $"<span>{text}</span>" : $"<span class=\"l-{cls}\">{text}</span>");
            }
        }
        return new MarkupString(string.Join("\n", spans));
    }

    /// <summary>Heuristic colour bucket for one log line, or null for ordinary output.</summary>
    private static string? ClassifyLogLine(string line)
    {
        var t = line.TrimStart();
        if (t.Length == 0) return null;
        const StringComparison ci = StringComparison.OrdinalIgnoreCase;
        if (t.StartsWith('✗') || t.Contains("error AL", ci) || t.Contains(": error", ci)
            || t.Contains("error:", ci) || t.Contains("FAILED", StringComparison.Ordinal)
            || t.Contains("Build failed", ci))
            return "err";
        if (t.StartsWith('⚠') || t.Contains("warning AL", ci) || t.Contains(": warning", ci)
            || t.Contains("warning:", ci))
            return "warn";
        if (t.StartsWith('✓') || t.Contains("compiled", ci) || t.Contains("succeeded", ci)
            || t.Contains("Created package", ci))
            return "ok";
        if (t.StartsWith('$') || t.StartsWith("===", ci) || t.StartsWith("Restoring", ci)
            || t.StartsWith("Provisioning", ci) || t.StartsWith('['))
            return "dim";
        return null;
    }

    /// <summary>The latest build's representative commit (first repo's, shortened), or null.</summary>
    private string? LatestCommitShort()
        => _latestDetail?.RepoCommits.FirstOrDefault()?.CommitHash is { Length: > 0 } h ? Short(h) : null;

    /// <summary>The repo name when the latest build has exactly one, for the log terminal header.</summary>
    private string? LatestSingleRepoName()
        => _latestDetail is { RepoCommits.Count: 1 } d ? d.RepoCommits[0].RepoName : null;

    private string LogStatusWord() => _latest!.Status switch
    {
        "ready" => "ready",
        "failed" => "failed",
        "building" => "building",
        "queued" => "queued",
        _ => _latest.Status,
    };

    private static string FormatBytes(long bytes) => bytes switch
    {
        < 1024 => $"{bytes} B",
        < 1024 * 1024 => $"{bytes / 1024.0:0.#} KB",
        _ => $"{bytes / (1024.0 * 1024):0.#} MB",
    };

    /// <summary>Two-letter avatar initials from an owner's display name.</summary>
    private static string Initials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length == 0) return "?";
        var first = char.ToUpperInvariant(parts[0][0]);
        return parts.Length > 1 ? $"{first}{char.ToUpperInvariant(parts[^1][0])}" : first.ToString();
    }

    public ValueTask DisposeAsync()
    {
        StopPoll();
        return ValueTask.CompletedTask;
    }
}
