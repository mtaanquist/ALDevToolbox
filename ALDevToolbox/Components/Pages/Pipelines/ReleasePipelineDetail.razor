@page "/releases/{Id:int}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject ALDevToolbox.Services.ObjectExplorer.ReleasePipelineService Releases
@inject ALDevToolbox.Services.ObjectExplorer.DeliveryService Deliveries
@inject ALDevToolbox.Services.ObjectExplorer.ArtifactService Artifacts
@inject NavigationManager Nav
@inject ILogger<ReleasePipelineDetail> Log
@using ALDevToolbox.Services.ObjectExplorer
@using ALDevToolbox.Domain.Entities.ObjectExplorer
@using ALDevToolbox.Domain.ValueObjects

@*
    A release pipeline's detail page: its target + how it publishes, the canonical
    "Release" action (enabled once the source build pipeline has a successful build),
    and the delivery history with live status. Mirrors the build pipeline's
    /pipelines/{id} (builds) for the release side. See .design/saas-delivery.md.

    Named user: a BC consultant who set up a release target and now ships a build to it,
    then watches it install.
*@

<PageTitle>@(_rp?.Name ?? "Release pipeline") · AL Dev Toolbox</PageTitle>

<div class="art-page art-detail">
    <div class="det-bc">
        <a href="/releases"><Icon Name="chevron-left" Width="14" Height="14" />Releases</a>
        <span>/</span>
        <span class="cur">@(_rp?.Name ?? "...")</span>
    </div>

    @if (_loading)
    {
        <p class="muted">Loading...</p>
    }
    else if (_rp is null)
    {
        <div class="rel-empty">
            <Icon Name="send" Width="30" Height="30" Css="rel-empty-ico" />
            <div class="rel-empty-h">This release pipeline doesn't exist</div>
            <p class="rel-empty-p">It may have been deleted. Head back to the list to pick another.</p>
            <a class="btn btn--primary" href="/releases"><Icon Name="arrow-left" Width="16" Height="16" /><span>All releases</span></a>
        </div>
    }
    else
    {
        <div class="det-head">
            <div class="det-id">
                <span class="det-pico"><Icon Name="send" Width="24" Height="24" /></span>
                <div class="det-title">
                    <h1>@_rp.Name</h1>
                    <div class="det-sub">
                        <span class="type-pill @(_isProduction ? "prod" : "sandbox")"><span class="td"></span>@_rp.ProjectEnvironment!.Type</span>
                        <span class="meta">@_rp.ProjectEnvironment.Name@(_rp.ProjectEnvironment.CompanyName is { } co ? $" · {co}" : "")</span>
                        <span class="meta"><Icon Name="rocket" Width="14" Height="14" />from <a class="al-sublink" href="@($"/pipelines/{_rp.BuildPipelineId}")">@_rp.BuildPipeline!.Name</a></span>
                    </div>
                </div>
            </div>
            <div class="det-actions">
                <a class="btn" href="/releases"><Icon Name="arrow-left" Width="15" Height="15" /><span>All releases</span></a>
                @if (_canManage)
                {
                    <button type="button" class="btn" @onclick="EditAsync">
                        <Icon Name="pencil" Width="15" Height="15" /><span>Edit</span>
                    </button>
                    <button type="button" class="btn btn--primary" @onclick="OpenReleaseAsync" disabled="@(_successfulBuilds.Count == 0)"
                            title="@(_successfulBuilds.Count == 0 ? "The build pipeline has no successful build to release yet." : null)">
                        <Icon Name="send" Width="15" Height="15" /><span>Release</span>
                    </button>
                }
            </div>
        </div>

        @if (_rp.ProjectEnvironment.MissingSince is not null)
        {
            <p class="art-fail" role="alert">
                This release pipeline's target environment is no longer present in Business Central. Refresh the
                environments on <a href="@($"/projects/{_rp.ProjectId}")">the project's Business Central page</a> before releasing.
            </p>
        }
        else if (_canManage && _successfulBuilds.Count == 0)
        {
            <p class="muted">
                <b>@_rp.BuildPipeline!.Name</b> has no successful build yet. Run a build on
                <a href="@($"/pipelines/{_rp.BuildPipelineId}")">the build pipeline</a>, then come back to release it.
            </p>
        }

        <div class="set-sec-head">
            <h2>Deliveries</h2>
            <span class="desc">Each release of a build to @_rp.ProjectEnvironment.Name, newest first.</span>
        </div>

        @if (_deliveries.Count == 0)
        {
            <div class="rel-empty">
                <Icon Name="send" Width="28" Height="28" Css="rel-empty-ico" />
                <div class="rel-empty-h">No releases yet</div>
                <p class="rel-empty-p">
                    When you release a successful build, it uploads and installs the apps into
                    @_rp.ProjectEnvironment.Name and the run shows up here.
                </p>
                @if (_canManage && _successfulBuilds.Count > 0)
                {
                    <button type="button" class="btn btn--primary" @onclick="OpenReleaseAsync">
                        <Icon Name="send" Width="16" Height="16" /><span>Release</span>
                    </button>
                }
            </div>
        }
        else
        {
            <div class="del-list">
                @foreach (var d in _deliveries)
                {
                    <div class="del-row">
                        <div class="del-row-head">
                            <DeliveryStatusPill Status="@d.Status" />
                            <span class="del-build">Build #@d.ProjectBuildId</span>
                            @if (d.IsScheduled)
                            {
                                <span class="del-when" title="@ScheduledAbsolute(d)">for @ScheduledWhen(d)</span>
                            }
                            else
                            {
                                <span class="del-when" title="@AbsoluteWhen(d)">@RelativeWhen(d)</span>
                            }
                            @if (d.ScheduledOutsideWindow)
                            {
                                <span class="del-outside" title="Scheduled outside the environment's update window"><Icon Name="triangle-alert" Width="12" Height="12" />outside window</span>
                            }
                            @if (d.TriggeredByName is { } who)
                            {
                                <span class="del-by"><span class="av sm">@Initials(who)</span>@who</span>
                            }
                            @if (d.IsScheduled && _canManage)
                            {
                                <span class="del-actions">
                                    <button type="button" class="btn btn--sm" @onclick="() => OpenRescheduleAsync(d)">Reschedule</button>
                                    <button type="button" class="btn btn--sm btn--danger" @onclick="() => CancelAsync(d)">Cancel</button>
                                </span>
                            }
                        </div>

                        @if (!string.IsNullOrEmpty(d.FailureMessage))
                        {
                            <p class="del-fail">@d.FailureMessage</p>
                        }

                        @if (d.Apps.Count > 0)
                        {
                            <div class="del-apps">
                                @foreach (var a in d.Apps)
                                {
                                    <div class="del-app">
                                        <span class="del-app-dot del-app-dot--@AppCss(a.Status)" title="@AppLabel(a.Status)"></span>
                                        <span class="del-app-name">@a.AppName</span>
                                        <span class="del-app-ver">@a.AppVersion</span>
                                        @if (a.Status == ProjectDeliveryResultStatus.Failed && !string.IsNullOrEmpty(a.Message))
                                        {
                                            <span class="del-app-msg">@a.Message</span>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }
    }
</div>

<ReleasePipelineEditorDialog @ref="_editor" OnSaved="OnEditedAsync" />
<ReleaseBuildDialog @ref="_releaseDialog" OnReleased="OnReleasedAsync" />
<ConfirmDialog @ref="_cancelConfirm" Title="Cancel this delivery?"
               ConfirmLabel="Cancel delivery" ConfirmButtonClass="btn--danger" ConfirmIcon="circle-x" />

@if (_rescheduleId is not null)
{
    <div class="confirm-modal" role="dialog" aria-modal="true" aria-labelledby="rs-title" tabindex="-1">
        <div class="confirm-modal__backdrop" @onclick="CloseReschedule" aria-hidden="true"></div>
        <div class="confirm-modal__panel" @onclick:stopPropagation>
            <h2 id="rs-title" class="confirm-modal__title">Reschedule delivery</h2>
            <div class="pe-field">
                <label class="field__label" for="rs-when">New time</label>
                <input id="rs-when" type="datetime-local" class="field__input" @bind="_rescheduleLocal" disabled="@_rescheduling" />
                <small class="muted">Time is in the customer's timezone (@_tzLabel).</small>
            </div>
            @if (_rescheduleError is { } err)
            {
                <p class="art-fail" role="alert">@err</p>
            }
            <div class="confirm-modal__actions">
                <button type="button" class="btn" @onclick="CloseReschedule" disabled="@_rescheduling">Cancel</button>
                <button type="button" class="btn btn--primary" @onclick="SaveRescheduleAsync" disabled="@_rescheduling">
                    <Icon Name="save" Width="14" Height="14" /><span>@(_rescheduling ? "Saving..." : "Reschedule")</span>
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private bool _loading = true;
    private ReleasePipeline? _rp;
    private bool _canManage;
    private bool _isProduction;
    private List<DeliveryHistoryRow> _deliveries = new();
    private List<ReleaseBuildDialog.ReleasableBuildOption> _successfulBuilds = new();

    private ReleasePipelineEditorDialog? _editor;
    private ReleaseBuildDialog? _releaseDialog;
    private ConfirmDialog? _cancelConfirm;

    private TimeZoneInfo _tz = TimeZoneInfo.Utc;
    private string _tzLabel = "UTC";

    // Reschedule modal state.
    private int? _rescheduleId;
    private DateTime _rescheduleLocal;
    private bool _rescheduling;
    private string? _rescheduleError;

    private static readonly TimeSpan PollInterval = TimeSpan.FromSeconds(2);
    private PeriodicTimer? _poll;
    private CancellationTokenSource? _pollCts;

    protected override async Task OnInitializedAsync() => await LoadAsync(startPollIfActive: true);

    private async Task LoadAsync(bool startPollIfActive)
    {
        _loading = true;
        _rp = await Releases.GetReleasePipelineAsync(Id);
        if (_rp is null) { _loading = false; return; }

        _isProduction = string.Equals(_rp.ProjectEnvironment?.Type, "Production", StringComparison.OrdinalIgnoreCase);
        _tz = ALDevToolbox.Domain.ValueObjects.ObjectExplorer.UpdateWindow.ResolveTimeZone(_rp.Project?.BcTimeZone);
        _tzLabel = string.IsNullOrWhiteSpace(_rp.Project?.BcTimeZone) ? "UTC" : _rp.Project!.BcTimeZone!;
        _canManage = await Releases.CanManageAsync(Id);
        _deliveries = await Deliveries.ListDeliveryHistoryAsync(Id);

        // The releasable builds are the source build pipeline's successful builds, newest first.
        var builds = await Artifacts.ListBuildsAsync(_rp.BuildPipelineId);
        _successfulBuilds = builds
            .Where(b => b.Status == "ready")
            .OrderByDescending(b => b.FinishedAt ?? b.StartedAt)
            .Select(b => new ReleaseBuildDialog.ReleasableBuildOption(b.Id, BuildLabel(b)))
            .ToList();

        _loading = false;
        if (startPollIfActive) EnsurePolling();
    }

    private async Task EditAsync()
    {
        if (_editor is null || _rp is null) return;
        var row = new ReleasePipelineRow(
            _rp.Id, _rp.ProjectId, _rp.Name, _rp.BuildPipelineId, _rp.BuildPipeline?.Name ?? "",
            _rp.ProjectEnvironmentId, _rp.ProjectEnvironment?.Name ?? "", _rp.ProjectEnvironment?.Type ?? "",
            _rp.ProjectEnvironment?.CompanyName, _rp.ProjectEnvironment?.MissingSince != null,
            _rp.VersionMode, _rp.SchemaSyncMode);
        await _editor.OpenForEditAsync(row);
    }

    private async Task OnEditedAsync(int _) => await LoadAsync(startPollIfActive: false);

    private async Task OpenReleaseAsync()
    {
        if (_releaseDialog is null || _rp is null || _successfulBuilds.Count == 0) return;
        await _releaseDialog.OpenAsync(
            _rp.Id, _rp.ProjectEnvironment!.Name, _rp.ProjectEnvironment.Type,
            _rp.VersionMode, _rp.SchemaSyncMode, _successfulBuilds,
            _rp.Project?.BcTimeZone, _rp.ProjectEnvironment.UpdateWindowStart, _rp.ProjectEnvironment.UpdateWindowEnd);
    }

    private async Task OnReleasedAsync(int _)
    {
        await LoadAsync(startPollIfActive: false);
        EnsurePolling(); // a release-now delivery is active → start watching
    }

    // ── Cancel + reschedule (scheduled deliveries only) ───────────────────────

    private async Task CancelAsync(DeliveryHistoryRow d)
    {
        if (_cancelConfirm is null) return;
        var confirmed = await _cancelConfirm.OpenAsync(
            "Cancel this delivery?",
            $"Cancel the delivery of build #{d.ProjectBuildId} scheduled for {ScheduledWhen(d)}? It won't run.",
            "Cancel delivery");
        if (!confirmed) return;
        try
        {
            await Deliveries.CancelDeliveryAsync(d.Id);
            await LoadAsync(startPollIfActive: false);
        }
        catch (PlanValidationException ex)
        {
            // Lost the race — it already started. Reflect the new state.
            Log.LogInformation(ex, "Cancel race on delivery {DeliveryId}.", d.Id);
            await LoadAsync(startPollIfActive: true);
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Failed to cancel delivery {DeliveryId}.", d.Id);
        }
    }

    private void OpenRescheduleAsync(DeliveryHistoryRow d)
    {
        _rescheduleId = d.Id;
        _rescheduleError = null;
        _rescheduling = false;
        // Prefill to the delivery's current time in the customer's tz.
        var local = TimeZoneInfo.ConvertTimeFromUtc(DateTime.SpecifyKind(d.ScheduledFor, DateTimeKind.Utc), _tz);
        _rescheduleLocal = new DateTime(local.Year, local.Month, local.Day, local.Hour, local.Minute, 0, DateTimeKind.Unspecified);
    }

    private void CloseReschedule()
    {
        if (_rescheduling) return;
        _rescheduleId = null;
    }

    private async Task SaveRescheduleAsync()
    {
        if (_rescheduleId is not { } id) return;
        _rescheduling = true;
        _rescheduleError = null;
        try
        {
            var utc = TimeZoneInfo.ConvertTimeToUtc(DateTime.SpecifyKind(_rescheduleLocal, DateTimeKind.Unspecified), _tz);
            await Deliveries.RescheduleDeliveryAsync(id, utc);
            _rescheduleId = null;
            await LoadAsync(startPollIfActive: true);
        }
        catch (PlanValidationException ex)
        {
            _rescheduleError = ex.Errors.Values.FirstOrDefault() ?? "Couldn't reschedule the delivery.";
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Failed to reschedule delivery {DeliveryId}.", id);
            _rescheduleError = "Couldn't reschedule the delivery.";
        }
        finally
        {
            _rescheduling = false;
        }
    }

    // ── Live polling of in-flight deliveries ──────────────────────────────────

    private void EnsurePolling()
    {
        if (_poll is not null) return;
        if (!_deliveries.Any(d => d.IsActive)) return;
        _pollCts = new CancellationTokenSource();
        _poll = new PeriodicTimer(PollInterval);
        _ = PollLoopAsync(_poll, _pollCts.Token);
    }

    private async Task PollLoopAsync(PeriodicTimer timer, CancellationToken token)
    {
        try
        {
            while (await timer.WaitForNextTickAsync(token))
            {
                _deliveries = await Deliveries.ListDeliveryHistoryAsync(Id, token);
                await InvokeAsync(StateHasChanged);
                if (!_deliveries.Any(d => d.IsActive)) { StopPoll(); break; }
            }
        }
        catch (OperationCanceledException) { /* navigating away */ }
        catch (Exception ex)
        {
            Log.LogError(ex, "Delivery poll failed for release pipeline {ReleasePipelineId}.", Id);
        }
        finally
        {
            StopPoll();
        }
    }

    private void StopPoll()
    {
        _poll?.Dispose();
        _poll = null;
        _pollCts?.Cancel();
        _pollCts?.Dispose();
        _pollCts = null;
    }

    public ValueTask DisposeAsync()
    {
        StopPoll();
        return ValueTask.CompletedTask;
    }

    // ── Display helpers ───────────────────────────────────────────────────────

    private static string BuildLabel(BuildRow b)
    {
        var ver = string.IsNullOrEmpty(b.BcVersion) ? "" : $" · BC {b.BcVersion}";
        var when = (b.FinishedAt ?? b.StartedAt).ToString("yyyy-MM-dd HH:mm");
        return $"#{b.Id}{ver} · {when}";
    }

    private static string AppCss(string status) => status switch
    {
        ProjectDeliveryResultStatus.Completed => "ok",
        ProjectDeliveryResultStatus.Failed => "fail",
        ProjectDeliveryResultStatus.Uploading or ProjectDeliveryResultStatus.Installing => "busy",
        ProjectDeliveryResultStatus.Skipped => "skip",
        _ => "pending",
    };

    private static string AppLabel(string status) => status switch
    {
        ProjectDeliveryResultStatus.Completed => "Installed",
        ProjectDeliveryResultStatus.Failed => "Failed",
        ProjectDeliveryResultStatus.Uploading => "Uploading",
        ProjectDeliveryResultStatus.Installing => "Installing",
        ProjectDeliveryResultStatus.Skipped => "Skipped",
        _ => "Pending",
    };

    private static string AbsoluteWhen(DeliveryHistoryRow d) => d.CreatedAt.ToString("yyyy-MM-dd HH:mm");

    /// <summary>The scheduled time in the customer's timezone, e.g. "2026-07-01 22:00".</summary>
    private string ScheduledWhen(DeliveryHistoryRow d) =>
        TimeZoneInfo.ConvertTimeFromUtc(DateTime.SpecifyKind(d.ScheduledFor, DateTimeKind.Utc), _tz).ToString("yyyy-MM-dd HH:mm");

    private string ScheduledAbsolute(DeliveryHistoryRow d) => $"{ScheduledWhen(d)} ({_tzLabel})";

    private static string RelativeWhen(DeliveryHistoryRow d)
    {
        var span = DateTime.UtcNow - d.CreatedAt;
        if (span < TimeSpan.Zero) span = TimeSpan.Zero;
        return span switch
        {
            { TotalSeconds: < 60 } => "just now",
            { TotalMinutes: < 60 } => $"{(int)span.TotalMinutes} min ago",
            { TotalHours: < 24 } => $"{(int)span.TotalHours} hr ago",
            { TotalDays: < 7 } => $"{(int)span.TotalDays} day{((int)span.TotalDays == 1 ? "" : "s")} ago",
            _ => $"on {d.CreatedAt:yyyy-MM-dd}",
        };
    }

    private static string Initials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length == 0) return "?";
        var first = char.ToUpperInvariant(parts[0][0]);
        return parts.Length > 1 ? $"{first}{char.ToUpperInvariant(parts[^1][0])}" : first.ToString();
    }
}
