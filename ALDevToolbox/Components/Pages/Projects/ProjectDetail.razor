@page "/projects/new"
@page "/projects/{Id:int}"
@attribute [Authorize]
@rendermode InteractiveServer
@inject ALDevToolbox.Services.ObjectExplorer.ProjectService Projects
@inject ALDevToolbox.Services.ObjectExplorer.PipelineService PipelinesSvc
@inject ALDevToolbox.Services.ObjectExplorer.ArtifactService Artifacts
@inject ALDevToolbox.Services.ObjectExplorer.Bc.ProjectConnectionService Connection
@inject ALDevToolbox.Services.OrganizationConfigService Config
@inject NavigationManager Nav
@inject ILogger<ProjectDetail> Log
@using ALDevToolbox.Domain.Entities.ObjectExplorer
@using ALDevToolbox.Domain.ValueObjects
@using ALDevToolbox.Services
@using ALDevToolbox.Services.ObjectExplorer
@using ALDevToolbox.Services.ObjectExplorer.Bc

@*
    One project's setup: its name, default country, and the Git repositories that
    make up its solution, plus a link into the Pipelines tool where builds are
    started and their output downloaded. Doubles as the create form (/projects/new).

    Only the owner or an org admin can edit or delete — the affordances are hidden
    for everyone else, who still sees the repositories read-only and can follow
    through to download builds. Named user: the project's owner setting up a
    customer solution. Primary action: Save. See .design/artifacts.md.
*@

<PageTitle>@(_header?.Name ?? (Id is null ? "New project" : "Project")) · Projects · AL Dev Toolbox</PageTitle>

<div class="admin-page">
    <header class="admin-page__header">
        <div>
            <h1>@HeaderTitle()</h1>
            @if (_header?.OwnerName is { } owner)
            {
                <p class="muted">Owned by @owner</p>
            }
        </div>
        <div class="admin-page__header-actions">
            @if (!_loading && !_notFound)
            {
                @if (_canManage)
                {
                    @if (_dirty)
                    {
                        <span class="cust-save-hint">Unsaved changes</span>
                    }
                    @* Save is the page's primary action in create mode; once the
                       project exists, building moves to the Pipelines tool, so Save
                       drops to the outline style and there's no primary here. *@
                    <button type="button" class="btn btn--sm @(Id is null ? "btn--primary" : "")" @onclick="SaveAsync" disabled="@_saving">
                        <Icon Name="save" Width="14" Height="14" />
                        <span>@(_saving ? "Saving..." : "Save project")</span>
                    </button>
                }
            }
            <a class="btn btn--sm" href="/projects">
                <Icon Name="arrow-left" Width="14" Height="14" />
                <span>All projects</span>
            </a>
        </div>
    </header>

    @if (_message is not null)
    {
        <p class="form-success" role="status">@_message</p>
    }
    @if (_errors.Count > 0)
    {
        <div class="form-error" role="alert">
            @foreach (var err in _errors.Values.Distinct())
            {
                <p>@err</p>
            }
        </div>
    }

    @if (_loading)
    {
        <p class="muted">Loading...</p>
    }
    else if (_notFound)
    {
        <p class="muted">This project doesn't exist. <a href="/projects">Back to projects</a>.</p>
    }
    else if (_providers.Count == 0)
    {
        <p class="muted">
            Your organisation hasn't enabled any source-control providers yet, so projects can't be built.
            An administrator turns them on under <a href="/admin/administration/repositories">Administration → Repositories</a>.
        </p>
    }
    else
    {
        @if (Id is null)
        {
            <p class="muted">
                Name the project and add the repositories that make up its solution. After saving, you (or an admin) can build them.
            </p>
        }
        else if (!_canManage)
        {
            <p class="muted">
                You're viewing this project. Only its owner@(_header?.OwnerName is { } ownerName ? $" ({ownerName})" : "") or an admin can change or build it — you can still
                <a href="@($"/pipelines/{Id}")">download its builds</a>.
            </p>
        }
        <div class="cust-grid @((Id is null) ? "cust-grid--single" : "")">
            <div class="cust-main">
                <section class="manage-card">
                    <h2 class="manage-card__title">Details</h2>
                    <div class="form-grid">
                        <section class="form-section">
                            <label class="field__label" for="proj-name">Name</label>
                            <input id="proj-name" type="text" class="field__input" maxlength="200" @bind="_edit.Name" @bind:after="MarkDirty"
                                   disabled="@(_saving || !_canManage)" placeholder="e.g. CRONUS A/S" />
                            <small class="muted">Labels each build, e.g. "CRONUS A/S on BC 26.0".</small>
                        </section>
                        <section class="form-section">
                            <label class="field__label" for="proj-country">Default country code <span class="muted">· optional</span></label>
                            <input id="proj-country" type="text" class="field__input" maxlength="20" pattern="[A-Za-z0-9]{2,10}"
                                   @bind="_edit.Country" @bind:after="MarkDirty" disabled="@(_saving || !_canManage)" placeholder="e.g. dk or w1" />
                            <small class="muted">Country code of the Microsoft localisation to compile against (e.g. dk for Denmark, w1 for the base/worldwide version). Blank uses the organisation default.</small>
                        </section>
                    </div>
                </section>

                <section class="manage-card manage-card--wide">
                    <h2 class="manage-card__title">Repositories</h2>
                    <div class="form-grid">
                        <section class="form-section">
                            @if (_edit.Repos.Count == 0)
                            {
                                <p class="muted">No repositories yet. Add the Git repositories that make up this project's solution.</p>
                            }
                            else
                            {
                                <div class="row-editor">
                                    <table class="data-table row-editor__table">
                                        <thead>
                                            <tr>
                                                <th scope="col">Host</th>
                                                <th scope="col">Repository URL</th>
                                                <th scope="col">Display name</th>
                                                @if (_canManage)
                                                {
                                                    <th scope="col"></th>
                                                }
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var repo in _edit.Repos)
                                            {
                                                <tr @key="repo">
                                                    <td>
                                                        @if (_canManage && _providers.Count > 1)
                                                        {
                                                            <select class="row-role-select" @bind="repo.Provider" @bind:after="MarkDirty" disabled="@_saving" aria-label="Host">
                                                                @foreach (var prov in _providers)
                                                                {
                                                                    <option value="@prov">@prov.DisplayName()</option>
                                                                }
                                                            </select>
                                                        }
                                                        else
                                                        {
                                                            <span>@repo.Provider.DisplayName()</span>
                                                        }
                                                    </td>
                                                    <td>
                                                        @if (_canManage)
                                                        {
                                                            <input type="text" @bind="repo.Url" @bind:event="oninput" @bind:after="MarkDirty"
                                                                   disabled="@_saving" placeholder="https://github.com/org/repo" aria-label="Repository URL" />
                                                        }
                                                        else
                                                        {
                                                            <span class="mono">@repo.Url</span>
                                                        }
                                                    </td>
                                                    <td>
                                                        @if (_canManage)
                                                        {
                                                            <input type="text" @bind="repo.DisplayName" @bind:event="oninput" @bind:after="MarkDirty"
                                                                   disabled="@_saving" placeholder="optional" aria-label="Display name" />
                                                        }
                                                        else
                                                        {
                                                            <span>@repo.DisplayName</span>
                                                        }
                                                    </td>
                                                    @if (_canManage)
                                                    {
                                                        <td class="row-editor__cell-center">
                                                            <button type="button" class="btn btn--sm" @onclick="() => RemoveRepo(repo)"
                                                                    disabled="@_saving" aria-label="Remove repository">
                                                                <Icon Name="trash-2" Width="14" Height="14" />
                                                            </button>
                                                        </td>
                                                    }
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            @if (_canManage)
                            {
                                <div class="form-section__add">
                                    <button type="button" class="btn btn--sm" @onclick="AddRepo" disabled="@_saving">
                                        <Icon Name="plus" Width="14" Height="14" />
                                        <span>Add repository</span>
                                    </button>
                                </div>
                            }
                        </section>
                    </div>
                </section>

                @if (Id is not null && _canManage)
                {
                    <section class="manage-card manage-card--wide">
                        <h2 class="manage-card__title">Business Central connection</h2>
                        <p class="muted">
                            Connect this customer's Business Central tenant so builds can be delivered to their environments.
                            The client secret is stored encrypted and never shown again.
                        </p>

                        @if (_bcMessage is not null)
                        {
                            <p class="@(_bcOk ? "form-success" : "form-error")" role="status">@_bcMessage</p>
                        }
                        @if (_bcErrors.Count > 0)
                        {
                            <div class="form-error" role="alert">
                                @foreach (var err in _bcErrors.Values.Distinct())
                                {
                                    <p>@err</p>
                                }
                            </div>
                        }

                        <div class="form-grid">
                            <section class="form-section">
                                <label class="field__label" for="bc-tenant">Tenant ID</label>
                                <input id="bc-tenant" type="text" class="field__input" @bind="_bcEdit.TenantId" disabled="@_bcSaving"
                                       placeholder="00000000-0000-0000-0000-000000000000" />
                                <small class="muted">The customer's Microsoft Entra (Azure AD) tenant ID.</small>
                            </section>
                            <section class="form-section">
                                <label class="field__label" for="bc-client">Client ID</label>
                                <input id="bc-client" type="text" class="field__input" @bind="_bcEdit.ClientId" disabled="@_bcSaving"
                                       placeholder="the app registration's application (client) ID" />
                                <small class="muted">From the customer's app registration set up for service-to-service access.</small>
                            </section>
                            <section class="form-section">
                                <label class="field__label" for="bc-secret">Client secret</label>
                                <input id="bc-secret" type="password" class="field__input" @bind="_bcEdit.Secret" disabled="@_bcSaving"
                                       placeholder="@(_bc?.HasSecret == true ? "•••••••• (leave blank to keep)" : "the app registration's client secret")" />
                                <small class="muted">@(_bc?.HasSecret == true ? "A secret is stored. Enter a new one only to replace it." : "Stored encrypted; never shown again.")</small>
                            </section>
                            <section class="form-section">
                                <label class="field__label" for="bc-expiry">Secret expires</label>
                                <input id="bc-expiry" type="date" class="field__input" @bind="_bcEdit.SecretExpires" disabled="@_bcSaving" />
                                <small class="muted">
                                    Entra shows this when you create the secret (it lasts at most two years).
                                    @if (_bc?.SecretExpiresAt is { } exp)
                                    {
                                        <text> Current: @exp.ToString("yyyy-MM-dd").</text>
                                    }
                                </small>
                            </section>
                            <section class="form-section">
                                <label class="field__label" for="bc-tz">Time zone <span class="muted">· optional</span></label>
                                <input id="bc-tz" type="text" class="field__input" @bind="_bcEdit.TimeZone" disabled="@_bcSaving"
                                       placeholder="e.g. Europe/Copenhagen" />
                                <small class="muted">The customer's local time, used when scheduling deliveries. Blank uses the organisation default.</small>
                            </section>
                        </div>

                        <div class="manage-card__actions">
                            <button type="button" class="btn btn--sm" @onclick="SaveBcAsync" disabled="@(_bcSaving || _bcTesting)">
                                <Icon Name="save" Width="14" Height="14" />
                                <span>@(_bcSaving ? "Saving..." : "Save connection")</span>
                            </button>
                            <button type="button" class="btn btn--sm" @onclick="TestConnectionAsync" disabled="@(_bcSaving || _bcTesting || _bc?.IsConfigured != true)">
                                <Icon Name="plug" Width="14" Height="14" />
                                <span>@(_bcTesting ? "Testing..." : "Test connection")</span>
                            </button>
                            @if (_bc?.VerifiedAt is { } verified)
                            {
                                <span class="muted">Last verified @verified.ToString("yyyy-MM-dd HH:mm") UTC</span>
                            }
                        </div>

                        <h3 class="manage-card__subtitle">Environments</h3>
                        @if (_environments.Count == 0)
                        {
                            <p class="muted">No environments yet. Save the connection, then Test connection to fetch them.</p>
                        }
                        else
                        {
                            <div class="row-editor">
                                <table class="data-table">
                                    <thead>
                                        <tr>
                                            <th scope="col">Name</th>
                                            <th scope="col">Type</th>
                                            <th scope="col">Company</th>
                                            <th scope="col"></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var env in _environments)
                                        {
                                            <tr @key="env.Id">
                                                <td>
                                                    @env.Name
                                                    @if (env.MissingSince is not null)
                                                    {
                                                        <span class="muted"> · no longer present</span>
                                                    }
                                                </td>
                                                <td>@env.Type</td>
                                                <td>
                                                    @if (_companyPickerEnvId == env.Id)
                                                    {
                                                        @if (_loadingCompanies)
                                                        {
                                                            <span class="muted">Loading companies...</span>
                                                        }
                                                        else
                                                        {
                                                            <select class="row-role-select" @bind="_selectedCompanyId" aria-label="Company">
                                                                <option value="">Select a company...</option>
                                                                @foreach (var co in _companyOptions)
                                                                {
                                                                    <option value="@co.Id">@co.Name</option>
                                                                }
                                                            </select>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        @(env.CompanyName ?? "—")
                                                    }
                                                </td>
                                                <td class="row-editor__cell-center">
                                                    @if (_companyPickerEnvId == env.Id)
                                                    {
                                                        <button type="button" class="btn btn--sm" @onclick="() => SaveCompanyAsync(env.Id)"
                                                                disabled="@(_loadingCompanies || string.IsNullOrEmpty(_selectedCompanyId))">Use</button>
                                                        <button type="button" class="btn btn--sm" @onclick="CancelCompanyPicker">Cancel</button>
                                                    }
                                                    else if (env.MissingSince is null)
                                                    {
                                                        <button type="button" class="btn btn--sm" @onclick="() => OpenCompanyPickerAsync(env.Id)" disabled="@_bcSaving">
                                                            @(env.CompanyId is null ? "Choose company" : "Change")
                                                        </button>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                            <div class="form-section__add">
                                <button type="button" class="btn btn--sm" @onclick="TestConnectionAsync" disabled="@(_bcSaving || _bcTesting)">
                                    <Icon Name="refresh-cw" Width="14" Height="14" />
                                    <span>Refresh environments</span>
                                </button>
                            </div>
                        }
                    </section>

                    <section class="manage-card manage-card--danger">
                        <h2 class="manage-card__title">Danger zone</h2>
                        @if (_confirmingDelete)
                        {
                            <p class="muted">Delete <strong>@_header?.Name</strong>? Its past builds stay downloadable; only this project's setup (name and repositories) is removed.</p>
                            <div class="manage-card__actions">
                                <button type="button" class="btn btn--sm btn--danger" @onclick="ConfirmDeleteAsync">Yes, delete</button>
                                <button type="button" class="btn btn--sm" @onclick="() => _confirmingDelete = false">Cancel</button>
                            </div>
                        }
                        else
                        {
                            <button type="button" class="btn" @onclick="() => _confirmingDelete = true">
                                <Icon Name="trash-2" Width="14" Height="14" />
                                <span>Delete project</span>
                            </button>
                        }
                    </section>
                }
            </div>

            @if (Id is not null)
            {
                <aside class="cust-rail">
                    <div class="card">
                        <div class="card-head"><span class="cap-label">Pipelines</span></div>
                        <div class="cust-rail-body">
                            @if (_pipelines.Count > 0)
                            {
                                <div class="pl-list">
                                    @foreach (var pl in _pipelines)
                                    {
                                        <a class="pl-item" href="@($"/pipelines/{pl.Id}")">
                                            <Icon Name="rocket" Width="14" Height="14" />
                                            <span>@pl.Name</span>
                                        </a>
                                    }
                                </div>
                            }
                            else
                            {
                                <p class="muted">
                                    @(_canManage
                                        ? "No pipelines yet. Add one to choose which extensions to build and start producing .app files."
                                        : "No pipelines yet. The owner hasn't set one up.")
                                </p>
                            }
                            @if (_canManage)
                            {
                                <button type="button" class="btn btn--sm" @onclick="NewPipelineAsync">
                                    <Icon Name="plus" Width="14" Height="14" />
                                    <span>New pipeline</span>
                                </button>
                            }
                        </div>
                    </div>
                </aside>
            }
        </div>
    }
</div>

<PipelineEditorDialog @ref="_editor" OnSaved="OnPipelineCreatedAsync" />

@code {
    [Parameter] public int? Id { get; set; }

    private bool _loading = true;
    private bool _notFound;
    private bool _saving;
    private bool _dirty;
    private bool _confirmingDelete;
    private bool _canManage;
    private string? _message;
    private Dictionary<string, string> _errors = new();

    private ProjectHeader? _header;
    private List<Pipeline> _pipelines = new();
    private List<RepositoryProvider> _providers = new();
    private EditModel _edit = new();
    private PipelineEditorDialog? _editor;

    // Business Central connection (owner/admin only).
    private BcConnectionStatus? _bc;
    private BcEdit _bcEdit = new();
    private bool _bcSaving;
    private bool _bcTesting;
    private bool _bcOk;
    private string? _bcMessage;
    private Dictionary<string, string> _bcErrors = new();
    private List<ProjectEnvironmentRow> _environments = new();
    private int? _companyPickerEnvId;
    private List<BcCompany> _companyOptions = new();
    private bool _loadingCompanies;
    private string? _selectedCompanyId;

    protected override async Task OnInitializedAsync()
    {
        _providers = (await Config.GetAllowedProvidersAsync()).ToList();

        if (Id is null)
        {
            // Anyone may create. The creator becomes the owner.
            _canManage = true;
            _edit = new EditModel { Repos = { new RepoRow { Provider = DefaultProvider } } };
        }
        else
        {
            await LoadAsync();
            if (!_notFound)
            {
                _canManage = await Projects.CanManageAsync(Id.Value);
                HydrateEdit();
                if (_canManage) await LoadBcAsync();
            }
        }
        _loading = false;
    }

    private async Task LoadBcAsync()
    {
        _bc = await Connection.GetConnectionAsync(Id!.Value);
        _environments = (await Connection.ListEnvironmentsAsync(Id.Value)).ToList();
        HydrateBcEdit();
    }

    private void HydrateBcEdit()
    {
        _bcEdit = new BcEdit
        {
            TenantId = _bc?.TenantId?.ToString() ?? string.Empty,
            ClientId = _bc?.ClientId ?? string.Empty,
            Secret = string.Empty,
            SecretExpires = _bc?.SecretExpiresAt?.Date,
            TimeZone = _bc?.TimeZone ?? string.Empty,
        };
    }

    private async Task LoadAsync()
    {
        var project = await Projects.GetProjectAsync(Id!.Value);
        if (project is null) { _notFound = true; return; }
        _header = await Artifacts.GetProjectHeaderAsync(Id.Value);
        _pipelines = await PipelinesSvc.ListPipelinesAsync(Id.Value);
        _loadedProject = project;
    }

    private async Task NewPipelineAsync()
    {
        if (_editor is null || Id is null) return;
        await _editor.OpenForCreateAsync(Id.Value, _header?.Name ?? _edit.Name);
    }

    private void OnPipelineCreatedAsync(int pipelineId) => Nav.NavigateTo($"/pipelines/{pipelineId}");

    private Project? _loadedProject;

    private void HydrateEdit()
    {
        _edit = new EditModel
        {
            Name = _loadedProject!.Name,
            Country = _loadedProject.DefaultArtifactCountry ?? string.Empty,
            Repos = _loadedProject.Repositories
                .Select(r => new RepoRow { Provider = r.Provider, Url = r.Url, DisplayName = r.DisplayName })
                .ToList(),
        };
        _dirty = false;
    }

    private void MarkDirty() => _dirty = true;
    private void AddRepo() { _edit.Repos.Add(new RepoRow { Provider = DefaultProvider }); _dirty = true; }
    private void RemoveRepo(RepoRow row) { _edit.Repos.Remove(row); _dirty = true; }

    private RepositoryProvider DefaultProvider =>
        _providers.Contains(RepositoryProvider.GitHub) ? RepositoryProvider.GitHub
        : _providers.FirstOrDefault();

    private string HeaderTitle() => Id is null ? "New project" : _header?.Name ?? "Project";

    private async Task SaveAsync()
    {
        if (_saving) return;
        _saving = true;
        _message = null;
        _errors = new();
        try
        {
            var repos = _edit.Repos.Where(r => !r.IsBlank())
                .Select(r => new ProjectRepositoryInput(r.Provider, r.Url, r.DisplayName))
                .ToList();
            var input = new ProjectInput(_edit.Name, string.IsNullOrWhiteSpace(_edit.Country) ? null : _edit.Country, repos);

            if (Id is null)
            {
                var newId = await Projects.CreateProjectAsync(input);
                Nav.NavigateTo($"/projects/{newId}");
                return;
            }
            await Projects.UpdateProjectAsync(Id.Value, input);
            await LoadAsync();
            HydrateEdit();
            _message = "Project saved.";
        }
        catch (PlanValidationException ex)
        {
            _errors = new(ex.Errors);
        }
        catch (ProjectAccessDeniedException)
        {
            _errors = new() { ["_"] = "Only the project owner or an admin can change this project." };
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Failed to save project {ProjectId}.", Id);
            _errors = new() { ["_"] = "An unexpected error occurred. The change was not saved." };
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task ConfirmDeleteAsync()
    {
        try
        {
            await Projects.SoftDeleteProjectAsync(Id!.Value);
            Nav.NavigateTo("/projects");
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Failed to delete project {ProjectId}.", Id);
            _errors = new() { ["_"] = "Could not delete the project." };
            _confirmingDelete = false;
        }
    }

    private async Task SaveBcAsync()
    {
        if (_bcSaving) return;
        _bcSaving = true;
        _bcMessage = null;
        _bcErrors = new();
        try
        {
            Guid? tenant = null;
            if (!string.IsNullOrWhiteSpace(_bcEdit.TenantId))
            {
                if (Guid.TryParse(_bcEdit.TenantId.Trim(), out var g)) tenant = g;
                else _bcErrors["BcTenantId"] = "Tenant ID must be a GUID.";
            }
            if (_bcErrors.Count == 0)
            {
                var expires = _bcEdit.SecretExpires is { } d ? DateTime.SpecifyKind(d, DateTimeKind.Utc) : (DateTime?)null;
                var input = new BcConnectionInput(
                    tenant,
                    _bcEdit.ClientId,
                    string.IsNullOrWhiteSpace(_bcEdit.Secret) ? null : _bcEdit.Secret,
                    expires,
                    string.IsNullOrWhiteSpace(_bcEdit.TimeZone) ? null : _bcEdit.TimeZone);
                await Connection.SaveConnectionAsync(Id!.Value, input);
                await LoadBcAsync();
                _bcOk = true;
                _bcMessage = "Connection saved. Test it to fetch this customer's environments.";
            }
        }
        catch (PlanValidationException ex)
        {
            _bcErrors = new(ex.Errors);
        }
        catch (ProjectAccessDeniedException)
        {
            _bcErrors = new() { ["_"] = "Only the project owner or an admin can change the connection." };
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Failed to save BC connection for project {ProjectId}.", Id);
            _bcErrors = new() { ["_"] = "An unexpected error occurred. The connection was not saved." };
        }
        finally
        {
            _bcSaving = false;
        }
    }

    private async Task TestConnectionAsync()
    {
        if (_bcTesting) return;
        _bcTesting = true;
        _bcMessage = null;
        _bcErrors = new();
        try
        {
            var result = await Connection.TestConnectionAsync(Id!.Value);
            _bcOk = result.IsSuccess;
            _bcMessage = result.Message;
            await LoadBcAsync();
        }
        catch (ProjectAccessDeniedException)
        {
            _bcErrors = new() { ["_"] = "Only the project owner or an admin can test the connection." };
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Failed to test BC connection for project {ProjectId}.", Id);
            _bcErrors = new() { ["_"] = "An unexpected error occurred while testing the connection." };
        }
        finally
        {
            _bcTesting = false;
        }
    }

    private async Task OpenCompanyPickerAsync(int environmentId)
    {
        _companyPickerEnvId = environmentId;
        _selectedCompanyId = null;
        _companyOptions = new();
        _loadingCompanies = true;
        _bcErrors = new();
        try
        {
            _companyOptions = (await Connection.FetchCompaniesAsync(Id!.Value, environmentId)).ToList();
        }
        catch (PlanValidationException ex)
        {
            _bcErrors = new(ex.Errors);
            _companyPickerEnvId = null;
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Failed to fetch companies for environment {EnvId}.", environmentId);
            _bcErrors = new() { ["_"] = "Could not list companies for this environment." };
            _companyPickerEnvId = null;
        }
        finally
        {
            _loadingCompanies = false;
        }
    }

    private void CancelCompanyPicker()
    {
        _companyPickerEnvId = null;
        _companyOptions = new();
        _selectedCompanyId = null;
    }

    private async Task SaveCompanyAsync(int environmentId)
    {
        if (string.IsNullOrEmpty(_selectedCompanyId) || !Guid.TryParse(_selectedCompanyId, out var companyId)) return;
        var name = _companyOptions.FirstOrDefault(c => c.Id == companyId)?.Name ?? string.Empty;
        try
        {
            await Connection.PickCompanyAsync(Id!.Value, environmentId, companyId, name);
            CancelCompanyPicker();
            await LoadBcAsync();
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Failed to set company for environment {EnvId}.", environmentId);
            _bcErrors = new() { ["_"] = "Could not save the company selection." };
        }
    }

    private sealed class BcEdit
    {
        public string TenantId { get; set; } = string.Empty;
        public string ClientId { get; set; } = string.Empty;
        public string Secret { get; set; } = string.Empty;
        public DateTime? SecretExpires { get; set; }
        public string TimeZone { get; set; } = string.Empty;
    }

    private sealed class EditModel
    {
        public string Name { get; set; } = string.Empty;
        public string Country { get; set; } = string.Empty;
        public List<RepoRow> Repos { get; set; } = new();
    }

    private sealed class RepoRow
    {
        public RepositoryProvider Provider { get; set; } = RepositoryProvider.GitHub;
        public string Url { get; set; } = string.Empty;
        public string DisplayName { get; set; } = string.Empty;
        public bool IsBlank() => string.IsNullOrWhiteSpace(Url) && string.IsNullOrWhiteSpace(DisplayName);
    }
}
