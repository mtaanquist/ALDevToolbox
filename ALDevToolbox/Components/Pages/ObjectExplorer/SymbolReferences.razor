@page "/object-explorer/{VersionId:int}/symbols/{SymbolId:long}/references"
@attribute [Authorize]
@rendermode InteractiveServer
@inject BaseAppService BaseApp
@inject NavigationManager Nav
@using ALDevToolbox.Domain.Entities
@using ALDevToolbox.Services

<PageTitle>References · @(_result?.Symbol.Name ?? "Symbol") · AL Dev Toolbox</PageTitle>

<div class="object-explorer__references">
    <nav class="object-explorer__crumbs">
        <a href="/object-explorer">Object Explorer</a>
        <span>›</span>
        <a href="@($"/object-explorer/{VersionId}")">@VersionLabel</a>
        @if (_result?.Symbol.File is not null)
        {
            <span>›</span>
            <a href="@($"/object-explorer/{VersionId}/files/{_result.Symbol.File.Id}")">
                @_result.Symbol.File.ObjectName
            </a>
        }
        <span>›</span>
        <span>References</span>
    </nav>

    @if (_result is null)
    {
        <p class="muted">Loading…</p>
    }
    else if (_result.Symbol.Id == 0)
    {
        <p class="muted">Symbol not found.</p>
    }
    else
    {
        <header class="object-explorer__file-header">
            <div>
                <h1>
                    <span class="object-explorer__type">@_result.Symbol.Kind</span>
                    @_result.Symbol.Name
                </h1>
                <p class="muted small">
                    Declared on
                    @if (_result.Symbol.File is { } file)
                    {
                        <a href="@($"/object-explorer/{VersionId}/files/{file.Id}#L{_result.Symbol.LineNumber}")">
                            <strong>@file.ObjectType @(file.ObjectId?.ToString() ?? "") "@file.ObjectName"</strong>
                            · line @_result.Symbol.LineNumber
                        </a>
                    }
                    @if (_result.OverloadCount > 1)
                    {
                        <span> · <strong>@_result.OverloadCount overloads</strong> merged into this search.</span>
                    }
                    @if (!IsTrivialSignature(_result.Symbol.Signature))
                    {
                        <br />
                        <code class="small">@_result.Symbol.Signature</code>
                    }
                </p>
            </div>
        </header>

        @if (_result.Likely.Count == 0 && _result.PossiblyRelated.Count == 0)
        {
            <p class="muted">
                No references found in this version. The symbol is declared
                but nothing in the imported source calls it — possibly an
                internal helper that's only invoked from generated code, or
                the calls live in an app that hasn't been uploaded yet.
            </p>
        }

        @if (_result.Likely.Count > 0)
        {
            <section class="references__section">
                <h2>Likely references <span class="muted small">(@_result.Likely.Count)</span></h2>
                @RenderHits(_result.Likely)
            </section>
        }

        @if (_result.PossiblyRelated.Count > 0)
        {
            <section class="references__section">
                <button type="button"
                        class="references__toggle"
                        @onclick="() => _showPossiblyRelated = !_showPossiblyRelated">
                    <Icon Name="@(_showPossiblyRelated ? "chevron-down" : "chevron-right")" Width="14" Height="14" />
                    <span>Possibly related</span>
                    <span class="muted small">(@_result.PossiblyRelated.Count)</span>
                </button>
                <p class="muted small references__possibly-related-explainer">
                    Bare <code>@(_result.Symbol.Name)(</code> calls in files that don't
                    mention <code>"@(_result.Symbol.File?.ObjectName)"</code>. These could
                    be calls to a different overload on another object with the same name.
                </p>
                @if (_showPossiblyRelated)
                {
                    @RenderHits(_result.PossiblyRelated)
                }
            </section>
        }
    }
</div>

@code {
    [Parameter] public int VersionId { get; set; }
    [Parameter] public long SymbolId { get; set; }

    private BaseAppReferenceResult? _result;
    private bool _showPossiblyRelated;
    private BaseAppVersion? _version;

    private string VersionLabel => _version is null
        ? VersionId.ToString()
        : $"BC {_version.Major}.{_version.CumulativeUpdate}";

    // The signature regex captures `()` for parameterless procedures and
    // triggers; showing a literal empty pair of parentheses adds noise but no
    // information, so suppress it.
    private static bool IsTrivialSignature(string? signature)
    {
        if (string.IsNullOrWhiteSpace(signature)) return true;
        var stripped = signature.Replace(" ", "").Replace("\t", "");
        return stripped is "" or "()";
    }

    protected override async Task OnInitializedAsync()
    {
        _version = await BaseApp.GetVersionAsync(VersionId);
        _result = await BaseApp.FindReferencesAsync(SymbolId);
        if (_result.Symbol.Id != 0 && _result.Symbol.VersionId != VersionId)
        {
            Nav.NavigateTo($"/object-explorer/{_result.Symbol.VersionId}/symbols/{SymbolId}/references");
        }
    }

    private RenderFragment RenderHits(IReadOnlyList<BaseAppReferenceHit> hits) => builder =>
    {
        var byFile = hits
            .GroupBy(h => (h.FileId, h.ObjectType, h.ObjectId, h.ObjectName, h.Path))
            .ToList();
        var seq = 0;
        foreach (var group in byFile)
        {
            builder.OpenElement(seq++, "article");
            builder.AddAttribute(seq++, "class", "references__file");

            builder.OpenElement(seq++, "header");
            builder.AddAttribute(seq++, "class", "references__file-header");
            builder.OpenElement(seq++, "span");
            builder.AddAttribute(seq++, "class", "object-explorer__type");
            builder.AddContent(seq++, group.Key.ObjectType);
            builder.CloseElement();
            if (group.Key.ObjectId is { } objId)
            {
                builder.OpenElement(seq++, "span");
                builder.AddAttribute(seq++, "class", "muted");
                builder.AddContent(seq++, objId.ToString());
                builder.CloseElement();
            }
            builder.OpenElement(seq++, "strong");
            builder.AddContent(seq++, group.Key.ObjectName);
            builder.CloseElement();
            builder.OpenElement(seq++, "span");
            builder.AddAttribute(seq++, "class", "muted small");
            builder.AddContent(seq++, $" · {group.Count()} hit{(group.Count() == 1 ? "" : "s")}");
            builder.CloseElement();
            builder.CloseElement(); // header

            builder.OpenElement(seq++, "ul");
            builder.AddAttribute(seq++, "class", "references__hits");
            foreach (var hit in group)
            {
                builder.OpenElement(seq++, "li");
                builder.AddAttribute(seq++, "class", "references__hit");

                builder.OpenElement(seq++, "a");
                builder.AddAttribute(seq++, "class", "references__hit-link");
                builder.AddAttribute(seq++, "href",
                    $"/object-explorer/{VersionId}/files/{hit.FileId}#L{hit.LineNumber}");
                builder.OpenElement(seq++, "span");
                builder.AddAttribute(seq++, "class", "references__hit-line");
                builder.AddContent(seq++, $"L{hit.LineNumber}");
                builder.CloseElement();
                builder.OpenElement(seq++, "code");
                builder.AddAttribute(seq++, "class", "references__hit-snippet");
                builder.AddContent(seq++, hit.Snippet);
                builder.CloseElement();
                builder.CloseElement(); // a

                builder.CloseElement(); // li
            }
            builder.CloseElement(); // ul

            builder.CloseElement(); // article
        }
    };
}
