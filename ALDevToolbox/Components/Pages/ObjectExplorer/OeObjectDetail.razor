@page "/object-explorer/object/{ObjectId:long}"
@attribute [Authorize]
@rendermode InteractiveServer
@inject ALDevToolbox.Services.ObjectExplorer.ObjectExplorerService ObjectExplorer
@inject ALDevToolbox.Services.ObjectExplorer.ObjectExplorerLinks Links
@inject ALDevToolbox.Services.ObjectExplorer.ReferenceSessionService ReferenceSessions
@inject ALDevToolbox.Data.AppDbContext Db
@inject Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthState
@using ALDevToolbox.Services.ObjectExplorer
@using Microsoft.EntityFrameworkCore

<PageTitle>@(_object?.Name ?? "Object") · AL Dev Toolbox</PageTitle>

<div class="object-explorer">
    @if (_object is null)
    {
        <p class="muted">Loading…</p>
    }
    else
    {
        <header class="admin-page__header">
            <div>
                <p class="muted">
                    <a href="/object-explorer">Releases</a>
                    @if (_releaseId is { } rid)
                    {
                        <span> / <a href="@($"/object-explorer/release/{rid}")">@_releaseLabel</a></span>
                    }
                    <span> / <a href="@($"/object-explorer/module/{_object.ModuleId}")">@_object.ModuleName</a></span>
                </p>
                <h1>@_object.Name</h1>
                <p class="muted">
                    @_object.Kind
                    @if (_object.ObjectId is { } oid)
                    {
                        <span> · id @oid</span>
                    }
                    @if (!string.IsNullOrEmpty(_object.Namespace))
                    {
                        <span> · @_object.Namespace</span>
                    }
                </p>
            </div>
            @if (_object.SourceFileId is { } fid)
            {
                <a class="btn" href="@Links.SourceFile(fid, _object.LineNumber)">
                    <Icon Name="file-code" Width="16" Height="16" />
                    <span>View source</span>
                </a>
            }
        </header>

        <div class="form-grid">
            <section class="form-section">
                <h2>Symbols</h2>
                @if (_object.Symbols.Count == 0)
                {
                    <p class="muted">No symbols recorded for this object.</p>
                }
                else
                {
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th scope="col">Kind</th>
                                <th scope="col">Name</th>
                                <th scope="col">Signature</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in _object.Symbols)
                            {
                                <tr>
                                    <td>@s.Kind</td>
                                    <td><strong>@s.Name</strong></td>
                                    <td class="muted">@(s.Signature ?? "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </section>

            <section class="form-section">
                <h2>Variables</h2>
                @if (_object.Variables.Count == 0)
                {
                    <p class="muted">No object-scoped variables.</p>
                }
                else
                {
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th scope="col">Name</th>
                                <th scope="col">Type</th>
                                <th scope="col">Target</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var v in _object.Variables)
                            {
                                <tr>
                                    <td><strong>@v.Name</strong></td>
                                    <td>@v.TypeName</td>
                                    <td class="muted">
                                        @if (v.TargetObjectName is not null)
                                        {
                                            <span>@v.TargetObjectKind "@v.TargetObjectName"</span>
                                            @if (v.TargetObjectId is { } tid)
                                            {
                                                <span> · id @tid</span>
                                            }
                                        }
                                        else
                                        {
                                            <span>—</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </section>

            <section class="form-section">
                <h2>Find references</h2>
                <p class="muted">
                    Every module in this Release's chain whose code mentions this
                    object. Resolution follows the parent-Release pointer upward
                    and shadows duplicate AppIds at the closest depth.
                </p>
                @if (_fromReleaseLabel is not null)
                {
                    <p class="muted">
                        Searching from <strong>@_fromReleaseLabel</strong> — references in
                        that release and its base are included.
                    </p>
                }
                @if (_referencesLoading)
                {
                    <p class="muted">Loading…</p>
                }
                else if (_references is null)
                {
                    <button class="btn" @onclick="LoadReferences">
                        <Icon Name="search" Width="14" Height="14" />
                        <span>Find references</span>
                    </button>
                }
                else if (_references.Count == 0)
                {
                    <p class="muted">No references found in this Release's chain.</p>
                }
                else
                {
                    <p class="muted">@_references.Count.ToString("N0") reference(s) found.</p>
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th scope="col">Module</th>
                                <th scope="col">Object</th>
                                <th scope="col">Kind</th>
                                <th scope="col">Reference kind</th>
                                <th scope="col">Source</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in _references)
                            {
                                <tr>
                                    <td>@r.SourceModuleName</td>
                                    <td>
                                        <a href="@($"/object-explorer/object/{r.SourceObjectId}")">@r.SourceObjectName</a>
                                    </td>
                                    <td>@r.SourceObjectKind</td>
                                    <td>@r.ReferenceKind</td>
                                    <td>
                                        @if (r.SourceFileId is { } srcFid && r.LineNumber is { } ln)
                                        {
                                            <a href="@FileLinkForRef(srcFid, ln)">L@(ln)</a>
                                        }
                                        else
                                        {
                                            <span class="muted">—</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </section>
        </div>
    }
</div>

@code {
    [Parameter] public long ObjectId { get; set; }

    /// <summary>
    /// Release the user is viewing from, carried as <c>?from=</c>. When this is
    /// a descendant of the object's home Release (the project-on-base case),
    /// find-references seeds here so the project's own code is included — the
    /// chain walk only goes upward. Null → seed at the object's home Release.
    /// </summary>
    [SupplyParameterFromQuery(Name = "from")] public int? FromReleaseId { get; set; }

    private ObjectDetail? _object;
    private int? _releaseId;
    private string? _releaseLabel;
    private string? _fromReleaseLabel;
    private Guid? _moduleAppId;
    private List<ReferenceMatch>? _references;
    private string? _refSetToken;
    private bool _referencesLoading;

    protected override async Task OnInitializedAsync()
    {
        _object = await ObjectExplorer.GetObjectAsync(ObjectId);
        if (_object is null) return;

        var modInfo = await Db.OeModules.AsNoTracking()
            .Where(m => m.Id == _object.ModuleId)
            .Select(m => new { m.AppId, m.ReleaseId, ReleaseLabel = m.Release!.Label })
            .SingleOrDefaultAsync();
        if (modInfo is not null)
        {
            _moduleAppId = modInfo.AppId;
            _releaseId = modInfo.ReleaseId;
            _releaseLabel = modInfo.ReleaseLabel;
        }

        // When viewing a base object "from" a descendant Release (the
        // project-on-base case), resolve that Release's label so the panel can
        // tell the user which Release the reference search is seeded at.
        if (FromReleaseId is { } from && from != _releaseId)
        {
            _fromReleaseLabel = await Db.OeReleases.AsNoTracking()
                .Where(r => r.Id == from)
                .Select(r => r.Label)
                .SingleOrDefaultAsync();
        }
    }

    /// <summary>
    /// Runs FindReferences and mints a ReferenceSession token in the
    /// shared cache. The token rides along on the file-viewer links so the
    /// References panel stays visible across navigations.
    /// </summary>
    private async Task LoadReferences()
    {
        if (_object is null) return;
        _referencesLoading = true;
        try
        {
            var owner = await OwnerKeyAsync();
            ReferenceSession? session = owner is null
                ? null
                : await ReferenceSessions.CreateFromSymbolAsync(ObjectId, owner, FromReleaseId);
            _references = session?.Results.ToList() ?? new List<ReferenceMatch>();
            _refSetToken = session?.Token;
        }
        finally
        {
            _referencesLoading = false;
        }
    }

    private string FileLinkForRef(long fileId, int line)
    {
        var url = Links.SourceFile(fileId, line);
        if (!string.IsNullOrEmpty(_refSetToken))
        {
            url += "&refSet=" + Uri.EscapeDataString(_refSetToken);
        }
        // Keep the view-Release context as the user clicks through results, so a
        // follow-up Find references from the landed file stays seeded correctly.
        if (FromReleaseId is { } from)
        {
            url += "&from=" + from;
        }
        return url;
    }

    private async Task<string?> OwnerKeyAsync()
    {
        // AuthenticationStateProvider works in both prerender and interactive
        // contexts, unlike IHttpContextAccessor (which returns null after
        // the SignalR circuit takes over).
        var state = await AuthState.GetAuthenticationStateAsync();
        var user = state.User;
        if (user?.Identity?.IsAuthenticated != true) return null;
        return user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value
            ?? user.Identity.Name;
    }
}
