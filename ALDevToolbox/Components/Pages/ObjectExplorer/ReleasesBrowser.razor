@page "/object-explorer"
@rendermode InteractiveServer
@attribute [Authorize]
@inject ALDevToolbox.Services.ObjectExplorer.ObjectExplorerService ObjectExplorer
@using ALDevToolbox.Services.ObjectExplorer
@using System.Text.RegularExpressions

<PageTitle>Object Explorer · AL Dev Toolbox</PageTitle>

<div class="oe-landing">
    <div class="page-head">
        <h1>Object Explorer</h1>
        <p class="sub">
            Browse the AL source of every reference package you've imported. Pick a
            release to search its objects, fields and procedures — or compare any
            object across versions.
        </p>
    </div>

    @if (_releases is null)
    {
        <p class="muted">Loading…</p>
    }
    else
    {
        <div class="src-tabs" role="tablist" aria-label="Release category">
            @foreach (var t in _tabs)
            {
                var active = _kind == t.Kind;
                <button type="button" class="@(active ? "on" : "")"
                        role="tab" aria-selected="@(active ? "true" : "false")"
                        @onclick="() => SetKind(t.Kind)">
                    <Icon Name="@t.Icon" Width="16" Height="16" />
                    <span>@t.Label</span>
                    <span class="src-n">@Count(t.Kind)</span>
                </button>
            }
        </div>

        var searching = !string.IsNullOrWhiteSpace(_search);
        var rows = _releases.Where(r => r.Kind == _kind)
            .Where(MatchesSearch)
            .OrderByDescending(VersionKey)
            .ThenByDescending(r => r.ImportedAt)
            .ToList();

        <div class="rel-search">
            <Icon Name="search" Width="15" Height="15" />
            <input type="search" @bind="_search" @bind:event="oninput"
                   placeholder="Search releases by name, version, or publisher…"
                   aria-label="Search releases" />
        </div>

        if (rows.Count == 0)
        {
            @if (searching)
            {
                <div class="rel-empty">
                    <div class="rel-empty-ico"><Icon Name="search" Width="26" Height="26" /></div>
                    <div class="rel-empty-h">No @CategoryNoun releases match “@_search”</div>
                    <p class="rel-empty-p">Try a different name, version, or publisher.</p>
                </div>
            }
            else
            {
                <div class="rel-empty">
                    <div class="rel-empty-ico"><Icon Name="box" Width="26" Height="26" /></div>
                    <div class="rel-empty-h">No @CategoryNoun packages imported yet</div>
                    <p class="rel-empty-p">
                        Import a @CategoryNoun reference package to explore its objects here,
                        side-by-side with the rest of your imported releases.
                    </p>
                    <AuthorizeView Roles="Admin,Editor">
                        <a class="btn btn--primary" href="/admin/object-explorer/new">
                            <Icon Name="package-plus" Width="15" Height="15" />
                            <span>Import a package</span>
                        </a>
                    </AuthorizeView>
                </div>
            }
        }
        else
        {
            var featured = rows[0];
            var totalFiles = rows.Sum(r => (long)r.SourceFileCount);

            @* The "Latest release" hero only makes sense for the full list; while
               searching, jump straight to the matching cards. *@
            @if (!searching)
            {
            <div class="rel-hero">
                <div class="rh-main">
                    <div class="rh-cap">
                        <span class="cap-label">Latest release</span>
                        <span class="status-pill status-pill--live"><span class="status-pill__dot"></span>Ready</span>
                    </div>
                    <h2 class="rh-title">@featured.Label</h2>
                    <div class="rh-meta">
                        @if (!string.IsNullOrEmpty(featured.BcVersion))
                        {
                            <span class="mono">@featured.BcVersion</span>
                            <span class="dotsep"></span>
                        }
                        @if (!string.IsNullOrEmpty(featured.Publisher))
                        {
                            <span>@featured.Publisher</span>
                            <span class="dotsep"></span>
                        }
                        <span class="rh-date">
                            <Icon Name="calendar" Width="14" Height="14" />
                            <span>Imported @featured.ImportedAt.ToString("yyyy-MM-dd") · @RelAgo(featured.ImportedAt)</span>
                        </span>
                    </div>
                </div>
                <div class="rh-side">
                    <div class="rh-stat">
                        <span class="rh-num">@featured.SourceFileCount.ToString("N0")</span>
                        <span class="rh-lbl">Files indexed</span>
                    </div>
                    <div class="rh-actions">
                        <a class="btn btn--primary btn--lg" href="@($"/object-explorer/release/{featured.Id}")">
                            <Icon Name="search" Width="15" Height="15" />
                            <span>Explore objects</span>
                        </a>
                        <a class="btn btn--lg" href="@($"/object-explorer/release/{featured.Id}?scope=Compare")">
                            <Icon Name="git-compare" Width="15" Height="15" />
                            <span>Compare</span>
                        </a>
                    </div>
                </div>
            </div>
            }

            <div class="rel-count">
                <b>@rows.Count</b> release@(rows.Count == 1 ? "" : "s") @(searching ? "matched" : "imported") ·
                <b>@totalFiles.ToString("N0")</b> files indexed
            </div>

            <div class="rel-timeline">
                @* All releases are grouped — including the featured "latest
                   import" — so each version group's count is complete (the
                   latest also appears under its own version, not only in the
                   hero above). *@
                @foreach (var group in GroupReleases(rows))
                {
                    <div class="rel-group">
                        @if (group.Title is not null)
                        {
                            <div class="rel-group-head">
                                <span class="rg-dot"></span>
                                <span class="rg-title">@group.Title</span>
                                <span class="rg-line"></span>
                                <span class="rg-count">@group.Items.Count release@(group.Items.Count == 1 ? "" : "s")</span>
                            </div>
                        }
                        <div class="rel-cards">
                            @foreach (var r in group.Items)
                            {
                                <a class="rel-card" href="@($"/object-explorer/release/{r.Id}")">
                                    <div class="rc-top">
                                        <div>
                                            <div class="rc-name">@r.Label</div>
                                            @if (!string.IsNullOrEmpty(r.BcVersion))
                                            {
                                                <div class="rc-ver mono">@r.BcVersion</div>
                                            }
                                        </div>
                                        <span class="rc-arrow"><Icon Name="arrow-right" Width="17" Height="17" /></span>
                                    </div>
                                    <div class="rc-foot">
                                        <span class="rc-files"><b>@r.SourceFileCount.ToString("N0")</b> files</span>
                                        <span class="rc-date">
                                            <Icon Name="calendar" Width="13" Height="13" />
                                            @RelAgo(r.ImportedAt)
                                        </span>
                                    </div>
                                </a>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    private List<ReleaseListItem>? _releases;
    private string _kind = "first_party";
    private string _search = string.Empty;

    private readonly (string Kind, string Label, string Icon)[] _tabs =
    {
        ("first_party", "Microsoft", "layers"),
        ("third_party", "Third-party", "box"),
        ("customer", "Customer", "users"),
    };

    private sealed record ReleaseGroup(string? Title, List<ReleaseListItem> Items);

    protected override async Task OnInitializedAsync()
    {
        _releases = await ObjectExplorer.ListReleasesAsync();
    }

    private void SetKind(string kind) => _kind = kind;

    private int Count(string kind) => _releases?.Count(r => r.Kind == kind) ?? 0;

    /// <summary>Substring match (case-insensitive) over label, publisher, customer, and BC version.</summary>
    private bool MatchesSearch(ReleaseListItem r)
    {
        if (string.IsNullOrWhiteSpace(_search)) return true;
        var q = _search.Trim();
        return Has(r.Label, q) || Has(r.Publisher, q) || Has(r.CustomerName, q) || Has(r.BcVersion, q);

        static bool Has(string? value, string needle) =>
            !string.IsNullOrEmpty(value) && value.Contains(needle, StringComparison.OrdinalIgnoreCase);
    }

    private string CategoryNoun => _kind switch
    {
        "first_party" => "Microsoft",
        "third_party" => "third-party",
        "customer" => "customer",
        _ => "",
    };

    /// <summary>
    /// Microsoft releases are grouped by major version (descending), matching
    /// the design's version timeline; third-party / customer render a single
    /// unlabelled group. The leading "NN." in the label is the major.
    /// </summary>
    private List<ReleaseGroup> GroupReleases(List<ReleaseListItem> list)
    {
        if (_kind != "first_party")
        {
            return list.Count == 0
                ? new List<ReleaseGroup>()
                : new List<ReleaseGroup> { new(null, list) };
        }

        return list
            .GroupBy(Major)
            .OrderByDescending(g => int.TryParse(g.Key, out var n) ? n : -1)
            .Select(g => new ReleaseGroup($"Version {g.Key}", g.ToList()))
            .ToList();
    }

    private static string Major(ReleaseListItem r)
    {
        var m = Regex.Match(r.BcVersion ?? string.Empty, @"(\d+)\.");
        if (!m.Success) m = Regex.Match(r.Label ?? string.Empty, @"(\d+)\.");
        return m.Success ? m.Groups[1].Value : "—";
    }

    /// <summary>
    /// "Newest first" sort key by release <em>version</em> rather than import
    /// date, so the hero features the greatest version and cards within a group
    /// run highest-first. Parses the numeric version from <c>BcVersion</c>
    /// (e.g. "28.2.50931.51034") or the label ("Business Central 28.2"); rows
    /// with no parseable version sort last.
    /// </summary>
    private static Version VersionKey(ReleaseListItem r)
    {
        if (Version.TryParse(r.BcVersion, out var v)) return v;
        var m = Regex.Match(r.Label ?? string.Empty, @"\d+(?:\.\d+)+");
        if (m.Success && Version.TryParse(m.Value, out var lv)) return lv;
        return new Version(0, 0);
    }

    /// <summary>Human "imported N ago" string relative to today (UTC).</summary>
    private static string RelAgo(DateTime imported)
    {
        var days = (int)Math.Round((DateTime.UtcNow.Date - imported.Date).TotalDays);
        if (days <= 0) return "today";
        if (days == 1) return "yesterday";
        if (days < 30) return $"{days} days ago";
        var months = (int)Math.Round(days / 30.0);
        return months <= 1 ? "1 month ago" : $"{months} months ago";
    }
}
