@page "/object-explorer/{VersionId:int}/files/{FileId:long}"
@attribute [Authorize]
@rendermode InteractiveServer
@inject BaseAppService BaseApp
@inject NavigationManager Nav
@using ALDevToolbox.Domain.Entities

<PageTitle>@(_file?.ObjectName ?? "Object") · AL Dev Toolbox</PageTitle>

<div class="object-explorer__file">
    <nav class="object-explorer__crumbs">
        <a href="/object-explorer">Object Explorer</a>
        <span>›</span>
        <a href="@($"/object-explorer/{VersionId}")">
            @(_version is null ? VersionId.ToString() : $"{_version.Major}.{_version.Minor} CU{_version.CumulativeUpdate}")
        </a>
        <span>›</span>
        <span>@(_file?.ObjectName ?? "")</span>
    </nav>

    @if (_file is null)
    {
        <p class="muted">Loading…</p>
    }
    else
    {
        <header class="object-explorer__file-header">
            <div>
                <h1>
                    <span class="object-explorer__type">@_file.ObjectType</span>
                    @if (_file.ObjectId is { } id)
                    {
                        <span class="muted">@id</span>
                    }
                    @_file.ObjectName
                </h1>
                <p class="muted small">
                    @_file.Path
                    @if (!string.IsNullOrWhiteSpace(_file.Namespace))
                    {
                        <span> · @_file.Namespace</span>
                    }
                </p>
            </div>

            @if (_otherVersions is not null && _otherVersions.Count > 0)
            {
                <div class="object-explorer__compare">
                    <label class="field">
                        <span class="field__label">Compare with</span>
                        <select class="field__input" @bind="_compareTarget" @bind:after="OpenCompareAsync">
                            <option value="">Pick a version…</option>
                            @foreach (var v in _otherVersions)
                            {
                                <option value="@v.Id">@v.Major.@v.Minor CU@v.CumulativeUpdate</option>
                            }
                        </select>
                    </label>
                </div>
            }
        </header>

        <CodeViewer Content="@_file.Content"
                    Language="al"
                    AriaLabel="@($"Source of {_file.ObjectName}")" />
    }
</div>

@code {
    [Parameter] public int VersionId { get; set; }
    [Parameter] public long FileId { get; set; }

    private BaseAppFile? _file;
    private BaseAppVersion? _version;
    private List<BaseAppVersion>? _otherVersions;
    private string _compareTarget = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        _file = await BaseApp.GetFileAsync(FileId);
        if (_file is null || _file.VersionId != VersionId)
        {
            Nav.NavigateTo($"/object-explorer/{VersionId}");
            return;
        }
        _version = await BaseApp.GetVersionAsync(VersionId);
        var all = await BaseApp.ListVersionsAsync();
        _otherVersions = all.Where(v => v.Id != VersionId).ToList();
    }

    private void OpenCompareAsync()
    {
        if (string.IsNullOrWhiteSpace(_compareTarget)) return;
        if (!int.TryParse(_compareTarget, out var otherId)) return;
        Nav.NavigateTo($"/object-explorer/{VersionId}/files/{FileId}/diff/{otherId}");
    }
}
