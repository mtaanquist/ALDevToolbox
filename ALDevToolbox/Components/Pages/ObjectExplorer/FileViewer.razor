@page "/object-explorer/{VersionId:int}/files/{FileId:long}"
@attribute [Authorize]
@rendermode InteractiveServer
@inject BaseAppService BaseApp
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IDisposable
@using ALDevToolbox.Components.Shared
@using ALDevToolbox.Domain.Entities
@using ALDevToolbox.Services.Al

@*
    The body splits into the code viewer on the left and the inspector panel
    on the right. The inspector hosts a stack of views — Outline by default,
    with Find references pushed on top as the user explores — and we keep the
    stack here so it survives FileId-stable re-renders.
*@

<PageTitle>@(_file?.ObjectName ?? "Object") · AL Dev Toolbox</PageTitle>

<div class="object-explorer__file">
    <nav class="object-explorer__crumbs">
        <a href="/object-explorer">Object Explorer</a>
        <span>›</span>
        <a href="@($"/object-explorer/{VersionId}")">
            @(_version is null ? VersionId.ToString() : $"BC {_version.Major}.{_version.CumulativeUpdate}")
        </a>
        <span>›</span>
        <span>@(_file?.ObjectName ?? "")</span>
    </nav>

    @if (_file is null)
    {
        <p class="muted">Loading…</p>
    }
    else
    {
        <header class="object-explorer__file-header">
            <div>
                <h1>
                    <span class="object-explorer__type">@_file.ObjectType</span>
                    @if (_file.ObjectId is { } id)
                    {
                        <span class="muted">@id</span>
                    }
                    @_file.ObjectName
                </h1>
                <p class="muted small">
                    @_file.Path
                    @if (!string.IsNullOrWhiteSpace(_file.Namespace))
                    {
                        <span> · @_file.Namespace</span>
                    }
                    <span>
                        · <strong>Cmd/Ctrl-click</strong> any name to go to its definition
                        · <strong>Right-click</strong> for Go to definition, Find references, Find in file
                        · <strong>Right rail</strong> for outline + results
                    </span>
                </p>
            </div>

            @if (_otherVersions is not null && _otherVersions.Count > 0)
            {
                <div class="object-explorer__compare">
                    <label class="field">
                        <span class="field__label">Compare with</span>
                        <select class="field__input" @bind="_compareTarget" @bind:after="OpenCompareAsync">
                            <option value="">Pick a version…</option>
                            @foreach (var v in _otherVersions)
                            {
                                <option value="@v.Id">BC @v.Major.@v.CumulativeUpdate</option>
                            }
                        </select>
                    </label>
                </div>
            }
        </header>

        @if (_lastDefinitionMissed is { } missed)
        {
            <p class="form-error" role="status">
                Couldn't resolve "@missed" in this version.
            </p>
        }

        <div class="object-explorer__file-layout">
            <CodeViewer Content="@_file.Content"
                        Language="al"
                        Declarations="_declarations"
                        Resolvables="_resolvables"
                        OnFindReferences="OnFindReferences"
                        OnGoToDefinition="OnGoToDefinition"
                        OnFindInFile="OnFindInFile"
                        ScrollToLine="_initialScrollLine"
                        ScrollSequence="_scrollSequence" />

            <InspectorPanel Stack="_panelHistory.Stack"
                            Cursor="_panelHistory.Cursor"
                            Symbols="_symbols"
                            VersionId="VersionId"
                            FileId="FileId"
                            OnPopTo="PopPanelTo"
                            OnPushReferences="PushReferencesView"
                            OnScrollTo="OnPanelScrollTo" />
        </div>
    }
</div>

@code {
    [Parameter] public int VersionId { get; set; }
    [Parameter] public long FileId { get; set; }

    private BaseAppFile? _file;
    private BaseAppVersion? _version;
    private List<BaseAppVersion>? _otherVersions;
    private string _compareTarget = string.Empty;
    private IReadOnlyList<CodeViewerDeclaration> _declarations = Array.Empty<CodeViewerDeclaration>();
    private IReadOnlyList<CodeViewerResolvable> _resolvables = Array.Empty<CodeViewerResolvable>();
    private IReadOnlyList<BaseAppSymbol> _symbols = Array.Empty<BaseAppSymbol>();
    private int? _initialScrollLine;
    // Monotonic counter passed through to CodeViewer so identical
    // scroll-to-line requests still trigger the flash + re-center. Bumped
    // every time we update _initialScrollLine.
    private int _scrollSequence;
    private string? _lastDefinitionMissed;
    private IDisposable? _locationChangedSubscription;

    // Inspector panel navigation stack. Resets to a fresh Outline view on
    // every file load — references state is per-file and doesn't survive
    // cross-file navigation (see the design discussion in the PR thread).
    private readonly InspectorPanelHistory _panelHistory = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        _locationChangedSubscription = Nav.RegisterLocationChangingHandler(OnLocationChanging);
        // LocationChanged is the post-navigation event. It fires reliably for
        // fragment-only changes, where LocationChangingHandler doesn't always
        // — this is the path that catches an outline-link click or a Go to
        // definition that lands inside the currently mounted file.
        Nav.LocationChanged += OnLocationChanged;
    }

    protected override async Task OnParametersSetAsync()
    {
        // Reload when the route's FileId changes (navigation within Object
        // Explorer keeps the page mounted and just re-renders).
        if (_file is not null && _file.Id != FileId)
        {
            await LoadAsync();
        }
    }

    private async Task LoadAsync()
    {
        _file = await BaseApp.GetFileAsync(FileId);
        if (_file is null || _file.VersionId != VersionId)
        {
            Nav.NavigateTo($"/object-explorer/{VersionId}");
            return;
        }
        _version = await BaseApp.GetVersionAsync(VersionId);
        var all = await BaseApp.ListVersionsAsync();
        _otherVersions = all.Where(v => v.Id != VersionId).ToList();

        _symbols = await BaseApp.ListSymbolsInFileAsync(FileId);
        _declarations = _symbols
            // Triggers are always local — there's nowhere to navigate to and
            // no "find references" worth running, so skip the underline /
            // right-click menu entirely.
            .Where(s => !string.Equals(s.Kind, "trigger", StringComparison.Ordinal))
            .Select(s => new CodeViewerDeclaration(
                s.Id, s.LineNumber, s.ColumnStart, s.ColumnEnd, s.Kind, s.Name))
            .ToList();

        var resolvables = await BaseApp.ListResolvableTokensInFileAsync(FileId);
        _resolvables = resolvables
            .Select(r => new CodeViewerResolvable(r.Line, r.ColumnStart, r.ColumnEnd))
            .ToList();

        SetScrollTarget(ExtractLineAnchor(Nav.Uri));

        // Fresh file, fresh stack — references state from the previous file
        // wouldn't make sense here.
        _panelHistory.Reset();
    }

    /// <summary>
    /// Updates the scroll target and bumps the sequence so CodeViewer flashes
    /// even if the line value is the same as the previous request.
    /// </summary>
    private void SetScrollTarget(int? line)
    {
        _initialScrollLine = line;
        _scrollSequence++;
    }

    /// <summary>
    /// Pulls the 1-based line number out of a <c>#L&lt;n&gt;</c> URL fragment.
    /// Returns <c>null</c> if the fragment is missing or malformed.
    /// </summary>
    private static int? ExtractLineAnchor(string uri)
    {
        var hashIdx = uri.IndexOf('#');
        if (hashIdx < 0 || hashIdx == uri.Length - 1) return null;
        var fragment = uri.Substring(hashIdx + 1);
        if (fragment.Length < 2 || (fragment[0] != 'L' && fragment[0] != 'l')) return null;
        if (!int.TryParse(fragment.AsSpan(1), out var line) || line < 1) return null;
        return line;
    }

    private void OpenCompareAsync()
    {
        if (string.IsNullOrWhiteSpace(_compareTarget)) return;
        if (!int.TryParse(_compareTarget, out var otherId)) return;
        Nav.NavigateTo($"/object-explorer/{VersionId}/files/{FileId}/diff/{otherId}");
    }

    private void OnFindReferences(long symbolId)
    {
        // Right-click "Find references" inside the editor — push a panel view
        // rather than navigating away. The standalone /symbols/{id}/references
        // route still exists for deep-linking but isn't the primary surface.
        var symbol = _symbols.FirstOrDefault(s => s.Id == symbolId);
        if (symbol is null) return;
        _panelHistory.Push(new ReferencesPanelView(symbol.Id, symbol.Name, symbol.Kind));
    }

    private void PushReferencesView(BaseAppSymbol symbol)
    {
        _panelHistory.Push(new ReferencesPanelView(symbol.Id, symbol.Name, symbol.Kind));
    }

    private void PopPanelTo(int index) => _panelHistory.PopTo(index);

    private void OnFindInFile(CodeViewerClick click)
    {
        // Extract the token at the click position so the panel has the actual
        // word to search for — the JS side only sees line/column. The locator
        // already handles quoted identifiers (Sales-Post) and bare ones.
        if (_file is null) return;
        var inspected = AlGoToDefinitionLocator.Inspect(_file.Content, click.Line, click.Column);
        if (inspected is null || string.IsNullOrWhiteSpace(inspected.Word)) return;
        _panelHistory.Push(new FileSearchPanelView(inspected.Word));
    }

    private async Task OnGoToDefinition(CodeViewerClick click)
    {
        _lastDefinitionMissed = null;
        var target = await BaseApp.GoToDefinitionAsync(FileId, click.Line, click.Column);
        if (target is null)
        {
            // Surface a small hint so the user knows the click was received
            // even though resolution failed. We can't echo the clicked word
            // (the click position is the only thing we have) — keeping the
            // message generic.
            _lastDefinitionMissed = $"line {click.Line}, column {click.Column}";
            StateHasChanged();
            return;
        }

        var url = $"/object-explorer/{VersionId}/files/{target.FileId}#L{target.LineNumber}";
        Nav.NavigateTo(url);
    }

    private ValueTask OnLocationChanging(LocationChangingContext context)
    {
        // Same page, different fragment: re-pull the line anchor so the
        // viewer scrolls again. Skip if the line is already the current
        // target — our own @onclick handler usually beat us to it, and
        // re-bumping the sequence would queue a redundant scroll dispatch.
        if (context.TargetLocation.StartsWith($"/object-explorer/{VersionId}/files/{FileId}", StringComparison.Ordinal))
        {
            var newScroll = ExtractLineAnchor(context.TargetLocation);
            if (newScroll != _initialScrollLine)
            {
                SetScrollTarget(newScroll);
                StateHasChanged();
            }
        }
        return ValueTask.CompletedTask;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        // Post-navigation safety net for URL changes we didn't initiate
        // ourselves — direct URL-bar edits, browser back/forward, etc. For
        // clicks routed through OnPanelScrollTo / OnGoToDefinition, the
        // scroll target has already been set; bumping the sequence again
        // here would dispatch a second scrollToLine and is what was
        // causing CodeMirror to thrash on far-down navigations.
        if (_file is null) return;
        var path = $"/object-explorer/{VersionId}/files/{FileId}";
        if (!e.Location.Contains(path, StringComparison.Ordinal)) return;
        var newScroll = ExtractLineAnchor(e.Location);
        if (newScroll is null || newScroll == _initialScrollLine) return;
        SetScrollTarget(newScroll);
        _ = InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Click from an inspector-panel anchor. Same-file hits scroll without
    /// a full navigation (browser nav for a same-URL anchor is a no-op, which
    /// would leave the editor stuck — this path always bumps the sequence so
    /// the viewer re-flashes). Cross-file hits fall through to Nav.NavigateTo
    /// so OnParametersSet reloads the page.
    /// </summary>
    private void OnPanelScrollTo((long FileId, int LineNumber) hit)
    {
        if (hit.FileId == FileId)
        {
            SetScrollTarget(hit.LineNumber);
            // `replace` keeps the back-stack from filling up with one entry
            // per outline click within the same file.
            Nav.NavigateTo(
                $"/object-explorer/{VersionId}/files/{FileId}#L{hit.LineNumber}",
                replace: true);
        }
        else
        {
            Nav.NavigateTo($"/object-explorer/{VersionId}/files/{hit.FileId}#L{hit.LineNumber}");
        }
    }

    public void Dispose()
    {
        _locationChangedSubscription?.Dispose();
        Nav.LocationChanged -= OnLocationChanged;
    }
}
