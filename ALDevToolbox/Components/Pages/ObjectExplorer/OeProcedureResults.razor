@inject ALDevToolbox.Services.ObjectExplorer.ObjectExplorerLinks Links
@using ALDevToolbox.Services.ObjectExplorer

@*
    Procedure-search result table for the Release search page. Loading /
    empty / populated states. Object links carry the view-Release seed so a
    follow-up Find references on an inherited base object stays seeded here.
*@

@if (Results is null)
{
    <p class="muted">Loading procedures…</p>
    return;
}
@if (Results.Count == 0)
{
    <p class="muted">No procedures match. Try a different name.</p>
    return;
}
<p class="muted">Showing @Results.Count.ToString("N0") procedure(s).</p>
<table class="data-table">
    <thead>
        <tr>
            <th scope="col">Module</th>
            <th scope="col">Object</th>
            <th scope="col">Kind</th>
            <th scope="col">Procedure</th>
            <th scope="col">Source</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var r in Results)
        {
            <tr>
                <td>@r.ModuleName</td>
                <td><a href="@ObjectLink(r.ObjectId)">@r.ObjectKind @r.ObjectName</a></td>
                <td>@r.ProcedureKind.Replace("_", " ")</td>
                <td>
                    <strong>@r.Name</strong>
                    @if (!string.IsNullOrEmpty(r.Signature))
                    {
                        <span class="muted">@r.Signature</span>
                    }
                    @if (!string.IsNullOrEmpty(r.ReturnType))
                    {
                        <span class="muted"> : @r.ReturnType</span>
                    }
                </td>
                <td>
                    @if (r.SourceFileId is { } fid)
                    {
                        <a href="@Links.SourceFile(fid, r.ObjectLineNumber, ViewReleaseSeed)">View source</a>
                    }
                    else
                    {
                        <span class="muted">—</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    [Parameter] public List<ReleaseProcedureMatch>? Results { get; set; }
    [Parameter] public int? ViewReleaseSeed { get; set; }

    /// <summary>Object-detail link, carrying the view-Release seed (so Find
    /// references on an inherited base object stays seeded at this Release).</summary>
    private string ObjectLink(long objectId) =>
        ViewReleaseSeed is { } from
            ? $"/object-explorer/object/{objectId}?from={from}"
            : $"/object-explorer/object/{objectId}";
}
