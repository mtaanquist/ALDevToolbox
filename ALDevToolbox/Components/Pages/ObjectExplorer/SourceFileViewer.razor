@page "/object-explorer/file/{FileId:long}"
@attribute [Authorize]
@inject ALDevToolbox.Services.ObjectExplorer.ObjectExplorerService ObjectExplorer
@inject IHttpContextAccessor Http
@using ALDevToolbox.Services.ObjectExplorer

@*
    Source-file viewer with an outline panel. Reads the body once via
    GetFileAsync, renders as a numbered table; the right-hand outline lists
    every object + symbol declared in the file with click-through to the
    line. The find-references panel and the per-object "View source" link
    both deep-link via ?line=N which lights up the target row in CSS.

    No syntax highlighting yet — the legacy CodeMirror integration was
    scoped out in PR 6. Plain <pre>-style lines keep the page renderable
    without a JS bundle while still giving the "click through to the
    actual code" payoff. Token right-click navigation (Find references /
    Go to definition on a clicked identifier) is the next step on top of
    this surface.
*@

<PageTitle>@(_header?.Path ?? "Source") · AL Dev Toolbox</PageTitle>

<div class="object-explorer source-viewer">
    @if (_header is null || _file is null)
    {
        <p class="muted">Loading…</p>
    }
    else
    {
        <header class="admin-page__header">
            <div>
                <p class="muted">
                    <a href="/object-explorer">Releases</a>
                    <span> / <a href="@($"/object-explorer/release/{_header.ReleaseId}")">@_header.ReleaseLabel</a></span>
                    <span> / <a href="@($"/object-explorer/module/{_header.ModuleId}")">@_header.ModuleName</a></span>
                </p>
                <h1>@_header.Path</h1>
                <p class="muted">@_header.LineCount.ToString("N0") line(s)</p>
            </div>
        </header>

        <div class="source-viewer__layout">
            <pre class="source-viewer__body"><code>@RenderNumberedLines(_file.Content, _highlightLine)</code></pre>

            <aside class="source-viewer__outline">
                <h2>Outline</h2>
                @if (_outline is null || _outline.Count == 0)
                {
                    <p class="muted">No outline available.</p>
                }
                else
                {
                    <ul class="source-viewer__outline-list">
                        @foreach (var item in _outline)
                        {
                            <li class="@OutlineItemClass(item)">
                                <a href="@OutlineHref(item)">
                                    <span class="source-viewer__outline-kind">@FormatKind(item.Kind)</span>
                                    <span class="source-viewer__outline-name">@item.Name</span>
                                    @if (!string.IsNullOrEmpty(item.Signature))
                                    {
                                        <span class="source-viewer__outline-sig muted">@item.Signature</span>
                                    }
                                </a>
                            </li>
                        }
                    </ul>
                }
            </aside>
        </div>
    }
</div>

@code {
    [Parameter] public long FileId { get; set; }

    private SourceFileHeader? _header;
    private SourceFileDetail? _file;
    private List<SourceFileOutlineItem>? _outline;
    private int? _highlightLine;

    protected override async Task OnInitializedAsync()
    {
        _header = await ObjectExplorer.GetFileHeaderAsync(FileId);
        if (_header is null) return;
        _file = await ObjectExplorer.GetFileAsync(FileId);
        _outline = await ObjectExplorer.GetFileOutlineAsync(FileId);

        var ctx = Http.HttpContext;
        if (ctx is not null && int.TryParse(ctx.Request.Query["line"], out var line) && line > 0)
        {
            _highlightLine = line;
        }
    }

    private string OutlineHref(SourceFileOutlineItem item)
    {
        // Objects (the major declarations) deserve a real navigation hop so
        // the user can find references / jump to symbols on them. Sub-symbol
        // rows just scroll the source view to their line via the fragment
        // anchor stamped by RenderNumberedLines.
        return item.ObjectId is { } oid
            ? $"/object-explorer/object/{oid}"
            : $"#L{item.LineNumber}";
    }

    private string OutlineItemClass(SourceFileOutlineItem item) =>
        item.ObjectId is null
            ? "source-viewer__outline-item source-viewer__outline-item--symbol"
            : "source-viewer__outline-item source-viewer__outline-item--object";

    private static string FormatKind(string kind) => kind switch
    {
        "internal_procedure" => "internal proc",
        "local_procedure"    => "local proc",
        "procedure"          => "procedure",
        "event_publisher"    => "event publisher",
        "event_subscriber"   => "event subscriber",
        "trigger"            => "trigger",
        "field"              => "field",
        _                    => kind,
    };

    private static RenderFragment RenderNumberedLines(string content, int? highlight) => __builder =>
    {
        if (string.IsNullOrEmpty(content)) return;
        var lines = content.Replace("\r\n", "\n").Split('\n');
        for (var i = 0; i < lines.Length; i++)
        {
            var lineNo = i + 1;
            var cssClass = highlight == lineNo
                ? "source-viewer__line source-viewer__line--hit"
                : "source-viewer__line";
            <div class="@cssClass" id="@($"L{lineNo}")">
                <span class="source-viewer__lineno">@lineNo</span>
                <span class="source-viewer__text">@lines[i]</span>
            </div>
        }
    };
}
