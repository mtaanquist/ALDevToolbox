@page "/object-explorer/file/{FileId:long}"
@attribute [Authorize]
@inject ALDevToolbox.Services.ObjectExplorer.ObjectExplorerService ObjectExplorer
@inject ALDevToolbox.Services.ObjectExplorer.ObjectExplorerLinks Links
@inject ALDevToolbox.Services.ObjectExplorer.ReferenceSessionService ReferenceSessions
@inject IHttpContextAccessor Http
@using ALDevToolbox.Services.ObjectExplorer
@using ALDevToolbox.Components.Shared
@using System.Text.Json
@using System.Security.Claims

@*
    Object Explorer source-file viewer (static SSR + source-viewer.js).
    Server renders the file content, outline and declarations into the HTML
    response; a small ES module (wwwroot/source-viewer.js) wires up the
    in-document affordances (outline filter, same-file jumps, Cmd-click,
    right-click menu, Find in this file). The page is intentionally not
    InteractiveServer — see .design/source-viewer-redesign.md for the
    rationale (Blazor enhanced-nav strips CodeMirror's runtime <style>
    tags on every interaction in the interactive mode).

    A legacy copy at /object-explorer/file-legacy/{id} stays interactive
    for one release so env-flag rollback is possible:
    SourceFileViewerLegacy.razor + OBJECT_EXPLORER_LEGACY_VIEWER=1.
*@

<PageTitle>@(_header?.Path ?? "Source") · AL Dev Toolbox</PageTitle>

<div class="object-explorer source-viewer"
     data-file-id="@FileId"
     data-initial-line="@(_highlightLine?.ToString() ?? string.Empty)"
     data-ref-set="@(_session?.Token ?? string.Empty)">
    @if (_header is null || _file is null)
    {
        <p class="muted">File not found.</p>
    }
    else
    {
        <header class="admin-page__header">
            <div>
                <p class="muted">
                    <a href="/object-explorer">Object Explorer</a>
                    <span> › <a href="@($"/object-explorer/release/{_header.ReleaseId}")">@_header.ReleaseLabel</a></span>
                </p>
                <h1>@BuildBreadcrumb(_header)</h1>
                @* Line count + cursor position render in the editor's
                   bottom status bar (see code-editor.js → buildStatusBarExtension).
                   The heading stays a clean breadcrumb. *@
            </div>
            <div class="source-viewer__header-actions">
                <a class="btn btn--sm"
                   href="@($"/api/object-explorer/files/{FileId}/download")"
                   download
                   title="Download the raw source for this file">Download source</a>
                @if (_compareTargets is { Count: > 0 })
                {
                    <form method="get" action="/object-explorer/compare/file" class="source-viewer__compare-picker">
                        <label class="field">
                            <span class="field__label">Compare with release</span>
                            <select name="right" class="field__input" onchange="this.form.submit()" aria-label="Compare this file with the same file in another release">
                                <option value="">None</option>
                                @foreach (var t in _compareTargets)
                                {
                                    <option value="@t.TargetFileId">@t.ReleaseLabel</option>
                                }
                            </select>
                        </label>
                        <input type="hidden" name="left" value="@FileId" />
                    </form>
                }
            </div>
        </header>

        <div class="source-viewer__layout">
            @*
                spellcheck="false" — AL identifiers (camelCase names,
                quoted phrases like "Sell-to Customer Name") trigger
                browser spellcheck's red squiggly underline, which is
                trivially confusable with the resolvable / declaration
                dotted underlines this viewer paints. Turning it off
                across the whole editor surface so what you see under
                a token is always us, never Chrome / Firefox.
            *@
            <div class="source-viewer__code"
                 data-language="al"
                 data-content="@_file.Content"
                 data-declarations="@SerializeDeclarations(FilterNavigableDeclarations(_declarations))"
                 data-resolvables="@SerializeResolvables(_resolvables)"
                 spellcheck="false"></div>

            @* Drag handle between the editor and the outline. source-viewer.js
               wires the pointer events and persists the chosen width in
               localStorage so subsequent loads inherit the user's choice. *@
            <div class="source-viewer__resizer"
                 role="separator"
                 aria-orientation="vertical"
                 aria-label="Resize outline panel"
                 tabindex="0"></div>

            @*
                The sticky positioning lives on the outer .source-viewer__outline
                aside. The inner .source-viewer__outline-inner takes the
                overflow:auto so sticky and overflow don't fight on the same
                element (a Chromium bug pattern that still bites with tall
                flex siblings).
            *@
            <aside class="source-viewer__outline">
                <div class="source-viewer__outline-inner">
                @{
                    var defaultTab = _session is not null ? "references" : "outline";
                }
                <nav class="source-viewer__tabs" role="tablist">
                    <button type="button"
                            class="source-viewer__tab @(defaultTab == "outline" ? "is-active" : null)"
                            role="tab"
                            data-tab="outline"
                            aria-selected="@(defaultTab == "outline" ? "true" : "false")">Outline</button>
                    <button type="button"
                            class="source-viewer__tab @(defaultTab == "references" ? "is-active" : null)"
                            role="tab"
                            data-tab="references"
                            aria-selected="@(defaultTab == "references" ? "true" : "false")"
                            hidden="@(_session is null)">
                        References
                        @if (_session is not null)
                        {
                            <span class="source-viewer__tab-count">@_session.Results.Count.ToString("N0")</span>
                        }
                    </button>
                    <button type="button"
                            class="source-viewer__tab"
                            role="tab"
                            data-tab="find"
                            aria-selected="false"
                            hidden>Find</button>
                    <button type="button"
                            class="source-viewer__tab source-viewer__tab--end"
                            role="tab"
                            data-tab="help"
                            aria-selected="false"
                            title="Keyboard and mouse shortcuts">Help</button>
                </nav>

                <div class="source-viewer__panel @(defaultTab == "outline" ? "is-active" : null)"
                     data-panel="outline"
                     role="tabpanel">
                    @if (_outline is null || _outline.Count == 0)
                    {
                        <p class="muted">No outline available.</p>
                    }
                    else
                    {
                        <input type="text"
                               class="source-viewer__outline-filter"
                               placeholder="Filter symbols…"
                               aria-label="Filter symbols" />

                        var groups = SourceFileOutlineGrouper.Build(_outline, filter: null);
                        <p class="muted source-viewer__outline-empty" hidden>No matches.</p>
                        @foreach (var group in groups)
                        {
                            <section class="source-viewer__outline-section is-open"
                                     data-section-key="@group.Key">
                                <button type="button"
                                        class="source-viewer__outline-section-toggle"
                                        aria-expanded="true">
                                    <span class="source-viewer__outline-section-chevron is-open">›</span>
                                    <span class="source-viewer__outline-section-title">@group.Title</span>
                                    <span class="source-viewer__outline-section-count">(@group.Items.Count)</span>
                                </button>
                                <ul class="source-viewer__outline-list">
                                    @foreach (var entry in group.Items)
                                    {
                                        <li class="source-viewer__outline-item @(entry.IsChild ? "source-viewer__outline-item--child" : null)"
                                            data-row-name="@entry.Item.Name"
                                            data-symbol-id="@(entry.Item.SymbolId?.ToString() ?? "")"
                                            data-object-id="@(entry.Item.ObjectId?.ToString() ?? "")">
                                            @if (entry.Item.ObjectId is { } oid)
                                            {
                                                <a href="@($"/object-explorer/object/{oid}")" title="@FormatTooltip(entry.Item)">
                                                    <span class="source-viewer__outline-badge @KindBadgeClass(entry.Item.Kind)">@KindBadgeLabel(entry.Item.Kind)</span>
                                                    <span class="source-viewer__outline-name">@entry.Item.Name</span>
                                                    @if (!string.IsNullOrEmpty(entry.Item.Signature))
                                                    {
                                                        <span class="source-viewer__outline-sig muted">@FormatSignature(entry.Item.Signature)</span>
                                                    }
                                                    @if (entry.Item.Kind != "implemented_by")
                                                    {
                                                        <span class="source-viewer__outline-line muted">L@(entry.Item.LineNumber)</span>
                                                    }
                                                </a>
                                            }
                                            else
                                            {
                                                <a href="@($"/object-explorer/file/{FileId}?line={entry.Item.LineNumber}")"
                                                   class="source-viewer__outline-link"
                                                   data-line="@entry.Item.LineNumber"
                                                   title="@FormatTooltip(entry.Item)">
                                                    <span class="source-viewer__outline-badge @KindBadgeClass(entry.Item.Kind)">@KindBadgeLabel(entry.Item.Kind)</span>
                                                    <span class="source-viewer__outline-name">@entry.Item.Name</span>
                                                    @if (!string.IsNullOrEmpty(entry.Item.Signature))
                                                    {
                                                        <span class="source-viewer__outline-sig muted">@FormatSignature(entry.Item.Signature)</span>
                                                    }
                                                    @if (entry.Item.Kind != "implemented_by")
                                                    {
                                                        <span class="source-viewer__outline-line muted">L@(entry.Item.LineNumber)</span>
                                                    }
                                                </a>
                                            }
                                        </li>
                                    }
                                </ul>
                            </section>
                        }

                        @* Outline-bottom dependency sections (#148). The
                           shells render empty on SSR; source-viewer.js fetches
                           /api/object-explorer/files/{id}/dependencies on
                           mount and fills in the lists. *@
                        <section class="source-viewer__outline-section is-open"
                                 data-section-key="using"
                                 data-deps-section="using">
                            <button type="button"
                                    class="source-viewer__outline-section-toggle"
                                    aria-expanded="true">
                                <span class="source-viewer__outline-section-chevron is-open">›</span>
                                <span class="source-viewer__outline-section-title">Using</span>
                                <span class="source-viewer__outline-section-count" data-deps-count>(…)</span>
                            </button>
                            <ul class="source-viewer__outline-list" data-deps-list="using"></ul>
                        </section>
                        <section class="source-viewer__outline-section is-open"
                                 data-section-key="used-by"
                                 data-deps-section="used-by">
                            <button type="button"
                                    class="source-viewer__outline-section-toggle"
                                    aria-expanded="true">
                                <span class="source-viewer__outline-section-chevron is-open">›</span>
                                <span class="source-viewer__outline-section-title">Used by</span>
                                <span class="source-viewer__outline-section-count" data-deps-count>(…)</span>
                            </button>
                            <ul class="source-viewer__outline-list" data-deps-list="used-by"></ul>
                        </section>
                    }
                </div>

                @*
                    References panel: when a refSet token is present on the
                    URL, ship the session payload as a data-* attribute and
                    let source-viewer.js render the panel client-side. This
                    keeps the grouping / row rendering logic in one place
                    (renderReferencesPanel) — the server is the cache for
                    the result list, the client is the single renderer.
                *@
                <div class="source-viewer__panel @(defaultTab == "references" ? "is-active" : null)"
                     data-panel="references"
                     role="tabpanel"
                     data-session="@SerializeSession(_session)"
                     hidden="@(_session is null)"></div>

                <div class="source-viewer__panel" data-panel="find" role="tabpanel" hidden>
                    <div class="source-viewer__find-host"></div>
                </div>

                <div class="source-viewer__panel" data-panel="help" role="tabpanel" hidden>
                    <dl class="source-viewer__help">
                        <dt><kbd>Cmd</kbd>/<kbd>Ctrl</kbd> + click</dt>
                        <dd>Jump to the definition of the clicked name.</dd>
                        <dt>Right-click</dt>
                        <dd>Find references to the clicked symbol, or find every occurrence of it inside this file.</dd>
                        <dt><kbd>Cmd</kbd>/<kbd>Ctrl</kbd> + <kbd>F</kbd></dt>
                        <dd>Open the editor's search panel to filter lines inside this file.</dd>
                        <dt>Right-click in Outline</dt>
                        <dd>Find references for a procedure, field or object without first navigating to it.</dd>
                    </dl>
                </div>

                <p class="muted source-viewer__notice" role="status" hidden></p>
                </div>
            </aside>
        </div>

        @* source-viewer.js is loaded at the shell (App.razor) — Blazor
           enhanced-nav doesn't execute <script> tags injected via page
           responses. The module's MutationObserver picks up the
           .source-viewer DOM as soon as it appears. *@
    }
</div>

@code {
    [Parameter] public long FileId { get; set; }

    private SourceFileHeader? _header;
    private SourceFileDetail? _file;
    private List<SourceFileOutlineItem>? _outline;
    private IReadOnlyList<CodeViewerDeclaration>? _declarations;
    private IReadOnlyList<CodeViewerResolvable>? _resolvables;
    private List<CompareTargetOption>? _compareTargets;
    private int? _highlightLine;
    private ReferenceSession? _session;

    protected override async Task OnInitializedAsync()
    {
        _header = await ObjectExplorer.GetFileHeaderAsync(FileId);
        if (_header is null) return;
        _file = await ObjectExplorer.GetFileAsync(FileId);
        _outline = await ObjectExplorer.GetFileOutlineAsync(FileId);
        _declarations = await ObjectExplorer.ListDeclarationsInFileAsync(FileId);
        _resolvables = await ObjectExplorer.ListResolvablesInFileAsync(FileId);
        _compareTargets = await ObjectExplorer.GetCompareTargetsAsync(FileId);

        var ctx = Http.HttpContext;
        if (ctx is not null && int.TryParse(ctx.Request.Query["line"], out var line) && line > 0)
        {
            _highlightLine = line;
        }

        var refSet = ctx?.Request.Query["refSet"].ToString();
        if (!string.IsNullOrEmpty(refSet))
        {
            var owner = OwnerKey(ctx);
            if (owner is not null)
            {
                _session = ReferenceSessions.Get(refSet, owner);
            }
        }
    }

    private string RefUrl(long fileId, int line)
    {
        var url = Links.SourceFile(fileId, line);
        if (_session is not null)
        {
            url += "&refSet=" + Uri.EscapeDataString(_session.Token);
        }
        return url;
    }

    private static string? OwnerKey(HttpContext? ctx)
    {
        var user = ctx?.User;
        if (user?.Identity?.IsAuthenticated != true) return null;
        return user.FindFirst(ClaimTypes.NameIdentifier)?.Value
            ?? user.Identity.Name;
    }

    private static string FormatSignature(string signature) => signature;

    /// <summary>
    /// Renders the page heading as <c>{Module} · {Namespace} · {File}</c> when
    /// the file has an AL namespace, otherwise <c>{Module} · {File}</c>. AL
    /// namespaces are the canonical "where does this live" identifier — the
    /// physical folder layout differs across vendors and BC versions, so the
    /// breadcrumb prefers the declared namespace over the raw <c>src/…</c>
    /// path. The full path is still available on the <c>title</c> of the
    /// heading for the rare cases when the folder layout matters.
    /// </summary>
    private static string BuildBreadcrumb(SourceFileHeader header)
    {
        var fileName = ExtractFileName(header.Path);
        if (!string.IsNullOrWhiteSpace(header.ObjectNamespace))
        {
            return $"{header.ModuleName} · {header.ObjectNamespace} · {fileName}";
        }
        return $"{header.ModuleName} · {fileName}";
    }

    private static string ExtractFileName(string path)
    {
        if (string.IsNullOrEmpty(path)) return path;
        // Module file paths are stored with forward slashes (the import
        // pipeline normalises both src/ and .Source.zip layouts to the same
        // shape). Stick to '/' rather than Path.GetFileName so the rendering
        // stays platform-independent in tests.
        var slash = path.LastIndexOf('/');
        return slash < 0 ? path : path[(slash + 1)..];
    }

    /// <summary>
    /// Serialises a reference session into the JSON shape source-viewer.js
    /// expects on the panel's data-session attribute. Empty string when
    /// there's no session — the JS reader treats that as "no panel".
    /// </summary>
    private static string SerializeSession(ReferenceSession? session)
    {
        if (session is null) return string.Empty;
        return JsonSerializer.Serialize(session, SessionJsonOptions);
    }

    private static readonly JsonSerializerOptions SessionJsonOptions = new()
    {
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
    };

    /// <summary>
    /// Short label shown in the kind badge next to each outline row.
    /// Keep it concise (≤ 9 chars) so it fits inside a 340px column
    /// alongside the name + signature; the full kind lives on the
    /// row's <c>title</c> tooltip.
    /// </summary>
    private static string KindBadgeLabel(string kind) => kind.ToLowerInvariant() switch
    {
        "table_field" or "page_field" => "field",
        "page_action" => "action",
        "trigger" => "trigger",
        "label" => "label",
        "procedure" => "proc",
        "internal_procedure" => "internal",
        "protected_procedure" => "protected",
        "local_procedure" => "local",
        "event_publisher" => "event pub",
        "event_subscriber" => "event sub",
        "codeunit" => "codeunit",
        "table" => "table",
        "tableextension" => "table ext",
        "page" => "page",
        "pageextension" => "page ext",
        "report" => "report",
        "reportextension" => "report ext",
        "xmlport" => "xmlport",
        "query" => "query",
        "controladdin" => "controladd",
        "enum" => "enum",
        "enumextension" => "enum ext",
        "interface" => "interface",
        "permissionset" => "permset",
        "permissionsetextension" => "permset ext",
        "profile" => "profile",
        "implemented_by" => "codeunit",
        _ => kind,
    };

    /// <summary>
    /// CSS modifier that tints the kind badge. Procedures share one
    /// colour family (method-like), triggers + events share another
    /// (event-like), fields and object headers get their own tints.
    /// </summary>
    private static string KindBadgeClass(string kind) => kind.ToLowerInvariant() switch
    {
        "table_field" or "page_field" => "source-viewer__outline-badge--field",
        "page_action" => "source-viewer__outline-badge--action",
        "trigger" => "source-viewer__outline-badge--trigger",
        "label" => "source-viewer__outline-badge--label",
        "event_publisher" or "event_subscriber" => "source-viewer__outline-badge--event",
        "procedure" or "internal_procedure" or "protected_procedure" or "local_procedure"
            => "source-viewer__outline-badge--proc",
        _ => "source-viewer__outline-badge--object",
    };

    private static string FormatTooltip(SourceFileOutlineItem item)
    {
        var sb = new System.Text.StringBuilder(item.Name);
        if (!string.IsNullOrEmpty(item.Signature))
        {
            sb.Append(item.Signature);
        }
        return sb.ToString();
    }

    /// <summary>
    /// Serialises declarations to JSON the way <c>code-editor.js</c>'s
    /// <c>mountReadOnly</c> expects them: camelCase keys, single line, safe
    /// to embed into a <c>data-*</c> attribute (browser unescaping +
    /// JSON.parse on the client). Symbol ids round-trip as numbers since
    /// JavaScript handles all current ALDevToolbox IDs (well below 2^53).
    /// </summary>
    private static string SerializeDeclarations(IReadOnlyList<CodeViewerDeclaration>? declarations)
    {
        if (declarations is null || declarations.Count == 0) return "[]";
        return JsonSerializer.Serialize(declarations, DeclarationJsonOptions);
    }

    /// <summary>
    /// Serialises resolvable ranges into the JSON shape code-editor.js'
    /// <c>buildResolvableDecorationExtensions</c> expects on the
    /// <c>data-resolvables</c> attribute — camelCase keys, plain array.
    /// Underlines the tokens that <see cref="ObjectExplorerService.GoToDefinitionAsync"/>
    /// can resolve to a definition; right-click + Cmd-click already work on
    /// any position, but the underline tells users which tokens are clickable
    /// without having to probe by hovering.
    /// </summary>
    private static string SerializeResolvables(IReadOnlyList<CodeViewerResolvable>? resolvables)
    {
        if (resolvables is null || resolvables.Count == 0) return "[]";
        return JsonSerializer.Serialize(resolvables, DeclarationJsonOptions);
    }

    /// <summary>
    /// Drops <b>field</b> and <b>trigger</b> declarations from the list
    /// passed to <c>code-editor.js</c>. The declarations list drives both
    /// <c>buildDeclarationDecorationExtensions</c> (the <c>cm-symbol-decl</c>
    /// underline) and the right-click "Find references" routing, so
    /// filtering at the source removes the visual noise AND stops the
    /// menu from offering an action that returns nothing useful:
    /// <list type="bullet">
    ///   <item>A page-side field LHS (the page's own field name) is a
    ///         declaration, not a navigation target — the RHS
    ///         <c>Rec."Field"</c> is what users want to click through
    ///         to the table's field. Underlining the LHS distracted
    ///         from the meaningful RHS reference.</item>
    ///   <item>Triggers (<c>OnValidate</c>, <c>OnAssistEdit</c>, …) are
    ///         invoked by the runtime, not by user code. There's
    ///         nothing useful to navigate to from the trigger
    ///         declaration — Find references on a trigger returns the
    ///         empty set in practice.</item>
    /// </list>
    /// Object headers (codeunit / table / page / …) and member-symbol
    /// declarations (procedures, event publishers / subscribers, labels)
    /// stay in the set — they ARE useful navigation targets.
    /// </summary>
    private static IReadOnlyList<CodeViewerDeclaration> FilterNavigableDeclarations(
        IReadOnlyList<CodeViewerDeclaration>? declarations)
    {
        if (declarations is null || declarations.Count == 0)
            return Array.Empty<CodeViewerDeclaration>();
        var kept = new List<CodeViewerDeclaration>(declarations.Count);
        foreach (var d in declarations)
        {
            if (IsNonNavigableDeclaration(d.Kind)) continue;
            kept.Add(d);
        }
        return kept;
    }

    /// <summary>
    /// Decides whether a declaration's underline + right-click "Find
    /// references" affordance should be shown. After the symbol-kind
    /// split (see .design/al-reference-extractor-refactor.md step 1),
    /// the kind alone carries the navigation intent — no owner-kind
    /// join needed:
    /// <list type="bullet">
    ///   <item><c>table_field</c> is the canonical field declaration —
    ///         a legitimate navigation target.</item>
    ///   <item><c>page_field</c> / <c>page_action</c> are page-local
    ///         control names — not navigation targets.</item>
    ///   <item><c>trigger</c> is runtime-invoked everywhere — never a
    ///         useful Find-references target.</item>
    /// </list>
    /// </summary>
    private static bool IsNonNavigableDeclaration(string kind) =>
        string.Equals(kind, "trigger", StringComparison.OrdinalIgnoreCase)
        || string.Equals(kind, "page_field", StringComparison.OrdinalIgnoreCase)
        || string.Equals(kind, "page_action", StringComparison.OrdinalIgnoreCase);

    private static readonly JsonSerializerOptions DeclarationJsonOptions = new()
    {
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
    };
}
