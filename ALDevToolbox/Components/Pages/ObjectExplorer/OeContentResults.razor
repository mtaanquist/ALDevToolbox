@inject ALDevToolbox.Services.ObjectExplorer.ObjectExplorerLinks Links
@using ALDevToolbox.Services.ObjectExplorer

@*
    File-content (grep) result table for the Release search page. The empty
    state nudges the user to type a substring; the "Searching..." state shows
    while a query runs; each hit deep-links into the source viewer at the line.
*@

@if (string.IsNullOrWhiteSpace(Search))
{
    <p class="muted">Type a substring to grep across every <code>.al</code> file in this Release.</p>
    return;
}
@if (Results is null)
{
    <p class="muted">Searching...</p>
    return;
}
@if (Results.Count == 0)
{
    <p class="muted">No lines match "@Search". Try a shorter substring.</p>
    return;
}
<p class="muted">Showing @Results.Count.ToString("N0") line(s)@(Results.Count >= 200 ? " (capped)" : "").</p>
<table class="data-table">
    <thead>
        <tr>
            <th scope="col">Module</th>
            <th scope="col">File</th>
            <th scope="col">Line</th>
            <th scope="col">Snippet</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var r in Results)
        {
            <tr>
                <td>@r.ModuleName</td>
                <td><code>@r.FilePath</code></td>
                <td><a href="@Links.SourceFile(r.FileId, r.LineNumber)">@r.LineNumber</a></td>
                <td><code>@r.Snippet</code></td>
            </tr>
        }
    </tbody>
</table>

@code {
    [Parameter] public List<ReleaseContentMatch>? Results { get; set; }
    [Parameter] public string Search { get; set; } = string.Empty;
}
