@page "/object-explorer"
@attribute [Authorize]
@rendermode InteractiveServer
@inject BaseAppService BaseApp
@using ALDevToolbox.Domain.Entities
@using ALDevToolbox.Services

<PageTitle>Object Explorer · AL Dev Toolbox</PageTitle>

<div class="object-explorer">
    <header class="admin-page__header">
        <div>
            <h1>Object Explorer</h1>
            <p class="muted">
                Browse Microsoft's Base Application source for any imported
                Business Central version. Pick a version below to open its
                catalogue of codeunits, tables, pages and the rest.
            </p>
        </div>
    </header>

    @if (_versions is null)
    {
        <p class="muted">Loading…</p>
    }
    else if (_versions.Count == 0)
    {
        <p class="muted">
            No Base Application versions have been imported into this organisation yet.
            An admin can upload a version at <a href="/admin/object-explorer">Admin → Object Explorer</a>.
        </p>
    }
    else
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th scope="col">Version</th>
                    <th scope="col">Cumulative update</th>
                    <th scope="col">Files</th>
                    <th scope="col">Uploaded</th>
                    <th scope="col">Notes</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var v in _versions)
                {
                    <tr>
                        <td>
                            <a href="@($"/object-explorer/{v.Id}")">
                                <strong>@v.Major.@v.Minor</strong>
                            </a>
                        </td>
                        <td>CU @v.CumulativeUpdate</td>
                        <td>@v.FileCount.ToString("N0")</td>
                        <td>@v.UploadedAt.ToString("yyyy-MM-dd")</td>
                        <td class="muted">@(string.IsNullOrWhiteSpace(v.Notes) ? "—" : v.Notes)</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private List<BaseAppVersion>? _versions;

    protected override async Task OnInitializedAsync()
    {
        _versions = await BaseApp.ListVersionsAsync();
    }
}
