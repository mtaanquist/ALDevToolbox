@page "/object-explorer/{VersionId:int}"
@attribute [Authorize]
@rendermode InteractiveServer
@implements IDisposable
@inject BaseAppService BaseApp
@inject NavigationManager Nav
@using ALDevToolbox.Domain.Entities
@using ALDevToolbox.Services

<PageTitle>@PageHeading · AL Dev Toolbox</PageTitle>

<div class="object-explorer__browser">
    <header class="admin-page__header">
        <div>
            <h1>@PageHeading</h1>
            <p class="muted">
                @if (_version is not null)
                {
                    <span>@_version.FileCount.ToString("N0") objects · uploaded @_version.UploadedAt.ToString("yyyy-MM-dd")</span>
                }
            </p>
        </div>
        <a class="btn" href="/object-explorer">
            <Icon Name="arrow-left" Width="16" Height="16" />
            <span>All versions</span>
        </a>
    </header>

    <div class="object-explorer__filters">
        <label class="field">
            <span class="field__label">Search</span>
            <input type="search"
                   class="admin-search-input"
                   placeholder="Object name or ID"
                   value="@_search"
                   @oninput="OnSearchChanged"
                   aria-label="Search by object name or ID" />
        </label>

        <label class="field">
            <span class="field__label">Object type</span>
            <select class="field__input" @bind="_objectType" @bind:after="ReloadAsync">
                <option value="">All</option>
                @if (_objectTypes is not null)
                {
                    @foreach (var type in _objectTypes)
                    {
                        <option value="@type">@type</option>
                    }
                }
            </select>
        </label>

        <label class="field">
            <span class="field__label">Module</span>
            <select class="field__input" @bind="_module" @bind:after="ReloadAsync">
                <option value="">All</option>
                @if (_modules is not null)
                {
                    @foreach (var m in _modules)
                    {
                        <option value="@m">@m</option>
                    }
                }
            </select>
        </label>

        <label class="field">
            <span class="field__label">Namespace</span>
            <select class="field__input" @bind="_namespace" @bind:after="ReloadAsync">
                <option value="">All</option>
                @if (_namespaces is not null)
                {
                    @foreach (var n in _namespaces)
                    {
                        <option value="@n">@n</option>
                    }
                }
            </select>
        </label>
    </div>

    @if (_page is null)
    {
        <p class="muted">Loading…</p>
    }
    else if (_page.Rows.Count == 0)
    {
        @if (HasFilters)
        {
            <p class="muted">No objects match the current filter.</p>
        }
        else
        {
            <p class="muted">This version is empty.</p>
        }
    }
    else
    {
        <p class="muted small">Showing @_page.Rows.Count of @_page.TotalCount object@(_page.TotalCount == 1 ? "" : "s").</p>
        <table class="data-table object-explorer__objects">
            <thead>
                <tr>
                    @SortableHeader(BaseAppFileSort.ObjectType, "Type")
                    @SortableHeader(BaseAppFileSort.ObjectId, "ID", numeric: true)
                    @SortableHeader(BaseAppFileSort.ObjectName, "Name")
                    @SortableHeader(BaseAppFileSort.Module, "Module")
                    @SortableHeader(BaseAppFileSort.Namespace, "Namespace")
                    @SortableHeader(BaseAppFileSort.LineCount, "Lines", numeric: true)
                </tr>
            </thead>
            <tbody>
                @foreach (var row in _page.Rows)
                {
                    <tr @onclick="() => OpenFile(row.Id)" class="object-explorer__row">
                        <td><span class="object-explorer__type">@row.ObjectType</span></td>
                        <td class="num">@(row.ObjectId?.ToString() ?? "")</td>
                        <td><a href="@($"/object-explorer/{VersionId}/files/{row.Id}")">@row.ObjectName</a></td>
                        <td class="muted">@(row.Module ?? "")</td>
                        <td class="muted small">@(row.Namespace ?? "")</td>
                        <td class="num muted">@row.LineCount</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    [Parameter] public int VersionId { get; set; }

    private BaseAppVersion? _version;
    private List<string>? _objectTypes;
    private List<string>? _modules;
    private List<string>? _namespaces;
    private BaseAppFilePage? _page;
    private string _search = string.Empty;
    private string _objectType = string.Empty;
    private string _module = string.Empty;
    private string _namespace = string.Empty;
    private BaseAppFileSort _sortBy = BaseAppFileSort.ObjectType;
    private bool _sortDescending;
    private CancellationTokenSource? _debounce;

    private string PageHeading => _version is null
        ? "Object Explorer"
        : $"Business Central {_version.Major}.{_version.CumulativeUpdate}";

    private bool HasFilters => !string.IsNullOrWhiteSpace(_search)
        || !string.IsNullOrWhiteSpace(_objectType)
        || !string.IsNullOrWhiteSpace(_module)
        || !string.IsNullOrWhiteSpace(_namespace);

    protected override async Task OnInitializedAsync()
    {
        _version = await BaseApp.GetVersionAsync(VersionId);
        if (_version is null)
        {
            Nav.NavigateTo("/object-explorer");
            return;
        }
        _objectTypes = await BaseApp.ListObjectTypesAsync(VersionId);
        _modules = await BaseApp.ListModulesAsync(VersionId);
        _namespaces = await BaseApp.ListNamespacesAsync(VersionId);
        await ReloadAsync();
    }

    private void OnSearchChanged(ChangeEventArgs e)
    {
        _search = e.Value?.ToString() ?? string.Empty;
        DebouncedReload();
    }

    private void DebouncedReload()
    {
        _debounce?.Cancel();
        _debounce?.Dispose();
        _debounce = new CancellationTokenSource();
        var token = _debounce.Token;
        _ = Task.Run(async () =>
        {
            try
            {
                await Task.Delay(250, token);
                if (token.IsCancellationRequested) return;
                await InvokeAsync(ReloadAsync);
            }
            catch (TaskCanceledException) { }
        });
    }

    private async Task ReloadAsync()
    {
        var filter = new BaseAppFileFilter(
            ObjectType: string.IsNullOrWhiteSpace(_objectType) ? null : _objectType,
            Module: string.IsNullOrWhiteSpace(_module) ? null : _module,
            Search: string.IsNullOrWhiteSpace(_search) ? null : _search,
            Namespace: string.IsNullOrWhiteSpace(_namespace) ? null : _namespace,
            SortBy: _sortBy,
            SortDescending: _sortDescending);
        _page = await BaseApp.ListFilesAsync(VersionId, filter, skip: 0, take: 500);
        StateHasChanged();
    }

    private void OpenFile(long fileId)
    {
        Nav.NavigateTo($"/object-explorer/{VersionId}/files/{fileId}");
    }

    private async Task ToggleSort(BaseAppFileSort column)
    {
        if (_sortBy == column)
        {
            _sortDescending = !_sortDescending;
        }
        else
        {
            _sortBy = column;
            _sortDescending = false;
        }
        await ReloadAsync();
    }

    private RenderFragment SortableHeader(BaseAppFileSort column, string label, bool numeric = false) => builder =>
    {
        var classes = numeric ? "num" : null;
        builder.OpenElement(0, "th");
        builder.AddAttribute(1, "scope", "col");
        if (classes is not null) builder.AddAttribute(2, "class", classes);
        builder.OpenElement(3, "button");
        builder.AddAttribute(4, "type", "button");
        builder.AddAttribute(5, "class", "data-table__sort-button" + (_sortBy == column ? " is-active" : ""));
        builder.AddAttribute(6, "onclick", EventCallback.Factory.Create(this, () => ToggleSort(column)));
        builder.AddContent(7, label);
        if (_sortBy == column)
        {
            builder.OpenElement(8, "span");
            builder.AddAttribute(9, "class", "data-table__sort-indicator");
            builder.AddAttribute(10, "aria-hidden", "true");
            builder.AddContent(11, _sortDescending ? " ▼" : " ▲");
            builder.CloseElement();
        }
        builder.CloseElement();
        builder.CloseElement();
    };

    public void Dispose()
    {
        _debounce?.Cancel();
        _debounce?.Dispose();
    }
}
