@page "/object-explorer/release/{ReleaseId:int}"
@attribute [Authorize]
@* prerender:false — under default InteractiveServer the page rendered
   twice (once during the static prerender, once after the circuit took
   over), so the table briefly appeared and then "refreshed". Skipping
   prerender lets the first paint be the loading state and the data
   loads exactly once on the interactive pass. *@
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@implements IAsyncDisposable
@inject ALDevToolbox.Services.ObjectExplorer.ObjectExplorerService ObjectExplorer
@inject ALDevToolbox.Services.ObjectExplorer.ReleaseComparisonService Comparison
@inject ALDevToolbox.Services.ObjectExplorer.ObjectSearchService Search
@inject ALDevToolbox.Services.ObjectExplorer.ObjectExplorerLinks Links
@inject NavigationManager Nav
@inject IJSRuntime JS
@using ALDevToolbox.Services.ObjectExplorer
@using System.Web

@*
    Search-first Release page modelled on the legacy VersionBrowser. Filter
    row across the top (Search in / Search / Object type / Extension /
    Module / Namespace), result table below with Type / Id / Name /
    Extension / Module / Namespace / Lines columns + a Find-references
    icon on every row. Every result links straight to the source viewer.

    The "Extension" filter maps to oe_modules (the .app — e.g. "Base
    Application", "OIOUBL"); "Module" is parsed from the namespace's
    second segment (the first under "Microsoft." or equivalent), matching
    the legacy convention.
*@

<PageTitle>@(_release?.Label ?? "Release") · AL Dev Toolbox</PageTitle>

<div class="object-explorer__browser">
    @if (_release is null)
    {
        <p class="muted">Loading…</p>
    }
    else
    {
        <header class="admin-page__header">
            <div>
                <h1>@_release.Label</h1>
                <p class="muted">
                    @_release.ModuleCount module(s)
                    @if (!string.IsNullOrEmpty(_release.BcVersion))
                    {
                        <span> · BC @_release.BcVersion</span>
                    }
                    <span> · @FormatStatus(_release.Status)</span>
                </p>
            </div>
            <div style="display:flex; gap:.5rem; align-items:center;">
                <AuthorizeView Roles="Admin,Editor">
                    <a class="btn btn--sm" href="/admin/object-explorer/release/@ReleaseId/modules">
                        <Icon Name="package-plus" Width="14" Height="14" />
                        <span>Add modules</span>
                    </a>
                </AuthorizeView>
                <a class="btn btn--sm" href="/object-explorer">
                    <Icon Name="arrow-left" Width="14" Height="14" />
                    <span>Back to releases</span>
                </a>
            </div>
        </header>

        <div class="object-explorer__filters object-explorer__filters--with-scope">
            <label class="field">
                <span class="field__label">Search in</span>
                <select class="field__input" @bind="_scope" @bind:after="OnScopeChanged"
                        aria-label="What to search for"
                        aria-keyshortcuts="Alt+1 Alt+2 Alt+3 Alt+4"
                        title="Alt+1..4 to switch">
                    <option value="@SearchScope.Objects">Objects (Alt+1)</option>
                    <option value="@SearchScope.Procedures">Procedures (Alt+2)</option>
                    <option value="@SearchScope.Content">File content (Alt+3)</option>
                    <option value="@SearchScope.Compare">Compare with release (Alt+4)</option>
                </select>
            </label>

            @if (_scope == SearchScope.Compare)
            {
                <label class="field">
                    <span class="field__label">Other release</span>
                    <select class="field__input" @bind="_compareRight" @bind:after="ReloadAsync"
                            aria-label="Release to compare with">
                        <option value="">Pick a release…</option>
                        @if (_otherReleases is not null)
                        {
                            @foreach (var r in _otherReleases)
                            {
                                <option value="@r.Id">@r.Label</option>
                            }
                        }
                    </select>
                </label>

                <label class="field">
                    <span class="field__label">Direction</span>
                    <select class="field__input" @bind="_compareDirection" @bind:after="ReloadAsync"
                            aria-label="Compare direction">
                        <option value="ab">A → B</option>
                        <option value="ba">B → A</option>
                    </select>
                </label>

                <label class="field">
                    <span class="field__label">Compare by</span>
                    <select class="field__input" @bind="_compareBy" @bind:after="ReloadAsync"
                            aria-label="Comparison granularity">
                        <option value="files">Files (by module / path)</option>
                        <option value="objects">Objects (by type + id)</option>
                    </select>
                </label>
            }
            else
            {
                <label class="field">
                    <span class="field__label">Search</span>
                    @*
                        Uncontrolled input — no `value="@_search"` binding.
                        InteractiveServer renders sent for every keystroke
                        race against the user's typing on a slow circuit
                        and reorder/drop characters; the initial value is
                        seeded via JS once after first render. See
                        wwwroot/uncontrolled-input.js.
                    *@
                    <input type="search"
                           class="admin-search-input"
                           placeholder="@SearchPlaceholder"
                           @ref="_searchInputRef"
                           @oninput="OnSearchChanged"
                           aria-label="@SearchPlaceholder" />
                </label>
            }

            @if (_scope == SearchScope.Objects)
            {
                <div class="field">
                    <span class="field__label">Object type</span>
                    <details class="kind-filter">
                        <summary class="field__input kind-filter__summary">@KindSummary</summary>
                        <div class="kind-filter__panel">
                            <label class="kind-filter__option">
                                <input type="checkbox"
                                       checked="@(_selectedKinds.Count == 0)"
                                       @onchange="OnAllKindsToggled" />
                                <span>All types</span>
                            </label>
                            @if (_kinds is not null)
                            {
                                @foreach (var k in _kinds)
                                {
                                    <label class="kind-filter__option">
                                        <input type="checkbox"
                                               checked="@_selectedKinds.Contains(k)"
                                               @onchange="@(e => OnKindToggled(k, e))" />
                                        <span>@k</span>
                                    </label>
                                }
                            }
                        </div>
                    </details>
                </div>
            }

            @if (_scope != SearchScope.Compare)
            {
                <label class="field">
                    <span class="field__label">Extension</span>
                    <select class="field__input" @bind="_moduleFilter" @bind:after="ReloadAsync">
                        <option value="">All</option>
                        @if (_modules is not null)
                        {
                            @foreach (var m in _modules)
                            {
                                <option value="@m.Id">@m.Name</option>
                            }
                        }
                    </select>
                </label>
            }

            @if (_scope == SearchScope.Objects)
            {
                <label class="field">
                    <span class="field__label">Namespace</span>
                    @*
                        Uncontrolled input — same rationale as the search
                        input above. The datalist still drives the dropdown
                        suggestions; the input's text content is owned by
                        the DOM after the first-render seed.
                    *@
                    <input type="search"
                           class="field__input"
                           list="@($"namespace-list-{ReleaseId}")"
                           placeholder="All"
                           @ref="_namespaceInputRef"
                           @oninput="OnNamespaceChanged"
                           aria-label="Filter by namespace" />
                    @if (_namespaces is not null)
                    {
                        <datalist id="@($"namespace-list-{ReleaseId}")">
                            @foreach (var n in _namespaces)
                            {
                                <option value="@n"></option>
                            }
                        </datalist>
                    }
                </label>
            }

            @if (_scope != SearchScope.Compare)
            {
                <div class="field object-explorer__filters-reset">
                    <button type="button" class="btn btn--sm btn--icon" @onclick="ResetFilters" disabled="@(!HasActiveFilters)"
                            title="Reset filters" aria-label="Reset filters">
                        <Icon Name="rotate-ccw" Width="14" Height="14" />
                    </button>
                </div>
            }
        </div>

        @switch (_scope)
        {
            case SearchScope.Objects:
                @RenderObjectsResults()
                break;
            case SearchScope.Procedures:
                @RenderProceduresResults()
                break;
            case SearchScope.Content:
                @RenderContentResults()
                break;
            case SearchScope.Compare:
                @RenderCompareResults()
                break;
        }
    }
</div>

@code {
    [Parameter] public int ReleaseId { get; set; }

    private enum SearchScope { Objects, Procedures, Content, Compare }

    private ReleaseDetail? _release;
    private List<ReleaseModuleSummary>? _modules;
    private List<string>? _kinds;
    private List<string>? _namespaces;
    private List<ReleaseListItem>? _otherReleases;
    // Other releases reshaped for the per-row "Compare with…" submenu. Built
    // once after _otherReleases loads so each row reuses the same list.
    private IReadOnlyList<RowActionsMenu.CompareTarget> _compareTargets = Array.Empty<RowActionsMenu.CompareTarget>();

    private SearchScope _scope = SearchScope.Objects;
    private string _search = string.Empty;
    private readonly HashSet<string> _selectedKinds = new(StringComparer.OrdinalIgnoreCase);
    private string _moduleFilter = string.Empty;
    private string _namespace = string.Empty;
    private string _compareRight = string.Empty;
    private string _compareDirection = "ab";
    private string _compareBy = "files";

    private List<ReleaseObjectMatch>? _objectResults;
    // Objects-grid sort + lazy-load paging state. A null sort column means the
    // default order: relevance when a search term is present (ObjectsRankedMode),
    // otherwise by Type ascending. Lazy paging only runs when not ranked.
    private ObjectSortColumn? _sortColumn;
    private bool _sortDescending;
    private int _objectsTotal;
    private bool _objectsLoadingMore;
    private const int ObjectsPageSize = 100;
    private List<ReleaseProcedureMatch>? _procedureResults;
    private List<ReleaseContentMatch>? _contentResults;
    private List<ReleaseCompareFileRow>? _compareResults;
    private List<ObjectCompareRow>? _objectCompareResults;

    // Refs to the search-style text inputs whose `value` attribute is
    // intentionally NOT bound from the server side. See the comment on
    // the inputs themselves and wwwroot/uncontrolled-input.js for why.
    private ElementReference _searchInputRef;
    private ElementReference _namespaceInputRef;

    private string SearchPlaceholder => _scope switch
    {
        SearchScope.Procedures => "Procedure name",
        SearchScope.Content    => "Text to grep across source",
        _                      => "Name, ID, 50000..99999, sales*, \"exact\"",
    };

    protected override async Task OnInitializedAsync()
    {
        _release = await ObjectExplorer.GetReleaseAsync(ReleaseId);
        if (_release is null) return;

        _modules = await ObjectExplorer.ListModuleSummariesAsync(ReleaseId);
        _kinds = await Search.ListObjectKindsInReleaseAsync(ReleaseId);
        _namespaces = await Search.ListNamespacesInReleaseAsync(ReleaseId);
        var allReleases = await ObjectExplorer.ListReleasesAsync();
        _otherReleases = allReleases
            .Where(r => r.Id != ReleaseId && r.Status == "ready" && r.DeletedAt is null)
            .ToList();
        _compareTargets = _otherReleases
            .Select(r => new RowActionsMenu.CompareTarget(r.Id, r.Label))
            .ToList();

        // Seed filter state from the URL query string so back-navigation
        // from a result detail page restores what the user was searching.
        HydrateFiltersFromUrl();

        await ReloadAsync();
    }

    /// <summary>
    /// Reads <c>scope</c>, <c>search</c>, <c>kind</c>, <c>module</c>,
    /// <c>segment</c>, and <c>namespace</c> from <see cref="Nav.Uri"/>
    /// and hydrates the corresponding filter fields. Unknown or invalid
    /// values fall back to defaults so a malformed URL just clears the
    /// filter rather than crashing the page.
    /// </summary>
    private void HydrateFiltersFromUrl()
    {
        var query = HttpUtility.ParseQueryString(new Uri(Nav.Uri).Query);
        var scopeRaw = query["scope"];
        if (!string.IsNullOrEmpty(scopeRaw)
            && Enum.TryParse<SearchScope>(scopeRaw, ignoreCase: true, out var parsedScope))
        {
            _scope = parsedScope;
        }
        _search = query["search"] ?? string.Empty;
        _selectedKinds.Clear();
        foreach (var k in (query["kind"] ?? string.Empty).Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
        {
            _selectedKinds.Add(k);
        }
        _moduleFilter = query["module"] ?? string.Empty;
        _namespace = query["namespace"] ?? string.Empty;
        _compareRight = query["right"] ?? string.Empty;
        var dir = query["dir"];
        _compareDirection = dir == "ba" ? "ba" : "ab";
        _compareBy = query["by"] == "objects" ? "objects" : "files";
    }

    /// <summary>
    /// Mirrors the current filter state into the URL bar via
    /// <c>history.replaceState</c>, so browser back-navigation from a
    /// result-detail page lands on the same search. Bypasses
    /// <c>Nav.NavigateTo</c> so the component doesn't re-initialise on
    /// every keystroke; the URL is the only thing that changes.
    /// </summary>
    private async Task UpdateUrlAsync()
    {
        // JS interop is forbidden during Blazor's static prerender
        // phase — the runtime throws InvalidOperationException because
        // the circuit isn't connected yet. The initial ReloadAsync
        // call from OnInitializedAsync runs during prerender, so skip
        // the URL sync there: the URL the user arrived on already
        // matches the filter state we just hydrated from it, so
        // there's nothing to sync. Subsequent reloads (search input,
        // dropdown changes) fire after first render when interop is
        // safe.
        if (!_isInteractive) return;

        var parts = new List<string>(8);
        if (_scope != SearchScope.Objects) parts.Add("scope=" + Uri.EscapeDataString(_scope.ToString()));
        if (!string.IsNullOrWhiteSpace(_search)) parts.Add("search=" + Uri.EscapeDataString(_search));
        if (_selectedKinds.Count > 0) parts.Add("kind=" + Uri.EscapeDataString(string.Join(",", _selectedKinds)));
        if (!string.IsNullOrWhiteSpace(_moduleFilter)) parts.Add("module=" + Uri.EscapeDataString(_moduleFilter));
        if (!string.IsNullOrWhiteSpace(_namespace)) parts.Add("namespace=" + Uri.EscapeDataString(_namespace));
        if (_scope == SearchScope.Compare && !string.IsNullOrWhiteSpace(_compareRight)) parts.Add("right=" + Uri.EscapeDataString(_compareRight));
        if (_scope == SearchScope.Compare && _compareDirection == "ba") parts.Add("dir=ba");
        if (_scope == SearchScope.Compare && _compareBy == "objects") parts.Add("by=objects");

        var url = $"/object-explorer/release/{ReleaseId}";
        if (parts.Count > 0) url += "?" + string.Join("&", parts);

        await JS.InvokeVoidAsync("history.replaceState", null, string.Empty, url);
    }

    private bool _isInteractive;
    private IJSObjectReference? _keybindModule;
    private DotNetObjectReference<OeReleaseDetail>? _selfRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isInteractive = true;

            // PageTitle alone doesn't update the head on this page because we
            // render with `prerender: false` — the initial response has no
            // <title>, and the interactive PageTitle update doesn't reach the
            // static-SSR HeadOutlet. Set document.title explicitly via JS now
            // that the circuit is connected and the release has loaded.
            if (_release is not null)
            {
                await JS.InvokeVoidAsync("aldt.setTitle", $"{_release.Label} · AL Dev Toolbox");
            }

            // Seed the uncontrolled text inputs with whatever filter values
            // we hydrated from the URL. After this single call the DOM owns
            // the input value so fast typing can never race a render diff.
            if (!string.IsNullOrEmpty(_search))
            {
                await JS.InvokeVoidAsync("aldt.seedInput", _searchInputRef, _search);
            }
            if (!string.IsNullOrEmpty(_namespace))
            {
                await JS.InvokeVoidAsync("aldt.seedInput", _namespaceInputRef, _namespace);
            }

            // Park focus in the search box on first render so a keyboard-first
            // user can land on the page and start typing. Compare mode doesn't
            // render a search input, so skip it there.
            if (_scope != SearchScope.Compare)
            {
                try { await _searchInputRef.FocusAsync(); }
                catch { /* input was removed before focus landed */ }
            }

            // Wire the document-level Alt+1..Alt+4 scope keybinds + F3 search focus.
            _keybindModule = await JS.InvokeAsync<IJSObjectReference>(
                "import", "./Components/Pages/ObjectExplorer/OeReleaseDetail.razor.js");
            _selfRef = DotNetObjectReference.Create(this);
            await _keybindModule.InvokeVoidAsync("init", _selfRef);
        }

        // Re-point the infinite-scroll observer at the current sentinel after
        // every render — the sentinel node is recreated when the result set or
        // scope changes, and watchSentinel is a no-op when it isn't present.
        if (_keybindModule is not null && _scope == SearchScope.Objects)
        {
            try { await _keybindModule.InvokeVoidAsync("watchSentinel"); }
            catch { /* circuit tearing down */ }
        }
    }

    /// <summary>
    /// Entry point invoked from <c>OeReleaseDetail.razor.js</c> when the
    /// user presses <kbd>Alt+1</kbd>..<kbd>Alt+4</kbd> anywhere on the
    /// page to flip the "Search in" scope.
    /// </summary>
    [JSInvokable]
    public async Task SetScopeFromKeybind(string scopeName)
    {
        if (!Enum.TryParse<SearchScope>(scopeName, ignoreCase: false, out var scope)) return;
        if (_scope == scope) return;
        _scope = scope;
        await OnScopeChanged();
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        _searchDebounceCts?.Cancel();
        _searchDebounceCts?.Dispose();
        if (_keybindModule is not null)
        {
            try { await _keybindModule.InvokeVoidAsync("detach"); } catch { }
            try { await _keybindModule.DisposeAsync(); } catch { }
        }
        _selfRef?.Dispose();
    }

    private async Task OnScopeChanged()
    {
        // Crossing search-mode boundaries — the kind dropdown's options
        // differ between Objects and Procedures, and Content has neither.
        _selectedKinds.Clear();
        _sortColumn = null;
        _sortDescending = false;
        await ReloadAsync();
    }

    /// <summary>
    /// Invoked from a row's "Compare with…" submenu. Flips the page into the
    /// Compare scope against the picked release, comparing by objects (the most
    /// useful granularity when you started from a single object row), and
    /// reloads — same state the Compare dropdowns would set, so URL sync and
    /// the existing compare query path work unchanged.
    /// </summary>
    private async Task SeedCompareWith(int releaseId)
    {
        _compareRight = releaseId.ToString();
        _compareBy = "objects";
        _scope = SearchScope.Compare;
        await OnScopeChanged();
        StateHasChanged();
    }

    /// <summary>Namespace up to and including the last dot (the muted prefix).</summary>
    private static string NamespaceHead(string ns)
    {
        var i = ns.LastIndexOf('.');
        return i < 0 ? string.Empty : ns[..(i + 1)];
    }

    /// <summary>Namespace after the last dot (the emphasised trailing segment).</summary>
    private static string NamespaceTail(string ns)
    {
        var i = ns.LastIndexOf('.');
        return i < 0 ? ns : ns[(i + 1)..];
    }

    // Debounce window for text inputs. Without it, every keystroke triggered
    // an immediate ReloadAsync — the queries pile up and the scoped EF
    // context can't be entered concurrently, so a fast typer hits errors
    // when one search starts before the previous finishes. 250ms is short
    // enough to feel live and long enough to coalesce a burst of keystrokes
    // into a single query. _reloadGate serialises the actual reload as a
    // belt-and-braces guard for the case where a query takes longer than
    // the debounce window.
    private static readonly TimeSpan SearchDebounce = TimeSpan.FromMilliseconds(250);
    private CancellationTokenSource? _searchDebounceCts;
    private readonly SemaphoreSlim _reloadGate = new(1, 1);

    private async Task OnSearchChanged(ChangeEventArgs args)
    {
        _search = args.Value?.ToString() ?? string.Empty;
        await DebounceReloadAsync();
    }

    private async Task OnNamespaceChanged(ChangeEventArgs args)
    {
        _namespace = args.Value?.ToString() ?? string.Empty;
        await DebounceReloadAsync();
    }

    private async Task DebounceReloadAsync()
    {
        _searchDebounceCts?.Cancel();
        _searchDebounceCts?.Dispose();
        var cts = new CancellationTokenSource();
        _searchDebounceCts = cts;
        try
        {
            await Task.Delay(SearchDebounce, cts.Token);
        }
        catch (TaskCanceledException)
        {
            return;
        }
        if (cts.IsCancellationRequested) return;
        await ReloadAsync();
        StateHasChanged();
    }

    private async Task ReloadAsync()
    {
        // Serialise reloads so a slow query and a fast typer never share
        // the same scoped DbContext at the same time.
        await _reloadGate.WaitAsync();
        try
        {
        // Keep the URL in step with the filter state on every reload —
        // ensures a result-detail click followed by browser-back lands
        // back on the same search results without re-typing.
        await UpdateUrlAsync();

        long? moduleId = long.TryParse(_moduleFilter, out var m) ? m : null;
        var trimmedSearch = string.IsNullOrWhiteSpace(_search) ? null : _search;
        var nsPrefix = string.IsNullOrWhiteSpace(_namespace) ? null : _namespace;

        switch (_scope)
        {
            case SearchScope.Objects:
                var objectFilter = new ObjectListFilter(
                    Kinds: _selectedKinds.Count == 0 ? null : _selectedKinds.ToList(),
                    Search: trimmedSearch);
                if (ObjectsRankedMode)
                {
                    // Relevance-ranked, capped — no lazy paging needed because a
                    // search term keeps the match set small.
                    _objectResults = await Search.SearchObjectsInReleaseAsync(
                        ReleaseId, objectFilter, moduleId: moduleId, namespacePrefix: nsPrefix, take: 500);
                    _objectsTotal = _objectResults.Count;
                }
                else
                {
                    // Column-sorted (or default Type order when browsing) — first
                    // page only; the scroll sentinel pulls the rest.
                    var (col, desc) = EffectiveSort();
                    var page = await Search.SearchObjectsPageInReleaseAsync(
                        ReleaseId, objectFilter, moduleId, nsPrefix, col, desc, skip: 0, take: ObjectsPageSize);
                    _objectResults = page.Rows.ToList();
                    _objectsTotal = page.TotalCount;
                }
                break;

            case SearchScope.Procedures:
                _procedureResults = await Search.SearchProceduresInReleaseAsync(
                    ReleaseId, trimmedSearch, moduleId, take: 500);
                break;

            case SearchScope.Content:
                if (string.IsNullOrEmpty(trimmedSearch))
                {
                    _contentResults = new();
                }
                else
                {
                    // Clear the previous results first so the panel shows its
                    // "Searching…" state (the _contentResults is null branch)
                    // while this query runs, rather than leaving a stale
                    // "No lines match…" message up until the query returns.
                    _contentResults = null;
                    StateHasChanged();
                    _contentResults = await Search.SearchContentInReleaseAsync(
                        ReleaseId, trimmedSearch, moduleId, take: 200);
                }
                break;

            case SearchScope.Compare:
                if (!int.TryParse(_compareRight, out var otherId) || otherId == ReleaseId)
                {
                    _compareResults = null;
                    _objectCompareResults = null;
                }
                else
                {
                    var (leftId, rightId) = _compareDirection == "ba"
                        ? (otherId, ReleaseId)
                        : (ReleaseId, otherId);
                    if (_compareBy == "objects")
                    {
                        _objectCompareResults = await Comparison.CompareReleaseObjectsAsync(leftId, rightId);
                        _compareResults = null;
                    }
                    else
                    {
                        _compareResults = await Comparison.CompareReleaseFilesFlatAsync(leftId, rightId);
                        _objectCompareResults = null;
                    }
                }
                break;
        }
        }
        finally
        {
            _reloadGate.Release();
        }
    }

    // ── Objects grid: sort, multi-kind, lazy paging ─────────────────────

    /// <summary>
    /// True when the objects list should use relevance ranking: a search term
    /// is present and the user hasn't picked an explicit sort column. In that
    /// case the (small) match set is fetched capped and ranked, so there's no
    /// lazy paging. Otherwise we page a column-sorted query as the user scrolls.
    /// </summary>
    private bool ObjectsRankedMode => _sortColumn is null && !string.IsNullOrWhiteSpace(_search);

    /// <summary>The sort to apply when not ranking — the picked column, or Type ascending by default.</summary>
    private (ObjectSortColumn Column, bool Descending) EffectiveSort()
        => _sortColumn is { } c ? (c, _sortDescending) : (ObjectSortColumn.Default, false);

    private string KindSummary => _selectedKinds.Count switch
    {
        0 => "All types",
        1 => _selectedKinds.First(),
        var n => $"{n} types",
    };

    /// <summary>True when any object filter or sort is in effect — gates the Reset button.</summary>
    private bool HasActiveFilters =>
        !string.IsNullOrWhiteSpace(_search)
        || _selectedKinds.Count > 0
        || !string.IsNullOrWhiteSpace(_moduleFilter)
        || !string.IsNullOrWhiteSpace(_namespace)
        || _sortColumn is not null;

    /// <summary>Clears every filter + sort back to the default view, including the uncontrolled inputs.</summary>
    private async Task ResetFilters()
    {
        _search = string.Empty;
        _selectedKinds.Clear();
        _moduleFilter = string.Empty;
        _namespace = string.Empty;
        _sortColumn = null;
        _sortDescending = false;
        if (_isInteractive)
        {
            // Both are uncontrolled inputs; clear their DOM values. The search
            // box renders in every non-Compare scope; the namespace box only in
            // Objects, so only seed it there.
            await JS.InvokeVoidAsync("aldt.seedInput", _searchInputRef, string.Empty);
            if (_scope == SearchScope.Objects)
            {
                await JS.InvokeVoidAsync("aldt.seedInput", _namespaceInputRef, string.Empty);
            }
        }
        await ReloadAsync();
        StateHasChanged();
    }

    private RenderFragment SortHeader(string label, ObjectSortColumn column) => __builder =>
    {
        var active = _sortColumn == column;
        <button type="button"
                class="data-table__sort-button @(active ? "is-active" : "")"
                @onclick="() => SortBy(column)">
            @label
            @if (active)
            {
                <span class="data-table__sort-indicator">@(_sortDescending ? "▼" : "▲")</span>
            }
        </button>
    };

    /// <summary>
    /// Header click: first click sorts ascending, second flips to descending,
    /// third clears the sort (back to relevance/default), BC-grid style.
    /// </summary>
    private async Task SortBy(ObjectSortColumn column)
    {
        if (_sortColumn != column)
        {
            _sortColumn = column;
            _sortDescending = false;
        }
        else if (!_sortDescending)
        {
            _sortDescending = true;
        }
        else
        {
            _sortColumn = null;
            _sortDescending = false;
        }
        await ReloadAsync();
        StateHasChanged();
    }

    private async Task OnKindToggled(string kind, ChangeEventArgs e)
    {
        if (e.Value is true) _selectedKinds.Add(kind);
        else _selectedKinds.Remove(kind);
        await ReloadAsync();
        StateHasChanged();
    }

    /// <summary>
    /// The "All types" affordance. An empty selection already means "all", so
    /// this just clears any per-kind picks. It auto-checks again (the bound
    /// <c>checked</c> tracks <c>Count == 0</c>) whenever the user clears every
    /// specific kind. No-op when nothing is selected. See issue #273.
    /// </summary>
    private async Task OnAllKindsToggled()
    {
        if (_selectedKinds.Count == 0) return;
        _selectedKinds.Clear();
        await ReloadAsync();
        StateHasChanged();
    }

    /// <summary>
    /// Invoked from JS when the scroll sentinel enters the viewport — appends
    /// the next page of objects. No-op while ranking, already loading, or once
    /// every row is in hand. Guarded by the reload gate so it never shares the
    /// scoped DbContext with an in-flight reload.
    /// </summary>
    [JSInvokable]
    public async Task LoadMoreObjects()
    {
        if (_scope != SearchScope.Objects || ObjectsRankedMode) return;
        if (_objectsLoadingMore || _objectResults is null || _objectResults.Count >= _objectsTotal) return;

        _objectsLoadingMore = true;
        try
        {
            await _reloadGate.WaitAsync();
            try
            {
                // Re-check under the gate: a reload (new search/filter) may have
                // run while we waited, flipping us into ranked mode or replacing
                // the result set.
                if (_scope != SearchScope.Objects || ObjectsRankedMode
                    || _objectResults is null || _objectResults.Count >= _objectsTotal)
                {
                    return;
                }

                long? moduleId = long.TryParse(_moduleFilter, out var m) ? m : null;
                var trimmedSearch = string.IsNullOrWhiteSpace(_search) ? null : _search;
                var nsPrefix = string.IsNullOrWhiteSpace(_namespace) ? null : _namespace;
                var filter = new ObjectListFilter(
                    Kinds: _selectedKinds.Count == 0 ? null : _selectedKinds.ToList(),
                    Search: trimmedSearch);
                var (col, desc) = EffectiveSort();
                var page = await Search.SearchObjectsPageInReleaseAsync(
                    ReleaseId, filter, moduleId, nsPrefix, col, desc,
                    skip: _objectResults.Count, take: ObjectsPageSize);
                _objectResults.AddRange(page.Rows);
                _objectsTotal = page.TotalCount;
            }
            finally
            {
                _reloadGate.Release();
            }
        }
        finally
        {
            _objectsLoadingMore = false;
        }
        StateHasChanged();
    }

    private static string FormatStatus(string s) => s switch
    {
        "ready"     => "Ready",
        "ingesting" => "Ingesting…",
        "failed"    => "Failed",
        _           => s,
    };

    // ── Result renderers ───────────────────────────────────────────────

    private RenderFragment RenderObjectsResults() => __builder =>
    {
        var hasFilters = !string.IsNullOrWhiteSpace(_search)
            || _selectedKinds.Count > 0
            || !string.IsNullOrWhiteSpace(_moduleFilter)
            || !string.IsNullOrWhiteSpace(_namespace);

        if (_objectResults is null)
        {
            <p class="muted">Loading objects…</p>
            return;
        }
        if (_objectResults.Count == 0)
        {
            <p class="muted">@(hasFilters ? "No objects match the current filter." : "No objects in this release yet.")</p>
            return;
        }
        <p class="muted">
            @if (ObjectsRankedMode)
            {
                <text>Showing @_objectResults.Count.ToString("N0") object(s)@(_objectResults.Count >= 500 ? " (capped — narrow the search to see the rest)" : "").</text>
            }
            else
            {
                <text>Showing @_objectResults.Count.ToString("N0") of @_objectsTotal.ToString("N0") object(s).</text>
            }
        </p>
        <table class="data-table data-table--objects">
            <colgroup>
                <col class="col-type" />
                <col class="col-id" />
                <col />
                <col class="col-extension" />
                <col />
                <col class="col-lines" />
                <col class="col-actions" />
            </colgroup>
            <thead>
                <tr>
                    <th scope="col">@SortHeader("Type", ObjectSortColumn.Type)</th>
                    <th scope="col">@SortHeader("ID", ObjectSortColumn.Id)</th>
                    <th scope="col">@SortHeader("Name", ObjectSortColumn.Name)</th>
                    <th scope="col">@SortHeader("Extension", ObjectSortColumn.Module)</th>
                    <th scope="col">@SortHeader("Namespace", ObjectSortColumn.Namespace)</th>
                    <th scope="col">@SortHeader("Lines", ObjectSortColumn.Lines)</th>
                    <th scope="col" class="oe-cell-actions"><span class="visually-hidden">Actions</span></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in _objectResults)
                {
                    <tr>
                        <td><span class="otype @r.Kind.ToLowerInvariant()">@r.Kind</span></td>
                        <td><span class="oid">@(r.ObjectId?.ToString() ?? "—")</span></td>
                        <td>
                            @if (r.SourceFileId is { } fid)
                            {
                                <a class="oname" href="@Links.SourceFile(fid, r.LineNumber)">@r.Name</a>
                            }
                            else
                            {
                                <span title="Source not shipped with this module" class="muted">@r.Name</span>
                            }
                            @if (!string.IsNullOrEmpty(r.VersionList))
                            {
                                <div class="oe-version-list muted" title="Version List">@r.VersionList</div>
                            }
                        </td>
                        <td><span class="oext">@r.ModuleName</span></td>
                        <td>
                            @if (string.IsNullOrEmpty(r.Namespace))
                            {
                                <span class="muted">—</span>
                            }
                            else
                            {
                                <span class="ons">@NamespaceHead(r.Namespace)<span class="ns-tail">@NamespaceTail(r.Namespace)</span></span>
                            }
                        </td>
                        <td>@(r.SourceFileId is null ? "—" : r.FileLineCount.ToString("N0"))</td>
                        <td class="oe-cell-actions">
                            @if (r.SourceFileId is { } afid)
                            {
                                <RowActionsMenu ViewHref="@Links.SourceFile(afid, r.LineNumber)"
                                                DownloadHref="@($"/api/object-explorer/files/{afid}/download")"
                                                CompareTargets="_compareTargets"
                                                OnCompare="SeedCompareWith" />
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (!ObjectsRankedMode && _objectResults.Count < _objectsTotal)
        {
            <div id="oe-objects-sentinel" class="oe-scroll-sentinel">
                <span class="muted">Loading more…</span>
            </div>
        }
    };

    private RenderFragment RenderProceduresResults() => __builder =>
    {
        if (_procedureResults is null)
        {
            <p class="muted">Loading procedures…</p>
            return;
        }
        if (_procedureResults.Count == 0)
        {
            <p class="muted">No procedures match. Try a different name.</p>
            return;
        }
        <p class="muted">Showing @_procedureResults.Count.ToString("N0") procedure(s).</p>
        <table class="data-table">
            <thead>
                <tr>
                    <th scope="col">Module</th>
                    <th scope="col">Object</th>
                    <th scope="col">Kind</th>
                    <th scope="col">Procedure</th>
                    <th scope="col">Source</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in _procedureResults)
                {
                    <tr>
                        <td>@r.ModuleName</td>
                        <td><a href="@($"/object-explorer/object/{r.ObjectId}")">@r.ObjectKind @r.ObjectName</a></td>
                        <td>@r.ProcedureKind.Replace("_", " ")</td>
                        <td>
                            <strong>@r.Name</strong>
                            @if (!string.IsNullOrEmpty(r.Signature))
                            {
                                <span class="muted">@r.Signature</span>
                            }
                            @if (!string.IsNullOrEmpty(r.ReturnType))
                            {
                                <span class="muted"> : @r.ReturnType</span>
                            }
                        </td>
                        <td>
                            @if (r.SourceFileId is { } fid)
                            {
                                <a href="@Links.SourceFile(fid, r.ObjectLineNumber)">View source</a>
                            }
                            else
                            {
                                <span class="muted">—</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    };

    private RenderFragment RenderCompareResults() => __builder =>
    {
        if (string.IsNullOrWhiteSpace(_compareRight))
        {
            <p class="muted">Pick a release to compare against.</p>
            return;
        }
        if (_compareBy == "objects")
        {
            @RenderObjectCompareResults()
            return;
        }
        if (_compareResults is null)
        {
            <p class="muted">Comparing…</p>
            return;
        }
        if (_compareResults.Count == 0)
        {
            <p class="muted">No file differences between these two releases.</p>
            return;
        }
        <p class="muted">Showing @_compareResults.Count.ToString("N0") file diff(s).</p>
        <table class="data-table">
            <thead>
                <tr>
                    <th scope="col">Module</th>
                    <th scope="col">File</th>
                    <th scope="col">Status</th>
                    <th scope="col"><span class="visually-hidden">Actions</span></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in _compareResults)
                {
                    <tr>
                        <td>@r.ModuleName</td>
                        <td><code>@r.Path</code></td>
                        <td><span class="badge @CompareBadgeClass(r.Status)">@r.Status</span></td>
                        <td class="row-actions">
                            @if (r.Status == "modified" && r.LeftFileId is { } lf && r.RightFileId is { } rf)
                            {
                                <a class="btn btn--sm" href="@Links.CompareFile(lf, rf)">Open diff</a>
                            }
                            else if (r.Status == "added" && r.RightFileId is { } addedId)
                            {
                                <a class="btn btn--sm" href="@Links.SourceFile(addedId)">Open</a>
                            }
                            else if (r.Status == "removed" && r.LeftFileId is { } removedId)
                            {
                                <a class="btn btn--sm" href="@Links.SourceFile(removedId)">Open</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    };

    private RenderFragment RenderObjectCompareResults() => __builder =>
    {
        if (_objectCompareResults is null)
        {
            <p class="muted">Comparing…</p>
            return;
        }
        // Unchanged objects are the bulk and rarely interesting — hide them and
        // surface the changes (matches the C/AL Base-vs-Customer use case).
        var changed = _objectCompareResults.Where(r => r.Status != "unchanged").ToList();
        if (changed.Count == 0)
        {
            <p class="muted">No object differences between these two releases (@_objectCompareResults.Count.ToString("N0") objects, all unchanged).</p>
            return;
        }
        <p class="muted">Showing @changed.Count.ToString("N0") changed object(s) of @_objectCompareResults.Count.ToString("N0").</p>
        <table class="data-table">
            <thead>
                <tr>
                    <th scope="col">Type</th>
                    <th scope="col">ID</th>
                    <th scope="col">Name</th>
                    <th scope="col">Status</th>
                    <th scope="col"><span class="visually-hidden">Actions</span></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in changed)
                {
                    <tr>
                        <td>@r.Kind</td>
                        <td>@(r.ObjectId?.ToString() ?? "—")</td>
                        <td>@r.Name</td>
                        <td><span class="badge @CompareBadgeClass(r.Status)">@r.Status</span></td>
                        <td class="row-actions">
                            @if (r.Status == "modified" && r.LeftFileId is { } lf && r.RightFileId is { } rf)
                            {
                                <a class="btn btn--sm" href="@Links.CompareFile(lf, rf)">Open diff</a>
                            }
                            else if (r.Status == "added" && r.RightFileId is { } addedId)
                            {
                                <a class="btn btn--sm" href="@Links.SourceFile(addedId)">Open</a>
                            }
                            else if (r.Status == "removed" && r.LeftFileId is { } removedId)
                            {
                                <a class="btn btn--sm" href="@Links.SourceFile(removedId)">Open</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    };

    private static string CompareBadgeClass(string status) => status switch
    {
        "added" => "badge--success",
        "removed" => "badge--danger",
        "modified" => "badge--warning",
        _ => "muted",
    };

    private RenderFragment RenderContentResults() => __builder =>
    {
        if (string.IsNullOrWhiteSpace(_search))
        {
            <p class="muted">Type a substring to grep across every <code>.al</code> file in this Release.</p>
            return;
        }
        if (_contentResults is null)
        {
            <p class="muted">Searching…</p>
            return;
        }
        if (_contentResults.Count == 0)
        {
            <p class="muted">No lines match "@_search". Try a shorter substring.</p>
            return;
        }
        <p class="muted">Showing @_contentResults.Count.ToString("N0") line(s)@(_contentResults.Count >= 200 ? " (capped)" : "").</p>
        <table class="data-table">
            <thead>
                <tr>
                    <th scope="col">Module</th>
                    <th scope="col">File</th>
                    <th scope="col">Line</th>
                    <th scope="col">Snippet</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in _contentResults)
                {
                    <tr>
                        <td>@r.ModuleName</td>
                        <td><code>@r.FilePath</code></td>
                        <td><a href="@Links.SourceFile(r.FileId, r.LineNumber)">@r.LineNumber</a></td>
                        <td><code>@r.Snippet</code></td>
                    </tr>
                }
            </tbody>
        </table>
    };
}
