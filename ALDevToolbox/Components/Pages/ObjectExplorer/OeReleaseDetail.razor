@page "/object-explorer/release/{ReleaseId:int}"
@attribute [Authorize]
@rendermode InteractiveServer
@inject ALDevToolbox.Services.ObjectExplorer.ObjectExplorerService ObjectExplorer
@using ALDevToolbox.Services.ObjectExplorer

<PageTitle>@(_release?.Label ?? "Release") · Releases · AL Dev Toolbox</PageTitle>

<div class="object-explorer">
    @if (_release is null)
    {
        <p class="muted">Loading…</p>
    }
    else
    {
        <header class="admin-page__header">
            <div>
                <p class="muted">
                    <a href="/object-explorer">Releases</a>
                    @if (_release.ParentReleaseId is { } pid)
                    {
                        <span> / <a href="@($"/object-explorer/release/{pid}")">@_release.ParentLabel</a></span>
                    }
                </p>
                <h1>@_release.Label</h1>
                <p class="muted">
                    @FormatKind(_release.Kind) · @_release.ModuleCount module(s)
                    @if (!string.IsNullOrEmpty(_release.BcVersion))
                    {
                        <span> · BC @_release.BcVersion</span>
                    }
                    <span> · @FormatStatus(_release.Status)</span>
                </p>
            </div>
            <a class="btn" href="@($"/object-explorer/release/{ReleaseId}/search")">
                <Icon Name="search" Width="16" Height="16" />
                <span>Search objects</span>
            </a>
        </header>

        <section class="form-section">
            <label class="field field--inline">
                <span class="field__label">Search</span>
                <input type="search"
                       placeholder="Filter by name or publisher"
                       value="@_search"
                       @oninput="OnSearch"
                       class="field__input" />
            </label>
        </section>

        @if (_modules is null)
        {
            <p class="muted">Loading modules…</p>
        }
        else if (_modules.Count == 0)
        {
            <p class="muted">No modules match the current filter.</p>
        }
        else
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th scope="col">Name</th>
                        <th scope="col">Publisher</th>
                        <th scope="col">Version</th>
                        <th scope="col">Objects</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in _modules)
                    {
                        <tr>
                            <td>
                                <a href="@($"/object-explorer/module/{m.Id}")"><strong>@m.Name</strong></a>
                                @if (m.IsTest)
                                {
                                    <span class="badge muted">Test</span>
                                }
                                @if (m.IsInternal)
                                {
                                    <span class="badge muted">Internal</span>
                                }
                            </td>
                            <td>@m.Publisher</td>
                            <td>@m.Version</td>
                            <td>@m.ObjectCount.ToString("N0")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    }
</div>

@code {
    [Parameter] public int ReleaseId { get; set; }

    private ReleaseDetail? _release;
    private List<ModuleListItem>? _modules;
    private string _search = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        _release = await ObjectExplorer.GetReleaseAsync(ReleaseId);
        if (_release is not null)
        {
            _modules = await ObjectExplorer.ListModulesAsync(ReleaseId, new ModuleListFilter());
        }
    }

    private async Task OnSearch(ChangeEventArgs args)
    {
        _search = args.Value?.ToString() ?? string.Empty;
        _modules = await ObjectExplorer.ListModulesAsync(
            ReleaseId, new ModuleListFilter(Search: string.IsNullOrWhiteSpace(_search) ? null : _search));
    }

    private static string FormatKind(string kind) => kind switch
    {
        "first_party" => "First-party",
        "third_party" => "Third-party",
        "customer"    => "Customer",
        _             => kind,
    };

    private static string FormatStatus(string s) => s switch
    {
        "ready"     => "Ready",
        "ingesting" => "Ingesting…",
        "failed"    => "Failed",
        _           => s,
    };
}
