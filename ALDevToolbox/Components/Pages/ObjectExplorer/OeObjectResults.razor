@inject ALDevToolbox.Services.ObjectExplorer.ObjectExplorerLinks Links
@using ALDevToolbox.Services.ObjectExplorer

@*
    Objects-grid result table for the Release search page. Renders the
    loading / empty / populated states, the sortable column headers, and the
    lazy-load scroll sentinel. Sort state and the SortBy callback are owned by
    the parent (OeReleaseDetail) so a header click re-runs its query.
*@

@if (Results is null)
{
    <p class="muted">Loading objects...</p>
    return;
}
@if (Results.Count == 0)
{
    <p class="muted">@(HasFilters ? "No objects match the current filter." : "No objects in this release yet.")</p>
    return;
}
<p class="muted">
    @if (RankedMode)
    {
        <text>@Results.Count.ToString("N0") match@(Results.Count == 1 ? "" : "es")@(Results.Count >= 500 ? " (capped at 500 - narrow the search to see more)" : "").</text>
    }
    else
    {
        <text>Showing @Results.Count.ToString("N0") of @Total.ToString("N0") object(s).</text>
    }
</p>
<table class="data-table data-table--objects">
    <colgroup>
        <col class="col-type" />
        <col class="col-id" />
        <col />
        <col class="col-extension" />
        <col />
        <col class="col-actions" />
    </colgroup>
    <thead>
        <tr>
            <th scope="col">@SortHeader("Type", ObjectSortColumn.Type)</th>
            <th scope="col">@SortHeader("ID", ObjectSortColumn.Id)</th>
            <th scope="col">@SortHeader("Name", ObjectSortColumn.Name)</th>
            <th scope="col">@SortHeader("Extension", ObjectSortColumn.Module)</th>
            <th scope="col">@SortHeader("Namespace", ObjectSortColumn.Namespace)</th>
            <th scope="col" class="oe-cell-actions"><span class="visually-hidden">Actions</span></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var r in Rows)
        {
            <tr>
                <td><span class="otype @r.Kind.ToLowerInvariant()">@r.Kind</span></td>
                <td><span class="oid">@(r.ObjectId?.ToString() ?? "—")</span></td>
                <td>
                    @if (r.SourceFileId is { } fid)
                    {
                        <a class="oname" href="@Links.SourceFile(fid, r.LineNumber, ViewReleaseSeed)">@r.Name</a>
                    }
                    else
                    {
                        <span title="Source not shipped with this module" class="muted">@r.Name</span>
                    }
                    @if (!string.IsNullOrEmpty(r.VersionList))
                    {
                        <div class="oe-version-list muted" title="Version List">@r.VersionList</div>
                    }
                </td>
                <td><span class="oext">@r.ModuleName</span></td>
                <td>
                    @if (string.IsNullOrEmpty(r.Namespace))
                    {
                        <span class="muted">—</span>
                    }
                    else
                    {
                        <span class="ons">@NamespaceHead(r.Namespace)<span class="ns-tail">@NamespaceTail(r.Namespace)</span></span>
                    }
                </td>
                <td class="oe-cell-actions">
                    @if (r.SourceFileId is { } afid)
                    {
                        <RowActionsMenu ViewHref="@Links.SourceFile(afid, r.LineNumber, ViewReleaseSeed)"
                                        DownloadHref="@($"/api/object-explorer/files/{afid}/download")"
                                        OnCompareRequested="OnCompareRequested" />
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
@if (!RankedMode && Results.Count < Total)
{
    <div id="oe-objects-sentinel" class="oe-scroll-sentinel">
        <span class="muted">Loading more...</span>
    </div>
}
@* Ranked results are all in memory (a search keeps the match set small-ish),
   but a broad term like "entry" still matches hundreds; render them in batches
   so the page isn't building hundreds of rows + per-row menus up front. *@
@if (RankedMode && Results.Count > _renderLimit)
{
    <div class="oe-show-more">
        <button type="button" class="btn btn--sm" @onclick="ShowMore">
            Show @NextBatchCount.ToString("N0") more (@Remaining.ToString("N0") remaining)
        </button>
    </div>
}

@code {
    [Parameter] public List<ReleaseObjectMatch>? Results { get; set; }
    [Parameter] public int Total { get; set; }
    [Parameter] public bool RankedMode { get; set; }
    [Parameter] public bool HasFilters { get; set; }
    [Parameter] public int? ViewReleaseSeed { get; set; }

    /// <summary>Raised when a row's "Compare with..." is picked - the parent
    /// opens its shared release-picker modal.</summary>
    [Parameter] public EventCallback OnCompareRequested { get; set; }

    // Ranked mode hands us the whole (capped) match set at once; rendering all
    // of it up front - every row builds a RowActionsMenu - is what made a broad
    // term like "entry" hang for seconds even though the query is ~10ms. Render
    // in batches and grow on demand. Browse mode is unaffected (it server-pages
    // via the scroll sentinel and Results only ever holds what's loaded).
    private const int RenderBatch = 100;
    private int _renderLimit = RenderBatch;
    private List<ReleaseObjectMatch>? _lastResults;

    protected override void OnParametersSet()
    {
        // Reset the window only when a new result set arrives (a fresh search or
        // re-sort), not on every incidental re-render - otherwise "Show more"
        // would collapse back to the first batch.
        if (!ReferenceEquals(Results, _lastResults))
        {
            _renderLimit = RenderBatch;
            _lastResults = Results;
        }
    }

    /// <summary>Rows actually rendered - capped to the current window in ranked
    /// mode, the full loaded set in browse mode.</summary>
    private IEnumerable<ReleaseObjectMatch> Rows =>
        RankedMode && Results is not null ? Results.Take(_renderLimit) : (Results ?? new());

    /// <summary>Matches not yet rendered (ranked mode only).</summary>
    private int Remaining => RankedMode && Results is not null ? Math.Max(0, Results.Count - _renderLimit) : 0;

    /// <summary>How many the next "Show more" click reveals.</summary>
    private int NextBatchCount => Math.Min(RenderBatch, Remaining);

    private void ShowMore() => _renderLimit += RenderBatch;

    /// <summary>Active sort column (null = default / relevance order), owned by the parent.</summary>
    [Parameter] public ObjectSortColumn? SortColumn { get; set; }
    [Parameter] public bool SortDescending { get; set; }
    /// <summary>Header click - the parent flips sort state and re-runs the query.</summary>
    [Parameter] public EventCallback<ObjectSortColumn> OnSortBy { get; set; }

    private RenderFragment SortHeader(string label, ObjectSortColumn column) => __builder =>
    {
        var active = SortColumn == column;
        <button type="button"
                class="data-table__sort-button @(active ? "is-active" : "")"
                @onclick="() => OnSortBy.InvokeAsync(column)">
            @label
            @if (active)
            {
                <span class="data-table__sort-indicator">@(SortDescending ? "▼" : "▲")</span>
            }
        </button>
    };

    /// <summary>Namespace up to and including the last dot (the muted prefix).</summary>
    private static string NamespaceHead(string ns)
    {
        var i = ns.LastIndexOf('.');
        return i < 0 ? string.Empty : ns[..(i + 1)];
    }

    /// <summary>Namespace after the last dot (the emphasised trailing segment).</summary>
    private static string NamespaceTail(string ns)
    {
        var i = ns.LastIndexOf('.');
        return i < 0 ? ns : ns[(i + 1)..];
    }
}
