@using ALDevToolbox.Services.ObjectExplorer

@if (Results is null)
{
    <p class="muted">Loading objects…</p>
}
else if (Results.Count == 0)
{
    <p class="muted">No objects match. Try a different name or remove the kind filter.</p>
}
else
{
    @if (Results.Count >= 200)
    {
        <p class="form-error" role="status">Showing the first 200 matches — narrow the search to see the rest.</p>
    }
    else
    {
        <p class="muted">@Results.Count.ToString("N0") object(s).</p>
    }
    <table class="data-table">
        <thead>
            <tr>
                <th scope="col">Module</th>
                <th scope="col">Kind</th>
                <th scope="col">Id</th>
                <th scope="col">Name</th>
                <th scope="col">Source</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Results)
            {
                <tr>
                    <td><a href="@($"/object-explorer/module/{r.ModuleId}")">@r.ModuleName</a></td>
                    <td>@r.Kind</td>
                    <td>@(r.ObjectId?.ToString() ?? "—")</td>
                    <td><a href="@($"/object-explorer/object/{r.Id}")">@r.Name</a></td>
                    <td>
                        @if (r.SourceFileId is { } fid)
                        {
                            <a href="@($"/object-explorer/file/{fid}?line={r.LineNumber}")">View source</a>
                        }
                        else
                        {
                            <span class="muted">—</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    [Parameter] public List<ReleaseObjectMatch>? Results { get; set; }
}
