@inject BaseAppService BaseApp
@using ALDevToolbox.Components.Shared
@using ALDevToolbox.Domain.Entities
@using ALDevToolbox.Services

@*
    Right-rail aside on the Object Explorer file viewer. Owns rendering of
    the navigation stack (Outline → Refs → Refs …) and dispatches push / pop
    events back to the host page, which owns the stack state itself.

    The breadcrumb above the body lets the user jump to any earlier view;
    clicking an earlier chip pops the stack (truncating forward history).
    Outline rows scroll the editor via the existing #L<n> URL fragment;
    cross-file hits fall back to a full anchor navigation so FileViewer's
    OnParametersSet reloads cleanly.
*@

<aside class="inspector-panel" aria-label="File inspector">
    <nav class="inspector-panel__crumbs" aria-label="Inspector history">
        @for (var i = 0; i < Stack.Count; i++)
        {
            var idx = i;
            var isCurrent = idx == Cursor;
            if (i > 0)
            {
                <span class="inspector-panel__crumb-sep" aria-hidden="true">›</span>
            }
            if (isCurrent)
            {
                <span class="inspector-panel__crumb inspector-panel__crumb--current">
                    @CrumbLabel(Stack[i])
                </span>
            }
            else
            {
                <button type="button"
                        class="inspector-panel__crumb inspector-panel__crumb--link"
                        @onclick="() => OnPopTo.InvokeAsync(idx)">
                    @CrumbLabel(Stack[i])
                </button>
            }
        }
    </nav>

    <div class="inspector-panel__body">
        @if (Stack.Count == 0 || Stack[Cursor] is OutlinePanelView)
        {
            @RenderOutline()
        }
        else if (Stack[Cursor] is ReferencesPanelView refs)
        {
            @RenderReferences(refs)
        }
        else if (Stack[Cursor] is FileSearchPanelView search)
        {
            @RenderFileSearch(search)
        }
    </div>
</aside>

@if (_menuSymbolId is { } openMenuId && Symbols.FirstOrDefault(s => s.Id == openMenuId) is { } menuSymbol)
{
    // Full-viewport backdrop captures outside clicks so the menu dismisses
    // on the next interaction — same pattern the editor's right-click menu
    // uses. The menu itself sits on top via z-index in .cm-symbol-menu.
    <div class="cm-symbol-menu-backdrop"
         @onclick="CloseRowMenu"
         @oncontextmenu="CloseRowMenu"
         @oncontextmenu:preventDefault="true"></div>
    <div class="cm-symbol-menu"
         style="@($"left: {_menuX.ToString(System.Globalization.CultureInfo.InvariantCulture)}px; top: {_menuY.ToString(System.Globalization.CultureInfo.InvariantCulture)}px;")"
         @onclick:stopPropagation="true"
         @oncontextmenu:stopPropagation="true">
        <button type="button"
                class="cm-symbol-menu__item"
                @onclick="() => GoToDefinitionFromMenu(menuSymbol)">
            Go to definition
        </button>
        @if (CanFindReferences(menuSymbol.Kind))
        {
            <button type="button"
                    class="cm-symbol-menu__item"
                    @onclick="() => FindReferencesFromMenu(menuSymbol)">
                Find references
            </button>
        }
        else
        {
            <span class="cm-symbol-menu__item cm-symbol-menu__item--disabled">
                Find references
            </span>
        }
    </div>
}

@code {
    [Parameter, EditorRequired] public IReadOnlyList<InspectorPanelView> Stack { get; set; } = default!;
    [Parameter, EditorRequired] public int Cursor { get; set; }
    [Parameter, EditorRequired] public IReadOnlyList<BaseAppSymbol> Symbols { get; set; } = default!;
    [Parameter, EditorRequired] public int VersionId { get; set; }
    [Parameter, EditorRequired] public long FileId { get; set; }

    /// <summary>Raised when a breadcrumb chip earlier than the cursor is clicked.</summary>
    [Parameter] public EventCallback<int> OnPopTo { get; set; }

    /// <summary>Raised when an outline row's "Find references" affordance is clicked.</summary>
    [Parameter] public EventCallback<BaseAppSymbol> OnPushReferences { get; set; }

    /// <summary>
    /// Raised when a navigation link in any panel view is clicked. Receives
    /// the target <c>(FileId, LineNumber)</c>. The host page decides whether
    /// to scroll in-place (same file) or run a full page navigation
    /// (different file).
    /// </summary>
    [Parameter] public EventCallback<(long FileId, int LineNumber)> OnScrollTo { get; set; }

    private string _outlineFilter = string.Empty;
    private long _lastFileId;
    // Per-file cache of references results; null entry means "loading".
    private Dictionary<long, BaseAppReferenceResult?> _referencesCache = new();
    // Per-file cache of in-file search hits; null entry means "loading".
    private Dictionary<string, FileSearchResult?> _fileSearchCache = new(StringComparer.Ordinal);
    // Outline section kinds the user has collapsed. Reset on file change so
    // each file starts fully expanded — most files are short enough to
    // scroll, and a stale "collapsed local procs" from a 2,000-line
    // codeunit shouldn't hide a 3-proc page's outline.
    private HashSet<string> _collapsedSections = new(StringComparer.Ordinal);
    // Right-click context menu state. _menuSymbolId is the row the menu is
    // anchored to; null means closed. x/y are viewport coordinates from
    // the contextmenu event.
    private long? _menuSymbolId;
    private double _menuX;
    private double _menuY;

    protected override async Task OnParametersSetAsync()
    {
        if (_lastFileId != FileId)
        {
            _lastFileId = FileId;
            _outlineFilter = string.Empty;
            _referencesCache.Clear();
            _fileSearchCache.Clear();
            _collapsedSections.Clear();
            _menuSymbolId = null;
        }

        if (Stack.Count == 0) return;
        if (Stack[Cursor] is ReferencesPanelView refs && !_referencesCache.ContainsKey(refs.SymbolId))
        {
            // Mark as loading first so the body renders the spinner instead of
            // a transient "no references" message while we wait for the query.
            _referencesCache[refs.SymbolId] = null;
            StateHasChanged();
            var result = await BaseApp.FindReferencesAsync(refs.SymbolId);
            _referencesCache[refs.SymbolId] = result;
        }
        else if (Stack[Cursor] is FileSearchPanelView search && !_fileSearchCache.ContainsKey(search.Word))
        {
            _fileSearchCache[search.Word] = null;
            StateHasChanged();
            var result = await BaseApp.FindInFileAsync(FileId, search.Word);
            _fileSearchCache[search.Word] = result;
        }
    }

    private static string CrumbLabel(InspectorPanelView view) => view switch
    {
        OutlinePanelView => "Outline",
        ReferencesPanelView r => $"Refs: {r.SymbolName}",
        FileSearchPanelView s => $"In file: {s.Word}",
        _ => "?",
    };

    // Categories shown in the outline, in render order. Object header and
    // fields lead so a table file reads top-down like the AL source itself.
    // Trigger and event subscribers are framework-fired but still useful to
    // see at a glance — they just don't get a Find-references button.
    private static readonly (string Kind, string Label)[] OutlineCategories =
    {
        ("object_declaration", "Object"),
        ("field", "Fields"),
        ("procedure", "Procedures"),
        ("internal_procedure", "Internal procedures"),
        ("protected_procedure", "Protected procedures"),
        ("local_procedure", "Local procedures"),
        ("event_publisher", "Event publishers"),
        ("event_subscriber", "Event subscribers"),
        ("trigger", "Triggers"),
    };

    private RenderFragment RenderOutline() => __builder =>
    {
        var filtered = string.IsNullOrWhiteSpace(_outlineFilter)
            ? Symbols
            : Symbols.Where(s => s.Name.Contains(_outlineFilter, StringComparison.OrdinalIgnoreCase)).ToList();

        <div class="inspector-panel__filter">
            <input type="search"
                   class="inspector-panel__filter-input"
                   placeholder="Filter symbols…"
                   value="@_outlineFilter"
                   @oninput="@(e => _outlineFilter = e.Value?.ToString() ?? string.Empty)" />
        </div>

        @if (Symbols.Count == 0)
        {
            <p class="muted small inspector-panel__empty">
                No symbols extracted for this file.
            </p>
        }
        else if (filtered.Count == 0)
        {
            <p class="muted small inspector-panel__empty">
                No matches for "<strong>@_outlineFilter</strong>".
            </p>
        }
        else
        {
            <ul class="inspector-panel__sections">
                @foreach (var (kind, label) in OutlineCategories)
                {
                    var rows = filtered.Where(s => s.Kind == kind).ToList();
                    if (rows.Count == 0) continue;
                    var isCollapsed = _collapsedSections.Contains(kind);
                    var sectionKind = kind;

                    <li class="inspector-panel__section @(isCollapsed ? "inspector-panel__section--collapsed" : null)">
                        <button type="button"
                                class="inspector-panel__section-toggle"
                                aria-expanded="@(!isCollapsed)"
                                @onclick="() => ToggleSection(sectionKind)">
                            <Icon Name="@(isCollapsed ? "chevron-right" : "chevron-down")" Width="12" Height="12" />
                            <span class="inspector-panel__section-title-text">@label</span>
                            <span class="muted small">(@rows.Count)</span>
                        </button>
                        @if (!isCollapsed)
                        {
                            <ul class="inspector-panel__items">
                                @foreach (var sym in rows)
                                {
                                    var symbol = sym;
                                    <li class="inspector-panel__item"
                                        @oncontextmenu="@(e => OpenRowMenu(e, symbol))"
                                        @oncontextmenu:preventDefault="true">
                                        <a class="inspector-panel__item-link"
                                           href="@($"/object-explorer/{VersionId}/files/{FileId}#L{symbol.LineNumber}")"
                                           @onclick="@(() => OnScrollTo.InvokeAsync((FileId, symbol.LineNumber)))"
                                           @onclick:preventDefault="true"
                                           @onclick:stopPropagation="true">
                                            <span class="inspector-panel__item-name">@symbol.Name</span>
                                            @if (!string.IsNullOrWhiteSpace(symbol.Signature))
                                            {
                                                <span class="muted small inspector-panel__item-sig"
                                                      title="@symbol.Signature">@FormatSignature(symbol)</span>
                                            }
                                            <span class="muted small inspector-panel__item-line">L@(symbol.LineNumber)</span>
                                        </a>
                                        @if (CanFindReferences(symbol.Kind))
                                        {
                                            <button type="button"
                                                    class="inspector-panel__item-action"
                                                    title="Find references"
                                                    @onclick="() => OnPushReferences.InvokeAsync(symbol)">
                                                <Icon Name="search" Width="13" Height="13" />
                                            </button>
                                        }
                                    </li>
                                }
                            </ul>
                        }
                    </li>
                }
            </ul>
        }
    };

    private void ToggleSection(string kind)
    {
        if (!_collapsedSections.Add(kind))
        {
            _collapsedSections.Remove(kind);
        }
    }

    /// <summary>
    /// Renders the row's signature/type as a compact muted suffix. For
    /// fields we show the bare type (<c>Code[20]</c>); for procedures we
    /// keep the leading <c>(</c> so the arg list reads as a signature.
    /// CSS handles overflow via ellipsis so the row never wraps.
    /// </summary>
    private static string FormatSignature(BaseAppSymbol sym)
    {
        var raw = sym.Signature?.Trim();
        if (string.IsNullOrEmpty(raw)) return string.Empty;
        return sym.Kind switch
        {
            "field" => ": " + raw,
            _ => raw,
        };
    }

    private void OpenRowMenu(MouseEventArgs e, BaseAppSymbol symbol)
    {
        _menuSymbolId = symbol.Id;
        _menuX = e.ClientX;
        _menuY = e.ClientY;
    }

    private void CloseRowMenu()
    {
        _menuSymbolId = null;
    }

    private async Task GoToDefinitionFromMenu(BaseAppSymbol symbol)
    {
        CloseRowMenu();
        await OnScrollTo.InvokeAsync((FileId, symbol.LineNumber));
    }

    private async Task FindReferencesFromMenu(BaseAppSymbol symbol)
    {
        CloseRowMenu();
        await OnPushReferences.InvokeAsync(symbol);
    }

    private static bool CanFindReferences(string kind)
    {
        // Triggers are framework-fired by name pattern, not by user-written
        // call sites — the references query would never produce useful hits.
        return kind != "trigger";
    }

    private RenderFragment RenderReferences(ReferencesPanelView refs) => __builder =>
    {
        var hasEntry = _referencesCache.TryGetValue(refs.SymbolId, out var result);
        if (!hasEntry || result is null)
        {
            <p class="muted small inspector-panel__empty">Loading references…</p>
            return;
        }

        if (result.Symbol.Id == 0)
        {
            <p class="muted small inspector-panel__empty">Symbol not found.</p>
            return;
        }

        <p class="muted small inspector-panel__refs-meta">
            <span class="object-explorer__type">@refs.SymbolKind</span>
            @refs.SymbolName
            @if (result.OverloadCount > 1)
            {
                <span> · @result.OverloadCount overloads</span>
            }
        </p>

        if (result.Likely.Count == 0 && result.PossiblyRelated.Count == 0)
        {
            <p class="muted small inspector-panel__empty">
                No references found in this version.
            </p>
            return;
        }

        if (result.Likely.Count > 0)
        {
            <section class="inspector-panel__refs-section">
                <h3 class="inspector-panel__section-title">
                    Likely <span class="muted small">(@result.Likely.Count)</span>
                </h3>
                @RenderHits(result.Likely)
            </section>
        }

        if (result.PossiblyRelated.Count > 0)
        {
            <section class="inspector-panel__refs-section">
                <h3 class="inspector-panel__section-title">
                    Possibly related <span class="muted small">(@result.PossiblyRelated.Count)</span>
                </h3>
                @RenderHits(result.PossiblyRelated)
            </section>
        }
    };

    private RenderFragment RenderFileSearch(FileSearchPanelView search) => __builder =>
    {
        var hasEntry = _fileSearchCache.TryGetValue(search.Word, out var result);
        if (!hasEntry || result is null)
        {
            <p class="muted small inspector-panel__empty">Searching…</p>
            return;
        }

        <p class="muted small inspector-panel__refs-meta">
            Occurrences of <code>@search.Word</code> in this file
            <span class="muted small">· @result.Hits.Count hit@(result.Hits.Count == 1 ? "" : "s")</span>
        </p>

        if (result.Hits.Count == 0)
        {
            <p class="muted small inspector-panel__empty">
                No occurrences found.
            </p>
            return;
        }

        <ul class="inspector-panel__refs-hits">
            @foreach (var hit in result.Hits)
            {
                <li>
                    <a class="inspector-panel__refs-hit"
                       href="@($"/object-explorer/{VersionId}/files/{FileId}#L{hit.LineNumber}")"
                       @onclick="@(() => OnScrollTo.InvokeAsync((FileId, hit.LineNumber)))"
                       @onclick:preventDefault="true"
                       @onclick:stopPropagation="true">
                        <span class="inspector-panel__refs-hit-line">L@(hit.LineNumber)</span>
                        <code class="inspector-panel__refs-hit-snippet">@hit.Snippet</code>
                    </a>
                </li>
            }
        </ul>
    };

    private RenderFragment RenderHits(IReadOnlyList<BaseAppReferenceHit> hits) => __builder =>
    {
        var grouped = hits
            .GroupBy(h => (h.FileId, h.ObjectType, h.ObjectId, h.ObjectName))
            .ToList();

        <ul class="inspector-panel__refs-files">
            @foreach (var group in grouped)
            {
                <li class="inspector-panel__refs-file">
                    <header class="inspector-panel__refs-file-header">
                        <span class="object-explorer__type">@group.Key.ObjectType</span>
                        @if (group.Key.ObjectId is { } objId)
                        {
                            <span class="muted small">@objId</span>
                        }
                        <strong>@group.Key.ObjectName</strong>
                        <span class="muted small">· @group.Count() hit@(group.Count() == 1 ? "" : "s")</span>
                    </header>
                    <ul class="inspector-panel__refs-hits">
                        @foreach (var hit in group)
                        {
                            var hitFileId = hit.FileId;
                            var hitLine = hit.LineNumber;
                            <li>
                                <a class="inspector-panel__refs-hit"
                                   href="@($"/object-explorer/{VersionId}/files/{hitFileId}#L{hitLine}")"
                                   @onclick="@(() => OnScrollTo.InvokeAsync((hitFileId, hitLine)))"
                                   @onclick:preventDefault="true"
                                   @onclick:stopPropagation="true">
                                    <span class="inspector-panel__refs-hit-line">L@(hitLine)</span>
                                    <code class="inspector-panel__refs-hit-snippet">@hit.Snippet</code>
                                </a>
                            </li>
                        }
                    </ul>
                </li>
            }
        </ul>
    };
}
