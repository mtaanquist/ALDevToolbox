@page "/admin/object-explorer/new"
@attribute [Authorize(Roles = "Admin")]
@inject ApplicationVersionService AppVersions
@inject IAntiforgery Antiforgery
@inject IHttpContextAccessor Http
@using ALDevToolbox.Domain.Entities
@using Microsoft.AspNetCore.Antiforgery

@*
    Multipart upload form for one or more Microsoft application source ZIPs.
    Posts straight to /admin/object-explorer/import (see BaseAppEndpoints)
    so the body streams through Kestrel rather than the Blazor SignalR
    circuit. Static-rendered: no @rendermode, no interactivity — Blazor would
    buffer multi-hundred-megabyte uploads through interop and choke.

    The catalogue-link select sits at the top because picking a known
    Application Versions row prefills Major + CU for the rest of the form.
    Two tiny inline scripts (data-prefill / data-upload) wire the catalogue
    prefill and the "uploading…" feedback overlay; both stay vanilla JS so
    the page works without an active SignalR connection.
*@

<PageTitle>Upload Application · Admin · AL Dev Toolbox</PageTitle>

<div class="admin-page">
    <header class="admin-page__header">
        <div>
            <h1>Upload Application</h1>
            <p class="muted">
                Pick one or more ZIPs containing AL source for a Business Central
                release — typically one ZIP per first-party app (Base Application,
                System Application, …) and any customer hotfix bundles. Files are
                stored as text; binary entries are skipped. Cap is 500 MB per ZIP.
            </p>
        </div>
        <a class="btn btn--sm" href="/admin/object-explorer">
            <Icon Name="arrow-left" Width="14" Height="14" />
            <span>Back</span>
        </a>
    </header>

    <form method="post"
          action="/admin/object-explorer/import"
          enctype="multipart/form-data"
          class="form-grid object-explorer-upload"
          data-upload>
        @if (_antiforgeryToken is not null)
        {
            <input type="hidden" name="@_antiforgeryToken.FormFieldName" value="@_antiforgeryToken.RequestToken" />
        }

        <section class="form-section">
            <label class="field">
                <span class="field__label">Application version (catalogue link, optional)</span>
                <select name="ApplicationVersionId" class="field__input" data-prefill>
                    <option value="">— none —</option>
                    @if (_appVersions is not null)
                    {
                        @foreach (var v in _appVersions)
                        {
                            <option value="@v.Id" data-application="@v.Application">@v.Name (@v.Application)</option>
                        }
                    }
                </select>
                <small class="field__caption muted">
                    Picking an entry prefills the version numbers below from its
                    application field. Doesn't change anything else — leave it on
                    "none" if you're uploading something not on the catalogue.
                </small>
            </label>

            <div class="form-row">
                <label class="field">
                    <span class="field__label">Major</span>
                    <input type="number" name="Major" min="1" max="999" required placeholder="28" data-prefill-major />
                </label>
                <label class="field">
                    <span class="field__label">Cumulative update</span>
                    <input type="number" name="CumulativeUpdate" min="0" max="99" required value="0" data-prefill-cu />
                    <small class="field__caption muted">
                        0 = RTM; increments monthly. Microsoft's <code>Application</code>
                        field's second number is the CU, so the catalogue prefill picks it up.
                    </small>
                </label>
            </div>

            <label class="field">
                <span class="field__label">ZIP file(s)</span>
                <span class="file-picker">
                    <input type="file" id="upload-zips" name="Zip" accept=".zip,application/zip" multiple required data-files />
                    <label for="upload-zips" class="btn btn--outline file-picker__button">
                        <Icon Name="upload" Width="14" Height="14" />
                        <span>Choose ZIPs…</span>
                    </label>
                    <span class="file-picker__status muted" data-files-status>No files selected.</span>
                </span>
                <small class="field__caption muted">
                    Hold Shift / Cmd / Ctrl while selecting to pick several at once.
                    When multiple ZIPs land for the same Business Central version,
                    the first uses the mode you chose below; the rest are forced
                    to <strong>Append</strong>.
                </small>
            </label>

            <label class="field">
                <span class="field__label">Notes (optional)</span>
                <textarea name="Notes" rows="3" maxlength="4000" placeholder="Release-engineering link, source URL, …"></textarea>
            </label>

            <label class="field">
                <span class="field__label">If this version already exists</span>
                <select name="Mode" class="field__input">
                    <option value="Reject" selected>Reject (default) — refuse the upload</option>
                    <option value="Append">Append — add these files to the existing version</option>
                    <option value="Replace">Replace — soft-delete the existing version and start fresh</option>
                </select>
            </label>
        </section>

        <div class="form-actions">
            <button type="submit" class="btn btn--primary" data-submit>
                <span class="btn__spinner" aria-hidden="true"></span>
                <Icon Name="upload" Width="16" Height="16" />
                <span class="btn__label">Upload &amp; import</span>
                <span class="btn__label-busy">Uploading…</span>
            </button>
            <a class="btn btn--outline" href="/admin/object-explorer" data-cancel>Cancel</a>
        </div>

        <div class="upload-progress" data-upload-progress role="status" aria-live="polite" hidden>
            <div class="upload-progress__spinner" aria-hidden="true"></div>
            <p>
                <strong>Uploading and parsing…</strong>
                <span class="muted">Large bundles can take a minute or two. Don't refresh.</span>
            </p>
        </div>
    </form>
</div>

<script>
    (() => {
        const form = document.querySelector('form[data-upload]');
        if (!form) return;

        const prefillSelect = form.querySelector('[data-prefill]');
        const majorInput = form.querySelector('[data-prefill-major]');
        const cuInput = form.querySelector('[data-prefill-cu]');
        const fileInput = form.querySelector('[data-files]');
        const fileStatus = form.querySelector('[data-files-status]');
        const submitBtn = form.querySelector('[data-submit]');
        const cancelLink = form.querySelector('[data-cancel]');
        const progress = form.querySelector('[data-upload-progress]');
        let submitted = false;

        // Catalogue-link prefill: Microsoft's `application` field is a
        // four-part version (e.g. "28.5.0.0"); first segment is the major
        // release, second is the cumulative update.
        prefillSelect?.addEventListener('change', () => {
            const opt = prefillSelect.selectedOptions[0];
            const application = opt?.dataset.application;
            if (!application) return;
            const parts = application.split('.');
            if (parts.length >= 1 && majorInput && !majorInput.value) majorInput.value = parts[0];
            if (parts.length >= 2 && cuInput) cuInput.value = parts[1];
        });

        // File-picker status: native <input type="file"> is ugly and silent
        // once styled away; we surface the chosen count + first filename
        // ourselves so the user can see what they're about to upload.
        fileInput?.addEventListener('change', () => {
            const files = fileInput.files;
            if (!files || files.length === 0) {
                fileStatus.textContent = 'No files selected.';
                return;
            }
            if (files.length === 1) {
                fileStatus.textContent = files[0].name;
            } else {
                fileStatus.textContent = `${files.length} files selected (${files[0].name} + ${files.length - 1} more).`;
            }
        });

        // Submit feedback: dim the form, switch the button into its
        // busy state, reveal the progress panel. The form still submits
        // — we don't preventDefault. The submitted-flag intercepts a
        // double-click; setting disabled directly before the browser
        // finishes capturing form data can race the upload, so we go
        // through a click guard instead.
        form.addEventListener('submit', (e) => {
            if (submitted) {
                e.preventDefault();
                return;
            }
            submitted = true;
            form.classList.add('is-uploading');
            form.setAttribute('aria-busy', 'true');
            submitBtn.classList.add('btn--loading');
            submitBtn.setAttribute('aria-disabled', 'true');
            cancelLink?.setAttribute('aria-disabled', 'true');
            cancelLink?.addEventListener('click', stopClickWhileUploading);
            progress?.removeAttribute('hidden');
            // Schedule the actual disable for the next tick — by then
            // the browser has already started shipping the request body.
            setTimeout(() => { submitBtn.disabled = true; }, 0);
        });

        function stopClickWhileUploading(ev) {
            if (form.classList.contains('is-uploading')) {
                ev.preventDefault();
            }
        }
    })();
</script>

@code {
    private List<ApplicationVersion>? _appVersions;
    private AntiforgeryTokenSet? _antiforgeryToken;

    protected override async Task OnInitializedAsync()
    {
        _appVersions = await AppVersions.GetAllForAdminAsync();
        if (Http.HttpContext is not null)
        {
            _antiforgeryToken = Antiforgery.GetAndStoreTokens(Http.HttpContext);
        }
    }
}
