@page "/admin/object-explorer/new/customer"
@attribute [Authorize(Roles = "Admin,Editor")]
@rendermode InteractiveServer
@inject ALDevToolbox.Services.ObjectExplorer.CustomerService Customers
@inject ALDevToolbox.Services.OrganizationConfigService Config
@inject ILogger<AdminReleasesImportCustomer> Log
@using ALDevToolbox.Domain.Entities.ObjectExplorer
@using ALDevToolbox.Domain.ValueObjects
@using ALDevToolbox.Services
@using ALDevToolbox.Services.ObjectExplorer

@*
    Customer tab of the Import Release page. Manage the customers whose solutions
    the toolbox compiles from source: each customer points at one or more Azure
    DevOps / GitHub repositories. Building from these repos (clone → resolve
    symbols → compile → ingest) lands in a follow-up; this tab is the management
    surface that defines them. See .design/object-explorer-customer-builds.md.
*@

<PageTitle>Import Release · Customer · Admin · AL Dev Toolbox</PageTitle>

<div class="admin-page admin-page--wide">
    <AdminReleasesImportHeader ActiveTab="AdminReleasesImportHeader.Tab.Customer" />

    @if (_message is not null)
    {
        <p class="form-success" role="status">@_message</p>
    }
    @if (_errors.Count > 0)
    {
        <div class="form-error" role="alert">
            @foreach (var err in _errors.Values.Distinct())
            {
                <p>@err</p>
            }
        </div>
    }

    @if (!_hasAnyPat)
    {
        <p class="muted">
            No repository token is configured yet. Add an Azure DevOps or GitHub
            token under <a href="/admin/administration/repositories">Administration →
            Repositories</a> before building a customer's solution.
        </p>
    }

    @if (_loading)
    {
        <p class="muted">Loading…</p>
    }
    else if (_edit is not null)
    {
        <section class="admin-section">
            <h2>@(_edit.Id is null ? "New customer" : "Edit customer")</h2>
            <div class="form-grid form-grid--narrow">
                <section class="form-section">
                    <label class="section-label" for="cust-name">Name</label>
                    <input id="cust-name" class="input" maxlength="200" @bind="_edit.Name" disabled="@_saving"
                           placeholder="e.g. Acme A/S" />
                    <small class="muted">Used to label the release, e.g. "Acme A/S on BC 25.18".</small>
                </section>

                <section class="form-section">
                    <label class="section-label" for="cust-country">Default country code <span class="muted">· optional</span></label>
                    <input id="cust-country" class="input" maxlength="20" pattern="[A-Za-z0-9]{2,10}"
                           @bind="_edit.Country" disabled="@_saving" placeholder="e.g. dk or w1" />
                    <small class="muted">
                        Which Microsoft localisation to compile symbols against.
                        Leave blank to use the organisation default.
                    </small>
                </section>

                <section class="form-section">
                    <label class="section-label">Repositories</label>
                    @if (_edit.Repos.Count == 0)
                    {
                        <p class="muted">Add at least one repository to build from.</p>
                    }
                    @foreach (var repo in _edit.Repos)
                    {
                        <div class="oe-repo-row">
                            <select class="input" @bind="repo.Provider" disabled="@_saving" aria-label="Provider">
                                <option value="@RepositoryProvider.AzureDevOps">Azure DevOps</option>
                                <option value="@RepositoryProvider.GitHub">GitHub</option>
                            </select>
                            <input class="input" @bind="repo.Url" disabled="@_saving"
                                   placeholder="https://github.com/org/repo" aria-label="Repository URL" />
                            <input class="input" @bind="repo.DisplayName" disabled="@_saving"
                                   placeholder="Display name (optional)" aria-label="Display name" />
                            <button type="button" class="btn btn--sm btn--outline" @onclick="() => RemoveRepo(repo)" disabled="@_saving"
                                    aria-label="Remove repository">
                                <Icon Name="trash-2" Width="14" Height="14" />
                            </button>
                        </div>
                    }
                    <button type="button" class="btn btn--sm" @onclick="AddRepo" disabled="@_saving">
                        <Icon Name="plus" Width="14" Height="14" />
                        <span>Add repository</span>
                    </button>
                </section>

                <section class="form-section form-section--actions">
                    <button type="button" class="btn btn--primary" @onclick="SaveAsync" disabled="@_saving">
                        <Icon Name="save" Width="14" Height="14" />
                        <span>@(_saving ? "Saving…" : "Save customer")</span>
                    </button>
                    <button type="button" class="btn btn--outline" @onclick="CancelEdit" disabled="@_saving">
                        <span>Cancel</span>
                    </button>
                </section>
            </div>
        </section>
    }
    else
    {
        <section class="admin-section">
            <div class="admin-section__header">
                <h2>Customers</h2>
                <button type="button" class="btn btn--sm" @onclick="StartCreate">
                    <Icon Name="plus" Width="14" Height="14" />
                    <span>New customer</span>
                </button>
            </div>

            @if (_customers.Count == 0)
            {
                <p class="muted">
                    No customers yet. Create one and point it at the repositories
                    that make up its solution.
                </p>
            }
            else
            {
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Country</th>
                            <th>Repositories</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in _customers)
                        {
                            <tr>
                                <td>@c.Name</td>
                                <td>@(string.IsNullOrEmpty(c.DefaultArtifactCountry) ? "—" : c.DefaultArtifactCountry)</td>
                                <td>
                                    @if (c.Repositories.Count == 0)
                                    {
                                        <span class="muted">none</span>
                                    }
                                    else
                                    {
                                        @foreach (var r in c.Repositories)
                                        {
                                            <div>
                                                <span class="muted">@r.Provider.DisplayName():</span>
                                                @(string.IsNullOrEmpty(r.DisplayName) ? r.Url : r.DisplayName)
                                            </div>
                                        }
                                    }
                                </td>
                                <td class="data-table__actions">
                                    @if (_deletingId == c.Id)
                                    {
                                        <span class="muted">Delete?</span>
                                        <button type="button" class="btn btn--sm btn--danger" @onclick="() => ConfirmDeleteAsync(c.Id)">Yes</button>
                                        <button type="button" class="btn btn--sm btn--outline" @onclick="() => _deletingId = null">No</button>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn btn--sm btn--outline" @onclick="() => StartEdit(c)">Edit</button>
                                        <button type="button" class="btn btn--sm btn--outline" @onclick="() => _deletingId = c.Id">Delete</button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </section>
    }
</div>

@code {
    private bool _loading = true;
    private bool _saving;
    private bool _hasAnyPat;
    private string? _message;
    private Dictionary<string, string> _errors = new();
    private List<Customer> _customers = new();
    private int? _deletingId;
    private EditModel? _edit;

    protected override async Task OnInitializedAsync()
    {
        var access = await Config.GetRepositoryAccessViewAsync();
        _hasAnyPat = access.HasAzureDevOpsPat || access.HasGitHubPat;
        await ReloadAsync();
        _loading = false;
    }

    private async Task ReloadAsync()
    {
        _customers = await Customers.ListCustomersAsync();
    }

    private void StartCreate()
    {
        _message = null;
        _errors = new();
        _edit = new EditModel { Repos = { new RepoRow() } };
    }

    private void StartEdit(Customer c)
    {
        _message = null;
        _errors = new();
        _edit = new EditModel
        {
            Id = c.Id,
            Name = c.Name,
            Country = c.DefaultArtifactCountry ?? string.Empty,
            Repos = c.Repositories
                .Select(r => new RepoRow { Provider = r.Provider, Url = r.Url, DisplayName = r.DisplayName })
                .ToList(),
        };
        if (_edit.Repos.Count == 0) _edit.Repos.Add(new RepoRow());
    }

    private void CancelEdit()
    {
        _edit = null;
        _errors = new();
    }

    private void AddRepo() => _edit?.Repos.Add(new RepoRow());

    private void RemoveRepo(RepoRow row) => _edit?.Repos.Remove(row);

    private async Task SaveAsync()
    {
        if (_edit is null || _saving) return;
        _saving = true;
        _message = null;
        _errors = new();
        try
        {
            var input = new CustomerInput(
                _edit.Name,
                string.IsNullOrWhiteSpace(_edit.Country) ? null : _edit.Country,
                _edit.Repos.Select(r => new CustomerRepositoryInput(r.Provider, r.Url, r.DisplayName)).ToList());

            if (_edit.Id is null)
            {
                await Customers.CreateCustomerAsync(input);
                _message = "Customer created.";
            }
            else
            {
                await Customers.UpdateCustomerAsync(_edit.Id.Value, input);
                _message = "Customer saved.";
            }
            _edit = null;
            await ReloadAsync();
        }
        catch (PlanValidationException ex)
        {
            _errors = new(ex.Errors);
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Failed to save customer.");
            _errors = new() { ["_"] = "An unexpected error occurred. The change was not saved." };
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task ConfirmDeleteAsync(int id)
    {
        try
        {
            await Customers.SoftDeleteCustomerAsync(id);
            _message = "Customer deleted.";
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Failed to delete customer {CustomerId}.", id);
            _errors = new() { ["_"] = "Could not delete the customer." };
        }
        finally
        {
            _deletingId = null;
        }
    }

    private sealed class EditModel
    {
        public int? Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public string Country { get; set; } = string.Empty;
        public List<RepoRow> Repos { get; set; } = new();
    }

    private sealed class RepoRow
    {
        public RepositoryProvider Provider { get; set; } = RepositoryProvider.GitHub;
        public string Url { get; set; } = string.Empty;
        public string DisplayName { get; set; } = string.Empty;
    }
}
