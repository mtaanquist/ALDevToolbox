@page "/admin/object-explorer"
@attribute [Authorize(Roles = "Admin,Editor")]
@inject ALDevToolbox.Services.ObjectExplorer.ObjectExplorerService ObjectExplorer
@inject IHttpContextAccessor Http
@using ALDevToolbox.Services.ObjectExplorer

@*
    Admin index for the Object Explorer surface: lists every Release in the
    organisation (active + soft-deleted) and exposes per-row admin actions.
    Statically rendered so the action forms post normally; the Object Explorer
    endpoints (see ObjectExplorerEndpoints.cs) handle the writes.

    The user-facing browser at /object-explorer keeps showing only active
    Releases without admin affordances — this page is the admin counterpart.
*@

<PageTitle>Object Explorer · Admin · AL Dev Toolbox</PageTitle>

<div class="admin-page">
    <header class="admin-page__header">
        <div>
            <h1>Object Explorer</h1>
            <p class="muted">
                Imported Releases in this organisation. Soft-deleted Releases
                are hidden from the user-facing browser but stay queryable
                here until they're permanently removed.
            </p>
        </div>
        <div class="row-actions">
            @if (_releases is not null && _releases.Any(r => r.Status == "ingesting"))
            {
                <a class="btn btn--sm" href="/admin/object-explorer" title="Reload to see import progress">
                    <Icon Name="refresh-cw" Width="14" Height="14" />
                    <span>Refresh</span>
                </a>
            }
            <a class="btn" href="/admin/object-explorer/new">
                <Icon Name="upload" Width="16" Height="16" />
                <span>Import Release</span>
            </a>
        </div>
    </header>

    @if (Status is { } status)
    {
        @if (status.IsError)
        {
            <div class="form-error" role="alert"><p>@status.Message</p></div>
        }
        else
        {
            <p class="form-success" role="status">@status.Message</p>
        }
    }

    @if (_releases is null)
    {
        <p class="muted">Loading…</p>
    }
    else if (_releases.Count == 0)
    {
        <p class="muted">
            No Releases yet. <a href="/admin/object-explorer/new">Import one now</a>.
        </p>
    }
    else
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th scope="col">Label</th>
                    <th scope="col">Kind</th>
                    <th scope="col">Publisher</th>
                    <th scope="col">Customer</th>
                    <th scope="col">Status</th>
                    <th scope="col">Files</th>
                    <th scope="col">Size</th>
                    <th scope="col">Imported</th>
                    <th scope="col">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in _releases)
                {
                    <tr>
                        <td>
                            <a href="@($"/object-explorer/release/{r.Id}")">
                                <strong>@r.Label</strong>
                            </a>
                            @if (r.DeletedAt is not null)
                            {
                                <span class="muted"> · soft-deleted</span>
                            }
                        </td>
                        <td>@FormatKind(r.Kind)</td>
                        <td>@(string.IsNullOrEmpty(r.Publisher) ? "—" : r.Publisher)</td>
                        <td>@(string.IsNullOrEmpty(r.CustomerName) ? "—" : r.CustomerName)</td>
                        <td>@FormatStatus(r.Status)</td>
                        <td>@r.SourceFileCount.ToString("N0")</td>
                        <td>@FormatBytes(r.SourceContentLength)</td>
                        <td>@r.ImportedAt.ToString("yyyy-MM-dd")</td>
                        <td class="row-actions">
                            <a class="btn btn--sm" href="@($"/admin/object-explorer/release/{r.Id}/manage")"
                               title="Edit details, add modules, translations, delete">
                                <Icon Name="settings" Width="14" Height="14" />
                                <span>Manage</span>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private List<ReleaseListItem>? _releases;
    private (string Message, bool IsError)? Status { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var ctx = Http.HttpContext;
        if (ctx is not null)
        {
            var err = ctx.Request.Query["err"].ToString();
            var msg = ctx.Request.Query["msg"].ToString();
            if (!string.IsNullOrEmpty(err) && !string.IsNullOrEmpty(msg))
            {
                Status = ($"{err}: {msg}", true);
            }
            else
            {
                var ok = ctx.Request.Query["ok"].ToString();
                if (!string.IsNullOrEmpty(ok))
                {
                    Status = (FormatOkMessage(ok, ctx.Request.Query["id"].ToString()), false);
                }
            }
        }

        _releases = await ObjectExplorer.ListReleasesAsync(includeSoftDeleted: true);
    }

    private static string FormatOkMessage(string ok, string id) => ok switch
    {
        "queued"       => $"Release {id} queued — importing in the background. Refresh this page to check on its progress.",
        "imported"     => $"Release {id} imported.",
        "updated"      => $"Release {id} metadata updated.",
        "soft-deleted" => $"Release {id} soft-deleted. Restore from this page if it was a mistake.",
        "restored"     => $"Release {id} restored.",
        "hard-deleted" => $"Release {id} permanently deleted.",
        _              => "Done.",
    };

    private static string FormatKind(string kind) => kind switch
    {
        "first_party" => "First-party",
        "third_party" => "Third-party",
        "customer"    => "Customer",
        _             => kind,
    };

    private static string FormatStatus(string s) => s switch
    {
        "ready"     => "Ready",
        "ingesting" => "Ingesting…",
        "failed"    => "Failed",
        _           => s,
    };

    private static string FormatBytes(long n)
    {
        if (n < 1024) return n + " B";
        if (n < 1024L * 1024) return (n / 1024d).ToString("0.0") + " KB";
        if (n < 1024L * 1024 * 1024) return (n / (1024d * 1024)).ToString("0.0") + " MB";
        return (n / (1024d * 1024 * 1024)).ToString("0.0") + " GB";
    }
}
