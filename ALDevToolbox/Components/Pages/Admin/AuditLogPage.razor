@page "/admin/audit"
@attribute [Authorize(Roles = "Admin")]
@inject AuditService Audit
@using ALDevToolbox.Components.Shared
@using ALDevToolbox.Domain.Entities
@using ALDevToolbox.Services
@using static ALDevToolbox.Components.Shared.AdminPageHelpers

<PageTitle>Audit log · AL Dev Toolbox</PageTitle>

<div class="admin-page audit-page">
    <header class="admin-page__header">
        <div>
            <h1>Audit log</h1>
            <p class="muted">
                Recent changes to runtime templates, modules, the well-known
                dependency catalogue, snippets, and other audited entities.
                Snapshots show the row's state immediately before the change;
                created rows have no prior state, so their snapshot is empty.
            </p>
        </div>
    </header>

    @*
        Filters apply on change rather than waiting for a submit button:
        selects fire change events synchronously, and the text inputs
        submit on Enter or when they lose focus. Keeping the form
        GET-based preserves bookmarkable URLs and uses the same
        SupplyParameterFromQuery wiring as the rest of the audit family.
    *@
    <form method="get" action="/admin/audit" class="admin-filter-form" onchange="this.submit()">
        <label>
            Entity type
            <select name="entityType">
                <option value="">Any</option>
                @foreach (var type in Enum.GetValues<AuditEntityType>())
                {
                    <option value="@type" selected="@(EntityType == type.ToString())">@FriendlyType(type)</option>
                }
            </select>
        </label>
        <label>
            Action
            <select name="action">
                <option value="">Any</option>
                @foreach (var act in Enum.GetValues<AuditAction>())
                {
                    <option value="@act" selected="@(Action == act.ToString())">@act</option>
                }
            </select>
        </label>
        <label>
            Entity id
            <input type="text" name="entityId" value="@EntityId" placeholder="exact match" />
        </label>
        <label>
            Actor contains
            <input type="text" name="actor" value="@Actor" placeholder="email or display name" />
        </label>
        <label>
            From (UTC)
            <input type="datetime-local" name="from" value="@FromUtc" />
        </label>
        <label>
            To (UTC)
            <input type="datetime-local" name="to" value="@ToUtc" />
        </label>
    </form>

    @if (_entries is null)
    {
        <p class="muted">Loading…</p>
    }
    else if (_entries.Count == 0)
    {
        <p class="muted">
            @(_total == 0 && !HasAnyFilter()
                ? "No changes recorded yet. Once an admin edits a template, module, or catalogue entry, the change will appear here."
                : "No audit entries match the current filters.")
        </p>
    }
    else
    {
        <table class="data-table audit-table">
            <thead>
                <tr>
                    <th>When (UTC)</th>
                    <th>Who</th>
                    <th>Entity</th>
                    <th>Id</th>
                    <th>Action</th>
                    <th>Snapshot</th>
                    <th class="data-table__actions"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in _entries)
                {
                    <tr>
                        <td><time datetime="@e.Timestamp.ToString("O")">@e.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</time></td>
                        <td>@e.ChangedBy</td>
                        <td>@FriendlyType(e.EntityType)</td>
                        <td><code>@e.EntityId</code></td>
                        <td><span class="audit-action audit-action--@e.Action.ToString().ToLowerInvariant()">@e.Action</span></td>
                        <td>
                            @if (string.IsNullOrEmpty(e.SnapshotJson))
                            {
                                <span class="muted">—</span>
                            }
                            else
                            {
                                <details>
                                    <summary>Show JSON</summary>
                                    <pre class="audit-snapshot"><code>@PrettyJson(e.SnapshotJson)</code></pre>
                                </details>
                            }
                        </td>
                        <td class="data-table__actions">
                            <a class="btn btn--sm" href="@($"/admin/audit/{e.Id}/diff")"
                               title="Compare this row's snapshot against the next change to the same entity">
                                <Icon Name="diff" Width="14" Height="14" />
                                <span>View change</span>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <nav class="audit-pagination" aria-label="Audit log pagination">
            <span class="muted">
                Showing @(_firstRowNumber.ToString("N0"))–@(_lastRowNumber.ToString("N0"))
                of @_total.ToString("N0").
            </span>
            <span class="audit-pagination__buttons">
                @{
                    var currentPage = Page ?? 1;
                    var hasPrev = currentPage > 1;
                    var hasNext = currentPage < _totalPages;
                }
                <a class="btn btn--sm @(hasPrev ? null : "btn--disabled")"
                   href="@BuildPageUrl(currentPage - 1)"
                   aria-disabled="@(hasPrev ? "false" : "true")"
                   tabindex="@(hasPrev ? 0 : -1)">
                    <Icon Name="chevron-left" Width="14" Height="14" />
                    <span>Previous</span>
                </a>
                <a class="btn btn--sm @(hasNext ? null : "btn--disabled")"
                   href="@BuildPageUrl(currentPage + 1)"
                   aria-disabled="@(hasNext ? "false" : "true")"
                   tabindex="@(hasNext ? 0 : -1)">
                    <span>Next</span>
                    <Icon Name="chevron-right" Width="14" Height="14" />
                </a>
            </span>
        </nav>
    }
</div>

@code {
    private const int PageSize = 50;

    [SupplyParameterFromQuery(Name = "entityType")] public string? EntityType { get; set; }
    [SupplyParameterFromQuery(Name = "action")] public string? Action { get; set; }
    [SupplyParameterFromQuery(Name = "entityId")] public string? EntityId { get; set; }
    [SupplyParameterFromQuery(Name = "actor")] public string? Actor { get; set; }
    [SupplyParameterFromQuery(Name = "from")] public string? FromUtc { get; set; }
    [SupplyParameterFromQuery(Name = "to")] public string? ToUtc { get; set; }
    [SupplyParameterFromQuery(Name = "page")] public int? Page { get; set; }

    private List<AuditLogEntry>? _entries;
    private int _total;
    private int _totalPages;
    private int _firstRowNumber;
    private int _lastRowNumber;

    protected override async Task OnParametersSetAsync()
    {
        if (Page is null or < 1) Page = 1;
        var filter = new AuditFilter(
            EntityType: Enum.TryParse<AuditEntityType>(EntityType, ignoreCase: false, out var et) ? et : null,
            Action: Enum.TryParse<AuditAction>(Action, ignoreCase: false, out var ac) ? ac : null,
            EntityId: string.IsNullOrWhiteSpace(EntityId) ? null : EntityId.Trim(),
            Actor: string.IsNullOrWhiteSpace(Actor) ? null : Actor,
            From: DateTime.TryParse(FromUtc, out var f) ? DateTime.SpecifyKind(f, DateTimeKind.Utc) : null,
            To: DateTime.TryParse(ToUtc, out var t) ? DateTime.SpecifyKind(t, DateTimeKind.Utc) : null);

        var skip = (Page!.Value - 1) * PageSize;
        var (items, total) = await Audit.GetPagedAsync(filter, skip, PageSize);
        _entries = items;
        _total = total;
        _totalPages = Math.Max(1, (int)Math.Ceiling(total / (double)PageSize));
        _firstRowNumber = total == 0 ? 0 : skip + 1;
        _lastRowNumber = skip + items.Count;
    }

    private bool HasAnyFilter() =>
        !string.IsNullOrWhiteSpace(EntityType)
        || !string.IsNullOrWhiteSpace(Action)
        || !string.IsNullOrWhiteSpace(EntityId)
        || !string.IsNullOrWhiteSpace(Actor)
        || !string.IsNullOrWhiteSpace(FromUtc)
        || !string.IsNullOrWhiteSpace(ToUtc);

    private string BuildPageUrl(int page)
    {
        var parts = new List<string>(8);
        if (!string.IsNullOrWhiteSpace(EntityType)) parts.Add("entityType=" + Uri.EscapeDataString(EntityType));
        if (!string.IsNullOrWhiteSpace(Action)) parts.Add("action=" + Uri.EscapeDataString(Action));
        if (!string.IsNullOrWhiteSpace(EntityId)) parts.Add("entityId=" + Uri.EscapeDataString(EntityId));
        if (!string.IsNullOrWhiteSpace(Actor)) parts.Add("actor=" + Uri.EscapeDataString(Actor));
        if (!string.IsNullOrWhiteSpace(FromUtc)) parts.Add("from=" + Uri.EscapeDataString(FromUtc));
        if (!string.IsNullOrWhiteSpace(ToUtc)) parts.Add("to=" + Uri.EscapeDataString(ToUtc));
        if (page > 1) parts.Add("page=" + page);
        return parts.Count == 0 ? "/admin/audit" : "/admin/audit?" + string.Join("&", parts);
    }

    private static string FriendlyType(AuditEntityType type) => type switch
    {
        AuditEntityType.RuntimeTemplate => "Template",
        AuditEntityType.WorkspaceExtension => "Extension",
        AuditEntityType.WorkspaceExtensionFolder => "Extension folder",
        AuditEntityType.WorkspaceExtensionFile => "Extension file",
        AuditEntityType.WorkspaceExtensionDependency => "Extension dependency",
        AuditEntityType.ModuleExtensionFolder => "Module folder",
        AuditEntityType.ModuleExtensionFile => "Module file",
        // Pre-unified labels — still used for historical rows written before
        // 20260514000000_UnifyExtensions.
        AuditEntityType.TemplateFolder => "Template folder",
        AuditEntityType.TemplateFile => "Template file",
        AuditEntityType.TemplateModuleFolder => "Template module folder",
        AuditEntityType.TemplateModuleFile => "Template module file",
        AuditEntityType.RuntimeTemplateDefaultModule => "Template default module",
        AuditEntityType.Module => "Module",
        AuditEntityType.ModuleDependency => "Module dependency",
        AuditEntityType.WellKnownDependency => "Catalogue entry",
        _ => type.ToString()
    };
}
