@*
    Top-level navigation for the admin Object Explorer area: Releases (the
    imported-release list) and Import (the upload / artifact / C·AL entry points).
    Each tab is a real <a href> via the shared PillTabs so every surface is
    bookmarkable and the back button behaves. Project builds moved to the Projects
    and Artifacts tools; see .design/artifacts.md.
*@

@using ALDevToolbox.Components.Shared

<header class="admin-page__header">
    <div>
        <h1>Object Explorer</h1>
        <p class="muted">@Subtitle</p>
    </div>
    @if (HeaderActions is not null)
    {
        <div class="admin-page__header-actions">
            @HeaderActions
        </div>
    }
</header>

<PillTabs Items="@_tabs" AriaLabel="Object Explorer section" />

@code {
    public enum Tab { Releases, Import }

    [Parameter, EditorRequired] public Tab ActiveTab { get; set; }

    /// <summary>Optional per-page actions rendered in the header (e.g. a "New project" button).</summary>
    [Parameter] public RenderFragment? HeaderActions { get; set; }

    private string Subtitle => ActiveTab switch
    {
        Tab.Releases  => "Imported releases in this organisation - browse their AL objects, references and source.",
        Tab.Import    => "Bring a release in: a Microsoft artifact, a third-party .app, or a legacy C/AL export.",
        _             => "",
    };

    private IReadOnlyList<PillTabs.PillTabItem> _tabs = Array.Empty<PillTabs.PillTabItem>();

    protected override void OnParametersSet()
    {
        _tabs = new List<PillTabs.PillTabItem>
        {
            new("Releases",  "/admin/object-explorer",           "layers", ActiveTab == Tab.Releases),
            new("Import",    "/admin/object-explorer/new/artifacts", "download", ActiveTab == Tab.Import),
        };
    }
}
