@page "/admin/modules"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@inject ModuleService Modules
@inject ILogger<AdminModuleList> Log
@using ALDevToolbox.Domain.Entities
@using ALDevToolbox.Domain.ValueObjects
@using static ALDevToolbox.Components.Shared.AdminPageHelpers

<PageTitle>Modules · Admin · AL Dev Toolbox</PageTitle>

<div class="admin-page">
    <header class="admin-page__header">
        <div>
            <h1>Modules</h1>
            <p class="muted">
                Modules drive the New Workspace module picker. Each module
                contributes its own extension folder and a dependency list to
                the generated <code>app.json</code>. Edits here apply on the
                next generation.
            </p>
        </div>
        <a class="btn btn--sm" href="/admin">
            <Icon Name="arrow-left" Width="14" Height="14" />
            <span>Back to admin</span>
        </a>
    </header>

    <div class="admin-page__toolbar">
        <label class="check-row">
            <input type="checkbox" @bind="_showDeleted" @bind:after="ReloadAsync" />
            <span>Show soft-deleted</span>
        </label>
        <label class="check-row">
            <input type="checkbox" @bind="_hideDeprecated" />
            <span>Hide deprecated</span>
        </label>
    </div>

    @if (_rows is null)
    {
        <p class="muted">Loading…</p>
    }
    else if (FilteredRows.Count == 0)
    {
        @if (_rows.Count == 0)
        {
            <p class="muted">
                No modules yet. Click <strong>New module</strong> to add one,
                or import a template from the site catalogue on the
                <a href="/admin/templates">Templates</a> page — referenced
                modules come along for the ride.
            </p>
        }
        else
        {
            <p class="muted">
                No modules match the current filters. Untick
                <strong>Hide deprecated</strong> to see deprecated rows.
            </p>
        }
    }
    else
    {
        @if (_selected.Count > 0)
        {
            <div class="bulk-bar" role="region" aria-label="Bulk actions" aria-live="polite">
                <span class="bulk-bar__summary">@_selected.Count selected</span>
                <div class="bulk-bar__actions">
                    <button type="button" class="btn btn--sm btn--danger" @onclick="() => RequestBulkAsync(BulkAction.SoftDelete)" disabled="@_busy">
                        <Icon Name="trash-2" Width="14" Height="14" />
                        <span>Delete</span>
                    </button>
                    <button type="button" class="btn btn--sm" @onclick="() => RequestBulkAsync(BulkAction.Restore)" disabled="@_busy">
                        <Icon Name="rotate-ccw" Width="14" Height="14" />
                        <span>Restore</span>
                    </button>
                    <button type="button" class="btn btn--sm" @onclick="ClearSelection" disabled="@_busy">
                        <Icon Name="x" Width="14" Height="14" />
                        <span>Clear</span>
                    </button>
                </div>
                @if (_lastError is not null)
                {
                    <p class="bulk-bar__error" role="alert">@_lastError</p>
                }
                @if (_lastSuccess is not null)
                {
                    <p class="bulk-bar__success" role="status">@_lastSuccess</p>
                }
            </div>
        }

        @if (_lastFailures.Count > 0)
        {
            <div class="bulk-failures">
                <h3>Some entries couldn't be processed</h3>
                <ul>
                    @foreach (var f in _lastFailures)
                    {
                        <li><strong>@f.DisplayName</strong> (id @f.Id): @f.Reason</li>
                    }
                </ul>
            </div>
        }

        <table class="data-table">
            <thead>
                <tr>
                    <th class="bulk-checkbox">
                        <input type="checkbox" aria-label="Select all visible"
                               checked="@AllVisibleSelected" @onchange="ToggleSelectAllVisible" />
                    </th>
                    <th>Key</th>
                    <th>Name</th>
                    <th>Dependencies</th>
                    <th>ID range size</th>
                    <th>Status</th>
                    <th>Last updated (UTC)</th>
                    <th class="data-table__actions"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var m in FilteredRows)
                {
                    <tr class="@(m.DeletedAt is not null ? "data-table__row--muted" : null)">
                        <td class="bulk-checkbox">
                            <input type="checkbox" aria-label="@($"Select {m.Name}")"
                                   checked="@_selected.Contains(m.Id)"
                                   @onchange="(e) => ToggleRow(m.Id, e)" />
                        </td>
                        <td><code>@m.Key</code></td>
                        <td>@m.Name</td>
                        <td>@m.Dependencies.Count</td>
                        <td>@(m.IdRangeSize?.ToString() ?? "—")</td>
                        <td>@SoftDeleteStatus(m.DeletedAt, m.Deprecated)</td>
                        <td><time datetime="@m.UpdatedAt.ToString("O")">@m.UpdatedAt.ToString("yyyy-MM-dd HH:mm:ss")</time></td>
                        <td class="data-table__actions">
                            <a class="btn btn--sm" href="@($"/admin/modules/{Uri.EscapeDataString(m.Key)}")">
                                <Icon Name="pencil" Width="14" Height="14" />
                                <span>Edit</span>
                            </a>
                            @if (m.DeletedAt is not null)
                            {
                                <button type="button" class="btn btn--sm"
                                        @onclick="() => RequestRestoreAsync(m)" disabled="@_busy">
                                    <Icon Name="rotate-ccw" Width="14" Height="14" />
                                    <span>Restore</span>
                                </button>
                            }
                            else
                            {
                                <button type="button" class="btn btn--sm btn--danger"
                                        @onclick="() => RequestDeleteAsync(m)" disabled="@_busy">
                                    <Icon Name="trash-2" Width="14" Height="14" />
                                    <span>Delete</span>
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <div class="admin-page__footer-actions">
        <a class="btn btn--primary" href="/admin/modules/new">
            <Icon Name="package-plus" Width="16" Height="16" />
            <span>New module</span>
        </a>
    </div>
</div>

<ConfirmDialog @ref="_confirm" />

@code {
    private bool _showDeleted;
    private bool _hideDeprecated;
    private List<Module>? _rows;
    private readonly HashSet<int> _selected = new();
    private bool _busy;
    private string? _lastError;
    private string? _lastSuccess;
    private IReadOnlyList<BulkActionFailure> _lastFailures = Array.Empty<BulkActionFailure>();
    private ConfirmDialog? _confirm;

    private enum BulkAction { SoftDelete, Restore }

    private List<Module> FilteredRows => _rows is null
        ? new()
        : (_hideDeprecated ? _rows.Where(m => !m.Deprecated).ToList() : _rows);

    private bool AllVisibleSelected =>
        FilteredRows.Count > 0 && FilteredRows.All(m => _selected.Contains(m.Id));

    protected override Task OnInitializedAsync() => ReloadAsync();

    private async Task ReloadAsync()
    {
        _rows = null;
        StateHasChanged();
        _rows = await Modules.GetAllForAdminAsync(includeDeleted: _showDeleted);
        _selected.RemoveWhere(id => !_rows.Any(r => r.Id == id));
    }

    private void ToggleRow(int id, ChangeEventArgs e)
    {
        if (e.Value is bool checkedNow && checkedNow) _selected.Add(id);
        else _selected.Remove(id);
    }

    private void ToggleSelectAllVisible(ChangeEventArgs e)
    {
        var checkedNow = e.Value is bool b && b;
        foreach (var m in FilteredRows)
        {
            if (checkedNow) _selected.Add(m.Id);
            else _selected.Remove(m.Id);
        }
    }

    private void ClearSelection()
    {
        _selected.Clear();
        _lastError = null;
        _lastSuccess = null;
        _lastFailures = Array.Empty<BulkActionFailure>();
    }

    private async Task RequestDeleteAsync(Module module)
    {
        if (_busy || _confirm is null) return;
        var confirmed = await _confirm.OpenAsync(
            title: $"Delete {module.Name}?",
            message: "It will disappear from the New Workspace module picker. You can restore it from this list while \"Show soft-deleted\" is ticked.",
            confirmLabel: "Delete",
            confirmButtonClass: "btn--danger");
        if (!confirmed) return;
        await RunSingleAsync(module, () => Modules.SoftDeleteAsync(module.Id), $"Deleted {module.Name}.", "delete");
    }

    private async Task RequestRestoreAsync(Module module)
    {
        if (_busy) return;
        await RunSingleAsync(module, () => Modules.RestoreAsync(module.Id), $"Restored {module.Name}.", "restore");
    }

    private async Task RunSingleAsync(Module module, Func<Task> action, string successMessage, string verb)
    {
        _busy = true;
        _lastError = null;
        _lastSuccess = null;
        _lastFailures = Array.Empty<BulkActionFailure>();
        try
        {
            await action();
            _lastSuccess = successMessage;
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Failed to {Verb} module id={Id}.", verb, module.Id);
            _lastError = $"Couldn't {verb} the module. Check the logs.";
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task RequestBulkAsync(BulkAction action)
    {
        if (_selected.Count == 0 || _busy || _rows is null) return;
        var ids = _selected.ToList();
        var affected = _rows.Where(r => ids.Contains(r.Id)).ToList();
        var label = action switch
        {
            BulkAction.SoftDelete => "delete",
            BulkAction.Restore => "restore",
            _ => action.ToString(),
        };
        if (_confirm is not null)
        {
            var names = string.Join(", ", affected.Take(8).Select(m => m.Name));
            if (affected.Count > 8) names += $", and {affected.Count - 8} more";
            var confirmed = await _confirm.OpenAsync(
                title: $"{Capitalize(label)} {affected.Count} module(s)?",
                message: $"This will {label}: {names}.",
                confirmLabel: Capitalize(label),
                confirmButtonClass: action == BulkAction.SoftDelete ? "btn--danger" : "btn--primary");
            if (!confirmed) return;
        }

        _busy = true;
        _lastError = null;
        _lastSuccess = null;
        _lastFailures = Array.Empty<BulkActionFailure>();
        try
        {
            BulkActionResult result = action switch
            {
                BulkAction.SoftDelete => await Modules.BulkSoftDeleteAsync(ids),
                BulkAction.Restore => await Modules.BulkRestoreAsync(ids),
                _ => throw new InvalidOperationException($"Unknown action {action}"),
            };
            _lastFailures = result.Failures;
            if (result.AllSucceeded)
            {
                _lastSuccess = $"Bulk {label} applied to {result.SucceededCount} module(s).";
            }
            else if (result.SucceededCount == 0)
            {
                _lastError = $"Bulk {label} failed for all {result.FailedCount} selected row(s). See details below.";
            }
            else
            {
                _lastSuccess = $"Bulk {label} applied to {result.SucceededCount} of {result.TotalRequested} module(s).";
            }
            _selected.Clear();
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Bulk {Action} on modules raised an unexpected error.", label);
            _lastError = "An unexpected error occurred. The change was not saved.";
        }
        finally
        {
            _busy = false;
        }
    }

}
