@page "/admin/modules"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@inject ModuleService Modules
@using ALDevToolbox.Domain.Entities

<PageTitle>Modules · Admin · AL Dev Toolbox</PageTitle>

<div class="admin-page">
    <header class="admin-page__header">
        <div>
            <h1>Modules</h1>
            <p class="muted">
                Modules drive the New Workspace module picker. Each module
                contributes its own extension folder and a dependency list to
                the generated <code>app.json</code>. Edits here apply on the
                next generation.
            </p>
        </div>
        <a class="btn btn--primary" href="/admin/modules/new">
            <Icon Name="package-plus" Width="16" Height="16" />
            <span>New module</span>
        </a>
    </header>

    <div class="admin-page__toolbar">
        <label class="check-row">
            <input type="checkbox" @bind="_showDeleted" @bind:after="ReloadAsync" />
            <span>Show soft-deleted</span>
        </label>
        <label class="check-row">
            <input type="checkbox" @bind="_hideDeprecated" />
            <span>Hide deprecated</span>
        </label>
    </div>

    @if (_rows is null)
    {
        <p class="muted">Loading…</p>
    }
    else if (FilteredRows.Count == 0)
    {
        @if (_rows.Count == 0)
        {
            <p class="muted">
                No modules yet. Click <strong>New module</strong> to add one, or
                populate <code>Templates.seed/modules.toml</code> and restart the
                app to seed from TOML.
            </p>
        }
        else
        {
            <p class="muted">
                No modules match the current filters. Untick
                <strong>Hide deprecated</strong> to see deprecated rows.
            </p>
        }
    }
    else
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>Key</th>
                    <th>Name</th>
                    <th>Dependencies</th>
                    <th>ID range size</th>
                    <th>Status</th>
                    <th>Last updated (UTC)</th>
                    <th class="data-table__actions"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var m in FilteredRows)
                {
                    <tr class="@(m.DeletedAt is not null ? "data-table__row--muted" : null)">
                        <td><code>@m.Key</code></td>
                        <td>@m.Name</td>
                        <td>@m.Dependencies.Count</td>
                        <td>@(m.IdRangeSize?.ToString() ?? "—")</td>
                        <td>@StatusFor(m)</td>
                        <td><time datetime="@m.UpdatedAt.ToString("O")">@m.UpdatedAt.ToString("yyyy-MM-dd HH:mm:ss")</time></td>
                        <td class="data-table__actions">
                            <a class="btn btn--sm" href="@($"/admin/modules/{Uri.EscapeDataString(m.Key)}")">
                                <Icon Name="pencil" Width="14" Height="14" />
                                <span>Edit</span>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private bool _showDeleted;
    private bool _hideDeprecated;
    private List<Module>? _rows;

    private List<Module> FilteredRows => _rows is null
        ? new()
        : (_hideDeprecated ? _rows.Where(m => !m.Deprecated).ToList() : _rows);

    protected override Task OnInitializedAsync() => ReloadAsync();

    private async Task ReloadAsync()
    {
        _rows = null;
        StateHasChanged();
        _rows = await Modules.GetAllForAdminAsync(includeDeleted: _showDeleted);
    }

    private static string StatusFor(Module m)
    {
        if (m.DeletedAt is not null) return "Deleted";
        if (m.Deprecated) return "Deprecated";
        return "Active";
    }
}
