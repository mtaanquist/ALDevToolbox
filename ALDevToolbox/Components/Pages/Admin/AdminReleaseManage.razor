@page "/admin/object-explorer/release/{ReleaseId:int}/manage"
@attribute [Authorize(Roles = "Admin,Editor")]
@inject ALDevToolbox.Services.ObjectExplorer.ObjectExplorerService ObjectExplorer
@inject ALDevToolbox.Services.ObjectExplorer.PersistedImportJobs ImportJobs
@inject IHttpContextAccessor Http
@using ALDevToolbox.Services.ObjectExplorer

@*
    Per-release admin hub. Consolidates everything that used to crowd the
    Object Explorer list's action column: editable metadata (publisher /
    project), links to the Add-modules and Translations sub-pages, and the
    soft-delete / restore / hard-delete actions. Statically rendered so the
    forms post normally to the Object Explorer endpoints.
*@

<PageTitle>Manage · @(_release?.Label ?? "Release") · AL Dev Toolbox</PageTitle>

<div class="admin-page">
    <header class="admin-page__header">
        <div>
            <h1>Manage release</h1>
            @if (_release is not null)
            {
                <p class="muted">
                    @_release.Label · @FormatKind(_release.Kind) · @FormatStatus(_release.Status, _release.Kind)
                    @if (!string.IsNullOrEmpty(_release.BcVersion))
                    {
                        <span> · BC @_release.BcVersion</span>
                    }
                    <span> · @_release.ModuleCount module(s)</span>
                    @if (_release.DeletedAt is not null)
                    {
                        <span> · soft-deleted</span>
                    }
                </p>
            }
        </div>
        <a class="btn btn--sm" href="/admin/object-explorer">
            <Icon Name="arrow-left" Width="14" Height="14" />
            <span>Back to releases</span>
        </a>
    </header>

    @if (Status is { } status)
    {
        @if (status.IsError)
        {
            <div class="form-error" role="alert"><p>@status.Message</p></div>
        }
        else
        {
            <p class="form-success" role="status">@status.Message</p>
        }
    }

    @if (_release is null)
    {
        <p class="muted">Release not found. <a href="/admin/object-explorer">Back to releases</a>.</p>
    }
    else
    {
        <section class="manage-card">
            <h2 class="manage-card__title">Details</h2>
            <form method="post" action="@($"/admin/object-explorer/{ReleaseId}/metadata")" class="form-grid">
                <AntiforgeryToken />
                <section class="form-section">
                    <label class="field">
                        <span class="field__label">Publisher</span>
                        <input type="text" name="Publisher" maxlength="200"
                               value="@_release.Publisher"
                               placeholder="e.g. Continia Software"
                               class="field__input" />
                        <small class="field__caption muted">Who owns this extension — handy when you've taken over an app someone else built.</small>
                    </label>
                    <label class="field">
                        <span class="field__label">Project</span>
                        <input type="text" name="ProjectName" maxlength="200"
                               value="@_release.ProjectName"
                               placeholder="e.g. Acme Co"
                               class="field__input" />
                        <small class="field__caption muted">The project a project-specific bundle belongs to.</small>
                    </label>
                </section>
                <section class="form-section">
                    <button type="submit" class="btn btn--primary">
                        <Icon Name="save" Width="16" Height="16" />
                        <span>Save details</span>
                    </button>
                </section>
            </form>
        </section>

        <section class="manage-card">
            <h2 class="manage-card__title">Content</h2>
            <p class="muted">Amend more <code>.app</code> modules into this release, or attach XLIFF translation files.</p>
            <div class="manage-card__actions">
                <a class="btn" href="@($"/admin/object-explorer/release/{ReleaseId}/modules")">
                    <Icon Name="package-plus" Width="16" Height="16" />
                    <span>Add modules</span>
                </a>
                <a class="btn" href="@($"/admin/object-explorer/release/{ReleaseId}/translations")">
                    <Icon Name="book-open" Width="16" Height="16" />
                    <span>Import translations</span>
                </a>
                @if (_release.DeletedAt is null)
                {
                    <form method="post" action="@($"/admin/object-explorer/{ReleaseId}/backfill-system-references")">
                        <AntiforgeryToken />
                        <button type="submit" class="btn" title="Re-extract built-in/system method calls (Insert, Modify, SetRange, …) over stored source. Needed for releases imported before this feature shipped.">
                            <Icon Name="rotate-ccw" Width="16" Height="16" />
                            <span>Backfill system references</span>
                        </button>
                    </form>
                }
            </div>
        </section>

        @if (_release.Kind == "project" && _buildResults.Count > 0)
        {
            <section class="manage-card">
                <h2 class="manage-card__title">
                    Build report
                    @if (_isPartial)
                    {
                        <span class="badge--warning" title="Some extensions failed to compile; the release was published with the ones that did.">partial</span>
                    }
                </h2>
                <p class="muted">Each extension compiled from the project's repositories. A failed row didn't make it into the release.</p>
                <table class="data-table data-table--card">
                    <thead>
                        <tr><th>Extension</th><th>Status</th><th>Source</th><th>Detail</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var r in _buildResults)
                        {
                            <tr>
                                <td>@(string.IsNullOrEmpty(r.AppName) ? "—" : r.AppName)</td>
                                <td><span class="@BuildBadgeClass(r.Status)">@r.Status</span></td>
                                <td class="muted">
                                    @if (!string.IsNullOrEmpty(r.RepoUrl))
                                    {
                                        <a href="@r.RepoUrl" target="_blank" rel="noopener noreferrer">@RepoName(r.RepoUrl)</a>
                                        @if (!string.IsNullOrEmpty(r.CommitSha))
                                        {
                                            <span> · <code>@ShortSha(r.CommitSha)</code></span>
                                        }
                                        @if (r.CommitDate is { } d)
                                        {
                                            <span> · @d.ToString("yyyy-MM-dd")</span>
                                        }
                                    }
                                    else
                                    {
                                        <span>—</span>
                                    }
                                </td>
                                <td class="muted">@(string.IsNullOrEmpty(r.Message) ? "—" : r.Message)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </section>
        }

        @if (_release.Kind == "project" && _release.DeletedAt is null
             && (_release.Status == "ready" || _release.Status == "failed")
             && _buildResults.Any(r => r.Status == "failed"))
        {
            <section class="manage-card">
                <h2 class="manage-card__title">Supply missing symbols</h2>
                <p class="muted">
                    An extension failed to compile because a third-party dependency's symbols
                    weren't in the repository or any Business Central artifact. Upload the
                    dependency's <code>.app</code> here and rebuild — the symbols are kept with
                    the project, so future builds use them too. The previous attempt's data is
                    cleared and replaced by the rebuild.
                </p>
                <form method="post" action="@($"/admin/object-explorer/{ReleaseId}/recover-symbols")"
                      enctype="multipart/form-data" class="form-grid">
                    <AntiforgeryToken />
                    <section class="form-section">
                        <label class="field">
                            <span class="field__label">Dependency symbols (.app)</span>
                            <input type="file" name="Symbols" accept=".app" multiple required class="field__input" />
                            <small class="field__caption muted">Pick one or more compiled <code>.app</code> packages — the dependencies named in the build report above.</small>
                        </label>
                        <button type="submit" class="btn btn--primary">
                            <Icon Name="hammer" Width="16" Height="16" />
                            <span>Upload &amp; rebuild</span>
                        </button>
                    </section>
                </form>
            </section>
        }

        @if ((_release.Status == "failed" || _isPartial) && _release.DeletedAt is null && _release.Kind == "project")
        {
            <section class="manage-card">
                <h2 class="manage-card__title">Retry build</h2>
                @if (!string.IsNullOrEmpty(_release.StatusMessage))
                {
                    <p class="muted">Last attempt failed: <span class="manage-card__reason">@_release.StatusMessage</span></p>
                }
                <p class="muted">
                    Re-clones the project's repositories at their latest commit and rebuilds into this same
                    release. The previous attempt's partial data is cleared first.
                    @if (_isPartial)
                    {
                        <text>Use this when some extensions failed for a transient reason; supply missing
                        dependency symbols above instead if the failures were unmet dependencies.</text>
                    }
                </p>
                <form method="post" action="@($"/admin/object-explorer/{ReleaseId}/retry")" class="form-grid">
                    <AntiforgeryToken />
                    <section class="form-section">
                        <button type="submit" class="btn btn--primary">
                            <Icon Name="rotate-ccw" Width="16" Height="16" />
                            <span>Retry build</span>
                        </button>
                    </section>
                </form>
            </section>
        }

        @if (_release.Status == "failed" && _release.DeletedAt is null && _release.Kind != "project")
        {
            <section class="manage-card">
                <h2 class="manage-card__title">Retry import</h2>
                @if (!string.IsNullOrEmpty(_release.StatusMessage))
                {
                    <p class="muted">Last attempt failed: <span class="manage-card__reason">@_release.StatusMessage</span></p>
                }
                <p class="muted">
                    Re-runs the import into this same release — the label and metadata stay put, and the
                    previous attempt's partial data is cleared first so the re-run starts clean.
                </p>
                <form method="post" action="@($"/admin/object-explorer/{ReleaseId}/retry")"
                      enctype="multipart/form-data" class="form-grid">
                    <AntiforgeryToken />
                    <section class="form-section">
                        @if (_origin is null || _origin.Kind == "url")
                        {
                            <label class="field">
                                <span class="field__label">Download URL</span>
                                <input type="url" name="DvdUrl" inputmode="url"
                                       value="@(_origin?.DownloadUrl)"
                                       placeholder="https://download.microsoft.com/…/Dynamics.365.BC.…DVD.zip"
                                       class="field__input" />
                                <small class="field__caption muted">
                                    Leave the original URL to re-run it, or paste a corrected one (some older
                                    DVDs moved). The host must be on the SiteAdmin download allow-list.
                                </small>
                            </label>
                        }
                        @if (_origin?.Kind == "staged_zip")
                        {
                            <label class="field">
                                <span class="field__label">Re-upload application folder ZIP</span>
                                <input type="file" name="FolderZip" accept=".zip" class="field__input field__input--file" />
                                <small class="field__caption muted">
                                    The original upload isn't kept on disk after the import, so retrying an
                                    uploaded ZIP means picking the file again.
                                </small>
                            </label>
                        }
                        @if (_origin?.Kind == "cal_txt")
                        {
                            <label class="field">
                                <span class="field__label">Re-upload C/AL TXT export</span>
                                <input type="file" name="CalTxtFile" accept=".txt" class="field__input field__input--file" />
                                <small class="field__caption muted">The original upload isn't kept on disk, so pick the file again.</small>
                            </label>
                            <label class="field">
                                <span class="field__label">C/AL codepage</span>
                                <select name="CalEncoding" class="field__input">
                                    <option value="850" selected>IBM 850 (OEM — classic finsql default)</option>
                                    <option value="1252">Windows-1252</option>
                                </select>
                            </label>
                        }
                        <label class="checkbox-label">
                            <input type="checkbox" name="StoreSymbolReference" value="true"
                                   checked="@(_origin?.StoreSymbolReference ?? false)" />
                            Store each extension's <code>SymbolReference.json</code> for debugging
                        </label>
                    </section>
                    <section class="form-section">
                        <button type="submit" class="btn btn--primary">
                            <Icon Name="rotate-ccw" Width="16" Height="16" />
                            <span>Retry import</span>
                        </button>
                    </section>
                </form>
            </section>
        }

        <section class="manage-card manage-card--danger">
            <h2 class="manage-card__title">Danger zone</h2>
            @if (_release.DeletedAt is null)
            {
                <p class="muted">Soft-delete hides this release from the user-facing browser but keeps it queryable here. Reversible.</p>
                <form method="post" action="@($"/admin/object-explorer/{ReleaseId}/soft-delete")">
                    <AntiforgeryToken />
                    <button type="submit" class="btn">
                        <Icon Name="archive" Width="16" Height="16" />
                        <span>Soft delete</span>
                    </button>
                </form>
            }
            else
            {
                <p class="muted">This release is soft-deleted. Restore it, or permanently remove it and all its ingested data.</p>
                <div class="manage-card__actions">
                    <form method="post" action="@($"/admin/object-explorer/{ReleaseId}/restore")">
                        <AntiforgeryToken />
                        <button type="submit" class="btn">
                            <Icon Name="rotate-ccw" Width="16" Height="16" />
                            <span>Restore</span>
                        </button>
                    </form>
                </div>
                <form method="post" action="@($"/admin/object-explorer/{ReleaseId}/hard-delete")" class="hard-delete-form">
                    <AntiforgeryToken />
                    <input type="text" name="ConfirmLabel" required
                           class="field__input hard-delete-form__input"
                           placeholder="Type the label to confirm"
                           aria-label="Confirm label" />
                    <button type="submit" class="btn btn--danger">
                        <Icon Name="trash-2" Width="16" Height="16" />
                        <span>Permanently delete</span>
                    </button>
                </form>
            }
        </section>
    }
</div>

@code {
    [Parameter] public int ReleaseId { get; set; }

    private ReleaseDetail? _release;
    private ImportJobOrigin? _origin;
    private List<ProjectBuildResultRow> _buildResults = new();
    private bool _isPartial;
    private (string Message, bool IsError)? Status { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var ctx = Http.HttpContext;
        if (ctx is not null)
        {
            var err = ctx.Request.Query["err"].ToString();
            var msg = ctx.Request.Query["msg"].ToString();
            if (!string.IsNullOrEmpty(err) && !string.IsNullOrEmpty(msg))
            {
                Status = ($"{err}: {msg}", true);
            }
            else
            {
                var ok = ctx.Request.Query["ok"].ToString();
                if (!string.IsNullOrEmpty(ok))
                {
                    Status = (FormatOkMessage(ok), false);
                }
            }
        }

        _release = await ObjectExplorer.GetReleaseAsync(ReleaseId);
        // Only the failed-release retry card needs the original import source;
        // load it lazily so the common (ready) path skips the extra query.
        if (_release is { Status: "failed", DeletedAt: null })
        {
            _origin = await ImportJobs.GetLatestForReleaseAsync(ReleaseId);
        }
        // Project releases carry a per-app build report; a "ready" release with
        // a failed row is a partial build.
        if (_release is { Kind: "project" })
        {
            _buildResults = await ObjectExplorer.GetProjectBuildResultsAsync(ReleaseId);
            _isPartial = _release.Status == "ready" && _buildResults.Any(r => r.Status == "failed");
        }
    }

    private static string BuildBadgeClass(string status) => status switch
    {
        "ingested" => "badge--success",
        "compiled" => "badge--warning",
        "failed"   => "badge--danger",
        _          => "muted",
    };

    /// <summary>The repo's last path segment (e.g. "core") for a compact link label, sans any .git suffix.</summary>
    private static string RepoName(string url) =>
        url.TrimEnd('/').Split('/').LastOrDefault()?.Replace(".git", "") is { Length: > 0 } name ? name : url;

    private static string ShortSha(string sha) => sha.Length > 7 ? sha[..7] : sha;

    private static string FormatOkMessage(string ok) => ok switch
    {
        "updated"          => "Details saved.",
        "soft-deleted"     => "Release soft-deleted. Restore it below if that was a mistake.",
        "restored"         => "Release restored.",
        "retry-queued"     => "Import retry queued. It runs in the background; watch this release flip from Failed to Ingesting to Ready.",
        "recover-queued"   => "Symbols saved and rebuild queued. It runs in the background; watch this release flip to Building, then Ready.",
        "backfill-queued"  => "System-reference backfill queued. It runs in the background; check the workers page for progress.",
        _                  => "Done.",
    };

    private static string FormatKind(string kind) => kind switch
    {
        "first_party" => "First-party",
        "third_party" => "Third-party",
        "project"    => "Project",
        _             => kind,
    };

    private static string FormatStatus(string s, string kind) => s switch
    {
        "ready"                             => "Ready",
        "ingesting" when kind == "project" => "Building…",
        "ingesting"                         => "Ingesting…",
        "failed"                            => "Failed",
        _                                   => s,
    };
}
