@page "/admin/users"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@using ALDevToolbox.Data
@using ALDevToolbox.Domain.Entities
@using ALDevToolbox.Domain.ValueObjects
@using ALDevToolbox.Services
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db
@inject IOrganizationContext Org
@inject AccountService Accounts
@inject ILogger<AdminUsers> Log

<PageTitle>Users · AL Dev Toolbox</PageTitle>

<div class="admin-page">
    <header class="admin-page__header">
        <div>
            <h1>Users</h1>
            <p class="muted">
                Approve pending signups, invite new users, change roles, and
                disable accounts in your organisation.
            </p>
        </div>
        <a class="btn btn--sm" href="/admin">
            <Icon Name="arrow-left" Width="14" Height="14" />
            <span>Back to admin</span>
        </a>
    </header>

@if (!string.IsNullOrEmpty(Error))
{
    <p class="form-error" role="alert">@Error</p>
}
@if (Ok == "invited")
{
    <p class="form-success" role="status">Invite sent. The link is valid for 7 days.</p>
}
else if (Ok == "invite-revoked")
{
    <p class="form-success" role="status">Invite revoked.</p>
}

@if (_pending is null || _active is null || _invites is null)
{
    <p class="muted">Loading…</p>
}
else
{
    <section class="admin-section">
        <h2>Invite a user</h2>
        <p class="muted">Send a single-use invite link by email. The invitee picks a display name and password — no further approval required.</p>
        <form method="post" action="/admin/users/invite" class="form-grid">
            <AntiforgeryToken />
            <section class="form-section">
                <label class="section-label" for="inv-email">Email</label>
                <input id="inv-email" type="email" name="Email" required maxlength="254" placeholder="e.g. alice@example.com" />
            </section>
            <section class="form-section">
                <label class="section-label" for="inv-role">Role</label>
                <select id="inv-role" name="Role">
                    <option value="User" selected>User</option>
                    <option value="Admin">Administrator</option>
                </select>
            </section>
            <section class="form-section">
                <label class="section-label" for="inv-message">Welcome message (optional)</label>
                <textarea id="inv-message" name="WelcomeMessage" rows="3" maxlength="2000" placeholder="A short note shown in the invite email."></textarea>
            </section>
            <button type="submit" class="btn">
                <Icon Name="mail-plus" Width="16" Height="16" />
                <span>Send invite</span>
            </button>
        </form>
    </section>

    <section class="admin-section">
        <h2>Pending invites (@_invites.Count)</h2>
        @if (_invites.Count == 0)
        {
            <p class="muted">No pending invites.</p>
        }
        else
        {
            <table class="data-table">
                <thead>
                    <tr><th>Email</th><th>Role</th><th>Invited by</th><th>Expires</th><th></th></tr>
                </thead>
                <tbody>
                @foreach (var (invite, invitedBy) in _invites)
                {
                    <tr>
                        <td>@invite.Email</td>
                        <td><span class="status-pill @(invite.Role == UserRole.Admin ? "" : "status-pill--muted")">@invite.Role</span></td>
                        <td>@(invitedBy?.DisplayName ?? "—")</td>
                        <td class="muted">@invite.ExpiresAt.ToString("yyyy-MM-dd HH:mm 'UTC'")</td>
                        <td class="row-actions">
                            <form method="post" action="/admin/users/invites/@invite.Id/revoke" style="display:inline">
                                <AntiforgeryToken />
                                <button type="submit" class="btn btn--sm">Revoke</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </section>

    <section class="admin-section">
        <h2>Pending signups (@_pending.Count)</h2>
        @if (_pending.Count == 0)
        {
            <p class="muted">No pending signups.</p>
        }
        else
        {
            <table class="data-table">
                <thead>
                    <tr><th>Email</th><th>Display name</th><th>Requested</th><th></th></tr>
                </thead>
                <tbody>
                @foreach (var (request, user) in _pending)
                {
                    <tr>
                        <td>@request.Email</td>
                        <td>@(user?.DisplayName ?? "—")</td>
                        <td class="muted">@request.RequestedAt.ToString("yyyy-MM-dd HH:mm 'UTC'")</td>
                        <td class="row-actions">
                            <form method="post" action="/admin/users/@request.Id/approve" style="display:inline">
                                <AntiforgeryToken />
                                <button type="submit" class="btn btn--sm btn--primary">Approve</button>
                            </form>
                            <form method="post" action="/admin/users/@request.Id/reject" style="display:inline">
                                <AntiforgeryToken />
                                <button type="submit" class="btn btn--sm">Reject</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </section>

    <section class="admin-section">
        <h2>Active &amp; disabled (@_active.Count)</h2>

        @if (_selected.Count > 0)
        {
            <div class="bulk-bar" role="region" aria-label="Bulk actions" aria-live="polite">
                <span class="bulk-bar__summary">@_selected.Count selected</span>
                <div class="bulk-bar__actions">
                    <button type="button" class="btn btn--sm" @onclick="() => RequestBulkAsync(BulkAction.Disable)" disabled="@_busy">
                        <Icon Name="user-x" Width="14" Height="14" />
                        <span>Disable</span>
                    </button>
                    <button type="button" class="btn btn--sm" @onclick="() => RequestBulkAsync(BulkAction.Enable)" disabled="@_busy">
                        <Icon Name="user-check" Width="14" Height="14" />
                        <span>Re-enable</span>
                    </button>
                    <button type="button" class="btn btn--sm" @onclick="() => RequestBulkAsync(BulkAction.PromoteAdmin)" disabled="@_busy">
                        <Icon Name="shield" Width="14" Height="14" />
                        <span>Promote to Admin</span>
                    </button>
                    <button type="button" class="btn btn--sm" @onclick="() => RequestBulkAsync(BulkAction.DemoteUser)" disabled="@_busy">
                        <Icon Name="shield-off" Width="14" Height="14" />
                        <span>Demote to User</span>
                    </button>
                    <button type="button" class="btn btn--sm" @onclick="ClearSelection" disabled="@_busy">
                        <Icon Name="x" Width="14" Height="14" />
                        <span>Clear</span>
                    </button>
                </div>
                @if (_lastError is not null)
                {
                    <p class="bulk-bar__error" role="alert">@_lastError</p>
                }
                @if (_lastSuccess is not null)
                {
                    <p class="bulk-bar__success" role="status">@_lastSuccess</p>
                }
            </div>
        }

        @if (_lastFailures.Count > 0)
        {
            <div class="bulk-failures">
                <h3>Some users couldn't be updated</h3>
                <ul>
                    @foreach (var f in _lastFailures)
                    {
                        <li><strong>@f.DisplayName</strong> (id @f.Id): @f.Reason</li>
                    }
                </ul>
            </div>
        }

        <table class="data-table">
            <thead>
                <tr>
                    <th class="bulk-checkbox">
                        <input type="checkbox" aria-label="Select all visible"
                               checked="@AllVisibleSelected" @onchange="ToggleSelectAllVisible" />
                    </th>
                    <th>Email</th>
                    <th>Display name</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th>Last login</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var u in _active)
            {
                <tr>
                    <td class="bulk-checkbox">
                        <input type="checkbox" aria-label="@($"Select {u.DisplayName}")"
                               checked="@_selected.Contains(u.Id)"
                               @onchange="(e) => ToggleRow(u.Id, e)" />
                    </td>
                    <td>@u.Email</td>
                    <td>@u.DisplayName</td>
                    <td>
                        <select class="row-role-select" aria-label="@($"Role for {u.DisplayName}")"
                                value="@u.Role"
                                disabled="@_busy"
                                @onchange="(e) => ChangeRoleAsync(u, e)">
                            @foreach (var role in Enum.GetValues<UserRole>())
                            {
                                <option value="@role">@role</option>
                            }
                        </select>
                    </td>
                    <td><span class="status-pill @(u.Status == UserStatus.Active ? "" : "status-pill--warn")">@u.Status</span></td>
                    <td class="muted">@(u.LastLoginAt?.ToString("yyyy-MM-dd HH:mm 'UTC'") ?? "—")</td>
                    <td class="row-actions">
                        @if (u.Status == UserStatus.Active)
                        {
                            <form method="post" action="/admin/users/@u.Id/disable" style="display:inline">
                                <AntiforgeryToken />
                                <button type="submit" class="btn btn--sm">Disable</button>
                            </form>
                        }
                        else if (u.Status == UserStatus.Disabled)
                        {
                            <form method="post" action="/admin/users/@u.Id/enable" style="display:inline">
                                <AntiforgeryToken />
                                <button type="submit" class="btn btn--sm">Re-enable</button>
                            </form>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </section>
}
</div>

<ConfirmDialog @ref="_confirm" />

@code {
    [SupplyParameterFromQuery(Name = "err")] public string? Error { get; set; }
    [SupplyParameterFromQuery(Name = "ok")] public string? Ok { get; set; }

    private List<(SignupRequest Request, User? User)>? _pending;
    private List<User>? _active;
    private List<(Invite Invite, User? InvitedBy)>? _invites;

    private readonly HashSet<int> _selected = new();
    private bool _busy;
    private string? _lastError;
    private string? _lastSuccess;
    private IReadOnlyList<BulkActionFailure> _lastFailures = Array.Empty<BulkActionFailure>();
    private ConfirmDialog? _confirm;

    private enum BulkAction { Disable, Enable, PromoteAdmin, DemoteUser }

    private bool AllVisibleSelected =>
        _active is { Count: > 0 } && _active.All(u => _selected.Contains(u.Id));

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        var orgId = Org.CurrentOrganizationId;
        if (orgId is null) return;

        var pendingRows = await Db.SignupRequests
            .IgnoreQueryFilters()
            .AsNoTracking()
            .Where(r => r.OrganizationId == orgId.Value && r.Decision == SignupDecision.Pending)
            .OrderBy(r => r.RequestedAt)
            .ToListAsync();
        _pending = new();
        foreach (var req in pendingRows)
        {
            User? user = null;
            if (req.UserId is int uid)
            {
                user = await Db.Users.IgnoreQueryFilters().AsNoTracking()
                    .FirstOrDefaultAsync(u => u.Id == uid);
            }
            _pending.Add((req, user));
        }

        _active = await Db.Users
            .IgnoreQueryFilters()
            .AsNoTracking()
            .Where(u => u.OrganizationId == orgId.Value && u.Status != UserStatus.Pending)
            .OrderBy(u => u.Status == UserStatus.Active ? 0 : 1)
            .ThenBy(u => u.DisplayName)
            .ToListAsync();
        _selected.RemoveWhere(id => !_active.Any(u => u.Id == id));

        var now = DateTime.UtcNow;
        var pendingInvites = await Db.Invites
            .AsNoTracking()
            .Where(i => i.AcceptedAt == null && i.RevokedAt == null && i.ExpiresAt > now)
            .OrderBy(i => i.ExpiresAt)
            .ToListAsync();
        _invites = new();
        foreach (var inv in pendingInvites)
        {
            var by = await Db.Users.IgnoreQueryFilters().AsNoTracking()
                .FirstOrDefaultAsync(u => u.Id == inv.InvitedByUserId);
            _invites.Add((inv, by));
        }
    }

    private void ToggleRow(int id, ChangeEventArgs e)
    {
        if (e.Value is bool checkedNow && checkedNow) _selected.Add(id);
        else _selected.Remove(id);
    }

    private void ToggleSelectAllVisible(ChangeEventArgs e)
    {
        var checkedNow = e.Value is bool b && b;
        if (_active is null) return;
        foreach (var u in _active)
        {
            if (checkedNow) _selected.Add(u.Id);
            else _selected.Remove(u.Id);
        }
    }

    private void ClearSelection()
    {
        _selected.Clear();
        _lastError = null;
        _lastSuccess = null;
        _lastFailures = Array.Empty<BulkActionFailure>();
    }

    private async Task ChangeRoleAsync(User user, ChangeEventArgs e)
    {
        if (_busy || _active is null) return;
        var orgId = Org.CurrentOrganizationId;
        if (orgId is null) return;
        var raw = e.Value?.ToString();
        if (string.IsNullOrEmpty(raw) || !Enum.TryParse<UserRole>(raw, out var newRole) || newRole == user.Role)
        {
            return;
        }

        if (_confirm is not null)
        {
            var confirmed = await _confirm.OpenAsync(
                title: $"Change {user.DisplayName}'s role?",
                message: $"Set role to {newRole}. The change applies immediately.",
                confirmLabel: "Change role",
                confirmButtonClass: newRole == UserRole.User ? "btn--danger" : "btn--primary");
            if (!confirmed)
            {
                // The select's bound value already changed; reload restores it.
                await LoadAsync();
                return;
            }
        }

        _busy = true;
        _lastError = null;
        _lastSuccess = null;
        try
        {
            await Accounts.ChangeRoleAsync(user.Id, newRole, orgId.Value);
            _lastSuccess = $"{user.DisplayName} is now a {newRole}.";
            await LoadAsync();
        }
        catch (PlanValidationException ex)
        {
            _lastError = ex.Errors.FirstOrDefault().Value ?? "The role change was rejected.";
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Failed to change role for user {Id}.", user.Id);
            _lastError = "An unexpected error occurred. The role was not changed.";
            await LoadAsync();
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task RequestBulkAsync(BulkAction action)
    {
        if (_selected.Count == 0 || _busy || _active is null) return;
        var orgId = Org.CurrentOrganizationId;
        if (orgId is null) return;

        var ids = _selected.ToList();
        var affected = _active.Where(u => ids.Contains(u.Id)).ToList();
        var label = action switch
        {
            BulkAction.Disable => "disable",
            BulkAction.Enable => "re-enable",
            BulkAction.PromoteAdmin => "promote to Admin",
            BulkAction.DemoteUser => "demote to User",
            _ => action.ToString(),
        };
        if (_confirm is not null)
        {
            var names = string.Join(", ", affected.Take(8).Select(u => u.DisplayName));
            if (affected.Count > 8) names += $", and {affected.Count - 8} more";
            var confirmed = await _confirm.OpenAsync(
                title: $"{Capitalize(label)} {affected.Count} user(s)?",
                message: $"This will {label}: {names}.",
                confirmLabel: Capitalize(label),
                confirmButtonClass: action == BulkAction.Disable ? "btn--danger" : "btn--primary");
            if (!confirmed) return;
        }

        _busy = true;
        _lastError = null;
        _lastSuccess = null;
        _lastFailures = Array.Empty<BulkActionFailure>();
        try
        {
            BulkActionResult result = action switch
            {
                BulkAction.Disable => await Accounts.BulkDisableUsersAsync(ids, orgId.Value),
                BulkAction.Enable => await Accounts.BulkEnableUsersAsync(ids, orgId.Value),
                BulkAction.PromoteAdmin => await Accounts.BulkChangeRoleAsync(ids, UserRole.Admin, orgId.Value),
                BulkAction.DemoteUser => await Accounts.BulkChangeRoleAsync(ids, UserRole.User, orgId.Value),
                _ => throw new InvalidOperationException($"Unknown action {action}"),
            };
            _lastFailures = result.Failures;
            if (result.AllSucceeded)
            {
                _lastSuccess = $"Bulk {label} applied to {result.SucceededCount} user(s).";
            }
            else if (result.SucceededCount == 0)
            {
                _lastError = $"Bulk {label} failed for all {result.FailedCount} selected user(s). See details below.";
            }
            else
            {
                _lastSuccess = $"Bulk {label} applied to {result.SucceededCount} of {result.TotalRequested} user(s).";
            }
            _selected.Clear();
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Bulk {Action} on users raised an unexpected error.", label);
            _lastError = "An unexpected error occurred. The change was not saved.";
        }
        finally
        {
            _busy = false;
        }
    }

    private static string Capitalize(string s) => string.IsNullOrEmpty(s) ? s : char.ToUpperInvariant(s[0]) + s[1..];
}
