@page "/admin/catalog"
@attribute [Authorize(Roles = "Admin,Editor")]
@rendermode InteractiveServer
@inject CatalogService Catalog
@inject IJSRuntime JS
@inject ILogger<AdminCatalog> Log
@implements IAsyncDisposable
@using ALDevToolbox.Domain.Entities
@using ALDevToolbox.Domain.ValueObjects

@*
    Table editor for the well-known dependency catalogue. Each entry is a single
    table row of inline inputs (Object Explorer data-table style); a blank
    "ghost" row sits permanently at the bottom and becomes a real row the moment
    you type in it (a fresh ghost then appears), so there's no explicit "add"
    step. Reorder and remove live in a toolbar that acts on the selected row. The
    whole list is submitted on Save; the service reconciles row by row so
    unchanged entries keep their primary keys and the audit log only records real
    changes.
*@

<PageTitle>Catalogue · Admin · AL Dev Toolbox</PageTitle>

<div class="admin-page admin-template-edit admin-page--wide">
    <header class="admin-page__header">
        <div>
            <h1>Well-known dependencies</h1>
            <p class="muted">
                These rows populate the New Extension dependency picker.
                Group items into categories (Continia, ForNAV, Other...) so they
                bucket sensibly in the picker UI.
            </p>
        </div>
        <div class="admin-page__header-actions">
            <a class="btn btn--sm" href="/admin">
                <Icon Name="arrow-left" Width="14" Height="14" />
                <span>Back to admin</span>
            </a>
            <button type="button" class="btn btn--sm btn--primary"
                    @onclick="SaveAsync"
                    disabled="@(_saving || _form is null)">
                <Icon Name="save" Width="14" Height="14" />
                <span>@(_saving ? "Saving..." : "Save catalogue")</span>
            </button>
        </div>
    </header>

    @if (_form is null)
    {
        <p class="muted">Loading...</p>
    }
    else
    {
        @if (_saveError is not null)
        {
            <p class="form-error" role="alert">@_saveError</p>
        }
        @if (_saveSuccess is not null)
        {
            <p class="form-success" role="status">@_saveSuccess</p>
        }

        <form class="form-grid admin-template-edit__form" @onsubmit="SaveAsync" @onsubmit:preventDefault>
            <section class="form-section">
                <div class="row-editor" @ref="_editorRef">
                    <div class="row-editor__toolbar">
                        <button type="button" class="btn btn--sm" title="Move to top"
                                disabled="@(!CanMoveUp)"
                                @onclick="() => MoveEntryToTop(SelectedIndex)">
                            <Icon Name="chevrons-up" Width="14" Height="14" />
                        </button>
                        <button type="button" class="btn btn--sm" title="Move up"
                                disabled="@(!CanMoveUp)"
                                @onclick="() => MoveEntry(SelectedIndex, -1)">
                            <Icon Name="chevron-up" Width="14" Height="14" />
                        </button>
                        <button type="button" class="btn btn--sm" title="Move down"
                                disabled="@(!CanMoveDown)"
                                @onclick="() => MoveEntry(SelectedIndex, 1)">
                            <Icon Name="chevron-down" Width="14" Height="14" />
                        </button>
                        <button type="button" class="btn btn--sm" title="Move to bottom"
                                disabled="@(!CanMoveDown)"
                                @onclick="() => MoveEntryToBottom(SelectedIndex)">
                            <Icon Name="chevrons-down" Width="14" Height="14" />
                        </button>
                        <span class="row-editor__divider" aria-hidden="true"></span>
                        <button type="button" class="btn btn--sm btn--danger" title="Remove selected row"
                                disabled="@(!SelectedIsReal)"
                                @onclick="() => RemoveEntry(SelectedIndex)">
                            <Icon Name="trash-2" Width="14" Height="14" />
                            <span>Remove</span>
                        </button>
                    </div>

                    <table class="data-table row-editor__table">
                        <colgroup>
                            <col class="row-editor__col-guid" />
                            <col />
                            <col />
                            <col class="row-editor__col-version" />
                            <col class="row-editor__col-category" />
                        </colgroup>
                        <thead>
                            <tr>
                                <th scope="col">GUID</th>
                                <th scope="col">Name</th>
                                <th scope="col">Publisher</th>
                                <th scope="col">Default version</th>
                                <th scope="col">Category</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (var i = 0; i < _form.Entries.Count; i++)
                            {
                                var index = i;
                                var row = _form.Entries[index];
                                <tr @key="row" class="@RowCss(index, row)"
                                    @onfocusin="() => _selected = row">
                                    <td>
                                        <input type="text" required placeholder="12345678-1234-1234-1234-1234567890ab"
                                               pattern="^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
                                               title="Must be a GUID in 8-4-4-4-12 hex form. Press F8 to copy the cell above."
                                               data-row="@index" data-col="0"
                                               @bind="row.DepId" @bind:event="oninput" @bind:after="EnsureTrailingBlank"
                                               @onkeydown="e => OnCellKeyDown(e, index, Col.DepId)" />
                                        <FieldError Field="@($"Entries[{index}].DepId")" Errors="_fieldErrors" />
                                    </td>
                                    <td>
                                        <input type="text" required placeholder="Name"
                                               title="Press F8 to copy the cell above."
                                               data-row="@index" data-col="1"
                                               @bind="row.DepName" @bind:event="oninput" @bind:after="EnsureTrailingBlank"
                                               @onkeydown="e => OnCellKeyDown(e, index, Col.DepName)" />
                                        <FieldError Field="@($"Entries[{index}].DepName")" Errors="_fieldErrors" />
                                    </td>
                                    <td>
                                        <input type="text" required placeholder="Publisher"
                                               title="Press F8 to copy the cell above."
                                               data-row="@index" data-col="2"
                                               @bind="row.DepPublisher" @bind:event="oninput" @bind:after="EnsureTrailingBlank"
                                               @onkeydown="e => OnCellKeyDown(e, index, Col.DepPublisher)" />
                                        <FieldError Field="@($"Entries[{index}].DepPublisher")" Errors="_fieldErrors" />
                                    </td>
                                    <td>
                                        <input type="text" required placeholder="1.0.0.0"
                                               title="Press F8 to copy the cell above."
                                               data-row="@index" data-col="3"
                                               @bind="row.DepVersionDefault" @bind:event="oninput" @bind:after="EnsureTrailingBlank"
                                               @onkeydown="e => OnCellKeyDown(e, index, Col.DepVersionDefault)" />
                                        <FieldError Field="@($"Entries[{index}].DepVersionDefault")" Errors="_fieldErrors" />
                                    </td>
                                    <td>
                                        <input type="text" placeholder="e.g. Continia"
                                               title="Press F8 to copy the cell above."
                                               data-row="@index" data-col="4"
                                               @bind="row.Category" @bind:event="oninput" @bind:after="EnsureTrailingBlank"
                                               @onkeydown="e => OnCellKeyDown(e, index, Col.Category)" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <small class="muted">
                        Start typing in the blank row at the bottom to add an
                        entry - a fresh blank row always follows. Click a row to
                        select it, then use the toolbar to move or remove it.
                        Press <kbd>F8</kbd> in any cell to copy the value from the
                        row above, or paste a range copied from Excel to fill
                        multiple rows at once. The default version pre-fills the
                        picker; users can override it per extension. Category
                        groups items in the picker UI.
                    </small>
                </div>
            </section>

            @* Hidden submit so pressing Enter inside an input still triggers
               SaveAsync - the visible Save button moved to the header. *@
            <button type="submit" class="visually-hidden" aria-hidden="true" tabindex="-1">Save</button>
        </form>
    }
</div>

@code {
    private FormState? _form;
    private bool _saving;
    private string? _saveError;
    private string? _saveSuccess;
    private IReadOnlyDictionary<string, string> _fieldErrors = new Dictionary<string, string>();

    // Tracked by reference (not index) so the highlight follows the row across
    // reorders - the toolbar acts on whichever row this points at.
    private EntryRow? _selected;

    // Excel-paste interop: the JS handler lives on this wrapper element and
    // calls back into OnGridPaste. Registered once the editor has rendered.
    private ElementReference _editorRef;
    private DotNetObjectReference<AdminCatalog>? _selfRef;
    private bool _pasteBound;

    private int SelectedIndex =>
        _selected is null || _form is null ? -1 : _form.Entries.IndexOf(_selected);

    // The last row is always the blank "ghost" placeholder; a real row is any
    // selected row that isn't it. Move/remove only apply to real rows, and a
    // real row can never be pushed below the ghost.
    private bool SelectedIsReal => _form is not null && SelectedIndex >= 0 && SelectedIndex < _form.Entries.Count - 1;
    private bool CanMoveUp => SelectedIsReal && SelectedIndex > 0;
    private bool CanMoveDown => SelectedIsReal && SelectedIndex < _form!.Entries.Count - 2;

    /// <summary>Columns that participate in the F8 "copy cell above" shortcut.</summary>
    private enum Col { DepId, DepName, DepPublisher, DepVersionDefault, Category }

    private string RowCss(int index, EntryRow row)
    {
        var css = row == _selected ? "is-selected" : "";
        if (index == _form!.Entries.Count - 1) css = (css + " is-ghost").Trim();
        return css;
    }

    protected override Task OnInitializedAsync() => ReloadAsync();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // The wrapper only exists once the form has hydrated (the first render
        // shows "Loading..."), so bind on whichever render first exposes it. The
        // element is stable across later re-renders, so bind exactly once.
        if (!_pasteBound && _form is not null)
        {
            _selfRef ??= DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("aldt.registerGridPaste", _editorRef, _selfRef);
            _pasteBound = true;
        }
    }

    private async Task ReloadAsync()
    {
        _form = null;
        _saving = false;
        _saveError = null;
        _saveSuccess = null;
        _selected = null;
        _fieldErrors = new Dictionary<string, string>();
        StateHasChanged();
        var rows = await Catalog.GetAllAsync();
        _form = FormState.From(rows);
        EnsureTrailingBlank();
    }

    /// <summary>
    /// Keeps exactly one empty row at the end of the list so there's always a
    /// place to start a new entry. Called after every cell edit (via
    /// <c>@bind:after</c>), F8, paste, removal, and load.
    /// </summary>
    private void EnsureTrailingBlank()
    {
        if (_form is null) return;
        if (_form.Entries.Count == 0 || !_form.Entries[^1].IsBlank())
        {
            _form.Entries.Add(new EntryRow());
        }
    }

    private void RemoveEntry(int index)
    {
        if (_form is null) return;
        if (index >= 0 && index < _form.Entries.Count)
        {
            if (_form.Entries[index] == _selected) _selected = null;
            _form.Entries.RemoveAt(index);
            EnsureTrailingBlank();
        }
    }

    private void MoveEntry(int index, int delta)
    {
        if (_form is null) return;
        var target = index + delta;
        if (index < 0 || index >= _form.Entries.Count || target < 0 || target >= _form.Entries.Count)
        {
            return;
        }
        // Never swap a real row past the trailing ghost.
        if (target == _form.Entries.Count - 1) return;
        (_form.Entries[index], _form.Entries[target]) =
            (_form.Entries[target], _form.Entries[index]);
    }

    private void MoveEntryToTop(int index)
    {
        if (_form is null) return;
        if (index <= 0 || index >= _form.Entries.Count) return;
        var row = _form.Entries[index];
        _form.Entries.RemoveAt(index);
        _form.Entries.Insert(0, row);
    }

    private void MoveEntryToBottom(int index)
    {
        if (_form is null) return;
        // Move to the last *real* slot - immediately above the trailing ghost.
        if (index < 0 || index >= _form.Entries.Count - 2) return;
        var row = _form.Entries[index];
        _form.Entries.RemoveAt(index);
        _form.Entries.Insert(_form.Entries.Count - 1, row);
    }

    /// <summary>
    /// Business-Central-style "copy field above" (F8): copies the same column's
    /// value from the previous row into the focused cell. No-op on the first row.
    /// </summary>
    private void OnCellKeyDown(KeyboardEventArgs e, int index, Col col)
    {
        if (e.Key != "F8" || _form is null || index <= 0 || index >= _form.Entries.Count) return;
        var above = _form.Entries[index - 1];
        var cur = _form.Entries[index];
        switch (col)
        {
            case Col.DepId: cur.DepId = above.DepId; break;
            case Col.DepName: cur.DepName = above.DepName; break;
            case Col.DepPublisher: cur.DepPublisher = above.DepPublisher; break;
            case Col.DepVersionDefault: cur.DepVersionDefault = above.DepVersionDefault; break;
            case Col.Category: cur.Category = above.Category; break;
        }
        EnsureTrailingBlank();
    }

    /// <summary>
    /// Excel-style paste: <paramref name="text"/> is a tab/newline-separated
    /// block dropped onto the cell at (<paramref name="startRow"/>,
    /// <paramref name="startCol"/>). Fills cells right/down from there, adding
    /// rows when the pasted block runs past the end of the list. Columns past
    /// the last one are ignored. Invoked from grid-paste.js.
    /// </summary>
    [JSInvokable]
    public void OnGridPaste(int startRow, int startCol, string text)
    {
        if (_form is null) return;
        var grid = GridPasteParser.Parse(text);
        if (grid.Count == 0) return;

        for (var r = 0; r < grid.Count; r++)
        {
            var rowIndex = startRow + r;
            while (_form.Entries.Count <= rowIndex) _form.Entries.Add(new EntryRow());
            var entry = _form.Entries[rowIndex];
            var cells = grid[r];
            for (var c = 0; c < cells.Count; c++)
            {
                ApplyCell(entry, startCol + c, cells[c]);
            }
        }

        var lastRow = startRow + grid.Count - 1;
        if (lastRow >= 0 && lastRow < _form.Entries.Count) _selected = _form.Entries[lastRow];
        EnsureTrailingBlank();
        StateHasChanged();
    }

    private static void ApplyCell(EntryRow row, int col, string value)
    {
        switch (col)
        {
            case 0: row.DepId = value; break;
            case 1: row.DepName = value; break;
            case 2: row.DepPublisher = value; break;
            case 3: row.DepVersionDefault = value; break;
            case 4: row.Category = value; break;
            // Columns beyond the table are ignored.
        }
    }

    private async Task SaveAsync()
    {
        if (_form is null || _saving) return;
        _saving = true;
        _saveError = null;
        _saveSuccess = null;
        _fieldErrors = new Dictionary<string, string>();

        var payload = _form.ToInputs();

        try
        {
            await Catalog.SaveAsync(payload);
            // Round-trip through the DB so newly-added rows pick up their
            // assigned primary key and ordering reflects the saved state.
            var rows = await Catalog.GetAllAsync();
            _form = FormState.From(rows);
            EnsureTrailingBlank();
            _selected = null;
            _saveSuccess = "Saved.";
        }
        catch (PlanValidationException ex)
        {
            _fieldErrors = ex.Errors;
            _saveError = $"Couldn't save: {ex.Errors.Count} validation error(s). See messages next to each field.";
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Unexpected error saving catalogue.");
            _saveError = "An unexpected error occurred. The change was not saved.";
        }
        finally
        {
            _saving = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_pasteBound)
        {
            // The circuit may already be gone on disposal; swallow the
            // disconnect rather than surface it as an unhandled exception.
            try { await JS.InvokeVoidAsync("aldt.unregisterGridPaste", _editorRef); }
            catch (JSDisconnectedException) { }
            catch (InvalidOperationException) { }
        }
        _selfRef?.Dispose();
    }

    private sealed class FormState
    {
        public List<EntryRow> Entries { get; } = new();

        public static FormState From(IReadOnlyList<WellKnownDependency> rows)
        {
            var state = new FormState();
            foreach (var r in rows)
            {
                state.Entries.Add(new EntryRow
                {
                    Id = r.Id,
                    DepId = r.DepId,
                    DepName = r.DepName,
                    DepPublisher = r.DepPublisher,
                    DepVersionDefault = r.DepVersionDefault,
                    Category = r.Category ?? string.Empty,
                });
            }
            return state;
        }

        /// <summary>
        /// Maps rows to service inputs, dropping trailing blank rows (the
        /// always-present ghost) so the add-placeholder is never validated or
        /// persisted. Only trailing blanks are dropped, which keeps every
        /// remaining row's index aligned with the <c>Entries[N]</c> error keys.
        /// </summary>
        public List<CatalogEntryInput> ToInputs()
        {
            var rows = Entries.ToList();
            while (rows.Count > 0 && rows[^1].IsBlank()) rows.RemoveAt(rows.Count - 1);
            return rows
                .Select(e => new CatalogEntryInput(
                    Id: e.Id,
                    DepId: e.DepId,
                    DepName: e.DepName,
                    DepPublisher: e.DepPublisher,
                    DepVersionDefault: e.DepVersionDefault,
                    Category: string.IsNullOrWhiteSpace(e.Category) ? null : e.Category))
                .ToList();
        }
    }

    private sealed class EntryRow
    {
        public int? Id { get; set; }
        public string DepId { get; set; } = string.Empty;
        public string DepName { get; set; } = string.Empty;
        public string DepPublisher { get; set; } = string.Empty;
        public string DepVersionDefault { get; set; } = string.Empty;
        public string Category { get; set; } = string.Empty;

        /// <summary>A row with no content - the ghost, or a fully-cleared row.</summary>
        public bool IsBlank() =>
            string.IsNullOrWhiteSpace(DepId) && string.IsNullOrWhiteSpace(DepName)
            && string.IsNullOrWhiteSpace(DepPublisher) && string.IsNullOrWhiteSpace(DepVersionDefault)
            && string.IsNullOrWhiteSpace(Category);
    }
}
