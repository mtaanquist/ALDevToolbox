@*
    The Release identity fields (Label / Kind / Parent / Publisher / Project)
    shared by the Upload and DVD import tabs. Rendered inside each tab's
    <form data-oe-import-form>; object-explorer-import.js shows/hides Parent,
    Publisher and Project by the selected Kind (no-JS submits leave them
    visible, which the endpoint tolerates). The Artifacts tab doesn't use this -
    those releases are always first-party with an auto-generated label.
*@

@using ALDevToolbox.Services.ObjectExplorer

<section class="form-section">
    <label class="field">
        <span class="field__label">Label</span>
        <input type="text" name="Label" required maxlength="120"
               placeholder="e.g. BC 25.18 DK or CRONUS on BC 25.18"
               class="field__input" />
        <small class="field__caption muted">
            Shown in the version picker. Use something memorable -
            "BC 25.18 DK" beats "release_20260601_v3".
        </small>
    </label>

    <label class="field">
        <span class="field__label">Kind</span>
        <select name="Kind" required class="field__input">
            <option value="first_party">First-party (Microsoft)</option>
            <option value="third_party">Third-party / partner</option>
            <option value="project">Project-specific bundle</option>
        </select>
        <small class="field__caption muted">
            Third-party and project releases build on top of a Microsoft
            (first-party) release - pick that base below.
        </small>
    </label>

    <label class="field" data-oe-field-parent>
        <span class="field__label">Parent Release (optional)</span>
        <select name="ParentReleaseId" class="field__input">
            <option value="">- none (first-party, no parent) -</option>
            @if (ParentCandidates is not null)
            {
                @foreach (var r in ParentCandidates)
                {
                    <option value="@r.Id">@r.Label</option>
                }
            }
        </select>
        <small class="field__caption muted">
            Required for third-party / project releases - the Microsoft base
            they extend, so references to its objects resolve correctly.
        </small>
    </label>

    <label class="field" data-oe-field-publisher>
        <span class="field__label">Publisher (optional)</span>
        <input type="text" name="Publisher" maxlength="200"
               placeholder="e.g. Continia Software"
               class="field__input" />
        <small class="field__caption muted">
            Who owns this extension. Mainly useful for third-party / project
            releases.
        </small>
    </label>

    <label class="field" data-oe-field-project>
        <span class="field__label">Project (optional)</span>
        <input type="text" name="ProjectName" maxlength="200"
               placeholder="e.g. CRONUS"
               class="field__input" />
        <small class="field__caption muted">
            Only used for project Releases - the project this bundle
            belongs to.
        </small>
    </label>
</section>

@code {
    /// <summary>Ready first-party Releases offered as parents in the dropdown.</summary>
    [Parameter] public IReadOnlyList<ReleaseListItem>? ParentCandidates { get; set; }
}
