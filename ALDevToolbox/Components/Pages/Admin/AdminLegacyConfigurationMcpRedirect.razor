@page "/admin/configuration/mcp"
@attribute [Authorize(Roles = "Admin")]
@inject NavigationManager Nav

@*
    Legacy redirect: the per-org MCP toggle moved into the unified Tools tab
    (it was previously /admin/configuration/mcp, then /admin/administration/mcp).
*@

@code {
    protected override void OnInitialized()
    {
        Nav.NavigateTo("/admin/administration/tools", replace: true);
    }
}
