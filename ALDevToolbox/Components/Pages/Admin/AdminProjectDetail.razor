@page "/admin/object-explorer/project/new"
@page "/admin/object-explorer/project/{Id:int}"
@attribute [Authorize(Roles = "Admin,Editor")]
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject ALDevToolbox.Services.ObjectExplorer.ProjectService Projects
@inject ALDevToolbox.Services.ObjectExplorer.ProjectBuildImporter Builds
@inject ALDevToolbox.Services.ObjectExplorer.AlCompilerProvisioner Compiler
@inject ALDevToolbox.Services.ObjectExplorer.ReleaseImportQueue ImportQueue
@inject ALDevToolbox.Services.ObjectExplorer.PersistedImportJobs ImportJobs
@inject ALDevToolbox.Services.ObjectExplorer.ReleaseManagementService ReleaseManagement
@inject ALDevToolbox.Services.OrganizationConfigService Config
@inject ALDevToolbox.Services.IOrganizationContext OrgContext
@inject NavigationManager Nav
@inject ILogger<AdminProjectDetail> Log
@using ALDevToolbox.Domain.Entities.ObjectExplorer
@using ALDevToolbox.Domain.ValueObjects
@using ALDevToolbox.Services
@using ALDevToolbox.Services.ObjectExplorer

@*
    One project: its repositories on the left (always editable, saved in one go
    via the Save button in the page header) and a factbox on the right with
    the Build all action, the build-tool status, and the history of releases its
    builds produced. Doubles as the create form (/project/new), where the right
    factbox is hidden until the project exists. Repositories are added with an
    explicit "+ Add repository" button. While a build is in flight the page polls
    the release list so the build's status updates in place without a refresh.
    See .design/object-explorer-project-builds.md.
*@

<PageTitle>@(_project?.Name ?? "Project") · Object Explorer · Admin · AL Dev Toolbox</PageTitle>

<div class="admin-page">
    <header class="admin-page__header">
        <div>
            <h1>@HeaderTitle()</h1>
        </div>
        <div class="admin-page__header-actions">
            @if (!_loading && !_notFound)
            {
                @if (_project is not null && _dirty)
                {
                    <span class="cust-save-hint">Unsaved changes</span>
                }
                <button type="button" class="btn btn--sm btn--primary" @onclick="SaveAsync" disabled="@_saving">
                    <Icon Name="save" Width="14" Height="14" />
                    <span>@(_saving ? "Saving…" : "Save project")</span>
                </button>
            }
            <a class="btn btn--sm" href="/admin/object-explorer/projects">
                <Icon Name="arrow-left" Width="14" Height="14" />
                <span>All projects</span>
            </a>
        </div>
    </header>

    @if (_message is not null)
    {
        <p class="form-success" role="status">@_message</p>
    }
    @if (_errors.Count > 0)
    {
        <div class="form-error" role="alert">
            @foreach (var err in _errors.Values.Distinct())
            {
                <p>@err</p>
            }
        </div>
    }

    @if (_loading)
    {
        <p class="muted">Loading…</p>
    }
    else if (_notFound)
    {
        <p class="muted">This project doesn't exist. <a href="/admin/object-explorer/projects">Back to projects</a>.</p>
    }
    else
    {
        @if (_project is null)
        {
            <p class="muted">
                Add the repositories that make up this project's solution. After saving, you can build them all into one release.
            </p>
        }
        <div class="cust-grid @(_project is null ? "cust-grid--single" : "")">
            <div class="cust-main">
                <section class="manage-card">
                    <h2 class="manage-card__title">Details</h2>
                    <div class="form-grid">
                        <section class="form-section">
                            <label class="field__label" for="cust-name">Name</label>
                            <input id="cust-name" type="text" class="field__input" maxlength="200" @bind="_edit.Name" @bind:after="MarkDirty"
                                   disabled="@_saving" placeholder="e.g. Acme A/S" />
                            <small class="muted">Labels the release, e.g. "Acme A/S on BC 26.0".</small>
                        </section>

                        <section class="form-section">
                            <label class="field__label" for="cust-country">Default country code <span class="muted">· optional</span></label>
                            <input id="cust-country" type="text" class="field__input" maxlength="20" pattern="[A-Za-z0-9]{2,10}"
                                   @bind="_edit.Country" @bind:after="MarkDirty" disabled="@_saving" placeholder="e.g. dk or w1" />
                            <small class="muted">Which Microsoft localisation to compile symbols against. Blank uses the organisation default.</small>
                        </section>

                        <section class="form-section">
                            <label class="field__label">
                                <input type="checkbox" @bind="_edit.AutoBuild" @bind:after="MarkDirty" disabled="@_saving" />
                                Auto-build nightly when the repository changes
                            </label>
                            <small class="muted">Once a day, rebuild this project if any repo has new commits since the last build. Needs a repository token.</small>
                        </section>
                    </div>
                </section>

                <section class="manage-card manage-card--wide">
                    <h2 class="manage-card__title">Repositories</h2>
                    <div class="form-grid">
                        <section class="form-section">
                            @if (_edit.Repos.Count == 0)
                            {
                                <p class="muted">No repositories yet. Add the Git repositories that make up this project's solution.</p>
                            }
                            else
                            {
                                <div class="row-editor">
                                    <table class="data-table row-editor__table">
                                        <colgroup>
                                            <col class="row-editor__col-key" />
                                            <col />
                                            <col class="row-editor__col-category" />
                                            <col class="row-editor__col-flag" />
                                        </colgroup>
                                        <thead>
                                            <tr>
                                                <th scope="col">Host</th>
                                                <th scope="col">Repository URL</th>
                                                <th scope="col">Display name</th>
                                                <th scope="col"></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var repo in _edit.Repos)
                                            {
                                                <tr @key="repo">
                                                    <td>
                                                        <select class="row-role-select" @bind="repo.Provider" @bind:after="MarkDirty" disabled="@_saving" aria-label="Host">
                                                            <option value="@RepositoryProvider.GitHub">GitHub</option>
                                                            <option value="@RepositoryProvider.AzureDevOps">Azure DevOps</option>
                                                        </select>
                                                    </td>
                                                    <td>
                                                        <input type="text" @bind="repo.Url" @bind:event="oninput" @bind:after="MarkDirty"
                                                               disabled="@_saving" placeholder="https://github.com/org/repo" aria-label="Repository URL" />
                                                    </td>
                                                    <td>
                                                        <input type="text" @bind="repo.DisplayName" @bind:event="oninput" @bind:after="MarkDirty"
                                                               disabled="@_saving" placeholder="optional" aria-label="Display name" />
                                                    </td>
                                                    <td class="row-editor__cell-center">
                                                        <button type="button" class="btn btn--sm btn--outline" @onclick="() => RemoveRepo(repo)"
                                                                disabled="@_saving" aria-label="Remove repository">
                                                            <Icon Name="trash-2" Width="14" Height="14" />
                                                        </button>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            <div class="form-section__add">
                                <button type="button" class="btn btn--sm btn--outline" @onclick="AddRepo" disabled="@_saving">
                                    <Icon Name="plus" Width="14" Height="14" />
                                    <span>Add repository</span>
                                </button>
                            </div>
                        </section>
                    </div>
                </section>

                @if (_project is not null)
                {
                    <section class="manage-card manage-card--wide">
                        <h2 class="manage-card__title">Supplemental symbols</h2>
                        <p class="muted">
                            Dependency <code>.app</code> packages uploaded to recover a failed build — used as
                            symbols on every build of this project. Upload them from a build's
                            <strong>Manage</strong> page when an extension fails for a missing third-party dependency.
                        </p>
                        @if (_symbols.Count == 0)
                        {
                            <p class="muted">None uploaded.</p>
                        }
                        else
                        {
                            <table class="data-table data-table--card">
                                <thead><tr><th>Package</th><th>Size</th><th>Uploaded</th><th></th></tr></thead>
                                <tbody>
                                    @foreach (var s in _symbols)
                                    {
                                        <tr>
                                            <td><code>@s.FileName</code></td>
                                            <td>@FormatBytes(s.ContentLength)</td>
                                            <td>@s.CreatedAt.ToString("yyyy-MM-dd")</td>
                                            <td class="row-editor__cell-center">
                                                <button type="button" class="btn btn--sm btn--outline" @onclick="() => RemoveSymbolAsync(s.Id)"
                                                        disabled="@_removingSymbol" aria-label="@($"Remove {s.FileName}")">
                                                    <Icon Name="trash-2" Width="14" Height="14" />
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </section>

                    <section class="manage-card manage-card--danger">
                        <h2 class="manage-card__title">Danger zone</h2>
                        @if (_confirmingDelete)
                        {
                            <p class="muted">Delete <strong>@_project.Name</strong>? Its past builds stay; only this project's setup (name and repositories) is removed.</p>
                            <div class="manage-card__actions">
                                <button type="button" class="btn btn--sm btn--danger" @onclick="ConfirmDeleteAsync">Yes, delete</button>
                                <button type="button" class="btn btn--sm btn--outline" @onclick="() => _confirmingDelete = false">Cancel</button>
                            </div>
                        }
                        else
                        {
                            <button type="button" class="btn btn--outline" @onclick="() => _confirmingDelete = true">
                                <Icon Name="trash-2" Width="14" Height="14" />
                                <span>Delete project</span>
                            </button>
                        }
                    </section>
                }
            </div>

            @if (_project is not null)
            {
                <aside class="cust-rail">
                    <div class="card">
                        <div class="card-head"><span class="cap-label">Build</span></div>
                        <div class="cust-rail-body">
                            <button type="button" class="btn btn--outline cust-build-all" @onclick="BuildAsync"
                                    disabled="@(_building || _buildPending || _dirty || _project.Repositories.Count == 0 || !_hasAnyPat)"
                                    title="@BuildHint()">
                                <Icon Name="hammer" Width="15" Height="15" />
                                <span>@BuildLabel()</span>
                            </button>
                            @if (!_hasAnyPat)
                            {
                                <p class="muted">
                                    No repository token is configured yet. Add an Azure DevOps or GitHub token under
                                    <a href="/admin/administration/repositories">Administration → Repositories</a> before building.
                                </p>
                            }
                            @if (_compiler is not null)
                            {
                                <p class="muted">
                                    <Icon Name="settings" Width="13" Height="13" />
                                    @if (_compiler.Available)
                                    {
                                        <span>AL compiler @_compiler.InstalledVersion</span>
                                        @if (_compiler.UpdateAvailable)
                                        {
                                            <span> · newer available (@_compiler.NewestVersion) </span>
                                            <button type="button" class="btn btn--sm btn--outline" @onclick="UpdateCompilerAsync" disabled="@_updatingCompiler">
                                                <span>@(_updatingCompiler ? "Updating…" : "Update")</span>
                                            </button>
                                        }
                                        else { <span> · up to date</span> }
                                    }
                                    else
                                    {
                                        <span>AL compiler not installed yet — it's downloaded automatically on the first build.</span>
                                    }
                                </p>
                            }
                        </div>
                    </div>

                    <div class="card">
                        <div class="card-head">
                            <span class="cap-label">Builds</span>
                            @if (_releases.Count > 0)
                            {
                                <span class="cust-builds-n">@_releases.Count</span>
                            }
                        </div>
                        @if (_releases.Count == 0)
                        {
                            <p class="muted cust-rail-body">No builds yet. Hit <strong>Build all</strong> to compile this project's solution into a release.</p>
                        }
                        else
                        {
                            <div class="cust-builds">
                                @foreach (var rel in _releases)
                                {
                                    <div class="cust-build">
                                        <div class="cust-build-top">
                                            <a class="cust-build-label" href="@($"/object-explorer/release/{rel.Id}")">@rel.Label</a>
                                            <details class="ra__menu">
                                                <summary class="ra__solo" title="Build actions" aria-label="Build actions" aria-haspopup="menu">
                                                    <Icon Name="ellipsis-vertical" Width="16" Height="16" />
                                                </summary>
                                                <div class="ra__pop" role="menu">
                                                    <a class="ra__item" href="@($"/admin/object-explorer/release/{rel.Id}/manage")" role="menuitem">
                                                        <Icon Name="settings" Width="15" Height="15" />
                                                        <span>Manage</span>
                                                    </a>
                                                    <a class="ra__item" href="@($"/admin/object-explorer/release/{rel.Id}/modules")" role="menuitem">
                                                        <Icon Name="package-plus" Width="15" Height="15" />
                                                        <span>Add modules</span>
                                                    </a>
                                                    <a class="ra__item" href="@($"/admin/object-explorer/release/{rel.Id}/translations")" role="menuitem">
                                                        <Icon Name="book-open" Width="15" Height="15" />
                                                        <span>Import translations</span>
                                                    </a>
                                                    @if (rel.DeletedAt is null)
                                                    {
                                                        <button type="button" class="ra__item" role="menuitem" @onclick="() => BackfillAsync(rel.Id)">
                                                            <Icon Name="rotate-ccw" Width="15" Height="15" />
                                                            <span>Backfill system references</span>
                                                        </button>
                                                        <div class="ra__divider"></div>
                                                        <button type="button" class="ra__item ra__item--danger" role="menuitem" @onclick="() => SoftDeleteReleaseAsync(rel.Id, rel.Label)">
                                                            <Icon Name="archive" Width="15" Height="15" />
                                                            <span>Soft delete</span>
                                                        </button>
                                                    }
                                                </div>
                                            </details>
                                        </div>
                                        <div class="cust-build-meta">
                                            <span>@FormatStatus(rel.Status)</span>
                                            <span class="dotsep"></span>
                                            <span class="mono">@(string.IsNullOrEmpty(rel.BcVersion) ? "—" : rel.BcVersion)</span>
                                            <span class="dotsep"></span>
                                            <span>@rel.ImportedAt.ToString("yyyy-MM-dd")</span>
                                            @if (rel.DeletedAt is not null)
                                            {
                                                <span class="dotsep"></span>
                                                <span>deleted</span>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </aside>
            }
        </div>
    }
</div>

<ConfirmDialog @ref="_confirmDelete" ConfirmButtonClass="btn--danger" ConfirmIcon="archive" />

@code {
    [Parameter] public int? Id { get; set; }

    private bool _loading = true;
    private bool _notFound;
    private bool _saving;
    private bool _building;
    // True once the form has unsaved edits — gates Build all so a build never
    // runs against stale repos the admin has changed but not yet saved.
    private bool _dirty;
    // True while a build for this project is queued or running (any release is
    // still "ingesting"). Drives the Build all button's disabled/label state and
    // keeps the status poll alive.
    private bool _buildPending;
    private bool _updatingCompiler;
    private bool _confirmingDelete;
    private bool _hasAnyPat;
    private bool _hasAzureDevOpsPat;
    private bool _hasGitHubPat;
    private string? _message;
    private Dictionary<string, string> _errors = new();
    private ConfirmDialog _confirmDelete = default!;

    // The app's only status poll: a self-limiting loop that re-reads the release
    // list while a build is in flight, so the Builds card flips Building…→Ready
    // without a manual refresh. Disposed with the circuit.
    private PeriodicTimer? _poll;
    private CancellationTokenSource? _pollCts;
    private static readonly TimeSpan PollInterval = TimeSpan.FromSeconds(2.5);

    private bool _removingSymbol;
    private Project? _project;
    private List<ProjectReleaseRow> _releases = new();
    private List<ProjectSymbolRow> _symbols = new();
    private AlCompilerStatus? _compiler;
    private EditModel _edit = new();

    protected override async Task OnInitializedAsync()
    {
        var access = await Config.GetRepositoryAccessViewAsync();
        _hasAzureDevOpsPat = access.HasAzureDevOpsPat;
        _hasGitHubPat = access.HasGitHubPat;
        _hasAnyPat = _hasAzureDevOpsPat || _hasGitHubPat;
        _compiler = await Compiler.GetStatusAsync();

        if (Id is null)
        {
            // Create mode — an empty editable form with one blank repo row.
            _edit = new EditModel { Repos = { new RepoRow { Provider = DefaultProvider } } };
        }
        else
        {
            await LoadAsync();
            if (!_notFound) HydrateEdit();
        }
        _loading = false;

        // A build may already be in flight when the page opens (e.g. the admin
        // navigated back to it) — pick the poll back up so the status still
        // updates live.
        if (_buildPending) StartPoll();
    }

    private async Task LoadAsync()
    {
        _project = await Projects.GetProjectAsync(Id!.Value);
        if (_project is null) { _notFound = true; return; }
        _releases = await Projects.ListProjectReleasesAsync(_project.Id);
        _symbols = await Projects.ListSupplementalSymbolsAsync(_project.Id);
        _buildPending = _releases.Any(r => r.Status == "ingesting");
    }

    /// <summary>Fills the always-editable form from the loaded project.</summary>
    private void HydrateEdit()
    {
        _edit = new EditModel
        {
            Name = _project!.Name,
            Country = _project.DefaultArtifactCountry ?? string.Empty,
            AutoBuild = _project.AutoBuildEnabled,
            Repos = _project.Repositories
                .Select(r => new RepoRow { Provider = r.Provider, Url = r.Url, DisplayName = r.DisplayName })
                .ToList(),
        };
        _dirty = false;
    }

    private void MarkDirty() => _dirty = true;

    /// <summary>Adds a blank repository row for the admin to fill in.</summary>
    private void AddRepo() { _edit.Repos.Add(new RepoRow { Provider = DefaultProvider }); _dirty = true; }

    private async Task RemoveSymbolAsync(int symbolId)
    {
        if (_removingSymbol || _project is null) return;
        _removingSymbol = true;
        try
        {
            await Projects.DeleteSupplementalSymbolAsync(_project.Id, symbolId);
            _symbols = await Projects.ListSupplementalSymbolsAsync(_project.Id);
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Failed to remove supplemental symbol {SymbolId} from project {ProjectId}.", symbolId, _project.Id);
            _errors = new() { ["_"] = "Could not remove the symbol." };
        }
        finally
        {
            _removingSymbol = false;
        }
    }

    private static string FormatBytes(long bytes) => bytes switch
    {
        < 1024 => $"{bytes} B",
        < 1024 * 1024 => $"{bytes / 1024.0:0.#} KB",
        _ => $"{bytes / (1024.0 * 1024):0.#} MB",
    };

    private void RemoveRepo(RepoRow row) { _edit.Repos.Remove(row); _dirty = true; }

    /// <summary>The host a fresh repo row defaults to — the one that has a PAT configured, so the common case needs no change.</summary>
    private RepositoryProvider DefaultProvider =>
        _hasGitHubPat ? RepositoryProvider.GitHub
        : _hasAzureDevOpsPat ? RepositoryProvider.AzureDevOps
        : RepositoryProvider.GitHub;

    private string HeaderTitle() =>
        Id is null ? "New project"
        : _project?.Name ?? "Project";

    private async Task SaveAsync()
    {
        if (_saving) return;
        _saving = true;
        _message = null;
        _errors = new();
        try
        {
            var repos = _edit.Repos.Where(r => !r.IsBlank())
                .Select(r => new ProjectRepositoryInput(r.Provider, r.Url, r.DisplayName))
                .ToList();
            var input = new ProjectInput(_edit.Name, string.IsNullOrWhiteSpace(_edit.Country) ? null : _edit.Country, repos, _edit.AutoBuild);

            if (Id is null)
            {
                var newId = await Projects.CreateProjectAsync(input);
                Nav.NavigateTo($"/admin/object-explorer/project/{newId}");
                return;
            }
            await Projects.UpdateProjectAsync(Id.Value, input);
            await LoadAsync();
            HydrateEdit();
            _message = "Project saved.";
        }
        catch (PlanValidationException ex)
        {
            _errors = new(ex.Errors);
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Failed to save project {ProjectId}.", Id);
            _errors = new() { ["_"] = "An unexpected error occurred. The change was not saved." };
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task BuildAsync()
    {
        if (_building || _buildPending || _project is null) return;
        _building = true;
        _message = null;
        _errors = new();
        try
        {
            await Builds.StartBuildAsync(_project.Id);
            // Stay on the page: surface the new "Building…" release in the factbox
            // and poll until the worker finishes, rather than dumping the admin on
            // the Manage release screen.
            await LoadAsync();
            _message = "Build queued. It runs in the background; this list updates as it progresses.";
            if (_buildPending) StartPoll();
        }
        catch (PlanValidationException ex)
        {
            _errors = new(ex.Errors);
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Failed to start build for project {ProjectId}.", _project.Id);
            _errors = new() { ["_"] = "Could not start the build." };
        }
        finally
        {
            _building = false;
        }
    }

    /// <summary>
    /// Starts the bounded status poll if it isn't already running. The loop
    /// re-reads the release list every <see cref="PollInterval"/> and stops itself
    /// once no release is still ingesting, so it only ticks while a build is in
    /// flight — the app's single concession to polling.
    /// </summary>
    private void StartPoll()
    {
        if (_poll is not null) return;
        _pollCts = new CancellationTokenSource();
        _poll = new PeriodicTimer(PollInterval);
        _ = PollLoopAsync(_poll, _pollCts.Token);
    }

    private async Task PollLoopAsync(PeriodicTimer timer, CancellationToken token)
    {
        try
        {
            while (await timer.WaitForNextTickAsync(token))
            {
                if (_project is null) break;
                await LoadAsync();
                await InvokeAsync(StateHasChanged);
                if (!_buildPending) break;
            }
        }
        catch (OperationCanceledException) { /* circuit tearing down */ }
        catch (Exception ex)
        {
            Log.LogError(ex, "Build-status poll failed for project {ProjectId}.", _project?.Id);
        }
        finally
        {
            StopPoll();
        }
    }

    private void StopPoll()
    {
        _poll?.Dispose();
        _poll = null;
        _pollCts?.Cancel();
        _pollCts?.Dispose();
        _pollCts = null;
    }

    /// <summary>Queues a system-reference backfill for one build, mirroring the Manage page's action.</summary>
    private async Task BackfillAsync(int releaseId)
    {
        _message = null;
        _errors = new();
        try
        {
            var identity = new AmbientOrganizationScope.OrganizationIdentity(
                OrganizationId: OrgContext.CurrentOrganizationId
                    ?? throw new InvalidOperationException("No organization in scope."),
                UserId: OrgContext.CurrentUserId,
                IsSiteAdmin: OrgContext.IsSiteAdmin,
                IsSystemOrganization: OrgContext.IsSystemOrganization);
            var source = new ReleaseImportSource.Backfill();
            var jobRowId = await ImportJobs.CreateAsync(releaseId, identity, source, storeSymbolReference: false);
            await ImportQueue.EnqueueAsync(new ReleaseImportJob(releaseId, identity, source, false, jobRowId));
            _message = "System-reference backfill queued. It runs in the background.";
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Failed to queue backfill for release {ReleaseId}.", releaseId);
            _errors = new() { ["_"] = "Could not queue the backfill." };
        }
    }

    /// <summary>Soft-deletes one build (release) after confirmation, then refreshes the list.</summary>
    private async Task SoftDeleteReleaseAsync(int releaseId, string label)
    {
        var ok = await _confirmDelete.OpenAsync(
            "Soft delete this build?",
            $"\"{label}\" will be hidden from the Object Explorer but stays queryable and can be restored from its Manage page.",
            "Soft delete");
        if (!ok) return;
        _message = null;
        _errors = new();
        try
        {
            await ReleaseManagement.SoftDeleteAsync(releaseId);
            if (_project is not null) await LoadAsync();
            _message = "Build soft-deleted. Restore it from its Manage page if that was a mistake.";
        }
        catch (PlanValidationException ex)
        {
            _errors = new(ex.Errors);
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Failed to soft-delete release {ReleaseId}.", releaseId);
            _errors = new() { ["_"] = "Could not soft-delete the build." };
        }
    }

    private async Task UpdateCompilerAsync()
    {
        if (_updatingCompiler || _compiler?.NewestVersion is not { } newest) return;
        _updatingCompiler = true;
        try
        {
            await Compiler.ProvisionVersionAsync(newest);
            _compiler = await Compiler.GetStatusAsync();
            _message = $"AL compiler updated to {newest}.";
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Failed to update the AL compiler to {Version}.", newest);
            _errors = new() { ["_"] = "Could not update the compiler — the server may not have internet access. Ask an administrator to check." };
        }
        finally
        {
            _updatingCompiler = false;
        }
    }

    private async Task ConfirmDeleteAsync()
    {
        try
        {
            await Projects.SoftDeleteProjectAsync(_project!.Id);
            Nav.NavigateTo("/admin/object-explorer/projects");
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Failed to delete project {ProjectId}.", _project?.Id);
            _errors = new() { ["_"] = "Could not delete the project." };
            _confirmingDelete = false;
        }
    }

    private string BuildLabel() =>
        _buildPending ? "Building…"
        : _building ? "Starting…"
        : "Build all";

    private string BuildHint() =>
        _project is null ? ""
        : _buildPending ? "A build is already running"
        : _dirty ? "Save your changes first"
        : _project.Repositories.Count == 0 ? "Add a repository first"
        : !_hasAnyPat ? "Configure a repository token first"
        : "Pull and compile every repository into one release";

    private static string FormatStatus(string s) => s switch
    {
        "ready"     => "Ready",
        "ingesting" => "Building…",
        "failed"    => "Failed",
        _           => s,
    };

    private sealed class EditModel
    {
        public string Name { get; set; } = string.Empty;
        public string Country { get; set; } = string.Empty;
        public bool AutoBuild { get; set; }
        public List<RepoRow> Repos { get; set; } = new();
    }

    private sealed class RepoRow
    {
        public RepositoryProvider Provider { get; set; } = RepositoryProvider.GitHub;
        public string Url { get; set; } = string.Empty;
        public string DisplayName { get; set; } = string.Empty;

        public bool IsBlank() => string.IsNullOrWhiteSpace(Url) && string.IsNullOrWhiteSpace(DisplayName);
    }

    public ValueTask DisposeAsync()
    {
        StopPoll();
        return ValueTask.CompletedTask;
    }
}
