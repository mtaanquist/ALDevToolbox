@page "/admin/templates"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@inject TemplateService Templates
@inject TemplateImportService Imports
@inject IOrganizationContext OrgContext
@inject NavigationManager Nav
@inject ILogger<AdminTemplateList> Log
@using ALDevToolbox.Domain.Entities
@using ALDevToolbox.Domain.ValueObjects

<PageTitle>Templates · Admin · AL Dev Toolbox</PageTitle>

<div class="admin-page">
    <header class="admin-page__header">
        <div>
            <h1>Templates</h1>
            <p class="muted">
                Runtime templates back the New Workspace dropdown. Edits here
                take effect on the next generation; the previous state is captured
                in the audit log for every change.
            </p>
        </div>
        <a class="btn btn--sm" href="/admin">
            <Icon Name="arrow-left" Width="14" Height="14" />
            <span>Back to admin</span>
        </a>
    </header>

    @if (Ok == "default-set")
    {
        <p class="form-success" role="status">Default template updated.</p>
    }
    @if (!string.IsNullOrEmpty(Msg))
    {
        <p class="form-error" role="alert">@Msg</p>
    }

    <div class="admin-page__toolbar">
        <label class="check-row">
            <input type="checkbox" @bind="_showDeleted" @bind:after="ReloadAsync" />
            <span>Show soft-deleted</span>
        </label>
        <label class="check-row">
            <input type="checkbox" @bind="_hideDeprecated" />
            <span>Hide deprecated</span>
        </label>
    </div>

    @if (!OrgContext.IsSystemOrganization)
    {
        <section class="admin-section">
            <h2>From the site catalogue</h2>
            <p class="muted">
                Templates published by the site. Importing copies the template
                (with its referenced modules and application version) into this
                organisation; later edits in either copy are independent.
            </p>
            @if (_systemTemplates is null)
            {
                <p class="muted">Loading…</p>
            }
            else if (_systemTemplates.Count == 0)
            {
                <p class="muted">The site catalogue is empty.</p>
            }
            else
            {
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Key</th>
                            <th>Runtime</th>
                            <th>Name</th>
                            <th>Description</th>
                            <th class="data-table__actions"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in _systemTemplates)
                        {
                            <tr>
                                <td><code>@t.Key</code></td>
                                <td>@t.Runtime</td>
                                <td>@t.Name</td>
                                <td class="muted">@t.Description</td>
                                <td class="data-table__actions">
                                    @if (t.AlreadyImported)
                                    {
                                        <span class="muted">Already imported</span>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn btn--sm"
                                                @onclick="() => ImportFromSiteAsync(t.Id)" disabled="@_importBusy">
                                            <Icon Name="download" Width="14" Height="14" />
                                            <span>Import</span>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            @if (_importError is not null)
            {
                <p class="form-error" role="alert">@_importError</p>
            }
            @if (_importSuccess is not null)
            {
                <p class="form-success" role="status">@_importSuccess</p>
            }
        </section>
    }

    @if (_rows is null)
    {
        <p class="muted">Loading…</p>
    }
    else if (FilteredRows.Count == 0)
    {
        @if (_rows.Count == 0)
        {
            <p class="muted">
                No templates yet. Click <strong>New template</strong> to add
                one — or import one from the site catalogue below.
            </p>
        }
        else
        {
            <p class="muted">
                No templates match the current filters. Untick
                <strong>Hide deprecated</strong> to see deprecated rows.
            </p>
        }
    }
    else
    {
        @if (_selected.Count > 0)
        {
            <div class="bulk-bar" role="region" aria-label="Bulk actions" aria-live="polite">
                <span class="bulk-bar__summary">@_selected.Count selected</span>
                <div class="bulk-bar__actions">
                    <button type="button" class="btn btn--sm" @onclick="() => RequestBulkAsync(BulkAction.SoftDelete)" disabled="@_busy">
                        <Icon Name="trash-2" Width="14" Height="14" />
                        <span>Soft-delete</span>
                    </button>
                    <button type="button" class="btn btn--sm" @onclick="() => RequestBulkAsync(BulkAction.Restore)" disabled="@_busy">
                        <Icon Name="rotate-ccw" Width="14" Height="14" />
                        <span>Restore</span>
                    </button>
                    <button type="button" class="btn btn--sm" @onclick="() => RequestBulkAsync(BulkAction.Deprecate)" disabled="@_busy">
                        <Icon Name="archive" Width="14" Height="14" />
                        <span>Deprecate</span>
                    </button>
                    <button type="button" class="btn btn--sm" @onclick="() => RequestBulkAsync(BulkAction.UnDeprecate)" disabled="@_busy">
                        <Icon Name="archive-restore" Width="14" Height="14" />
                        <span>Un-deprecate</span>
                    </button>
                    <button type="button" class="btn btn--sm" @onclick="ClearSelection" disabled="@_busy">
                        <Icon Name="x" Width="14" Height="14" />
                        <span>Clear</span>
                    </button>
                </div>
                @if (_lastError is not null)
                {
                    <p class="bulk-bar__error" role="alert">@_lastError</p>
                }
                @if (_lastSuccess is not null)
                {
                    <p class="bulk-bar__success" role="status">@_lastSuccess</p>
                }
            </div>
        }

        @if (_lastFailures.Count > 0)
        {
            <div class="bulk-failures">
                <h3>Some entries couldn't be processed</h3>
                <ul>
                    @foreach (var f in _lastFailures)
                    {
                        <li><strong>@f.DisplayName</strong> (id @f.Id): @f.Reason</li>
                    }
                </ul>
            </div>
        }

        <table class="data-table">
            <thead>
                <tr>
                    <th class="bulk-checkbox">
                        <input type="checkbox" aria-label="Select all visible"
                               checked="@AllVisibleSelected" @onchange="ToggleSelectAllVisible" />
                    </th>
                    <th>Key</th>
                    <th>Runtime</th>
                    <th>Name</th>
                    <th>Folders</th>
                    <th>Status</th>
                    <th>Last updated (UTC)</th>
                    <th class="data-table__actions"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in FilteredRows)
                {
                    <tr class="@(t.DeletedAt is not null ? "data-table__row--muted" : null)">
                        <td class="bulk-checkbox">
                            <input type="checkbox" aria-label="@($"Select {t.Name}")"
                                   checked="@_selected.Contains(t.Id)"
                                   @onchange="(e) => ToggleRow(t.Id, e)" />
                        </td>
                        <td>
                            <code>@t.Key</code>
                            @if (t.IsDefault)
                            {
                                <span class="status-pill status-pill--inline" title="Selected by default on New Workspace / New Extension">Default</span>
                            }
                        </td>
                        <td>@t.Runtime</td>
                        <td>@t.Name</td>
                        <td>@t.Folders.Count</td>
                        <td>@StatusFor(t)</td>
                        <td><time datetime="@t.UpdatedAt.ToString("O")">@t.UpdatedAt.ToString("yyyy-MM-dd HH:mm:ss")</time></td>
                        <td class="data-table__actions">
                            @if (!t.IsDefault && t.DeletedAt is null && !t.Deprecated)
                            {
                                <form method="post" action="@($"/admin/templates/{t.Id}/default")" style="display:inline">
                                    <AntiforgeryToken />
                                    <button type="submit" class="btn btn--sm" title="Use this template by default on New Workspace / New Extension">
                                        <Icon Name="star" Width="14" Height="14" />
                                        <span>Set default</span>
                                    </button>
                                </form>
                            }
                            <a class="btn btn--sm" href="@($"/admin/templates/{Uri.EscapeDataString(t.Key)}")">
                                <Icon Name="pencil" Width="14" Height="14" />
                                <span>Edit</span>
                            </a>
                            <a class="btn btn--sm" href="@($"/admin/templates/new?from={Uri.EscapeDataString(t.Key)}")"
                               title="Create a new template pre-filled from this one">
                                <Icon Name="copy" Width="14" Height="14" />
                                <span>Duplicate</span>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <div class="admin-page__footer-actions">
        <a class="btn btn--primary" href="/admin/templates/new">
            <Icon Name="folder-plus" Width="16" Height="16" />
            <span>New template</span>
        </a>
    </div>
</div>

<ConfirmDialog @ref="_confirm" />

@code {
    [SupplyParameterFromQuery(Name = "ok")] public string? Ok { get; set; }
    [SupplyParameterFromQuery(Name = "msg")] public string? Msg { get; set; }

    private bool _showDeleted;
    private bool _hideDeprecated;
    private List<RuntimeTemplate>? _rows;
    private readonly HashSet<int> _selected = new();
    private bool _busy;
    private string? _lastError;
    private string? _lastSuccess;
    private IReadOnlyList<BulkActionFailure> _lastFailures = Array.Empty<BulkActionFailure>();
    private ConfirmDialog? _confirm;

    private List<SystemTemplateSummary>? _systemTemplates;
    private bool _importBusy;
    private string? _importError;
    private string? _importSuccess;

    private enum BulkAction { SoftDelete, Restore, Deprecate, UnDeprecate }

    private List<RuntimeTemplate> FilteredRows => _rows is null
        ? new()
        : (_hideDeprecated ? _rows.Where(t => !t.Deprecated).ToList() : _rows);

    private bool AllVisibleSelected =>
        FilteredRows.Count > 0 && FilteredRows.All(t => _selected.Contains(t.Id));

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
        if (!OrgContext.IsSystemOrganization)
        {
            await ReloadSystemTemplatesAsync();
        }
    }

    private async Task ReloadAsync()
    {
        _rows = null;
        StateHasChanged();
        _rows = await Templates.GetAllForAdminAsync(includeDeleted: _showDeleted);
        // Drop selections for rows that no longer match the filter so the
        // bulk bar count stays honest.
        _selected.RemoveWhere(id => !_rows.Any(r => r.Id == id));
    }

    private async Task ReloadSystemTemplatesAsync()
    {
        _systemTemplates = await Imports.ListSystemTemplatesAsync();
    }

    private async Task ImportFromSiteAsync(int systemTemplateId)
    {
        if (_importBusy) return;
        _importBusy = true;
        _importError = null;
        _importSuccess = null;
        try
        {
            var imported = await Imports.ImportTemplateAsync(systemTemplateId);
            _importSuccess = $"Imported template '{imported.Key}'.";
            await ReloadAsync();
            await ReloadSystemTemplatesAsync();
        }
        catch (PlanValidationException ex)
        {
            _importError = ex.Errors.FirstOrDefault().Value ?? "Import failed.";
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Import-from-site failed for system template {Id}.", systemTemplateId);
            _importError = "An unexpected error occurred. The import was not applied.";
        }
        finally
        {
            _importBusy = false;
        }
    }

    private void ToggleRow(int id, ChangeEventArgs e)
    {
        if (e.Value is bool checkedNow && checkedNow) _selected.Add(id);
        else _selected.Remove(id);
    }

    private void ToggleSelectAllVisible(ChangeEventArgs e)
    {
        var checkedNow = e.Value is bool b && b;
        foreach (var t in FilteredRows)
        {
            if (checkedNow) _selected.Add(t.Id);
            else _selected.Remove(t.Id);
        }
    }

    private void ClearSelection()
    {
        _selected.Clear();
        _lastError = null;
        _lastSuccess = null;
        _lastFailures = Array.Empty<BulkActionFailure>();
    }

    private async Task RequestBulkAsync(BulkAction action)
    {
        if (_selected.Count == 0 || _busy || _rows is null) return;
        var ids = _selected.ToList();
        var affected = _rows.Where(r => ids.Contains(r.Id)).ToList();
        var label = action switch
        {
            BulkAction.SoftDelete => "soft-delete",
            BulkAction.Restore => "restore",
            BulkAction.Deprecate => "deprecate",
            BulkAction.UnDeprecate => "un-deprecate",
            _ => action.ToString(),
        };
        if (_confirm is not null)
        {
            var names = string.Join(", ", affected.Take(8).Select(t => t.Name));
            if (affected.Count > 8) names += $", and {affected.Count - 8} more";
            var confirmed = await _confirm.OpenAsync(
                title: $"{Capitalize(label)} {affected.Count} template(s)?",
                message: $"This will {label}: {names}.",
                confirmLabel: Capitalize(label),
                confirmButtonClass: action == BulkAction.SoftDelete ? "btn--danger" : "btn--primary");
            if (!confirmed) return;
        }

        _busy = true;
        _lastError = null;
        _lastSuccess = null;
        _lastFailures = Array.Empty<BulkActionFailure>();
        try
        {
            BulkActionResult result = action switch
            {
                BulkAction.SoftDelete => await Templates.BulkSoftDeleteAsync(ids),
                BulkAction.Restore => await Templates.BulkRestoreAsync(ids),
                BulkAction.Deprecate => await Templates.BulkDeprecateAsync(ids),
                BulkAction.UnDeprecate => await Templates.BulkUnDeprecateAsync(ids),
                _ => throw new InvalidOperationException($"Unknown action {action}"),
            };
            _lastFailures = result.Failures;
            if (result.AllSucceeded)
            {
                _lastSuccess = $"Bulk {label} applied to {result.SucceededCount} template(s).";
            }
            else if (result.SucceededCount == 0)
            {
                _lastError = $"Bulk {label} failed for all {result.FailedCount} selected row(s). See details below.";
            }
            else
            {
                _lastSuccess = $"Bulk {label} applied to {result.SucceededCount} of {result.TotalRequested} template(s).";
            }
            _selected.Clear();
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Bulk {Action} on templates raised an unexpected error.", label);
            _lastError = "An unexpected error occurred. The change was not saved.";
        }
        finally
        {
            _busy = false;
        }
    }

    private static string Capitalize(string s) => string.IsNullOrEmpty(s) ? s : char.ToUpperInvariant(s[0]) + s[1..];

    private static string StatusFor(RuntimeTemplate t)
    {
        if (t.DeletedAt is not null) return "Deleted";
        if (t.Deprecated) return "Deprecated";
        return "Active";
    }
}
