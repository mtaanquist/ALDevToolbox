@page "/admin/configuration/logo"
@page "/admin/templates/logo"
@attribute [Authorize(Roles = "Admin")]
@inject NavigationManager Nav

@*
    Logo lives inside /admin/templates/defaults as of P4.21 — folded in to
    cut the per-page count. Both legacy URLs (/admin/configuration/logo and
    /admin/templates/logo) redirect here so old bookmarks keep working.
*@

@code {
    protected override void OnInitialized() => Nav.NavigateTo("/admin/templates/defaults", replace: true);
}
