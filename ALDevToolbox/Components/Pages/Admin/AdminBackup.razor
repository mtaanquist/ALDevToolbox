@page "/admin/backup"
@attribute [Authorize(Roles = "Admin")]

@*
    Per-organisation backup & restore surface. The dashboard's "Export all to
    TOML" download moved here alongside the configuration import that used to
    live on /admin/configuration — both are destructive or large operations
    that benefit from their own page instead of cluttering day-to-day editing.
*@

<PageTitle>Backup &amp; restore · Admin · AL Dev Toolbox</PageTitle>

<div class="admin-page">
    <header class="admin-page__header">
        <div>
            <h1>Backup &amp; restore</h1>
            <p class="muted">
                Export this organisation's templates, modules, catalogue and
                configuration as a TOML snapshot, or replay a previously
                exported <code>organization-config.toml</code> to overwrite the
                current configuration block.
            </p>
        </div>
        <a class="btn btn--sm" href="/admin">
            <Icon Name="arrow-left" Width="14" Height="14" />
            <span>Back to admin</span>
        </a>
    </header>

    @if (Ok == "imported")
    {
        <p class="form-success" role="status">Configuration imported.</p>
    }
    @if (!string.IsNullOrEmpty(Msg))
    {
        <p class="form-error" role="alert">@Msg</p>
    }

    <section class="admin-section">
        <h2>Export</h2>
        <p class="muted">
            Download every active template, module, and catalogue entry as a
            TOML ZIP. Use it as a point-in-time snapshot or to grep the live
            state outside the app.
        </p>
        <form method="post" action="/admin/export">
            <AntiforgeryToken />
            <button type="submit" class="btn">
                <Icon Name="download" Width="16" Height="16" />
                <span>Export all to TOML</span>
            </button>
        </form>
    </section>

    <section class="admin-section admin-configuration__danger">
        <h2>Restore configuration</h2>
        <p class="muted">
            Paste an <code>organization-config.toml</code> from an export ZIP and
            replace this organisation's defaults, logo and file list. Existing
            values are wiped — confirm before submitting.
        </p>
        <form method="post" action="/admin/backup/import" class="form-grid">
            <AntiforgeryToken />
            <section class="form-section">
                <label class="section-label" for="cfg-import-toml">TOML</label>
                <textarea id="cfg-import-toml" name="Toml" rows="8"
                          placeholder="[settings]&#10;default_publisher = …"></textarea>
            </section>
            <label class="check-row">
                <input type="checkbox" name="Confirm" value="true" />
                <span>I understand this overwrites the current configuration.</span>
            </label>
            <div class="form-actions">
                <button type="submit" class="btn btn--danger">
                    <Icon Name="upload" Width="14" Height="14" />
                    <span>Restore from TOML</span>
                </button>
            </div>
        </form>
    </section>
</div>

@code {
    [SupplyParameterFromQuery(Name = "ok")] public string? Ok { get; set; }
    [SupplyParameterFromQuery(Name = "err")] public string? Err { get; set; }
    [SupplyParameterFromQuery(Name = "msg")] public string? Msg { get; set; }
}
