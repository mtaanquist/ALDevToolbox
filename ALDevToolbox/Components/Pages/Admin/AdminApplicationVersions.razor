@page "/admin/application-versions"
@attribute [Authorize(Roles = "Admin,Editor")]
@rendermode InteractiveServer
@inject ApplicationVersionService Versions
@inject IJSRuntime JS
@inject ILogger<AdminApplicationVersions> Log
@implements IAsyncDisposable
@using ALDevToolbox.Domain.Entities
@using ALDevToolbox.Domain.ValueObjects

@*
    Table editor for the curated application-version catalogue (Milestone P2.4).
    Each entry is a single table row of inline inputs (Object Explorer
    data-table style); a blank "ghost" row sits permanently at the bottom and
    becomes a real row the moment you type in it (a fresh ghost then appears),
    so there's no explicit "add" step. Reorder and remove live in a toolbar
    that acts on the selected row. The whole list is submitted on Save; the
    service reconciles row by row so unchanged entries keep their primary keys
    and the audit log only records real changes. Removed rows are soft-deleted
    so existing template foreign keys stay resolvable.
*@

<PageTitle>Application versions · Admin · AL Dev Toolbox</PageTitle>

<div class="admin-page admin-template-edit admin-page--wide">
    <header class="admin-page__header">
        <div>
            <h1>Application versions</h1>
            <p class="muted">
                These rows back the Application Version select on the New
                Workspace and New Extension forms. Picking an entry there fills
                both the <code>application</code> and <code>runtime</code>
                fields on the generated <code>app.json</code>. Removed rows are
                soft-deleted so historical templates stay linkable in the audit
                log.
            </p>
        </div>
        <div class="admin-page__header-actions">
            <a class="btn btn--sm" href="/admin">
                <Icon Name="arrow-left" Width="14" Height="14" />
                <span>Back to admin</span>
            </a>
            <button type="button" class="btn btn--sm btn--primary"
                    @onclick="SaveAsync"
                    disabled="@(_saving || _form is null)">
                <Icon Name="save" Width="14" Height="14" />
                <span>@(_saving ? "Saving…" : "Save catalogue")</span>
            </button>
        </div>
    </header>

    @if (_form is null)
    {
        <p class="muted">Loading…</p>
    }
    else
    {
        @if (_saveError is not null)
        {
            <div class="form-error" role="alert">
                <p>@_saveError</p>
                @if (_globalErrors.Count > 0)
                {
                    @* Errors that aren't pinned to a specific row — almost
                       always the in-use guard rejecting a removal. Listed
                       here so the admin sees what to fix. *@
                    <ul class="form-error__list">
                        @foreach (var err in _globalErrors)
                        {
                            <li>@err.Value</li>
                        }
                    </ul>
                }
            </div>
        }
        @if (_saveSuccess is not null)
        {
            <p class="form-success" role="status">@_saveSuccess</p>
        }

        <form class="form-grid admin-template-edit__form" @onsubmit="SaveAsync" @onsubmit:preventDefault>
            <section class="form-section">
                <div class="row-editor" @ref="_editorRef">
                    <div class="row-editor__toolbar">
                        <button type="button" class="btn btn--sm" title="Move to top"
                                disabled="@(!CanMoveUp)"
                                @onclick="() => MoveEntryToTop(SelectedIndex)">
                            <Icon Name="chevrons-up" Width="14" Height="14" />
                        </button>
                        <button type="button" class="btn btn--sm" title="Move up"
                                disabled="@(!CanMoveUp)"
                                @onclick="() => MoveEntry(SelectedIndex, -1)">
                            <Icon Name="chevron-up" Width="14" Height="14" />
                        </button>
                        <button type="button" class="btn btn--sm" title="Move down"
                                disabled="@(!CanMoveDown)"
                                @onclick="() => MoveEntry(SelectedIndex, 1)">
                            <Icon Name="chevron-down" Width="14" Height="14" />
                        </button>
                        <button type="button" class="btn btn--sm" title="Move to bottom"
                                disabled="@(!CanMoveDown)"
                                @onclick="() => MoveEntryToBottom(SelectedIndex)">
                            <Icon Name="chevrons-down" Width="14" Height="14" />
                        </button>
                        <span class="row-editor__divider" aria-hidden="true"></span>
                        <button type="button" class="btn btn--sm btn--danger" title="Remove selected row"
                                disabled="@(!SelectedIsReal)"
                                @onclick="() => RemoveEntry(SelectedIndex)">
                            <Icon Name="trash-2" Width="14" Height="14" />
                            <span>Remove</span>
                        </button>
                    </div>

                    <table class="data-table row-editor__table">
                        <colgroup>
                            <col class="row-editor__col-key" />
                            <col />
                            <col class="row-editor__col-version" />
                            <col class="row-editor__col-version" />
                            <col class="row-editor__col-flag" />
                            <col class="row-editor__col-flag" />
                        </colgroup>
                        <thead>
                            <tr>
                                <th scope="col">Key</th>
                                <th scope="col">Friendly name</th>
                                <th scope="col">Application</th>
                                <th scope="col">Runtime</th>
                                <th scope="col">Deprecated</th>
                                <th scope="col">In use</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (var i = 0; i < _form.Entries.Count; i++)
                            {
                                var index = i;
                                var row = _form.Entries[index];
                                <tr @key="row" class="@RowCss(index, row)"
                                    @onfocusin="() => _selected = row">
                                    <td>
                                        <input type="text" required placeholder="bc-2026-w1"
                                               pattern="[a-z0-9-]+"
                                               title="Lowercase letters, digits, hyphens. Press F8 to copy the cell above."
                                               data-row="@index" data-col="0"
                                               @bind="row.Key" @bind:event="oninput" @bind:after="EnsureTrailingBlank"
                                               @onkeydown="e => OnCellKeyDown(e, index, Col.Key)" />
                                        <FieldError Field="@($"Entries[{index}].Key")" Errors="_fieldErrors" />
                                    </td>
                                    <td>
                                        <input type="text" required placeholder="Business Central 2026 Release Wave 1"
                                               title="Press F8 to copy the cell above."
                                               data-row="@index" data-col="1"
                                               @bind="row.Name" @bind:event="oninput" @bind:after="EnsureTrailingBlank"
                                               @onkeydown="e => OnCellKeyDown(e, index, Col.Name)" />
                                        <FieldError Field="@($"Entries[{index}].Name")" Errors="_fieldErrors" />
                                    </td>
                                    <td>
                                        <input type="text" required placeholder="28.0.0.0"
                                               title="Type a number; missing parts auto-pad with .0 on blur. Press F8 to copy the cell above."
                                               data-row="@index" data-col="2"
                                               @bind="row.Application" @bind:event="oninput" @bind:after="EnsureTrailingBlank"
                                               @onblur="() => NormaliseApplication(row)"
                                               @onkeydown="e => OnCellKeyDown(e, index, Col.Application)" />
                                        <FieldError Field="@($"Entries[{index}].Application")" Errors="_fieldErrors" />
                                    </td>
                                    <td>
                                        <input type="text" required placeholder="15.2"
                                               title="Type a number; missing parts auto-pad with .0 on blur. Press F8 to copy the cell above."
                                               data-row="@index" data-col="3"
                                               @bind="row.Runtime" @bind:event="oninput" @bind:after="EnsureTrailingBlank"
                                               @onblur="() => NormaliseRuntime(row)"
                                               @onkeydown="e => OnCellKeyDown(e, index, Col.Runtime)" />
                                        <FieldError Field="@($"Entries[{index}].Runtime")" Errors="_fieldErrors" />
                                    </td>
                                    <td class="row-editor__cell-center">
                                        <input type="checkbox" @bind="row.Deprecated" />
                                        <FieldError Field="@($"Entries[{index}].Deprecated")" Errors="_fieldErrors" />
                                    </td>
                                    <td class="row-editor__cell-center">
                                        @if (row.Id is int rowId && _usage.TryGetValue(rowId, out var usingTemplates) && usingTemplates.Count > 0)
                                        {
                                            <span class="row-editor__usage"
                                                  title="@($"In use by {usingTemplates.Count} active template{(usingTemplates.Count == 1 ? "" : "s")}: {string.Join(", ", usingTemplates)}")">
                                                @usingTemplates.Count
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="muted">—</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <small class="muted">
                        Start typing in the blank row at the bottom to add an
                        entry — a fresh blank row always follows. Click a row to
                        select it, then use the toolbar to move or remove it.
                        Press <kbd>F8</kbd> in any cell to copy the value from the
                        row above, or paste a range copied from Excel to fill
                        multiple rows at once. Picking an entry on the builder
                        forms fills both <code>application</code> and
                        <code>runtime</code> atomically. The <code>key</code> is
                        what <code>template.toml</code> stores in
                        <code>default_application_version</code>.
                    </small>
                </div>
            </section>

            @* Hidden submit so pressing Enter inside an input still triggers
               SaveAsync — the visible Save button moved to the header. *@
            <button type="submit" class="visually-hidden" aria-hidden="true" tabindex="-1">Save</button>
        </form>
    }
</div>

@code {
    private FormState? _form;
    private bool _saving;
    private string? _saveError;
    private string? _saveSuccess;
    private IReadOnlyDictionary<string, string> _fieldErrors = new Dictionary<string, string>();
    private IReadOnlyDictionary<string, string> _globalErrors = new Dictionary<string, string>();
    private Dictionary<int, List<string>> _usage = new();

    // Tracked by reference (not index) so the highlight follows the row across
    // reorders — the toolbar acts on whichever row this points at.
    private EntryRow? _selected;

    // Excel-paste interop: the JS handler lives on this wrapper element and
    // calls back into OnGridPaste. Registered once the editor has rendered.
    private ElementReference _editorRef;
    private DotNetObjectReference<AdminApplicationVersions>? _selfRef;
    private bool _pasteBound;

    private int SelectedIndex =>
        _selected is null || _form is null ? -1 : _form.Entries.IndexOf(_selected);

    // The last row is always the blank "ghost" placeholder; a real row is any
    // selected row that isn't it. Move/remove only apply to real rows, and a
    // real row can never be pushed below the ghost.
    private bool SelectedIsReal => _form is not null && SelectedIndex >= 0 && SelectedIndex < _form.Entries.Count - 1;
    private bool CanMoveUp => SelectedIsReal && SelectedIndex > 0;
    private bool CanMoveDown => SelectedIsReal && SelectedIndex < _form!.Entries.Count - 2;

    /// <summary>Columns that participate in the F8 "copy cell above" shortcut.</summary>
    private enum Col { Key, Name, Application, Runtime }

    private string RowCss(int index, EntryRow row)
    {
        var css = row == _selected ? "is-selected" : "";
        if (index == _form!.Entries.Count - 1) css = (css + " is-ghost").Trim();
        return css;
    }

    protected override Task OnInitializedAsync() => ReloadAsync();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // The wrapper only exists once the form has hydrated (the first render
        // shows "Loading…"), so bind on whichever render first exposes it. The
        // element is stable across later re-renders, so bind exactly once.
        if (!_pasteBound && _form is not null)
        {
            _selfRef ??= DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("aldt.registerGridPaste", _editorRef, _selfRef);
            _pasteBound = true;
        }
    }

    private async Task ReloadAsync()
    {
        _form = null;
        _saving = false;
        _saveError = null;
        _saveSuccess = null;
        _selected = null;
        _fieldErrors = new Dictionary<string, string>();
        _globalErrors = new Dictionary<string, string>();
        StateHasChanged();
        // Hide soft-deleted rows from the editor — the service silently
        // soft-deletes anything that isn't in the input list, so showing
        // historical rows here would tempt admins to "fix" them in place.
        var rows = await Versions.GetActiveAsync(includeDeprecated: true);
        _usage = await Versions.GetActiveUsageAsync();
        _form = FormState.From(rows);
        EnsureTrailingBlank();
    }

    /// <summary>
    /// Keeps exactly one empty row at the end of the list so there's always a
    /// place to start a new entry. Called after every cell edit (via
    /// <c>@bind:after</c>), F8, paste, removal, and load.
    /// </summary>
    private void EnsureTrailingBlank()
    {
        if (_form is null) return;
        if (_form.Entries.Count == 0 || !_form.Entries[^1].IsBlank())
        {
            _form.Entries.Add(new EntryRow());
        }
    }

    private void NormaliseApplication(EntryRow row) =>
        row.Application = PadVersion(row.Application, 4);

    private void NormaliseRuntime(EntryRow row) =>
        row.Runtime = PadVersion(row.Runtime, 2);

    private static readonly System.Text.RegularExpressions.Regex VersionShape =
        new(@"^\d+(\.\d+)*$", System.Text.RegularExpressions.RegexOptions.Compiled);

    /// <summary>
    /// Mirror of <c>ApplicationVersionService.PadVersion</c>: pads short
    /// numeric input up to <paramref name="parts"/> segments. Anything that
    /// doesn't already look numeric passes through so the regular validators
    /// can complain about it.
    /// </summary>
    private static string PadVersion(string raw, int parts)
    {
        var trimmed = (raw ?? string.Empty).Trim();
        if (trimmed.Length == 0) return trimmed;
        if (!VersionShape.IsMatch(trimmed)) return trimmed;
        var segments = trimmed.Split('.').ToList();
        while (segments.Count < parts) segments.Add("0");
        return string.Join('.', segments);
    }

    private void RemoveEntry(int index)
    {
        if (_form is null) return;
        if (index >= 0 && index < _form.Entries.Count)
        {
            if (_form.Entries[index] == _selected) _selected = null;
            _form.Entries.RemoveAt(index);
            EnsureTrailingBlank();
        }
    }

    private void MoveEntry(int index, int delta)
    {
        if (_form is null) return;
        var target = index + delta;
        if (index < 0 || index >= _form.Entries.Count || target < 0 || target >= _form.Entries.Count)
        {
            return;
        }
        // Never swap a real row past the trailing ghost.
        if (target == _form.Entries.Count - 1) return;
        (_form.Entries[index], _form.Entries[target]) =
            (_form.Entries[target], _form.Entries[index]);
    }

    private void MoveEntryToTop(int index)
    {
        if (_form is null) return;
        if (index <= 0 || index >= _form.Entries.Count) return;
        var row = _form.Entries[index];
        _form.Entries.RemoveAt(index);
        _form.Entries.Insert(0, row);
    }

    private void MoveEntryToBottom(int index)
    {
        if (_form is null) return;
        // Move to the last *real* slot — immediately above the trailing ghost.
        if (index < 0 || index >= _form.Entries.Count - 2) return;
        var row = _form.Entries[index];
        _form.Entries.RemoveAt(index);
        _form.Entries.Insert(_form.Entries.Count - 1, row);
    }

    /// <summary>
    /// Business-Central-style "copy field above" (F8): copies the same column's
    /// value from the previous row into the focused cell. No-op on the first row.
    /// </summary>
    private void OnCellKeyDown(KeyboardEventArgs e, int index, Col col)
    {
        if (e.Key != "F8" || _form is null || index <= 0 || index >= _form.Entries.Count) return;
        var above = _form.Entries[index - 1];
        var cur = _form.Entries[index];
        switch (col)
        {
            case Col.Key: cur.Key = above.Key; break;
            case Col.Name: cur.Name = above.Name; break;
            case Col.Application: cur.Application = above.Application; break;
            case Col.Runtime: cur.Runtime = above.Runtime; break;
        }
        EnsureTrailingBlank();
    }

    /// <summary>
    /// Excel-style paste: <paramref name="text"/> is a tab/newline-separated
    /// block dropped onto the cell at (<paramref name="startRow"/>,
    /// <paramref name="startCol"/>). Fills cells right/down from there, adding
    /// rows when the pasted block runs past the end of the list. Version cells
    /// are auto-padded so a pasted "28" lands as "28.0.0.0". Non-text columns
    /// (Deprecated, In use) and columns past them are ignored. Invoked from
    /// grid-paste.js.
    /// </summary>
    [JSInvokable]
    public void OnGridPaste(int startRow, int startCol, string text)
    {
        if (_form is null) return;
        var grid = GridPasteParser.Parse(text);
        if (grid.Count == 0) return;

        for (var r = 0; r < grid.Count; r++)
        {
            var rowIndex = startRow + r;
            while (_form.Entries.Count <= rowIndex) _form.Entries.Add(new EntryRow());
            var entry = _form.Entries[rowIndex];
            var cells = grid[r];
            for (var c = 0; c < cells.Count; c++)
            {
                ApplyCell(entry, startCol + c, cells[c]);
            }
        }

        var lastRow = startRow + grid.Count - 1;
        if (lastRow >= 0 && lastRow < _form.Entries.Count) _selected = _form.Entries[lastRow];
        EnsureTrailingBlank();
        StateHasChanged();
    }

    private static void ApplyCell(EntryRow row, int col, string value)
    {
        switch (col)
        {
            case 0: row.Key = value; break;
            case 1: row.Name = value; break;
            case 2: row.Application = PadVersion(value, 4); break;
            case 3: row.Runtime = PadVersion(value, 2); break;
            // Deprecated/In-use and any further columns are ignored.
        }
    }

    private async Task SaveAsync()
    {
        if (_form is null || _saving) return;
        _saving = true;
        _saveError = null;
        _saveSuccess = null;
        _fieldErrors = new Dictionary<string, string>();
        _globalErrors = new Dictionary<string, string>();

        // Apply the same auto-pad the service does so the values shown in the
        // form match what would be persisted, and so any subsequent client-side
        // pattern check in the browser doesn't disagree with the server.
        foreach (var row in _form.Entries)
        {
            row.Application = PadVersion(row.Application, 4);
            row.Runtime = PadVersion(row.Runtime, 2);
        }

        var payload = _form.ToInputs();

        try
        {
            await Versions.SaveAsync(payload);
            var rows = await Versions.GetActiveAsync(includeDeprecated: true);
            _usage = await Versions.GetActiveUsageAsync();
            _form = FormState.From(rows);
            EnsureTrailingBlank();
            _selected = null;
            _saveSuccess = "Saved.";
        }
        catch (PlanValidationException ex)
        {
            // Split per-row errors (Entries[N]....) from global errors so the
            // page can render in-use guard messages above the form rather than
            // hiding them next to a field that doesn't exist.
            _fieldErrors = ex.Errors
                .Where(p => p.Key.StartsWith("Entries[", StringComparison.Ordinal))
                .ToDictionary(p => p.Key, p => p.Value);
            _globalErrors = ex.Errors
                .Where(p => !p.Key.StartsWith("Entries[", StringComparison.Ordinal))
                .ToDictionary(p => p.Key, p => p.Value);
            _saveError = $"Couldn't save: {ex.Errors.Count} validation error(s).";
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Unexpected error saving application versions.");
            _saveError = "An unexpected error occurred. The change was not saved.";
        }
        finally
        {
            _saving = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_pasteBound)
        {
            // The circuit may already be gone on disposal; swallow the
            // disconnect rather than surface it as an unhandled exception.
            try { await JS.InvokeVoidAsync("aldt.unregisterGridPaste", _editorRef); }
            catch (JSDisconnectedException) { }
            catch (InvalidOperationException) { }
        }
        _selfRef?.Dispose();
    }

    private sealed class FormState
    {
        public List<EntryRow> Entries { get; } = new();

        public static FormState From(IReadOnlyList<ApplicationVersion> rows)
        {
            var state = new FormState();
            foreach (var r in rows)
            {
                state.Entries.Add(new EntryRow
                {
                    Id = r.Id,
                    Key = r.Key,
                    Name = r.Name,
                    Application = r.Application,
                    Runtime = r.Runtime,
                    Deprecated = r.Deprecated,
                });
            }
            return state;
        }

        /// <summary>
        /// Maps rows to service inputs, dropping trailing blank rows (the
        /// always-present ghost) so the add-placeholder is never validated or
        /// persisted. Only trailing blanks are dropped, which keeps every
        /// remaining row's index aligned with the <c>Entries[N]</c> error keys.
        /// </summary>
        public List<ApplicationVersionInput> ToInputs()
        {
            var rows = Entries.ToList();
            while (rows.Count > 0 && rows[^1].IsBlank()) rows.RemoveAt(rows.Count - 1);
            return rows
                .Select(e => new ApplicationVersionInput(
                    Id: e.Id,
                    Key: e.Key,
                    Name: e.Name,
                    Application: e.Application,
                    Runtime: e.Runtime,
                    Deprecated: e.Deprecated))
                .ToList();
        }
    }

    private sealed class EntryRow
    {
        public int? Id { get; set; }
        public string Key { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string Application { get; set; } = string.Empty;
        public string Runtime { get; set; } = string.Empty;
        public bool Deprecated { get; set; }

        /// <summary>A row with no text content — the ghost, or a cleared row.
        /// <c>Deprecated</c> is ignored: a deprecated-only row is meaningless.</summary>
        public bool IsBlank() =>
            string.IsNullOrWhiteSpace(Key) && string.IsNullOrWhiteSpace(Name)
            && string.IsNullOrWhiteSpace(Application) && string.IsNullOrWhiteSpace(Runtime);
    }
}
