@page "/admin/snippets/new"
@page "/admin/snippets/{Id:int}"
@attribute [Authorize(Roles = "Admin,Editor")]
@rendermode InteractiveServer
@inject SnippetService Snippets
@inject ApplicationVersionService ApplicationVersions
@inject NavigationManager Nav
@inject ILogger<AdminSnippetEdit> Log
@using ALDevToolbox.Domain.Entities
@using ALDevToolbox.Domain.ValueObjects

<PageTitle>@(IsEdit ? "Edit snippet" : "New snippet") · Admin · AL Dev Toolbox</PageTitle>

<div class="admin-page">
    <header class="admin-page__header">
        <div>
            <h1>@(IsEdit ? "Edit snippet" : "New snippet")</h1>
            <p class="muted">
                @(IsEdit
                    ? "Update the published snippet. Changes apply on next reload of the user-facing browser."
                    : "Add a new snippet to the published library for this organisation.")
            </p>
        </div>
        <div class="admin-page__header-actions">
            <a class="btn btn--sm" href="/admin/snippets">
                <Icon Name="arrow-left" Width="14" Height="14" />
                <span>Back to snippets</span>
            </a>
            @if (!IsEdit || !_loadFailed)
            {
                <button type="button" class="btn btn--sm btn--primary" @onclick="SaveAsync" disabled="@_busy">
                    <Icon Name="save" Width="14" Height="14" />
                    <span>@(_busy ? "Saving…" : IsEdit ? "Save changes" : "Create snippet")</span>
                </button>
            }
        </div>
    </header>

    @if (IsEdit && _loadFailed)
    {
        <p class="form-error" role="alert">Snippet @Id was not found.</p>
    }
    else
    {
        <section class="admin-section">
            <h2>Details</h2>
            <div class="form-grid form-grid--narrow">
                <section class="form-section">
                    <label class="section-label" for="snippet-title">Title</label>
                    <input id="snippet-title" type="text" maxlength="200"
                           @bind="_title" @bind:event="oninput"
                           placeholder="e.g. Doc. Attachment List Factbox for an unsupported table" />
                    <FieldError Field="Title" Errors="_errors" />
                </section>

                <section class="form-section">
                    <label class="section-label" for="snippet-description">Description</label>
                    <textarea id="snippet-description" rows="4" maxlength="2000"
                              @bind="_description" @bind:event="oninput"
                              placeholder="What does this snippet do, and when would you use it?"></textarea>
                    <FieldError Field="Description" Errors="_errors" />
                </section>

                <section class="form-section">
                    <label class="section-label" for="snippet-keywords">Keywords</label>
                    <input id="snippet-keywords" type="text" maxlength="500"
                           @bind="_keywords" @bind:event="oninput"
                           placeholder="space-separated, e.g. factbox attachment subscriber" />
                    <FieldError Field="Keywords" Errors="_errors" />
                </section>

                <section class="form-section">
                    <label class="section-label" for="snippet-min-version">Minimum BC application version</label>
                    <select id="snippet-min-version" @bind="_minimumApplicationVersionId">
                        <option value="">No minimum</option>
                        @foreach (var v in _applicationVersions)
                        {
                            <option value="@v.Id">@v.Name (@v.Application)</option>
                        }
                    </select>
                    <small class="muted">
                        Shown as a badge on the browser card and detail page so users can
                        tell at a glance whether this snippet targets their runtime.
                    </small>
                    <FieldError Field="MinimumApplicationVersionId" Errors="_errors" />
                </section>

                <section class="form-section">
                    <label class="section-label" for="snippet-instructions">Instructions (Markdown)</label>
                    <textarea id="snippet-instructions" rows="6" maxlength="10000"
                              @bind="_instructions" @bind:event="oninput"
                              placeholder="Optional setup notes. Markdown is rendered on the public detail page (headings, lists, code fences, links)."></textarea>
                    <FieldError Field="Instructions" Errors="_errors" />
                </section>

                <label class="check-row">
                    <input type="checkbox" @bind="_deprecated" />
                    <span>Deprecated (hidden from the user-facing browser)</span>
                </label>
            </div>
        </section>

        <section class="admin-section">
            <h2>Files</h2>
            <p class="muted">
                Each file becomes one AL object. Existing rows collapse to the
                file name — click to expand and edit the content.
            </p>
            <SnippetFileEditor Files="_files" Errors="_errors" />
        </section>

        @if (_lastError is not null)
        {
            <p class="form-error" role="alert">@_lastError</p>
        }
    }
</div>

@code {
    [Parameter] public int? Id { get; set; }

    private bool IsEdit => Id is not null;
    private string _title = string.Empty;
    private string _description = string.Empty;
    private string _keywords = string.Empty;
    private bool _deprecated;
    private string _instructions = string.Empty;
    private string _minimumApplicationVersionId = string.Empty;
    private List<ApplicationVersion> _applicationVersions = new();
    private List<SnippetFileEditor.EditableFile> _files = new() { new SnippetFileEditor.EditableFile() };
    private IReadOnlyDictionary<string, string>? _errors;
    private string? _lastError;
    private bool _busy;
    private bool _loadFailed;

    protected override async Task OnInitializedAsync()
    {
        _applicationVersions = await ApplicationVersions.GetActiveAsync();
        if (Id is null) return;
        var existing = await Snippets.GetAsync(Id.Value);
        if (existing is null)
        {
            _loadFailed = true;
            return;
        }
        _title = existing.Title;
        _description = existing.Description;
        _keywords = existing.Keywords;
        _deprecated = existing.Deprecated;
        _instructions = existing.Instructions ?? string.Empty;
        _minimumApplicationVersionId = existing.MinimumApplicationVersionId?.ToString() ?? string.Empty;
        // If the snippet points at a deprecated or soft-deleted catalogue row
        // the active-only list wouldn't include it; surface the existing
        // navigation entity as a synthetic option so the dropdown stays
        // consistent with what's persisted.
        if (existing.MinimumApplicationVersion is { } current
            && !_applicationVersions.Any(v => v.Id == current.Id))
        {
            _applicationVersions = _applicationVersions.Append(current).ToList();
        }
        _files = existing.Files
            .OrderBy(f => f.Ordering)
            .Select(f => new SnippetFileEditor.EditableFile { FileName = f.FileName, Content = f.Content })
            .ToList();
        if (_files.Count == 0)
        {
            _files.Add(new SnippetFileEditor.EditableFile());
        }
    }

    private async Task SaveAsync()
    {
        if (_busy) return;
        _busy = true;
        _errors = null;
        _lastError = null;
        try
        {
            var input = new SnippetInput(
                _title,
                _description,
                _keywords,
                _deprecated,
                _files.Select(f => new SnippetFileInput(f.FileName, f.Content)).ToList(),
                Instructions: _instructions,
                MinimumApplicationVersionId: int.TryParse(_minimumApplicationVersionId, out var avId) ? avId : null);
            if (Id is null)
            {
                var created = await Snippets.CreateAsync(input);
                Nav.NavigateTo($"/admin/snippets/{created.Id}");
            }
            else
            {
                await Snippets.UpdateAsync(Id.Value, input);
                Nav.NavigateTo("/admin/snippets");
            }
        }
        catch (PlanValidationException ex)
        {
            _errors = ex.Errors;
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Failed to save snippet.");
            _lastError = "An unexpected error occurred. The snippet was not saved.";
        }
        finally
        {
            _busy = false;
        }
    }
}
