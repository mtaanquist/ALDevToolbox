@*
    Sub-navigation for the Import tab of the admin Object Explorer. The top-level
    OE tabs (Releases / Projects / Import) come from AdminObjectExplorerHeader;
    these pills pick the import *mechanism*: a Microsoft artifact from the CDN
    (the precise first-party path; the older DVD-URL import is still reachable as
    an advanced link on that page), a third-party .app upload, or a legacy C/AL
    text export. Project builds moved to their own top-level Projects tab. Each
    pill is a real <a href> so every route is bookmarkable. See
    .design/object-explorer-project-builds.md.
*@

@using ALDevToolbox.Components.Shared

<AdminObjectExplorerHeader ActiveTab="AdminObjectExplorerHeader.Tab.Import" />

<PillTabs Items="@_tabs" AriaLabel="Import mode" Equal="true" />

@code {
    // Dvd is intentionally not a pill - the DVD-URL page highlights the Microsoft
    // pill (it's the advanced variant of the Microsoft/artifacts path).
    public enum Tab { Microsoft, ThirdParty, Cal }

    [Parameter, EditorRequired] public Tab ActiveTab { get; set; }

    private IReadOnlyList<PillTabs.PillTabItem> _tabs = Array.Empty<PillTabs.PillTabItem>();

    protected override void OnParametersSet()
    {
        _tabs = new List<PillTabs.PillTabItem>
        {
            new("Microsoft",   "/admin/object-explorer/new/artifacts", "package",  ActiveTab == Tab.Microsoft),
            new("Third-party", "/admin/object-explorer/new",           "upload",   ActiveTab == Tab.ThirdParty),
            new("C/AL",        "/admin/object-explorer/new/cal",       "file-code", ActiveTab == Tab.Cal),
        };
    }
}
