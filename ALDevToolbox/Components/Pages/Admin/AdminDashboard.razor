@page "/admin"
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.AspNetCore.Authorization
@using ALDevToolbox.Services
@inject IOrganizationContext OrgContext

<PageTitle>Admin · AL Dev Toolbox</PageTitle>

@*
    Single admin landing page. Tiles are gated by whether the current org is
    the system org (which has no per-org user list, configuration, or
    per-org backup workflow) and by whether the signed-in user is a
    SiteAdmin (who gets the cross-org tools alongside the starter-entity
    pages). See NavMenu.razor for the same gating rules driving the
    sidebar.
*@

<AuthorizeView Roles="Admin">
    <Authorized Context="adminCtx">
        @{
            var isSiteAdmin = adminCtx.User.IsInRole(HttpOrganizationContext.SiteAdminRole);
            var isSystemOrg = OrgContext.IsSystemOrganization;
        }
        <div class="admin-dashboard">
            <h1>Admin</h1>
            <p class="muted">
                @if (isSystemOrg)
                {
                    <text>System organisation — curate the starter templates, modules, snippets and catalogue that other orgs import.</text>
                }
                else
                {
                    <text>Manage runtime templates, modules, the well-known dependency catalogue, and view the audit log.</text>
                }
            </p>

            <div class="admin-tiles">
                <a class="admin-tile admin-tile--link" href="/admin/templates">
                    <Icon Name="layers" Width="20" Height="20" Css="admin-tile__icon" />
                    <div class="admin-tile__body">
                        <div class="admin-tile__title">Templates</div>
                        <div class="admin-tile__caption">Edit runtime templates, their folder layouts, and JSON defaults.</div>
                    </div>
                </a>
                <a class="admin-tile admin-tile--link" href="/admin/modules">
                    <Icon Name="package" Width="20" Height="20" Css="admin-tile__icon" />
                    <div class="admin-tile__body">
                        <div class="admin-tile__title">Modules</div>
                        <div class="admin-tile__caption">Edit modules and the dependencies each one contributes to <code>app.json</code>.</div>
                    </div>
                </a>
                <a class="admin-tile admin-tile--link" href="/admin/catalog">
                    <Icon Name="book-open" Width="20" Height="20" Css="admin-tile__icon" />
                    <div class="admin-tile__body">
                        <div class="admin-tile__title">Catalogue</div>
                        <div class="admin-tile__caption">Maintain the well-known dependency list users pick from in the New Extension flow.</div>
                    </div>
                </a>
                <a class="admin-tile admin-tile--link" href="/admin/snippets">
                    <Icon Name="square-code" Width="20" Height="20" Css="admin-tile__icon" />
                    <div class="admin-tile__body">
                        <div class="admin-tile__title">Snippets</div>
                        <div class="admin-tile__caption">Curate the snippet library and review user-submitted suggestions.</div>
                    </div>
                </a>
                <a class="admin-tile admin-tile--link" href="/admin/application-versions">
                    <Icon Name="tag" Width="20" Height="20" Css="admin-tile__icon" />
                    <div class="admin-tile__body">
                        <div class="admin-tile__title">Application versions</div>
                        <div class="admin-tile__caption">Curate the BC release list users pick on New Workspace and New Extension.</div>
                    </div>
                </a>

                @if (!isSystemOrg)
                {
                    <a class="admin-tile admin-tile--link" href="/admin/configuration">
                        <Icon Name="settings" Width="20" Height="20" Css="admin-tile__icon" />
                        <div class="admin-tile__body">
                            <div class="admin-tile__title">Configuration</div>
                            <div class="admin-tile__caption">Edit defaults, the logo, and always-included files for this organisation.</div>
                        </div>
                    </a>
                    <a class="admin-tile admin-tile--link" href="/admin/users">
                        <Icon Name="users" Width="20" Height="20" Css="admin-tile__icon" />
                        <div class="admin-tile__body">
                            <div class="admin-tile__title">Users</div>
                            <div class="admin-tile__caption">Approve signups, invite users, change roles, and disable accounts in your organisation.</div>
                        </div>
                    </a>
                }

                @if (isSiteAdmin)
                {
                    <a class="admin-tile admin-tile--link" href="/site-admin/users">
                        <Icon Name="users-round" Width="20" Height="20" Css="admin-tile__icon" />
                        <div class="admin-tile__body">
                            <div class="admin-tile__title">@(isSystemOrg ? "Users" : "All users")</div>
                            <div class="admin-tile__caption">Search every organisation by email or display name and grant or revoke the SiteAdmin flag.</div>
                        </div>
                    </a>
                }

                <a class="admin-tile admin-tile--link" href="@(isSiteAdmin ? "/site-admin/audit" : "/admin/audit")">
                    <Icon Name="history" Width="20" Height="20" Css="admin-tile__icon" />
                    <div class="admin-tile__body">
                        <div class="admin-tile__title">Audit log</div>
                        <div class="admin-tile__caption">
                            @if (isSiteAdmin)
                            {
                                <text>Cross-organisation audit search across every entity type and actor.</text>
                            }
                            else
                            {
                                <text>Browse recent changes to templates, modules, and the catalogue.</text>
                            }
                        </div>
                    </div>
                </a>

                @if (!isSystemOrg)
                {
                    <a class="admin-tile admin-tile--link" href="/admin/export">
                        <Icon Name="archive" Width="20" Height="20" Css="admin-tile__icon" />
                        <div class="admin-tile__body">
                            <div class="admin-tile__title">Export</div>
                            <div class="admin-tile__caption">Export this organisation's templates, modules and catalogue as a TOML snapshot, or replay a configuration import.</div>
                        </div>
                    </a>
                }

                @if (isSiteAdmin)
                {
                    <a class="admin-tile admin-tile--link" href="/site-admin/backups">
                        <Icon Name="database-backup" Width="20" Height="20" Css="admin-tile__icon" />
                        <div class="admin-tile__body">
                            <div class="admin-tile__title">@(isSystemOrg ? "Backups" : "Database backups")</div>
                            <div class="admin-tile__caption">Browse, pin, restore, and trigger ad-hoc <code>pg_dump</code> backups.</div>
                        </div>
                    </a>
                    <a class="admin-tile admin-tile--link" href="/site-admin/storage">
                        <Icon Name="hard-drive" Width="20" Height="20" Css="admin-tile__icon" />
                        <div class="admin-tile__body">
                            <div class="admin-tile__title">Storage</div>
                            <div class="admin-tile__caption">Per-organisation database usage, billable size, and storage quotas.</div>
                        </div>
                    </a>
                    <a class="admin-tile admin-tile--link" href="/site-admin/settings">
                        <Icon Name="server-cog" Width="20" Height="20" Css="admin-tile__icon" />
                        <div class="admin-tile__body">
                            <div class="admin-tile__title">Settings</div>
                            <div class="admin-tile__caption">SMTP overrides, the system banner, backup schedule, and signup defaults.</div>
                        </div>
                    </a>
                }
            </div>
        </div>
    </Authorized>
</AuthorizeView>
