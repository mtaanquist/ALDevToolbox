@page "/admin"
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.AspNetCore.Authorization
@using ALDevToolbox.Services
@using ALDevToolbox.Services.SingleTenant
@inject IOrganizationContext OrgContext
@inject ISingleTenantMode SingleTenant

<PageTitle>Admin · AL Dev Toolbox</PageTitle>

@*
    Single admin landing page. Tiles are gated by whether the current org is
    the system org (which has no per-org user list, configuration, or
    per-org backup workflow) and by whether the signed-in user is a
    SiteAdmin (who gets the cross-org tools alongside the starter-entity
    pages). See NavMenu.razor for the same gating rules driving the
    sidebar.
*@

<AuthorizeView Roles="Admin">
    <Authorized Context="adminCtx">
        @{
            var isSiteAdmin = adminCtx.User.IsInRole(HttpOrganizationContext.SiteAdminRole);
            var isSystemOrg = OrgContext.IsSystemOrganization;
            // Single-tenant: the lone org IS the system org but manages its own
            // content, so show the per-org Administration tile and copy.
            var showPerOrgContent = !isSystemOrg || SingleTenant.IsEnabled;
        }
        <div class="admin-dashboard">
            <h1>Admin</h1>
            <p class="muted">
                @if (isSystemOrg && !SingleTenant.IsEnabled)
                {
                    <text>System organisation - curate the starter templates, modules, snippets and catalogue that other orgs import.</text>
                }
                else
                {
                    <text>Manage runtime templates, modules, the well-known dependency catalogue, and view the audit log.</text>
                }
            </p>

            <div class="tile-grid">
                <a class="tile tile--link" href="/admin/templates">
                    <Icon Name="layers" Width="20" Height="20" Css="tile__icon" />
                    <div class="tile__body">
                        <div class="tile__title">Templates</div>
                        <div class="tile__caption">Edit runtime templates, their folder layouts, and JSON defaults.</div>
                    </div>
                </a>
                <a class="tile tile--link" href="/admin/modules">
                    <Icon Name="package" Width="20" Height="20" Css="tile__icon" />
                    <div class="tile__body">
                        <div class="tile__title">Modules</div>
                        <div class="tile__caption">Edit modules and the dependencies each one contributes to <code>app.json</code>.</div>
                    </div>
                </a>
                <a class="tile tile--link" href="/admin/catalog">
                    <Icon Name="book-open" Width="20" Height="20" Css="tile__icon" />
                    <div class="tile__body">
                        <div class="tile__title">Catalogue</div>
                        <div class="tile__caption">Maintain the well-known dependency list users pick from in the New Extension flow.</div>
                    </div>
                </a>
                <a class="tile tile--link" href="/admin/snippets">
                    <Icon Name="square-code" Width="20" Height="20" Css="tile__icon" />
                    <div class="tile__body">
                        <div class="tile__title">Snippets</div>
                        <div class="tile__caption">Curate the snippet library and review user-submitted suggestions.</div>
                    </div>
                </a>
                <a class="tile tile--link" href="/admin/application-versions">
                    <Icon Name="tag" Width="20" Height="20" Css="tile__icon" />
                    <div class="tile__body">
                        <div class="tile__title">Application versions</div>
                        <div class="tile__caption">Curate the BC release list users pick on New Workspace and New Extension.</div>
                    </div>
                </a>

                @if (showPerOrgContent)
                {
                    <a class="tile tile--link" href="/admin/administration">
                        <Icon Name="settings" Width="20" Height="20" Css="tile__icon" />
                        <div class="tile__body">
                            <div class="tile__title">Administration</div>
                            <div class="tile__caption">Identity, MCP, users, OAuth clients, and configuration export - all in one place.</div>
                        </div>
                    </a>
                }

                @if (isSiteAdmin)
                {
                    <a class="tile tile--link" href="/site-admin/users">
                        <Icon Name="users-round" Width="20" Height="20" Css="tile__icon" />
                        <div class="tile__body">
                            <div class="tile__title">@(isSystemOrg ? "Users" : "All users")</div>
                            <div class="tile__caption">Search every organisation by email or full name and grant or revoke the SiteAdmin flag.</div>
                        </div>
                    </a>
                }

                <a class="tile tile--link" href="@(isSiteAdmin ? "/site-admin/audit" : "/admin/audit")">
                    <Icon Name="history" Width="20" Height="20" Css="tile__icon" />
                    <div class="tile__body">
                        <div class="tile__title">Audit log</div>
                        <div class="tile__caption">
                            @if (isSiteAdmin)
                            {
                                <text>Cross-organisation audit search across every entity type and actor.</text>
                            }
                            else
                            {
                                <text>Browse recent changes to templates, modules, and the catalogue.</text>
                            }
                        </div>
                    </div>
                </a>

                @if (isSiteAdmin)
                {
                    <a class="tile tile--link" href="/site-admin/backup-storage">
                        <Icon Name="database-backup" Width="20" Height="20" Css="tile__icon" />
                        <div class="tile__body">
                            <div class="tile__title">Backup &amp; storage</div>
                            <div class="tile__caption">
                                @(SingleTenant.IsEnabled
                                    ? "Database backups for this deployment."
                                    : "Database backups, per-tenant snapshots, and storage quotas in one place.")
                            </div>
                        </div>
                    </a>
                    <a class="tile tile--link" href="/site-admin/settings">
                        <Icon Name="server-cog" Width="20" Height="20" Css="tile__icon" />
                        <div class="tile__body">
                            <div class="tile__title">Settings</div>
                            <div class="tile__caption">SMTP overrides, the system banner, backup schedule, and signup defaults.</div>
                        </div>
                    </a>
                }
            </div>
        </div>
    </Authorized>
</AuthorizeView>
