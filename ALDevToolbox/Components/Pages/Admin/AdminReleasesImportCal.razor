@page "/admin/object-explorer/new/cal"
@attribute [Authorize(Roles = "Admin,Editor")]
@inject ALDevToolbox.Services.ObjectExplorer.ObjectExplorerService ObjectExplorer
@inject IAntiforgery Antiforgery
@inject IHttpContextAccessor Http
@using ALDevToolbox.Services.ObjectExplorer
@using Microsoft.AspNetCore.Antiforgery

@*
    C/AL tab of the Import Release page. Statically rendered; posts the classic
    NAV "Export Objects to text" dump to the shared /admin/object-explorer/import
    endpoint, which dispatches to the C/AL ingest (Services/Cal/) on the presence
    of CalTxtFile. Kept on its own pill because the C/AL pipeline - text parsing,
    OEM codepage, the Base-vs-Customer comparison flow - is a different model from
    the .app-based Upload / DVD / Artifacts modes.
*@

<PageTitle>Import Release · C/AL · Admin · AL Dev Toolbox</PageTitle>

<div class="admin-page">
    <AdminReleasesImportHeader ActiveTab="AdminReleasesImportHeader.Tab.Cal" />

    @if (_errorMessage is not null)
    {
        <div class="form-error" role="alert"><p>@_errorMessage</p></div>
    }

    <form method="post"
          action="/admin/object-explorer/import"
          enctype="multipart/form-data"
          class="form-grid"
          data-oe-import-form>
        @if (_antiforgeryToken is not null)
        {
            <input type="hidden" name="@_antiforgeryToken.FormFieldName" value="@_antiforgeryToken.RequestToken" />
        }

        <div class="oe-import-progress" data-oe-import-progress hidden role="status" aria-live="polite">
            <div class="oe-import-progress__row">
                <span class="oe-import-progress__label" data-oe-import-label>Uploading...</span>
                <span class="oe-import-progress__pct" data-oe-import-pct></span>
            </div>
            <progress class="oe-import-progress__bar" data-oe-import-bar max="100" value="0"></progress>
            <p class="oe-import-progress__hint muted" data-oe-import-hint></p>
        </div>

        <ReleaseImportMetadataFields ParentCandidates="_parentCandidates" />

        <section class="form-section">
            <label class="field">
                <span class="field__label">Legacy C/AL TXT export</span>
                <input type="file" name="CalTxtFile" accept=".txt" required
                       class="field__input field__input--file" />
                <small class="field__caption muted">
                    A classic NAV <em>Export Objects to text</em> file. To
                    compare a customer's objects against the standard: import the
                    plain Microsoft objects first with Kind set to
                    <strong>First-party</strong>, then the customer's file with
                    Kind <strong>Project-specific</strong> and the Microsoft
                    release picked as its parent. Up to 1 GB.
                </small>
            </label>

            <label class="field">
                <span class="field__label">C/AL codepage</span>
                <select name="CalEncoding" class="field__input">
                    <option value="850" selected>IBM 850 (OEM - classic finsql default)</option>
                    <option value="1252">Windows-1252</option>
                </select>
                <small class="field__caption muted">
                    The classic Windows client exports in the OEM codepage (850 for
                    Western Europe); pick 1252 if accented characters look wrong
                    after import.
                </small>
            </label>
        </section>

        <section class="form-section">
            <button type="submit" class="btn btn--primary" data-oe-import-submit>
                <Icon Name="file-code" Width="16" Height="16" />
                <span>Import Release</span>
            </button>
        </section>
    </form>
</div>

@code {
    private AntiforgeryTokenSet? _antiforgeryToken;
    private List<ReleaseListItem>? _parentCandidates;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        var ctx = Http.HttpContext;
        if (ctx is not null)
        {
            _antiforgeryToken = Antiforgery.GetAndStoreTokens(ctx);
            var err = ctx.Request.Query["err"].ToString();
            var msg = ctx.Request.Query["msg"].ToString();
            if (!string.IsNullOrEmpty(err) && !string.IsNullOrEmpty(msg))
            {
                _errorMessage = $"{err}: {msg}";
            }
        }

        // Only ready first-party Releases are sensible parents - a customer C/AL
        // file resolves its references against the base picked here.
        var all = await ObjectExplorer.ListReleasesAsync();
        _parentCandidates = all
            .Where(r => r.Status == "ready" && r.Kind == "first_party")
            .OrderBy(r => r.Label)
            .ToList();
    }
}
