@page "/admin/snippets"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@inject SnippetService Snippets
@inject SnippetSuggestionService Suggestions
@inject NavigationManager Nav
@inject ILogger<AdminSnippets> Log
@using ALDevToolbox.Domain.Entities
@using ALDevToolbox.Domain.ValueObjects

<PageTitle>Snippets · Admin · AL Dev Toolbox</PageTitle>

<div class="admin-page">
    <header class="admin-page__header">
        <div>
            <h1>Snippets</h1>
            <p class="muted">
                Curate the snippet library for this organisation. End users see
                the published list at <code>/snippets</code>; user-submitted
                suggestions appear in the queue below.
            </p>
        </div>
        <a class="btn btn--sm" href="/admin">
            <Icon Name="arrow-left" Width="14" Height="14" />
            <span>Back to admin</span>
        </a>
    </header>

    <div class="admin-page__toolbar">
        <label class="check-row">
            <input type="checkbox" @bind="_showDeleted" @bind:after="ReloadAsync" />
            <span>Show soft-deleted</span>
        </label>
    </div>

    @if (!string.IsNullOrEmpty(_lastError))
    {
        <p class="form-error" role="alert">@_lastError</p>
    }
    @if (!string.IsNullOrEmpty(_lastSuccess))
    {
        <p class="form-success" role="status">@_lastSuccess</p>
    }

    @if (_rows is null)
    {
        <p class="muted">Loading…</p>
    }
    else if (_rows.Count == 0)
    {
        <p class="muted">No snippets yet. Click <strong>New snippet</strong> below to create one.</p>
    }
    else
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Files</th>
                    <th>Keywords</th>
                    <th>Status</th>
                    <th>Last updated (UTC)</th>
                    <th class="data-table__actions"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in _rows)
                {
                    <tr class="@(s.DeletedAt is not null ? "data-table__row--muted" : null)">
                        <td>@s.Title</td>
                        <td>@s.Files.Count</td>
                        <td class="muted">@s.Keywords</td>
                        <td>@StatusFor(s)</td>
                        <td><time datetime="@s.UpdatedAt.ToString("O")">@s.UpdatedAt.ToString("yyyy-MM-dd HH:mm:ss")</time></td>
                        <td class="data-table__actions">
                            <a class="btn btn--sm" href="@($"/admin/snippets/{s.Id}")">
                                <Icon Name="pencil" Width="14" Height="14" />
                                <span>Edit</span>
                            </a>
                            @if (s.DeletedAt is null)
                            {
                                <button type="button" class="btn btn--sm" @onclick="() => SetDeprecatedAsync(s, !s.Deprecated)" disabled="@_busy">
                                    <Icon Name="@(s.Deprecated ? "archive-restore" : "archive")" Width="14" Height="14" />
                                    <span>@(s.Deprecated ? "Un-deprecate" : "Deprecate")</span>
                                </button>
                                <button type="button" class="btn btn--sm btn--danger" @onclick="() => SoftDeleteAsync(s)" disabled="@_busy">
                                    <Icon Name="trash-2" Width="14" Height="14" />
                                    <span>Delete</span>
                                </button>
                            }
                            else
                            {
                                <button type="button" class="btn btn--sm" @onclick="() => RestoreAsync(s)" disabled="@_busy">
                                    <Icon Name="rotate-ccw" Width="14" Height="14" />
                                    <span>Restore</span>
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <div class="admin-page__footer-actions">
        <a class="btn btn--primary" href="/admin/snippets/new">
            <Icon Name="plus" Width="16" Height="16" />
            <span>New snippet</span>
        </a>
    </div>

    <section class="admin-section">
        <h2>Suggestions</h2>
        <p class="muted">
            Drafts submitted by users awaiting review. Open one to approve or
            reject it.
        </p>
        @if (_suggestions is null)
        {
            <p class="muted">Loading…</p>
        }
        else if (_suggestions.Count == 0)
        {
            <p class="muted">No pending suggestions.</p>
        }
        else
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Submitted by</th>
                        <th>Files</th>
                        <th>Submitted (UTC)</th>
                        <th class="data-table__actions"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in _suggestions)
                    {
                        <tr>
                            <td>@s.Title</td>
                            <td class="muted">@(s.SuggestedByUser?.DisplayName ?? "unknown user")</td>
                            <td>@s.Files.Count</td>
                            <td><time datetime="@s.RequestedAt.ToString("O")">@s.RequestedAt.ToString("yyyy-MM-dd HH:mm:ss")</time></td>
                            <td class="data-table__actions">
                                <a class="btn btn--sm" href="@($"/admin/snippets/suggestions#suggestion-{s.Id}")">
                                    <Icon Name="inbox" Width="14" Height="14" />
                                    <span>Review</span>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>
</div>

@code {
    private bool _showDeleted;
    private List<Snippet>? _rows;
    private List<SnippetSuggestion>? _suggestions;
    private bool _busy;
    private string? _lastError;
    private string? _lastSuccess;

    protected override Task OnInitializedAsync() => ReloadAsync();

    private async Task ReloadAsync()
    {
        _rows = await Snippets.GetAllForAdminAsync(includeDeleted: _showDeleted);
        _suggestions = await Suggestions.GetPendingAsync();
    }

    private async Task SoftDeleteAsync(Snippet s)
    {
        await RunActionAsync(() => Snippets.SoftDeleteAsync(s.Id), $"Snippet '{s.Title}' deleted.");
    }

    private async Task RestoreAsync(Snippet s)
    {
        await RunActionAsync(() => Snippets.RestoreAsync(s.Id), $"Snippet '{s.Title}' restored.");
    }

    private async Task SetDeprecatedAsync(Snippet s, bool deprecated)
    {
        var label = deprecated ? "deprecated" : "un-deprecated";
        await RunActionAsync(() => Snippets.SetDeprecatedAsync(s.Id, deprecated), $"Snippet '{s.Title}' {label}.");
    }

    private async Task RunActionAsync(Func<Task> action, string successMessage)
    {
        if (_busy) return;
        _busy = true;
        _lastError = null;
        _lastSuccess = null;
        try
        {
            await action();
            _lastSuccess = successMessage;
            await ReloadAsync();
        }
        catch (PlanValidationException ex)
        {
            _lastError = ex.Errors.FirstOrDefault().Value ?? "Validation failed.";
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Snippet admin action failed.");
            _lastError = "An unexpected error occurred. The change was not saved.";
        }
        finally
        {
            _busy = false;
        }
    }

    private static string StatusFor(Snippet s)
    {
        if (s.DeletedAt is not null) return "Deleted";
        if (s.Deprecated) return "Deprecated";
        return "Active";
    }
}
