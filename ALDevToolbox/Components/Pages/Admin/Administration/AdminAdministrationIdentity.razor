@page "/admin/administration/identity"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@inject OrganizationConfigService Config
@inject OrganizationAdminService OrgAdmin
@inject AppDbContext Db
@inject IOrganizationContext OrgCtx
@inject NavigationManager Nav
@inject ILogger<AdminAdministrationIdentity> Log
@using ALDevToolbox.Data
@using ALDevToolbox.Domain.Entities
@using ALDevToolbox.Domain.ValueObjects
@using Microsoft.EntityFrameworkCore

@*
    Organisation identity and email-domain claims. The display name shown in
    the top bar comes from Organization.Name; rename it here. Email domains
    are globally unique — claiming one routes future signups from that domain
    into this org as Pending users (admin still approves via the Users tab).
*@

<PageTitle>Identity · Administration · AL Dev Toolbox</PageTitle>

<div class="admin-page admin-configuration">
    <AdministrationHeader ActiveTab="AdministrationHeader.Tab.Identity" />

    @if (_loading)
    {
        <p class="muted">Loading…</p>
    }
    else
    {
        <section class="admin-section">
            <h2>Organisation name</h2>
            @if (!string.IsNullOrEmpty(_nameOkMessage))
            {
                <p class="form-success" role="status">@_nameOkMessage</p>
            }
            @if (!string.IsNullOrEmpty(_nameErrMessage))
            {
                <div class="form-error" role="alert"><p>@_nameErrMessage</p></div>
            }
            <div class="form-grid form-grid--narrow">
                <section class="form-section">
                    <label class="section-label" for="org-name">Name</label>
                    <input id="org-name" type="text" required minlength="2" maxlength="80"
                           @bind="_name" @bind:event="oninput" />
                    <small class="muted">
                        Shown next to the user's name in the top bar and in the admin tools.
                        Renaming takes effect for new logins — current sessions keep their
                        cached name until they sign out and back in.
                    </small>
                </section>
                <section class="form-section">
                    <label class="section-label" for="org-slug">Slug (read-only)</label>
                    <input id="org-slug" type="text" value="@_slug" readonly disabled />
                    <small class="muted">
                        The slug is baked into every signed-in cookie's org claim and
                        every saved URL; it can't be changed without invalidating both.
                    </small>
                </section>
                <section class="form-section">
                    <button type="button" class="btn btn--primary"
                            @onclick="SaveNameAsync"
                            disabled="@(_savingName || _name == _baseName)">
                        <Icon Name="save" Width="14" Height="14" />
                        <span>@(_savingName ? "Saving…" : "Save changes")</span>
                    </button>
                </section>
            </div>
        </section>

        <section class="admin-section">
            <h2>Strong authentication</h2>
            <p class="muted">
                Require every member of this organisation to have either two-factor
                authentication (authenticator app or email codes) or a passkey
                configured. Users without one will be sent to
                <a href="/account">your account</a> at the next request and can't
                reach anything else until they enrol.
            </p>
            @if (!string.IsNullOrEmpty(_strongAuthOkMessage))
            {
                <p class="form-success" role="status">@_strongAuthOkMessage</p>
            }
            @if (!string.IsNullOrEmpty(_strongAuthErrMessage))
            {
                <div class="form-error" role="alert"><p>@_strongAuthErrMessage</p></div>
            }
            <label class="checkbox-label">
                <input type="checkbox" @bind="_requireStrongAuth" @bind:after="SaveRequireStrongAuthAsync"
                       disabled="@_savingStrongAuth" />
                Require strong authentication for everyone in this organisation
            </label>
        </section>

        <section class="admin-section">
            <h2>Email domains</h2>
            <p class="muted">
                When someone signs up with an email at one of these domains we
                attach them to this organisation as a Pending user — they still
                need an admin's approval via the <a href="/admin/administration/users">Users</a> tab.
                A domain belongs to exactly one organisation deployment-wide.
            </p>
            @if (!string.IsNullOrEmpty(_domainOkMessage))
            {
                <p class="form-success" role="status">@_domainOkMessage</p>
            }
            @if (!string.IsNullOrEmpty(_domainErrMessage))
            {
                <div class="form-error" role="alert"><p>@_domainErrMessage</p></div>
            }

            @if (_domains.Count == 0)
            {
                <p class="muted">No email domains claimed yet.</p>
            }
            else
            {
                <ul class="email-domain-list">
                    @foreach (var domain in _domains)
                    {
                        <li class="email-domain-row">
                            <code>@domain.Domain</code>
                            <button type="button" class="btn btn--sm" @onclick="() => RemoveAsync(domain.Id)" disabled="@_savingDomain">
                                <Icon Name="trash-2" Width="14" Height="14" />
                                <span>Remove</span>
                            </button>
                        </li>
                    }
                </ul>
            }

            <div class="form-grid form-grid--narrow">
                <section class="form-section">
                    <label class="section-label" for="org-domain">Add domain</label>
                    <input id="org-domain" type="text" placeholder="e.g. acme.com" maxlength="253"
                           @bind="_newDomain" @bind:event="oninput" />
                    <small class="muted">Lowercased; a leading <code>@@</code> is stripped if you paste it.</small>
                </section>
                <section class="form-section">
                    <button type="button" class="btn btn--primary"
                            @onclick="AddAsync"
                            disabled="@(_savingDomain || string.IsNullOrWhiteSpace(_newDomain))">
                        <Icon Name="plus" Width="14" Height="14" />
                        <span>@(_savingDomain ? "Saving…" : "Add domain")</span>
                    </button>
                </section>
            </div>
        </section>
    }
</div>

@code {
    private bool _loading = true;
    private bool _savingName;
    private bool _savingDomain;
    private bool _savingStrongAuth;
    private string? _nameOkMessage;
    private string? _nameErrMessage;
    private string? _domainOkMessage;
    private string? _domainErrMessage;
    private string? _strongAuthOkMessage;
    private string? _strongAuthErrMessage;

    private string _name = string.Empty;
    private string _baseName = string.Empty;
    private string _slug = string.Empty;
    private string _newDomain = string.Empty;
    private bool _requireStrongAuth;
    private List<OrganizationEmailDomain> _domains = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        var orgId = OrgCtx.CurrentOrganizationId
            ?? throw new InvalidOperationException("No organisation in scope.");
        var org = await Db.Organizations.AsNoTracking().FirstAsync(o => o.Id == orgId);
        _name = _baseName = org.Name;
        _slug = org.Slug;
        _requireStrongAuth = await Db.OrganizationSettings.AsNoTracking()
            .Where(s => s.OrganizationId == orgId)
            .Select(s => s.RequireStrongAuth)
            .FirstOrDefaultAsync();
        _domains = await OrgAdmin.ListEmailDomainsAsync();
        _loading = false;
    }

    private async Task SaveRequireStrongAuthAsync()
    {
        if (_savingStrongAuth) return;
        _savingStrongAuth = true;
        _strongAuthOkMessage = null;
        _strongAuthErrMessage = null;
        try
        {
            await OrgAdmin.SetRequireStrongAuthAsync(_requireStrongAuth);
            _strongAuthOkMessage = _requireStrongAuth
                ? "Strong-auth requirement is now on. Members without a 2FA method or passkey will be redirected to /account on their next request."
                : "Strong-auth requirement is now off.";
        }
        catch (PlanValidationException ex)
        {
            // Revert the toggle so the UI reflects the unchanged DB state.
            _requireStrongAuth = !_requireStrongAuth;
            _strongAuthErrMessage = ex.Errors.FirstOrDefault().Value ?? "Validation failed.";
        }
        catch (Exception ex)
        {
            _requireStrongAuth = !_requireStrongAuth;
            Log.LogError(ex, "Failed to toggle strong-auth requirement.");
            _strongAuthErrMessage = "An unexpected error occurred. The change was not saved.";
        }
        finally
        {
            _savingStrongAuth = false;
        }
    }

    private async Task SaveNameAsync()
    {
        if (_savingName || _name == _baseName) return;
        _savingName = true;
        _nameOkMessage = null;
        _nameErrMessage = null;
        try
        {
            await Config.RenameOrganizationAsync(_name);
            _baseName = _name.Trim();
            _name = _baseName;
            _nameOkMessage = "Organisation renamed. Sign out and back in to see it in the top bar.";
        }
        catch (PlanValidationException ex)
        {
            _nameErrMessage = ex.Errors.FirstOrDefault().Value ?? "Validation failed.";
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Failed to rename organisation.");
            _nameErrMessage = "An unexpected error occurred. The change was not saved.";
        }
        finally
        {
            _savingName = false;
        }
    }

    private async Task AddAsync()
    {
        if (_savingDomain) return;
        _savingDomain = true;
        _domainOkMessage = null;
        _domainErrMessage = null;
        try
        {
            await OrgAdmin.AddEmailDomainAsync(_newDomain);
            _newDomain = string.Empty;
            _domains = await OrgAdmin.ListEmailDomainsAsync();
            _domainOkMessage = "Domain added.";
        }
        catch (PlanValidationException ex)
        {
            _domainErrMessage = ex.Errors.FirstOrDefault().Value ?? "Validation failed.";
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Failed to add email domain.");
            _domainErrMessage = "An unexpected error occurred. The change was not saved.";
        }
        finally
        {
            _savingDomain = false;
        }
    }

    private async Task RemoveAsync(int domainId)
    {
        if (_savingDomain) return;
        _savingDomain = true;
        _domainOkMessage = null;
        _domainErrMessage = null;
        try
        {
            await OrgAdmin.RemoveEmailDomainAsync(domainId);
            _domains = await OrgAdmin.ListEmailDomainsAsync();
            _domainOkMessage = "Domain removed.";
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Failed to remove email domain.");
            _domainErrMessage = "An unexpected error occurred. The change was not saved.";
        }
        finally
        {
            _savingDomain = false;
        }
    }
}
