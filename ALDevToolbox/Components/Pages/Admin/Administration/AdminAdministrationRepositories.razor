@page "/admin/administration/repositories"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@inject OrganizationConfigService Config
@inject ILogger<AdminAdministrationRepositories> Log
@using ALDevToolbox.Services
@using ALDevToolbox.Domain.ValueObjects

@*
    Per-organisation source-control settings. The admin picks which Git hosts the
    org's projects may use; members store their own Personal Access Tokens under
    Account → Repository tokens. The project-build pipeline clones each repo as the
    user who triggered the build, using that user's token. See .design/artifacts.md.
*@

<PageTitle>Repositories · Administration · AL Dev Toolbox</PageTitle>

<div class="admin-page admin-configuration">
    <AdministrationHeader ActiveTab="AdministrationHeader.Tab.Repositories" />

    @if (_loading)
    {
        <p class="muted">Loading…</p>
    }
    else
    {
        @if (!string.IsNullOrEmpty(_okMessage))
        {
            <p class="form-success" role="status">@_okMessage</p>
        }
        @if (!string.IsNullOrEmpty(_errMessage))
        {
            <div class="form-error" role="alert"><p>@_errMessage</p></div>
        }

        <section class="admin-section">
            <h2>Source-control providers</h2>
            <p class="muted">
                Choose the Git hosts your team keeps project code on. Members only see
                these providers when they add a repository or set up their access token,
                so an org that uses just one host never deals with the other. Each member
                stores their own token under
                <a href="/account/repository-tokens">Account → Repository tokens</a> —
                a build clones as whoever started it, and fails for anyone without access.
            </p>

            <div class="form-grid form-grid--narrow">
                <section class="form-section">
                    <label class="section-label section-label--inline">
                        <input type="checkbox" @bind="_allowGitHub" disabled="@_saving" />
                        <span>GitHub <span class="muted">· github.com</span></span>
                    </label>
                    <label class="section-label section-label--inline">
                        <input type="checkbox" @bind="_allowAzureDevOps" disabled="@_saving" />
                        <span>Azure DevOps <span class="muted">· dev.azure.com</span></span>
                    </label>
                    <small class="muted">Pick at least one.</small>
                </section>

                <section class="form-section form-section--actions">
                    <button type="button" class="btn btn--primary" @onclick="SaveAsync" disabled="@_saving">
                        <Icon Name="save" Width="14" Height="14" />
                        <span>@(_saving ? "Saving…" : "Save changes")</span>
                    </button>
                </section>
            </div>
        </section>
    }
</div>

@code {
    private bool _loading = true;
    private bool _saving;
    private string? _okMessage;
    private string? _errMessage;

    private bool _allowGitHub;
    private bool _allowAzureDevOps;

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
        _loading = false;
    }

    private async Task ReloadAsync()
    {
        var allowed = await Config.GetAllowedProvidersAsync();
        _allowGitHub = allowed.Contains(RepositoryProvider.GitHub);
        _allowAzureDevOps = allowed.Contains(RepositoryProvider.AzureDevOps);
    }

    private async Task SaveAsync()
    {
        if (_saving) return;
        _saving = true;
        _okMessage = _errMessage = null;
        try
        {
            var providers = new List<RepositoryProvider>();
            if (_allowGitHub) providers.Add(RepositoryProvider.GitHub);
            if (_allowAzureDevOps) providers.Add(RepositoryProvider.AzureDevOps);

            await Config.SaveAllowedProvidersAsync(providers);
            await ReloadAsync();
            _okMessage = "Source-control providers saved.";
        }
        catch (PlanValidationException ex)
        {
            _errMessage = ex.Errors.FirstOrDefault().Value ?? "Validation failed.";
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Failed to save allowed repository providers.");
            _errMessage = "An unexpected error occurred. The change was not saved.";
        }
        finally
        {
            _saving = false;
        }
    }
}
