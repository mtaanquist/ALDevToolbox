@page "/admin/administration/export"
@attribute [Authorize(Roles = "Admin")]

@*
    Export tab of the Administration surface. Per-organisation TOML export
    and configuration import. Database backups live on /site-admin/backups
    and are SiteAdmin-only; tenants only ever see this page and its TOML
    snapshot workflow. No global "Save changes" here — each form submits
    immediately to its own endpoint.
*@

<PageTitle>Export · Administration · AL Dev Toolbox</PageTitle>

<div class="admin-page">
    <AdministrationHeader ActiveTab="AdministrationHeader.Tab.Export" />

    @if (Ok == "imported")
    {
        <p class="form-success" role="status">Configuration imported.</p>
    }
    @if (!string.IsNullOrEmpty(Msg))
    {
        <p class="form-error" role="alert">@Msg</p>
    }

    <section class="admin-section">
        <h2>Export</h2>
        <p class="muted">
            Download every active template, module, and catalogue entry as a
            TOML ZIP. Use it as a point-in-time snapshot or to grep the live
            state outside the app.
        </p>
        <form method="post" action="/admin/export/download">
            <AntiforgeryToken />
            <button type="submit" class="btn">
                <Icon Name="download" Width="16" Height="16" />
                <span>Export all to TOML</span>
            </button>
        </form>
    </section>

    <section class="admin-section admin-configuration__danger">
        <h2>Restore configuration</h2>
        <p class="muted">
            Paste an <code>organization-config.toml</code> from an export ZIP and
            replace this organisation's defaults, logo and file list. Existing
            values are wiped — confirm before submitting.
        </p>
        <form method="post" action="/admin/export/import" class="form-grid">
            <AntiforgeryToken />
            <section class="form-section">
                <label class="section-label" for="cfg-import-toml">TOML</label>
                <textarea id="cfg-import-toml" name="Toml" rows="8"
                          placeholder="[settings]&#10;default_publisher = …"></textarea>
            </section>
            <label class="check-row">
                <input type="checkbox" name="Confirm" value="true" />
                <span>I understand this overwrites the current configuration.</span>
            </label>
            <div class="form-actions">
                <button type="submit" class="btn btn--danger">
                    <Icon Name="upload" Width="14" Height="14" />
                    <span>Restore from TOML</span>
                </button>
            </div>
        </form>
    </section>
</div>

@code {
    [SupplyParameterFromQuery(Name = "ok")] public string? Ok { get; set; }
    [SupplyParameterFromQuery(Name = "err")] public string? Err { get; set; }
    [SupplyParameterFromQuery(Name = "msg")] public string? Msg { get; set; }
}
