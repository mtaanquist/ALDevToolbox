@page "/admin/administration/mcp"
@attribute [Authorize(Roles = "Admin")]
@inject NavigationManager Nav

@*
    The per-org MCP opt-out moved into the unified Tools tab. This legacy route
    forwards there so old bookmarks and links keep working.
*@

@code {
    protected override void OnInitialized() =>
        Nav.NavigateTo("/admin/administration/tools", replace: true);
}
