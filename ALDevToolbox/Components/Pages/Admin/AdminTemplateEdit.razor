@page "/admin/templates/new"
@page "/admin/templates/{Key}"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@inject TemplateService Templates
@inject ApplicationVersionService Versions
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject ILogger<AdminTemplateEdit> Log
@implements IAsyncDisposable
@using System.Text.Json
@using ALDevToolbox.Components.Shared
@using ALDevToolbox.Domain.Entities
@using ALDevToolbox.Domain.ValueObjects

@*
    Combined create/edit page.
    - /admin/templates/new      → no [Key] route value. Opens in TOML mode
                                  because authoring a fresh template is usually
                                  faster as a single TOML document than
                                  clicking through the structured form.
    - /admin/templates/{key}    → loads the existing row by key. Opens in the
                                  structured form because surgical edits are
                                  what people do most often.

    Reordering uses Up/Down buttons rather than HTML5 drag-and-drop because the
    latter would need .razor.js plumbing for v1; can be upgraded later if asked
    for. Form state lives in TemplateFormState (Components/Shared) so the
    recursive folder editor can bind against the same models the page does;
    on save we pack into TemplateAuthoring and call TemplateService directly.
*@

<PageTitle>@PageTitleText · Admin · AL Dev Toolbox</PageTitle>

<div class="admin-page admin-template-edit">
    <header class="admin-page__header">
        <div>
            <h1>@PageTitleText</h1>
            <p class="muted">
                @if (IsEdit)
                {
                    <span>Editing template <code>@Key</code>. Changes apply on the next generation.</span>
                }
                else
                {
                    <span>Create a new runtime template. Extensions, defaults, and ID ranges can all be edited later.</span>
                }
            </p>
        </div>
        <a class="btn btn--sm" href="/admin/templates">
            <Icon Name="arrow-left" Width="14" Height="14" />
            <span>Back to list</span>
        </a>
    </header>

    @if (IsEdit && _loadFailed)
    {
        <p class="form-error" role="alert">
            No template with key <code>@Key</code> was found. It may have been
            renamed or hard-deleted.
        </p>
    }
    else if (_form is null)
    {
        <p class="muted">Loading…</p>
    }
    else
    {
        <div class="admin-template-edit__mode" role="tablist" aria-label="Editor mode">
            <button type="button"
                    class="@ModeButtonClass(EditorMode.Form)"
                    role="tab"
                    aria-selected="@(_mode == EditorMode.Form)"
                    @onclick="() => SwitchModeAsync(EditorMode.Form)">
                <Icon Name="list" Width="14" Height="14" />
                <span>Structured form</span>
            </button>
            <button type="button"
                    class="@ModeButtonClass(EditorMode.Toml)"
                    role="tab"
                    aria-selected="@(_mode == EditorMode.Toml)"
                    @onclick="() => SwitchModeAsync(EditorMode.Toml)">
                <Icon Name="file-code" Width="14" Height="14" />
                <span>TOML</span>
            </button>
        </div>

        @if (_saveError is not null)
        {
            <div class="form-error" role="alert">
                <p>@_saveError</p>
                @if (_fieldErrors.Count > 0)
                {
                    <ul class="form-error__list">
                        @foreach (var e in _fieldErrors)
                        {
                            <li><code>@e.Key</code>: @e.Value</li>
                        }
                    </ul>
                }
            </div>
        }
        @if (_saveSuccess is not null)
        {
            <p class="form-success" role="status">@_saveSuccess</p>
        }
    }

    @if (_form is not null)
    {
        <div class="admin-template-edit__layout">
            <div class="admin-template-edit__editor">
                @if (_mode == EditorMode.Toml)
                {
        <form class="form-grid admin-template-edit__form admin-template-edit__toml-form"
              @onsubmit="SaveTomlAsync" @onsubmit:preventDefault>
            <section class="form-section">
                <span class="section-label">template.toml</span>
                <div class="admin-template-edit__toml" @ref="_tomlContainer"></div>
                @if (_tomlIssues.Count > 0)
                {
                    <ul class="form-error__list admin-template-edit__toml-issues">
                        @foreach (var issue in _tomlIssues)
                        {
                            <li>line @issue.Line: @issue.Message</li>
                        }
                    </ul>
                }
                <small class="muted">
                    Edits the same data the structured form does. Toggle
                    <code>deprecated</code> and reorder extensions in the
                    structured view — those aren't represented in TOML.
                </small>
            </section>

            <div class="admin-template-edit__actions">
                <button type="submit" class="btn btn--primary" disabled="@_saving">
                    <Icon Name="save" Width="16" Height="16" />
                    <span>@(_saving ? "Saving…" : (IsEdit ? "Save TOML" : "Create from TOML"))</span>
                </button>
                <button type="button" class="btn" @onclick="RefreshPreviewAsync" disabled="@_saving"
                        title="Parse the TOML and rebuild the preview without leaving this view">
                    <Icon Name="refresh-cw" Width="14" Height="14" />
                    <span>Refresh preview</span>
                </button>
                <button type="button" class="btn" @onclick="() => SwitchModeAsync(EditorMode.Form)" disabled="@_saving">
                    <span>Discard &amp; back to form</span>
                </button>
            </div>
        </form>
                }
                else
                {
        <form class="form-grid admin-template-edit__form" @onsubmit="SaveAsync" @onsubmit:preventDefault>
            <section class="form-section">
                <label class="section-label" for="tpl-key">Key</label>
                <input id="tpl-key" type="text" @bind="_form.Key" @bind:event="oninput"
                       readonly="@IsEdit" pattern="[a-z0-9-]+" required
                       placeholder="e.g. runtime-15" />
                <small class="muted">
                    @(IsEdit ? "The key is fixed once a template is created." : "Lowercase letters, digits, hyphens. Used in admin URLs.")
                </small>
                <FieldError Field="Key" Errors="_fieldErrors" />
            </section>

            <section class="form-section form-section--row">
                <div>
                    <label class="section-label" for="tpl-runtime">Runtime</label>
                    <input id="tpl-runtime" type="text" required
                           pattern="\d+(\.\d+)?" placeholder="e.g. 15 or 15.2"
                           @bind="_form.Runtime" @bind:event="oninput" />
                    <small class="muted">Major or Major.Minor. Goes into <code>app.json</code> as <code>runtime</code>.</small>
                    <FieldError Field="Runtime" Errors="_fieldErrors" />
                </div>
                <div>
                    <label class="section-label" for="tpl-name">Name</label>
                    <input id="tpl-name" type="text" required
                           @bind="_form.Name" @bind:event="oninput"
                           placeholder="e.g. Runtime 15 (BC 24)" />
                    <FieldError Field="Name" Errors="_fieldErrors" />
                </div>
            </section>

            <section class="form-section">
                <label class="section-label" for="tpl-description">Description</label>
                <textarea id="tpl-description" rows="2"
                          @bind="_form.Description" @bind:event="oninput"></textarea>
                <small class="muted">Caption shown under the template dropdown on the New Workspace page.</small>
            </section>

            <section class="form-section form-section--row">
                <div>
                    <label class="section-label" for="tpl-app">Default application</label>
                    <input id="tpl-app" type="text" required pattern="\d+\.\d+\.\d+\.\d+"
                           @bind="_form.DefaultApplication" @bind:event="oninput"
                           placeholder="e.g. 24.0.0.0" />
                    <small class="muted">Spliced into <code>defaults.application</code> on save.</small>
                    <FieldError Field="DefaultApplication" Errors="_fieldErrors" />
                </div>
                <div>
                    <label class="section-label" for="tpl-platform">Default platform</label>
                    <input id="tpl-platform" type="text" required pattern="\d+\.\d+\.\d+\.\d+"
                           @bind="_form.DefaultPlatform" @bind:event="oninput"
                           placeholder="e.g. 1.0.0.0" />
                    <small class="muted">Spliced into <code>defaults.platform</code> on save.</small>
                    <FieldError Field="DefaultPlatform" Errors="_fieldErrors" />
                </div>
            </section>

            <section class="form-section">
                <label class="section-label" for="tpl-app-version">Default application version</label>
                <select id="tpl-app-version" @bind="_form.DefaultApplicationVersionKey">
                    <option value="">(none — fall back to free-text)</option>
                    @foreach (var v in _availableApplicationVersions)
                    {
                        <option value="@v.Key">
                            @v.Name (@v.Application / @v.Runtime)@(v.Deprecated ? " — deprecated" : null)
                        </option>
                    }
                </select>
                <small class="muted">
                    Picking an entry here preselects it on the New Workspace and
                    New Extension forms; users can still override per project.
                    Curate the list at <a href="/admin/application-versions">Application versions</a>.
                </small>
                <FieldError Field="DefaultApplicationVersionKey" Errors="_fieldErrors" />
            </section>

            <section class="form-section form-section--row">
                <div>
                    <label class="section-label" for="tpl-core-from">Core ID range from</label>
                    <input id="tpl-core-from" type="number" required min="1"
                           @bind="_form.CoreIdRangeFrom" @bind:event="oninput" />
                    <FieldError Field="CoreIdRangeFrom" Errors="_fieldErrors" />
                </div>
                <div>
                    <label class="section-label" for="tpl-core-to">Core ID range to</label>
                    <input id="tpl-core-to" type="number" required min="1"
                           @bind="_form.CoreIdRangeTo" @bind:event="oninput" />
                    <FieldError Field="CoreIdRangeTo" Errors="_fieldErrors" />
                </div>
            </section>

            <section class="form-section form-section--row">
                <div>
                    <label class="section-label" for="tpl-mod-start">Module ID range start</label>
                    <input id="tpl-mod-start" type="number" required min="1"
                           @bind="_form.ModuleIdRangeStart" @bind:event="oninput" />
                    <FieldError Field="ModuleIdRangeStart" Errors="_fieldErrors" />
                </div>
                <div>
                    <label class="section-label" for="tpl-mod-size">Module ID range size</label>
                    <input id="tpl-mod-size" type="number" required min="1"
                           @bind="_form.ModuleIdRangeSize" @bind:event="oninput" />
                    <FieldError Field="ModuleIdRangeSize" Errors="_fieldErrors" />
                </div>
            </section>

            <section class="form-section">
                <label class="section-label" for="tpl-defaults">Defaults JSON</label>
                <textarea id="tpl-defaults" class="json-editor" rows="10" spellcheck="false"
                          @bind="_form.DefaultsJson" @bind:event="oninput"></textarea>
                <small class="muted">
                    Merged into every generated <code>app.json</code>. Fields:
                    <code>publisher</code>, <code>target</code>, <code>features</code>,
                    <code>supportedLocales</code>, <code>url</code>, <code>logo</code>,
                    <code>extension_prefix</code>, <code>affix</code>, <code>affix_type</code>,
                    <code>resourceExposurePolicy</code>. The Default application /
                    platform fields above are spliced in automatically on save.
                </small>
                <FieldError Field="DefaultsJson" Errors="_fieldErrors" />
            </section>

            <section class="form-section">
                <label class="section-label" for="tpl-cop">AppSourceCop JSON</label>
                <textarea id="tpl-cop" class="json-editor" rows="6" spellcheck="false"
                          @bind="_form.AppSourceCopJson" @bind:event="oninput"></textarea>
                <small class="muted">
                    Set <code>"include": false</code> to suppress
                    <code>AppSourceCop.json</code> in generated extensions. When
                    included, the remaining fields are written verbatim. Fields:
                    <code>include</code>, <code>mandatoryPrefix</code>,
                    <code>supportedCountries</code>.
                </small>
                <FieldError Field="AppSourceCopJson" Errors="_fieldErrors" />
            </section>

            <section class="form-section">
                <label class="check-row">
                    <input type="checkbox" @bind="_form.Deprecated" />
                    <span>Deprecated — hide from the user-facing dropdown but keep available for admin regeneration.</span>
                </label>
            </section>

            <section class="form-section">
                <label class="section-label">Default modules</label>
                <small class="muted">
                    Pre-ticked on the New Workspace form when this template is picked.
                    End-users can still opt out of any entry; this only seeds the
                    initial selection.
                </small>
                @if (_availableModules.Count == 0)
                {
                    <p class="muted">No modules available. Add one under <a href="/admin/modules">Modules</a>.</p>
                }
                else
                {
                    <div class="module-list">
                        @foreach (var m in _availableModules)
                        {
                            var isChecked = _form.DefaultModuleKeys.Contains(m.Key);
                            <label class="module-card">
                                <input type="checkbox"
                                       checked="@isChecked"
                                       @onchange="e => OnDefaultModuleToggled(m.Key, (bool)(e.Value ?? false))" />
                                <span class="module-card__body">
                                    <span class="module-card__name">
                                        @m.Name
                                        @if (m.Deprecated)
                                        {
                                            <span class="muted"> (deprecated)</span>
                                        }
                                    </span>
                                    <span class="module-card__caption muted">
                                        <code>@m.Key</code>
                                    </span>
                                </span>
                            </label>
                        }
                    </div>
                    <FieldError Field="DefaultModuleKeys" Errors="_fieldErrors" />
                }
            </section>

            <section class="form-section">
                <div class="folder-editor__header">
                    <label class="section-label">Extensions</label>
                    <button type="button" class="btn btn--sm" @onclick="AddExtension">
                        <Icon Name="plus" Width="14" Height="14" />
                        <span>Add extension</span>
                    </button>
                </div>
                <small class="muted">
                    Each entry is one extension generated into the workspace.
                    <strong>Required</strong> extensions are always emitted;
                    <strong>optional</strong> ones surface as opt-in checkboxes
                    on the New Workspace form. Catalogue modules contribute a
                    cloned extension on top — those aren't authored here.
                </small>
                @if (_form.Extensions.Count == 0)
                {
                    <p class="muted">
                        No extensions yet. Add at least one — most templates start
                        with a <code>Core</code> required extension.
                    </p>
                }
                else
                {
                    <div class="folder-editor__list extension-editor__list">
                        @for (var i = 0; i < _form.Extensions.Count; i++)
                        {
                            var extIndex = i;
                            var ext = _form.Extensions[extIndex];
                            var extKey = $"Extensions[{extIndex}]";
                            <div class="folder-editor__row extension-editor__row">
                                <div class="folder-editor__row-head">
                                    <div class="folder-editor__order">
                                        <button type="button" class="btn btn--sm" disabled="@(extIndex == 0)"
                                                @onclick="() => MoveExtension(extIndex, -1)" title="Move up">
                                            <Icon Name="arrow-up" Width="12" Height="12" />
                                        </button>
                                        <button type="button" class="btn btn--sm" disabled="@(extIndex == _form.Extensions.Count - 1)"
                                                @onclick="() => MoveExtension(extIndex, 1)" title="Move down">
                                            <Icon Name="arrow-down" Width="12" Height="12" />
                                        </button>
                                    </div>
                                    <div class="folder-editor__path">
                                        <input type="text" required placeholder="e.g. Core"
                                               @bind="ext.Path" @bind:event="oninput" />
                                        <FieldError Field="@($"{extKey}.Path")" Errors="_fieldErrors" />
                                    </div>
                                    <button type="button" class="btn btn--sm" @onclick="() => RemoveExtension(extIndex)" title="Remove extension">
                                        <Icon Name="trash-2" Width="12" Height="12" />
                                    </button>
                                </div>

                                <div class="extension-editor__body">
                                    <div class="form-section form-section--row">
                                        <div>
                                            <label class="section-label">Name template</label>
                                            <input type="text" required placeholder="e.g. {{extension_prefix}} Core"
                                                   @bind="ext.NameTemplate" @bind:event="oninput" />
                                            <FieldError Field="@($"{extKey}.NameTemplate")" Errors="_fieldErrors" />
                                        </div>
                                        <div>
                                            <label class="check-row">
                                                <input type="checkbox" @bind="ext.Required" />
                                                <span>Required (always emitted)</span>
                                            </label>
                                            <small class="muted">
                                                Untick to expose as a checkbox on New Workspace.
                                            </small>
                                        </div>
                                    </div>

                                    <div class="form-section form-section--row">
                                        <div>
                                            <label class="section-label">Application override</label>
                                            <input type="text" placeholder="(use template default)"
                                                   @bind="ext.Application" @bind:event="oninput" />
                                        </div>
                                        <div>
                                            <label class="section-label">Runtime override</label>
                                            <input type="text" placeholder="(use template runtime)"
                                                   @bind="ext.Runtime" @bind:event="oninput" />
                                        </div>
                                    </div>

                                    <div class="form-section form-section--row">
                                        <div>
                                            <label class="section-label">ID range from</label>
                                            <input type="number" min="1" placeholder="(auto-allocate)"
                                                   @bind="ext.IdRangeFrom" @bind:event="oninput" />
                                            <FieldError Field="@($"{extKey}.IdRangeFrom")" Errors="_fieldErrors" />
                                            <FieldError Field="@($"{extKey}.IdRange")" Errors="_fieldErrors" />
                                        </div>
                                        <div>
                                            <label class="section-label">ID range to</label>
                                            <input type="number" min="1" placeholder="(auto-allocate)"
                                                   @bind="ext.IdRangeTo" @bind:event="oninput" />
                                            <FieldError Field="@($"{extKey}.IdRangeTo")" Errors="_fieldErrors" />
                                        </div>
                                    </div>

                                    <div class="form-section">
                                        <div class="folder-editor__header">
                                            <label class="section-label">Dependencies</label>
                                            <button type="button" class="btn btn--sm" @onclick="() => AddDependency(extIndex)">
                                                <Icon Name="plus" Width="12" Height="12" />
                                                <span>Add dependency</span>
                                            </button>
                                        </div>
                                        @if (ext.Dependencies.Count == 0)
                                        {
                                            <p class="muted">No dependencies on this extension.</p>
                                        }
                                        else
                                        {
                                            <div class="folder-editor__list">
                                                @for (var d = 0; d < ext.Dependencies.Count; d++)
                                                {
                                                    var depIndex = d;
                                                    var dep = ext.Dependencies[depIndex];
                                                    var depKey = $"{extKey}.Dependencies[{depIndex}]";
                                                    <div class="folder-editor__row dep-row">
                                                        <div class="folder-editor__row-head">
                                                            <div class="folder-editor__order">
                                                                <button type="button" class="btn btn--sm" disabled="@(depIndex == 0)"
                                                                        @onclick="() => MoveDependency(extIndex, depIndex, -1)" title="Move up">
                                                                    <Icon Name="arrow-up" Width="12" Height="12" />
                                                                </button>
                                                                <button type="button" class="btn btn--sm" disabled="@(depIndex == ext.Dependencies.Count - 1)"
                                                                        @onclick="() => MoveDependency(extIndex, depIndex, 1)" title="Move down">
                                                                    <Icon Name="arrow-down" Width="12" Height="12" />
                                                                </button>
                                                            </div>
                                                            <div class="folder-editor__path">
                                                                <select @bind="dep.Kind">
                                                                    <option value="@DependencyFormKind.Extension">Reference an extension in this template</option>
                                                                    <option value="@DependencyFormKind.Module">Reference a catalogue module</option>
                                                                    <option value="@DependencyFormKind.Literal">Literal dependency (id + name + publisher + version)</option>
                                                                </select>
                                                            </div>
                                                            <button type="button" class="btn btn--sm" @onclick="() => RemoveDependency(extIndex, depIndex)" title="Remove dependency">
                                                                <Icon Name="trash-2" Width="12" Height="12" />
                                                            </button>
                                                        </div>

                                                        <div class="dep-editor__fields">
                                                            @switch (dep.Kind)
                                                            {
                                                                case DependencyFormKind.Extension:
                                                                    <div>
                                                                        <label class="section-label">Extension path</label>
                                                                        <input type="text" placeholder="e.g. Core"
                                                                               @bind="dep.RefExtensionPath" @bind:event="oninput" />
                                                                        <FieldError Field="@($"{depKey}.Extension")" Errors="_fieldErrors" />
                                                                    </div>
                                                                    break;
                                                                case DependencyFormKind.Module:
                                                                    <div>
                                                                        <label class="section-label">Module key</label>
                                                                        <input type="text" placeholder="e.g. system-application"
                                                                               @bind="dep.RefModuleKey" @bind:event="oninput" />
                                                                    </div>
                                                                    break;
                                                                default:
                                                                    <div>
                                                                        <label class="section-label">ID (GUID)</label>
                                                                        <input type="text" @bind="dep.LitId" @bind:event="oninput" />
                                                                        <FieldError Field="@($"{depKey}.Id")" Errors="_fieldErrors" />
                                                                    </div>
                                                                    <div>
                                                                        <label class="section-label">Name</label>
                                                                        <input type="text" @bind="dep.LitName" @bind:event="oninput" />
                                                                        <FieldError Field="@($"{depKey}.Name")" Errors="_fieldErrors" />
                                                                    </div>
                                                                    <div>
                                                                        <label class="section-label">Publisher</label>
                                                                        <input type="text" @bind="dep.LitPublisher" @bind:event="oninput" />
                                                                        <FieldError Field="@($"{depKey}.Publisher")" Errors="_fieldErrors" />
                                                                    </div>
                                                                    <div>
                                                                        <label class="section-label">Version</label>
                                                                        <input type="text" placeholder="e.g. 1.0.0.0"
                                                                               @bind="dep.LitVersion" @bind:event="oninput" />
                                                                        <FieldError Field="@($"{depKey}.Version")" Errors="_fieldErrors" />
                                                                    </div>
                                                                    break;
                                                            }
                                                        </div>
                                                        <FieldError Field="@depKey" Errors="_fieldErrors" />
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>

                                    <div class="form-section">
                                        <div class="folder-editor__header">
                                            <label class="section-label">Folders</label>
                                            <button type="button" class="btn btn--sm" @onclick="() => AddRootFolder(extIndex)">
                                                <Icon Name="folder-plus" Width="12" Height="12" />
                                                <span>Add folder</span>
                                            </button>
                                        </div>
                                        @if (ext.Folders.Count == 0)
                                        {
                                            <p class="muted">No folders. Generation still produces <code>app.json</code> + the static fallback folders.</p>
                                        }
                                        else
                                        {
                                            <div class="folder-editor__list">
                                                @for (var f = 0; f < ext.Folders.Count; f++)
                                                {
                                                    var folderIndex = f;
                                                    var folder = ext.Folders[folderIndex];
                                                    <RecursiveFolderEditor Folder="folder"
                                                                           Index="folderIndex"
                                                                           SiblingCount="ext.Folders.Count"
                                                                           Depth="0"
                                                                           FieldKeyPrefix="@($"{extKey}.Folders[{folderIndex}]")"
                                                                           Errors="_fieldErrors"
                                                                           OnMove="d => MoveRootFolder(extIndex, folderIndex, d)"
                                                                           OnRemove="() => RemoveRootFolder(extIndex, folderIndex)" />
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </section>

            <div class="admin-template-edit__actions">
                <button type="submit" class="btn btn--primary" disabled="@_saving">
                    <Icon Name="save" Width="16" Height="16" />
                    <span>@(_saving ? "Saving…" : (IsEdit ? "Save changes" : "Create template"))</span>
                </button>
                @if (IsEdit && _existingId is not null)
                {
                    @if (_isDeleted)
                    {
                        <button type="button" class="btn" @onclick="RestoreAsync" disabled="@_saving">
                            <Icon Name="rotate-ccw" Width="16" Height="16" />
                            <span>Restore</span>
                        </button>
                    }
                    else
                    {
                        <button type="button" class="btn" @onclick="ConfirmDeleteAsync" disabled="@_saving">
                            <Icon Name="trash-2" Width="16" Height="16" />
                            <span>Soft-delete</span>
                        </button>
                    }
                }
            </div>
        </form>

                }
            </div>
            <aside class="admin-template-edit__preview">
                <details class="preview-card preview-card--collapsible" open>
                    <summary class="preview-card__summary">Mustache variables</summary>
                    <div class="preview-card__body">
                        <p class="muted preview-card__hint">
                            Substituted into file contents at generation time.
                            Unknown placeholders are left as-is and logged.
                        </p>
                        <dl class="mustache-vars">
                            <dt><code>@("{{name}}")</code></dt>
                            <dd>Full extension name (e.g. "Acme Customer Core").</dd>
                            <dt><code>@("{{workspaceName}}")</code></dt>
                            <dd>Workspace name as entered on New Workspace.</dd>
                            <dt><code>@("{{shortName}}")</code></dt>
                            <dd>Workspace name with spaces removed.</dd>
                            <dt><code>@("{{moduleName}}")</code></dt>
                            <dd>Module name; equals the workspace name in the Core extension.</dd>
                            <dt><code>@("{{publisher}}")</code></dt>
                            <dd>From <code>[defaults] publisher</code>.</dd>
                            <dt><code>@("{{extension_prefix}}")</code></dt>
                            <dd>From the New Workspace form; defaults to <code>defaults.extension_prefix</code>.</dd>
                            <dt><code>@("{{affix}}")</code></dt>
                            <dd>From <code>defaults.affix</code>; expands to empty when <code>affix_type = "None"</code>.</dd>
                            <dt><code>@("{{namespace}}")</code></dt>
                            <dd>Current folder path with <code>/</code> replaced by <code>.</code>.</dd>
                            <dt><code>@("{{guid}}")</code></dt>
                            <dd>Freshly generated GUID per occurrence.</dd>
                        </dl>
                    </div>
                </details>
                <details class="preview-card preview-card--collapsible preview-card--scroll" open>
                    <summary class="preview-card__summary">Preview</summary>
                    <div class="preview-card__body">
                        @if (_mode == EditorMode.Toml)
                        {
                            <p class="muted preview-card__hint">
                                Showing the last form-side state. Switch back to the
                                structured form to refresh.
                            </p>
                        }
                        <FolderTreePreview Root="BuildPreview()" />
                    </div>
                </details>
            </aside>
        </div>
    }

    @if (_form is not null && IsEdit && _existingId is not null)
    {
        <AuditHistoryPanel EntityType="AuditEntityType.RuntimeTemplate" EntityId="_existingId.Value" Title="Template history" />
    }
</div>

<ConfirmDialog @ref="_deleteConfirm"
               Title="Soft-delete this template?"
               Message="It will disappear from the user-facing dropdown. You can restore it from this page; the audit log keeps the change either way."
               ConfirmLabel="Soft-delete"
               ConfirmIcon="trash-2" />

<ConfirmDialog @ref="_leaveConfirm"
               Title="Leave with unsaved changes?"
               Message="Your edits to template.toml haven't been saved. Leaving now will discard them."
               ConfirmLabel="Discard changes"
               CancelLabel="Stay on page"
               ConfirmIcon="log-out" />

@code {
    [Parameter] public string? Key { get; set; }

    /// <summary>
    /// When the new-template form is opened via the list-page Duplicate
    /// action, this carries the source template's key. The form prefills
    /// from that template and clears the Key field so the admin can pick a
    /// fresh one before saving.
    /// </summary>
    [SupplyParameterFromQuery(Name = "from")] public string? DuplicateFrom { get; set; }

    private bool IsEdit => !string.IsNullOrEmpty(Key);
    private string PageTitleText => IsEdit ? "Edit template" : "New template";

    private TemplateFormState? _form;
    private int? _existingId;
    private bool _isDeleted;
    private bool _loadFailed;
    private bool _saving;
    private List<ALDevToolbox.Domain.Entities.Module> _availableModules = new();
    private List<ApplicationVersion> _availableApplicationVersions = new();
    private ConfirmDialog? _deleteConfirm;
    private ConfirmDialog? _leaveConfirm;
    private IDisposable? _locationChangingRegistration;
    private string? _saveError;
    private string? _saveSuccess;
    private IReadOnlyDictionary<string, string> _fieldErrors = new Dictionary<string, string>();
    private EditorMode _mode = EditorMode.Form;
    private string _toml = string.Empty;
    // CodeMirror 6 plumbing. The editor module is loaded lazily the first
    // time the TOML tab is rendered, so the structured-form path doesn't pay
    // the import cost. _editorId is the JS-side handle returned by mount().
    private ElementReference _tomlContainer;
    private IJSObjectReference? _editorModule;
    private int _editorId;
    private string _editorMountedToml = string.Empty;
    private List<TomlParseIssue> _tomlIssues = new();
    private bool _editorIssueSyncPending;
    // Guards against OnAfterRenderAsync re-entrancy: a second render can fire
    // while the first mount() is still awaiting and would otherwise spin up a
    // duplicate editor.
    private bool _editorMounting;

    /// <summary>
    /// Which editor surface is currently visible. The structured form is the
    /// default; TOML mode is opt-in for admins comfortable with the seed file
    /// shape. The DB stays the source of truth either way.
    /// </summary>
    private enum EditorMode { Form, Toml }

    protected override void OnInitialized()
    {
        // Intercept SPA navigation (sidebar links, "Back to list", browser
        // back to an in-app URL) so we can warn before the user discards
        // unsaved TOML edits. Browser-level navigation (full reload, tab
        // close, back to an external URL) goes through beforeunload in the
        // .razor.js companion.
        _locationChangingRegistration = Nav.RegisterLocationChangingHandler(OnLocationChangingAsync);
    }

    private async ValueTask OnLocationChangingAsync(LocationChangingContext context)
    {
        if (_editorId == 0 || _editorModule is null || _leaveConfirm is null) return;

        bool dirty;
        try
        {
            dirty = await _editorModule.InvokeAsync<bool>("isDirty", _editorId);
        }
        catch (Exception ex)
        {
            // If we can't check, fail open — blocking nav on a transient JS
            // hiccup would be worse than the rare lost edit.
            Log.LogWarning(ex, "Failed to read dirty state from editor; allowing navigation.");
            return;
        }

        if (!dirty) return;

        var leave = await _leaveConfirm.OpenAsync();
        if (!leave)
        {
            context.PreventNavigation();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        _saveError = null;
        _saveSuccess = null;
        _fieldErrors = new Dictionary<string, string>();
        _tomlIssues = new();
        _editorIssueSyncPending = false;

        // Module list drives the default-module multi-select. Include
        // deprecated entries so admins can keep them ticked on legacy
        // templates without losing the reference; the user-facing
        // dropdown filters them out separately.
        _availableModules = await Templates.GetModulesAsync(includeDeprecated: true);
        _availableApplicationVersions = await Versions.GetActiveAsync(includeDeprecated: true);

        if (!IsEdit)
        {
            _existingId = null;
            _isDeleted = false;
            _loadFailed = false;

            // Duplicate flow: prefill the new-template form from an existing
            // template's authoring shape. The Key is intentionally cleared so
            // the admin has to pick a fresh one; every other field carries
            // over and can be tweaked before save.
            if (!string.IsNullOrWhiteSpace(DuplicateFrom))
            {
                var source = await Templates.GetAuthoringByKeyAsync(DuplicateFrom);
                if (source is not null)
                {
                    _form = TemplateFormState.From(source);
                    _form.Key = string.Empty;
                    _form.Name = string.IsNullOrWhiteSpace(source.Name)
                        ? string.Empty
                        : $"{source.Name} (copy)";
                    // Don't carry the deprecated flag onto a brand-new copy.
                    _form.Deprecated = false;
                    _mode = EditorMode.Form;
                    _saveSuccess = $"Duplicated from \"{source.Key}\". Pick a new key, then click Create template.";
                    return;
                }
                Log.LogWarning("Duplicate source template '{Key}' not found; falling back to blank form.", DuplicateFrom);
            }

            _form = TemplateFormState.Blank();
            // New-template flow opens in TOML — pasting a template.toml is the
            // common path. Pre-render the blank scaffold once so the textarea
            // has something useful to start from.
            _mode = EditorMode.Toml;
            _toml = TemplateTomlMapper.BlankToml();
            return;
        }

        var existing = await Templates.GetAuthoringByKeyAsync(Key!);
        if (existing is null)
        {
            _loadFailed = true;
            _form = null;
            return;
        }

        // Need the existing row's id (and the soft-delete flag) for the
        // delete/restore buttons; the authoring payload doesn't carry it.
        var entity = await Templates.GetByKeyAsync(Key!);
        _loadFailed = false;
        _existingId = entity?.Id;
        _isDeleted = entity?.DeletedAt is not null;
        _form = TemplateFormState.From(existing);
        _mode = EditorMode.Form;
    }

    private void OnDefaultModuleToggled(string key, bool isChecked)
    {
        if (_form is null) return;
        if (isChecked)
        {
            if (!_form.DefaultModuleKeys.Contains(key))
            {
                _form.DefaultModuleKeys.Add(key);
            }
        }
        else
        {
            _form.DefaultModuleKeys.Remove(key);
        }
    }

    // ===== Extension list handlers =====

    private void AddExtension()
    {
        if (_form is null) return;
        _form.Extensions.Add(new ExtensionForm
        {
            Path = string.Empty,
            NameTemplate = "{{extension_prefix}} Extension",
            Required = true,
        });
    }

    private void RemoveExtension(int index)
    {
        if (_form is null) return;
        if (index < 0 || index >= _form.Extensions.Count) return;
        _form.Extensions.RemoveAt(index);
    }

    private void MoveExtension(int index, int delta)
    {
        if (_form is null) return;
        var target = index + delta;
        if (index < 0 || index >= _form.Extensions.Count) return;
        if (target < 0 || target >= _form.Extensions.Count) return;
        (_form.Extensions[index], _form.Extensions[target]) = (_form.Extensions[target], _form.Extensions[index]);
    }

    // ===== Top-level folder handlers (recursive editor owns nested ops) =====

    private void AddRootFolder(int extIndex)
    {
        if (_form is null || extIndex < 0 || extIndex >= _form.Extensions.Count) return;
        _form.Extensions[extIndex].Folders.Add(new TemplateFolderForm());
    }

    private void RemoveRootFolder(int extIndex, int folderIndex)
    {
        if (_form is null || extIndex < 0 || extIndex >= _form.Extensions.Count) return;
        var folders = _form.Extensions[extIndex].Folders;
        if (folderIndex < 0 || folderIndex >= folders.Count) return;
        folders.RemoveAt(folderIndex);
    }

    private void MoveRootFolder(int extIndex, int folderIndex, int delta)
    {
        if (_form is null || extIndex < 0 || extIndex >= _form.Extensions.Count) return;
        var folders = _form.Extensions[extIndex].Folders;
        var target = folderIndex + delta;
        if (folderIndex < 0 || folderIndex >= folders.Count) return;
        if (target < 0 || target >= folders.Count) return;
        (folders[folderIndex], folders[target]) = (folders[target], folders[folderIndex]);
    }

    // ===== Dependency handlers =====

    private void AddDependency(int extIndex)
    {
        if (_form is null || extIndex < 0 || extIndex >= _form.Extensions.Count) return;
        _form.Extensions[extIndex].Dependencies.Add(new DependencyForm
        {
            Kind = DependencyFormKind.Extension,
        });
    }

    private void RemoveDependency(int extIndex, int depIndex)
    {
        if (_form is null || extIndex < 0 || extIndex >= _form.Extensions.Count) return;
        var deps = _form.Extensions[extIndex].Dependencies;
        if (depIndex < 0 || depIndex >= deps.Count) return;
        deps.RemoveAt(depIndex);
    }

    private void MoveDependency(int extIndex, int depIndex, int delta)
    {
        if (_form is null || extIndex < 0 || extIndex >= _form.Extensions.Count) return;
        var deps = _form.Extensions[extIndex].Dependencies;
        var target = depIndex + delta;
        if (depIndex < 0 || depIndex >= deps.Count) return;
        if (target < 0 || target >= deps.Count) return;
        (deps[depIndex], deps[target]) = (deps[target], deps[depIndex]);
    }

    // ===== Save / delete / restore =====

    private async Task SaveAsync()
    {
        if (_form is null || _saving) return;
        _saving = true;
        _saveError = null;
        _saveSuccess = null;
        _fieldErrors = new Dictionary<string, string>();

        var payload = _form.ToAuthoring();

        try
        {
            if (IsEdit && _existingId is not null)
            {
                await Templates.UpdateAsync(_existingId.Value, payload);
                _saveSuccess = "Saved.";
            }
            else
            {
                await Templates.CreateAsync(payload);
                // Land back on the list so admins can immediately see the new
                // row in context. Editing it further is one click away.
                Nav.NavigateTo("/admin/templates");
                return;
            }
        }
        catch (PlanValidationException ex)
        {
            _fieldErrors = ex.Errors;
            _saveError = $"Couldn't save: {ex.Errors.Count} validation error(s). See messages next to each field.";
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Unexpected error saving template '{Key}'.", payload.Key);
            _saveError = "An unexpected error occurred. The change was not saved.";
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task ConfirmDeleteAsync()
    {
        if (_existingId is null || _saving || _deleteConfirm is null) return;
        if (!await _deleteConfirm.OpenAsync()) return;
        _saving = true;
        try
        {
            await Templates.SoftDeleteAsync(_existingId.Value);
            Nav.NavigateTo("/admin/templates");
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Failed to soft-delete template id={Id}.", _existingId);
            _saveError = "Couldn't delete the template. Check the logs.";
            _saving = false;
        }
    }

    private async Task RestoreAsync()
    {
        if (_existingId is null || _saving) return;
        _saving = true;
        try
        {
            await Templates.RestoreAsync(_existingId.Value);
            _isDeleted = false;
            _saveSuccess = "Template restored.";
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Failed to restore template id={Id}.", _existingId);
            _saveError = "Couldn't restore the template. Check the logs.";
        }
        finally
        {
            _saving = false;
        }
    }

    // ===== Mode switching =====

    private async Task SwitchModeAsync(EditorMode mode)
    {
        if (_form is null || _mode == mode || _saving) return;

        if (_mode == EditorMode.Toml && mode == EditorMode.Form)
        {
            // Validate-on-switch: parse what's in the editor and rebuild form
            // state from it. If the TOML doesn't parse, the gutter markers
            // stay visible and we refuse the switch — bidirectional sync only
            // works when both sides agree on the data shape.
            if (!await TryHydrateFormFromEditorAsync())
            {
                return;
            }
        }
        else if (_mode == EditorMode.Form && mode == EditorMode.Toml)
        {
            // Form → TOML: render the current form state. The TOML doc
            // becomes the source of truth from this point until the next
            // switch back; the editor's pristine baseline is reset by the
            // setValue call OnAfterRenderAsync issues when _toml changes.
            _toml = BuildTomlFromFormState();
            _tomlIssues = new();
        }

        _mode = mode;
        _saveError = null;
        _saveSuccess = null;
        _fieldErrors = new Dictionary<string, string>();
    }

    private async Task RefreshPreviewAsync()
    {
        if (_form is null || _saving) return;
        if (await TryHydrateFormFromEditorAsync())
        {
            _saveError = null;
            _saveSuccess = "Preview refreshed.";
        }
    }

    /// <summary>
    /// Pulls the current TOML out of the editor, parses it, and rebuilds
    /// <see cref="_form"/> from the result. Returns <c>false</c> (and surfaces
    /// the parse issues to the caller's UI state) when the TOML is malformed,
    /// so the caller can refuse the mode switch.
    /// </summary>
    private async Task<bool> TryHydrateFormFromEditorAsync()
    {
        if (_form is null) return false;

        if (_editorId != 0 && _editorModule is not null)
        {
            try
            {
                _toml = await _editorModule.InvokeAsync<string>("getValue", _editorId);
                _editorMountedToml = _toml;
            }
            catch (Exception ex)
            {
                Log.LogWarning(ex, "Failed to read TOML value from editor on mode switch.");
                _saveError = "Couldn't read the editor contents. Try again or refresh.";
                return false;
            }
        }

        try
        {
            var parsed = TemplateTomlMapper.FromToml(_toml, deprecated: _form.Deprecated);
            _form = TemplateFormState.From(parsed);
            _tomlIssues = new();
            _saveError = null;
            return true;
        }
        catch (TomlParseException ex)
        {
            _tomlIssues = ex.Issues.ToList();
            _editorIssueSyncPending = true;
            _saveError = _tomlIssues.Count == 1
                ? $"TOML parse error on line {_tomlIssues[0].Line}. Fix it to refresh the preview or switch to the form view."
                : $"TOML parse error: {_tomlIssues.Count} issue(s). See gutter markers — fix them to refresh the preview or switch to the form view.";
            return false;
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Unexpected error parsing TOML.");
            _saveError = "Couldn't parse the TOML. Fix the issue, or save anyway from the TOML view.";
            return false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_form is null) return;

        // Tear down first so a mode flip in the same render doesn't leak the
        // previous editor instance.
        if (_mode != EditorMode.Toml && _editorId != 0)
        {
            await DisposeEditorAsync();
        }

        if (_mode == EditorMode.Toml && _editorId == 0 && !_editorMounting)
        {
            _editorMounting = true;
            try
            {
                _editorModule ??= await JS.InvokeAsync<IJSObjectReference>(
                    "import", "./Components/Shared/CodeEditor.razor.js");
                _editorId = await _editorModule.InvokeAsync<int>("mount", _tomlContainer, _toml, "toml");
                _editorMountedToml = _toml;
                if (_tomlIssues.Count > 0)
                {
                    _editorIssueSyncPending = true;
                }
            }
            catch (Exception ex)
            {
                Log.LogError(ex, "Failed to mount the CodeMirror TOML editor.");
                return;
            }
            finally
            {
                _editorMounting = false;
            }
        }

        if (_mode == EditorMode.Toml && _editorId != 0 && _editorModule is not null)
        {
            if (_editorMountedToml != _toml)
            {
                await _editorModule.InvokeVoidAsync("setValue", _editorId, _toml);
                _editorMountedToml = _toml;
            }

            if (_editorIssueSyncPending)
            {
                _editorIssueSyncPending = false;
                var payload = _tomlIssues
                    .Select(i => new { line = i.Line, message = i.Message, severity = "error" })
                    .ToArray();
                await _editorModule.InvokeVoidAsync("setIssues", _editorId, payload);
            }
        }
    }

    private async Task DisposeEditorAsync()
    {
        if (_editorId == 0 || _editorModule is null) return;
        try
        {
            await _editorModule.InvokeVoidAsync("dispose", _editorId);
        }
        catch (JSDisconnectedException)
        {
            // Circuit gone — JS already cleaned up.
        }
        catch (Exception ex)
        {
            Log.LogWarning(ex, "Disposing the CodeMirror TOML editor failed.");
        }
        finally
        {
            _editorId = 0;
            _editorMountedToml = string.Empty;
        }
    }

    public async ValueTask DisposeAsync()
    {
        _locationChangingRegistration?.Dispose();
        _locationChangingRegistration = null;
        await DisposeEditorAsync();
        if (_editorModule is not null)
        {
            try
            {
                await _editorModule.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
                // Circuit already gone.
            }
            catch (Exception ex)
            {
                Log.LogWarning(ex, "Disposing the editor module failed.");
            }
            _editorModule = null;
        }
    }

    private string ModeButtonClass(EditorMode mode) =>
        _mode == mode ? "btn btn--sm admin-template-edit__mode-btn admin-template-edit__mode-btn--active"
                      : "btn btn--sm admin-template-edit__mode-btn";

    /// <summary>
    /// Renders the current form state as TOML for the Form → TOML mode switch.
    /// Falls back to a placeholder when the embedded JSON columns are
    /// unparseable so the editor still opens — the admin can fix the JSON in
    /// the form pane and switch back without losing it.
    /// </summary>
    private string BuildTomlFromFormState()
    {
        if (_form is null) return string.Empty;
        try
        {
            return TemplateTomlMapper.ToToml(_form.ToAuthoring());
        }
        catch (JsonException ex)
        {
            return $"# Could not render TOML — Defaults or AppSourceCop JSON is invalid:\n# {ex.Message}\n";
        }
        catch (Exception ex)
        {
            Log.LogWarning(ex, "Failed to render TOML from form state.");
            return $"# Could not render TOML: {ex.Message}\n";
        }
    }

    /// <summary>
    /// Folder-tree preview for the right column. Walks the form's extensions
    /// list and emits one extension subtree per <c>[[extensions]]</c> row.
    /// In TOML mode this reflects the last validated form state — typing in
    /// the TOML editor doesn't refresh the preview until the admin clicks
    /// "Refresh preview" or switches back to the form view.
    /// </summary>
    private PreviewNode BuildPreview()
    {
        if (_form is null)
        {
            return PreviewNode.Folder("(no template)");
        }

        var rootName = string.IsNullOrWhiteSpace(_form.Key) ? "template" : _form.Key;
        var includeCop = ParseIncludeAppSourceCop(_form.AppSourceCopJson);

        var children = new List<PreviewNode>();
        foreach (var ext in _form.Extensions)
        {
            children.Add(BuildExtensionPreview(ext, includeCop));
        }

        return PreviewTreeBuilder.SortForDisplay(
            new PreviewNode(rootName, PreviewNodeKind.Workspace, children));
    }

    /// <summary>
    /// Reads <c>include</c> from the AppSourceCop JSON textarea. Tolerates a
    /// malformed buffer (the user might be mid-edit) and defaults to true so
    /// the preview matches the generator's default behaviour.
    /// </summary>
    private static bool ParseIncludeAppSourceCop(string json)
    {
        if (string.IsNullOrWhiteSpace(json)) return true;
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(json);
            if (doc.RootElement.TryGetProperty("include", out var prop) && prop.ValueKind == System.Text.Json.JsonValueKind.False)
            {
                return false;
            }
        }
        catch (System.Text.Json.JsonException)
        {
            // Mid-edit malformed JSON; surface the default.
        }
        return true;
    }

    private static PreviewNode BuildExtensionPreview(ExtensionForm ext, bool includeAppSourceCop)
    {
        var contents = new List<PreviewNode> { PreviewNode.File("app.json") };
        if (includeAppSourceCop) contents.Add(PreviewNode.File("AppSourceCop.json"));

        foreach (var folder in ext.Folders.Where(f => !string.IsNullOrWhiteSpace(f.Path)))
        {
            contents.Add(BuildFolderPreview(folder));
        }

        var name = string.IsNullOrWhiteSpace(ext.Path) ? "(unnamed)" : ext.Path;
        return PreviewNode.Extension(name, contents);
    }

    private static PreviewNode BuildFolderPreview(TemplateFolderForm folder)
    {
        var children = new List<PreviewNode>();
        foreach (var file in folder.Files.Where(f => !string.IsNullOrWhiteSpace(f.Path)))
        {
            children.Add(PreviewNode.File(file.Path));
        }
        foreach (var child in folder.Folders.Where(f => !string.IsNullOrWhiteSpace(f.Path)))
        {
            children.Add(BuildFolderPreview(child));
        }
        if (children.Count == 0)
        {
            children.Add(PreviewNode.File(".gitkeep"));
        }
        return PreviewNode.Folder(folder.Path, children);
    }

    private async Task SaveTomlAsync()
    {
        if (_form is null || _saving) return;
        _saving = true;
        _saveError = null;
        _saveSuccess = null;
        _fieldErrors = new Dictionary<string, string>();
        _tomlIssues = new();

        // Pull the latest text from CodeMirror; the editor doesn't two-way
        // bind to _toml, so a stale value here would silently save the
        // pre-edit document.
        if (_editorId != 0 && _editorModule is not null)
        {
            try
            {
                _toml = await _editorModule.InvokeAsync<string>("getValue", _editorId);
                _editorMountedToml = _toml;
            }
            catch (Exception ex)
            {
                Log.LogError(ex, "Failed to read TOML value from editor before save.");
                _saveError = "Couldn't read the editor contents. Try again or refresh.";
                _saving = false;
                return;
            }
        }

        try
        {
            var payload = TemplateTomlMapper.FromToml(_toml, deprecated: _form.Deprecated);

            if (IsEdit && _existingId is not null)
            {
                await Templates.UpdateAsync(_existingId.Value, payload);
                var refreshed = await Templates.GetAuthoringByKeyAsync(Key!);
                if (refreshed is not null)
                {
                    _form = TemplateFormState.From(refreshed);
                    _toml = TemplateTomlMapper.ToToml(refreshed);
                    _editorMountedToml = _toml;
                    if (_editorId != 0 && _editorModule is not null)
                    {
                        await _editorModule.InvokeVoidAsync("setValue", _editorId, _toml);
                        await _editorModule.InvokeVoidAsync("markPristine", _editorId);
                    }
                }
                _saveSuccess = "Saved from TOML.";
            }
            else
            {
                await Templates.CreateAsync(payload);
                if (_editorId != 0 && _editorModule is not null)
                {
                    await _editorModule.InvokeVoidAsync("markPristine", _editorId);
                }
                Nav.NavigateTo("/admin/templates");
                return;
            }
        }
        catch (TomlParseException ex)
        {
            _tomlIssues = ex.Issues.ToList();
            _editorIssueSyncPending = true;
            _saveError = _tomlIssues.Count == 1
                ? $"TOML parse error on line {_tomlIssues[0].Line}."
                : $"TOML parse error: {_tomlIssues.Count} issue(s). See gutter markers.";
        }
        catch (InvalidDataException ex)
        {
            _saveError = ex.Message;
        }
        catch (PlanValidationException ex)
        {
            _fieldErrors = ex.Errors;
            _saveError = $"Couldn't save: {ex.Errors.Count} validation error(s).";
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Unexpected error saving template from TOML.");
            _saveError = "An unexpected error occurred. The change was not saved.";
        }
        finally
        {
            _saving = false;
        }
    }
}
