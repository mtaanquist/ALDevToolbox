<ConfirmDialog @ref="_deleteConfirm"
               Title="Soft-delete this template?"
               Message="It will disappear from the user-facing dropdown. You can restore it from this page; the audit log keeps the change either way."
               ConfirmLabel="Soft-delete"
               ConfirmIcon="trash-2" />

<ConfirmDialog @ref="_leaveConfirm"
               Title="Leave with unsaved changes?"
               Message="Your edits to template.toml haven't been saved. Leaving now will discard them."
               ConfirmLabel="Discard changes"
               CancelLabel="Stay on page"
               ConfirmIcon="log-out" />

@code {
    [Parameter] public string? Key { get; set; }

    /// <summary>
    /// When the new-template form is opened via the list-page Duplicate
    /// action, this carries the source template's key. The form prefills
    /// from that template and clears the Key field so the admin can pick a
    /// fresh one before saving.
    /// </summary>
    [SupplyParameterFromQuery(Name = "from")] public string? DuplicateFrom { get; set; }

    private bool IsEdit => !string.IsNullOrEmpty(Key);
    private string PageTitleText => IsEdit ? "Edit template" : "New template";

    private FormState? _form;
    private int? _existingId;
    private bool _isDeleted;
    private bool _loadFailed;
    private bool _saving;
    private List<ALDevToolbox.Domain.Entities.Module> _availableModules = new();
    private List<ApplicationVersion> _availableApplicationVersions = new();
    private ConfirmDialog? _deleteConfirm;
    private ConfirmDialog? _leaveConfirm;
    private IDisposable? _locationChangingRegistration;
    private string? _saveError;
    private string? _saveSuccess;
    private IReadOnlyDictionary<string, string> _fieldErrors = new Dictionary<string, string>();
    private EditorMode _mode = EditorMode.Form;
    private string _toml = string.Empty;
    // CodeMirror 6 plumbing. The editor module is loaded lazily the first
    // time the TOML tab is rendered, so the structured-form path doesn't pay
    // the import cost. _editorId is the JS-side handle returned by mount().
    private ElementReference _tomlContainer;
    private IJSObjectReference? _editorModule;
    private int _editorId;
    private string _editorMountedToml = string.Empty;
    private List<TomlParseIssue> _tomlIssues = new();
    private bool _editorIssueSyncPending;
    // Guards against OnAfterRenderAsync re-entrancy: a second render can fire
    // while the first mount() is still awaiting and would otherwise spin up a
    // duplicate editor.
    private bool _editorMounting;
    // Indices of folder rows whose file list is currently expanded. Tracked
    // outside FormState so reordering folders doesn't drag the wrong rows open.
    // Separate sets for the two editors (Core folders vs module folders) so
    // they expand independently.
    private readonly HashSet<int> _expandedFolders = new();
    private readonly HashSet<int> _expandedModuleFolders = new();

    private static readonly JsonSerializerOptions PrettyJson = new() { WriteIndented = true };

    /// <summary>
    /// Which editor surface is currently visible. The structured form is the
    /// default; TOML mode is opt-in for admins comfortable with the seed file
    /// shape. The DB stays the source of truth either way.
    /// </summary>
    private enum EditorMode { Form, Toml }

    protected override void OnInitialized()
    {
        // Intercept SPA navigation (sidebar links, "Back to list", browser
        // back to an in-app URL) so we can warn before the user discards
        // unsaved TOML edits. Browser-level navigation (full reload, tab
        // close, back to an external URL) goes through beforeunload in the
        // .razor.js companion.
        _locationChangingRegistration = Nav.RegisterLocationChangingHandler(OnLocationChangingAsync);
    }

    private async ValueTask OnLocationChangingAsync(LocationChangingContext context)
    {
        if (_editorId == 0 || _editorModule is null || _leaveConfirm is null) return;

        bool dirty;
        try
        {
            dirty = await _editorModule.InvokeAsync<bool>("isDirty", _editorId);
        }
        catch (Exception ex)
        {
            // If we can't check, fail open — blocking nav on a transient JS
            // hiccup would be worse than the rare lost edit.
            Log.LogWarning(ex, "Failed to read dirty state from editor; allowing navigation.");
            return;
        }

        if (!dirty) return;

        var leave = await _leaveConfirm.OpenAsync();
        if (!leave)
        {
            context.PreventNavigation();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        _saveError = null;
        _saveSuccess = null;
        _fieldErrors = new Dictionary<string, string>();
        _tomlIssues = new();
        _editorIssueSyncPending = false;

        // Module list drives the default-module multi-select. Include
        // deprecated entries so admins can keep them ticked on legacy
        // templates without losing the reference; the user-facing
        // dropdown filters them out separately.
        _availableModules = await Templates.GetModulesAsync(includeDeprecated: true);
        // Include deprecated entries so admins can keep templates linked to a
        // legacy application-version row without losing the reference; the
        // user-facing select filters them out.
        _availableApplicationVersions = await Versions.GetActiveAsync(includeDeprecated: true);

        if (!IsEdit)
        {
            _existingId = null;
            _isDeleted = false;
            _loadFailed = false;

            // Duplicate flow: prefill the new-template form from an existing
            // template's state. The Key is intentionally cleared so the admin
            // has to pick a fresh one — every other field carries over and
            // can be tweaked before save. Falls back to a blank form if the
            // source key is missing or no longer exists.
            if (!string.IsNullOrWhiteSpace(DuplicateFrom))
            {
                var source = await Templates.GetByKeyAsync(DuplicateFrom);
                if (source is not null)
                {
                    _form = FormState.From(source);
                    _form.Key = string.Empty;
                    _form.Name = string.IsNullOrWhiteSpace(source.Name)
                        ? string.Empty
                        : $"{source.Name} (copy)";
                    // Don't carry the deprecated flag onto a brand-new copy —
                    // the admin is starting fresh, not preserving end-of-life.
                    _form.Deprecated = false;
                    // Open the structured form so the empty Key is the first
                    // visible required field rather than buried in TOML.
                    _mode = EditorMode.Form;
                    _saveSuccess = $"Duplicated from \"{source.Key}\". Pick a new key, then click Create template.";
                    return;
                }
                Log.LogWarning("Duplicate source template '{Key}' not found; falling back to blank form.", DuplicateFrom);
            }

            // Always reset on the no-source path so navigating from
            // ?from=foo to a plain /new doesn't carry the prefilled state
            // through.
            _form = FormState.Blank();
            // New-template flow opens in TOML — pasting a template.toml is the
            // common path. Pre-render the blank scaffold once so the textarea
            // has something useful to start from.
            _mode = EditorMode.Toml;
            _toml = TemplateTomlMapper.BlankToml();
            return;
        }

        var existing = await Templates.GetByKeyAsync(Key!);
        if (existing is null)
        {
            _loadFailed = true;
            _form = null;
            return;
        }

        _loadFailed = false;
        _existingId = existing.Id;
        _isDeleted = existing.DeletedAt is not null;
        _form = FormState.From(existing);
        _mode = EditorMode.Form;
    }

    private void OnDefaultModuleToggled(string key, bool isChecked)
    {
        if (_form is null) return;
        if (isChecked)
        {
            if (!_form.DefaultModuleKeys.Contains(key))
            {
                _form.DefaultModuleKeys.Add(key);
            }
        }
        else
        {
            _form.DefaultModuleKeys.Remove(key);
        }
    }

    private void AddFolder()
    {
        _form?.Folders.Add(new FolderRow());
    }

    private void AddRootFolder()
    {
        if (_form is null || _form.Folders.Any(f => f.IsRoot)) return;
        // Surface the root row at the top so it sits next to app.json in
        // the reader's mental model.
        _form.Folders.Insert(0, new FolderRow { IsRoot = true });
        // Re-anchor the expanded-set: every existing index shifts by +1
        // because we just prepended a row.
        var bumped = _expandedFolders.Select(i => i + 1).ToList();
        _expandedFolders.Clear();
        foreach (var i in bumped) _expandedFolders.Add(i);
    }

    private void RemoveFolder(int index)
    {
        if (_form is null) return;
        if (index >= 0 && index < _form.Folders.Count)
        {
            _form.Folders.RemoveAt(index);
            _expandedFolders.Clear();
        }
    }

    private void MoveFolder(int index, int delta)
    {
        if (_form is null) return;
        var target = index + delta;
        if (index < 0 || index >= _form.Folders.Count || target < 0 || target >= _form.Folders.Count)
        {
            return;
        }
        (_form.Folders[index], _form.Folders[target]) = (_form.Folders[target], _form.Folders[index]);
        // Re-anchor expanded rows so the user keeps their open editor tracking
        // the folder they were editing, not the row index.
        var wasExpandedHere = _expandedFolders.Contains(index);
        var wasExpandedThere = _expandedFolders.Contains(target);
        _expandedFolders.Remove(index);
        _expandedFolders.Remove(target);
        if (wasExpandedHere) _expandedFolders.Add(target);
        if (wasExpandedThere) _expandedFolders.Add(index);
    }

    private bool IsFolderExpanded(int index) => _expandedFolders.Contains(index);

    private void ToggleFolderExpanded(int index)
    {
        if (!_expandedFolders.Add(index))
        {
            _expandedFolders.Remove(index);
        }
    }

    private void AddFile(int folderIndex)
    {
        if (_form is null || folderIndex < 0 || folderIndex >= _form.Folders.Count) return;
        _form.Folders[folderIndex].Files.Add(new FileRow());
        _expandedFolders.Add(folderIndex);
    }

    private void RemoveFile(int folderIndex, int fileIndex)
    {
        if (_form is null || folderIndex < 0 || folderIndex >= _form.Folders.Count) return;
        var files = _form.Folders[folderIndex].Files;
        if (fileIndex >= 0 && fileIndex < files.Count)
        {
            files.RemoveAt(fileIndex);
        }
    }

    private void MoveFile(int folderIndex, int fileIndex, int delta)
    {
        if (_form is null || folderIndex < 0 || folderIndex >= _form.Folders.Count) return;
        var files = _form.Folders[folderIndex].Files;
        var target = fileIndex + delta;
        if (fileIndex < 0 || fileIndex >= files.Count || target < 0 || target >= files.Count) return;
        (files[fileIndex], files[target]) = (files[target], files[fileIndex]);
    }

    // Parallel handlers for the module-folder editor. Same shape as the
    // Core-folder handlers above; the duplication is deliberate so the two
    // editors can expand and reorder independently without sharing state.
    private void AddModuleFolder()
    {
        _form?.ModuleFolders.Add(new FolderRow());
    }

    private void AddRootModuleFolder()
    {
        if (_form is null || _form.ModuleFolders.Any(f => f.IsRoot)) return;
        _form.ModuleFolders.Insert(0, new FolderRow { IsRoot = true });
        var bumped = _expandedModuleFolders.Select(i => i + 1).ToList();
        _expandedModuleFolders.Clear();
        foreach (var i in bumped) _expandedModuleFolders.Add(i);
    }

    private void RemoveModuleFolder(int index)
    {
        if (_form is null) return;
        if (index >= 0 && index < _form.ModuleFolders.Count)
        {
            _form.ModuleFolders.RemoveAt(index);
            _expandedModuleFolders.Clear();
        }
    }

    private void MoveModuleFolder(int index, int delta)
    {
        if (_form is null) return;
        var target = index + delta;
        if (index < 0 || index >= _form.ModuleFolders.Count || target < 0 || target >= _form.ModuleFolders.Count)
        {
            return;
        }
        (_form.ModuleFolders[index], _form.ModuleFolders[target]) = (_form.ModuleFolders[target], _form.ModuleFolders[index]);
        var wasExpandedHere = _expandedModuleFolders.Contains(index);
        var wasExpandedThere = _expandedModuleFolders.Contains(target);
        _expandedModuleFolders.Remove(index);
        _expandedModuleFolders.Remove(target);
        if (wasExpandedHere) _expandedModuleFolders.Add(target);
        if (wasExpandedThere) _expandedModuleFolders.Add(index);
    }

    private bool IsModuleFolderExpanded(int index) => _expandedModuleFolders.Contains(index);

    private void ToggleModuleFolderExpanded(int index)
    {
        if (!_expandedModuleFolders.Add(index))
        {
            _expandedModuleFolders.Remove(index);
        }
    }

    private void AddModuleFile(int folderIndex)
    {
        if (_form is null || folderIndex < 0 || folderIndex >= _form.ModuleFolders.Count) return;
        _form.ModuleFolders[folderIndex].Files.Add(new FileRow());
        _expandedModuleFolders.Add(folderIndex);
    }

    private void RemoveModuleFile(int folderIndex, int fileIndex)
    {
        if (_form is null || folderIndex < 0 || folderIndex >= _form.ModuleFolders.Count) return;
        var files = _form.ModuleFolders[folderIndex].Files;
        if (fileIndex >= 0 && fileIndex < files.Count)
        {
            files.RemoveAt(fileIndex);
        }
    }

    private void MoveModuleFile(int folderIndex, int fileIndex, int delta)
    {
        if (_form is null || folderIndex < 0 || folderIndex >= _form.ModuleFolders.Count) return;
        var files = _form.ModuleFolders[folderIndex].Files;
        var target = fileIndex + delta;
        if (fileIndex < 0 || fileIndex >= files.Count || target < 0 || target >= files.Count) return;
        (files[fileIndex], files[target]) = (files[target], files[fileIndex]);
    }

    private async Task SaveAsync()
    {
        if (_form is null || _saving) return;
        _saving = true;
        _saveError = null;
        _saveSuccess = null;
        _fieldErrors = new Dictionary<string, string>();

        var payload = _form.ToInput();

        try
        {
            if (IsEdit && _existingId is not null)
            {
                await Templates.UpdateAsync(_existingId.Value, payload);
                _saveSuccess = "Saved.";
            }
            else
            {
                await Templates.CreateAsync(payload);
                // Land back on the list so admins can immediately see the new
                // row in context. Editing it further is one click away.
                Nav.NavigateTo("/admin/templates");
                return;
            }
        }
        catch (PlanValidationException ex)
        {
            _fieldErrors = ex.Errors;
            _saveError = $"Couldn't save: {ex.Errors.Count} validation error(s). See messages next to each field.";
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Unexpected error saving template '{Key}'.", payload.Key);
            _saveError = "An unexpected error occurred. The change was not saved.";
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task ConfirmDeleteAsync()
    {
        if (_existingId is null || _saving || _deleteConfirm is null) return;
        if (!await _deleteConfirm.OpenAsync()) return;
        _saving = true;
        try
        {
            await Templates.SoftDeleteAsync(_existingId.Value);
            Nav.NavigateTo("/admin/templates");
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Failed to soft-delete template id={Id}.", _existingId);
            _saveError = "Couldn't delete the template. Check the logs.";
            _saving = false;
        }
    }

    private async Task RestoreAsync()
    {
        if (_existingId is null || _saving) return;
        _saving = true;
        try
        {
            await Templates.RestoreAsync(_existingId.Value);
            _isDeleted = false;
            _saveSuccess = "Template restored.";
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Failed to restore template id={Id}.", _existingId);
            _saveError = "Couldn't restore the template. Check the logs.";
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task SwitchModeAsync(EditorMode mode)
    {
        if (_form is null || _mode == mode || _saving) return;

        if (_mode == EditorMode.Toml && mode == EditorMode.Form)
        {
            // Validate-on-switch: parse what's in the editor and rebuild form
            // state from it. If the TOML doesn't parse, the gutter markers
            // stay visible and we refuse the switch — bidirectional sync only
            // works when both sides agree on the data shape.
            if (!await TryHydrateFormFromEditorAsync())
            {
                return;
            }
        }
        else if (_mode == EditorMode.Form && mode == EditorMode.Toml)
        {
            // Form → TOML: render the current form state. The TOML doc
            // becomes the source of truth from this point until the next
            // switch back; the editor's pristine baseline is reset by the
            // setValue call OnAfterRenderAsync issues when _toml changes.
            _toml = BuildTomlFromFormState();
            _tomlIssues = new();
        }

        _mode = mode;
        _saveError = null;
        _saveSuccess = null;
        _fieldErrors = new Dictionary<string, string>();
    }

    private async Task RefreshPreviewAsync()
    {
        if (_form is null || _saving) return;
        // Same parse + rebuild path the mode switch uses, just without the
        // mode flip. Successful parses update _form so the preview re-reads
        // it on the next render; failures populate _tomlIssues for the
        // gutter and leave the preview as-is.
        if (await TryHydrateFormFromEditorAsync())
        {
            _saveError = null;
            _saveSuccess = "Preview refreshed.";
        }
    }

    /// <summary>
    /// Pulls the current TOML out of the editor, parses it, and rebuilds
    /// <see cref="_form"/> from the result. Returns <c>false</c> (and surfaces
    /// the parse issues to the caller's UI state) when the TOML is malformed,
    /// so the caller can refuse the mode switch.
    /// </summary>
    private async Task<bool> TryHydrateFormFromEditorAsync()
    {
        if (_form is null) return false;

        if (_editorId != 0 && _editorModule is not null)
        {
            try
            {
                _toml = await _editorModule.InvokeAsync<string>("getValue", _editorId);
                _editorMountedToml = _toml;
            }
            catch (Exception ex)
            {
                Log.LogWarning(ex, "Failed to read TOML value from editor on mode switch.");
                _saveError = "Couldn't read the editor contents. Try again or refresh.";
                return false;
            }
        }

        try
        {
            var parsed = TemplateTomlMapper.FromToml(_toml, deprecated: _form.Deprecated);
            _form = FormState.FromInput(parsed, _form.Deprecated);
            _tomlIssues = new();
            _saveError = null;
            return true;
        }
        catch (TomlParseException ex)
        {
            _tomlIssues = ex.Issues.ToList();
            _editorIssueSyncPending = true;
            _saveError = _tomlIssues.Count == 1
                ? $"TOML parse error on line {_tomlIssues[0].Line}. Fix it to refresh the preview or switch to the form view."
                : $"TOML parse error: {_tomlIssues.Count} issue(s). See gutter markers — fix them to refresh the preview or switch to the form view.";
            return false;
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Unexpected error parsing TOML.");
            _saveError = "Couldn't parse the TOML. Fix the issue, or save anyway from the TOML view.";
            return false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_form is null) return;

        // Tear down first so a mode flip in the same render doesn't leak the
        // previous editor instance.
        if (_mode != EditorMode.Toml && _editorId != 0)
        {
            await DisposeEditorAsync();
        }

        if (_mode == EditorMode.Toml && _editorId == 0 && !_editorMounting)
        {
            _editorMounting = true;
            try
            {
                _editorModule ??= await JS.InvokeAsync<IJSObjectReference>(
                    "import", "./Components/Pages/Admin/AdminTemplateEdit.razor.js");
                _editorId = await _editorModule.InvokeAsync<int>("mount", _tomlContainer, _toml);
                _editorMountedToml = _toml;
                if (_tomlIssues.Count > 0)
                {
                    _editorIssueSyncPending = true;
                }
            }
            catch (Exception ex)
            {
                Log.LogError(ex, "Failed to mount the CodeMirror TOML editor.");
                return;
            }
            finally
            {
                _editorMounting = false;
            }
        }

        if (_mode == EditorMode.Toml && _editorId != 0 && _editorModule is not null)
        {
            if (_editorMountedToml != _toml)
            {
                await _editorModule.InvokeVoidAsync("setValue", _editorId, _toml);
                _editorMountedToml = _toml;
            }

            if (_editorIssueSyncPending)
            {
                _editorIssueSyncPending = false;
                var payload = _tomlIssues
                    .Select(i => new { line = i.Line, message = i.Message, severity = "error" })
                    .ToArray();
                await _editorModule.InvokeVoidAsync("setIssues", _editorId, payload);
            }
        }
    }

    private async Task DisposeEditorAsync()
    {
        if (_editorId == 0 || _editorModule is null) return;
        try
        {
            await _editorModule.InvokeVoidAsync("dispose", _editorId);
        }
        catch (JSDisconnectedException)
        {
            // Circuit gone — JS already cleaned up.
        }
        catch (Exception ex)
        {
            Log.LogWarning(ex, "Disposing the CodeMirror TOML editor failed.");
        }
        finally
        {
            _editorId = 0;
            _editorMountedToml = string.Empty;
        }
    }

    public async ValueTask DisposeAsync()
    {
        _locationChangingRegistration?.Dispose();
        _locationChangingRegistration = null;
        await DisposeEditorAsync();
        if (_editorModule is not null)
        {
            try
            {
                await _editorModule.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
                // Circuit already gone.
            }
            catch (Exception ex)
            {
                Log.LogWarning(ex, "Disposing the editor module failed.");
            }
            _editorModule = null;
        }
    }

    private string ModeButtonClass(EditorMode mode) =>
        _mode == mode ? "btn btn--sm admin-template-edit__mode-btn admin-template-edit__mode-btn--active"
                      : "btn btn--sm admin-template-edit__mode-btn";

    /// <summary>
    /// Builds a TOML view of the current in-memory form state. We round-trip
    /// through <see cref="TemplateInput"/> so the same JSON parsing behaviour
    /// is exercised in both modes — i.e. the TOML you see is the TOML the
    /// service would produce after parsing whatever JSON sat in the textareas.
    /// </summary>
    private string BuildTomlFromFormState()
    {
        if (_form is null) return string.Empty;
        try
        {
            var defaults = string.IsNullOrWhiteSpace(_form.DefaultsJson)
                ? new TemplateDefaults()
                : JsonSerializer.Deserialize<TemplateDefaults>(_form.DefaultsJson) ?? new TemplateDefaults();

            var stub = new RuntimeTemplate
            {
                Key = _form.Key,
                Runtime = _form.Runtime,
                Name = _form.Name,
                Description = _form.Description,
                DefaultApplication = _form.DefaultApplication,
                DefaultPlatform = _form.DefaultPlatform,
                Defaults = defaults,
                CoreIdRangeFrom = _form.CoreIdRangeFrom,
                CoreIdRangeTo = _form.CoreIdRangeTo,
                ModuleIdRangeStart = _form.ModuleIdRangeStart,
                ModuleIdRangeSize = _form.ModuleIdRangeSize,
                Deprecated = _form.Deprecated,
                Folders = _form.Folders.Select((f, i) => new TemplateFolder
                {
                    Ordering = i,
                    Path = f.Path,
                    Files = f.Files.Select((file, fi) => new TemplateFile
                    {
                        Ordering = fi,
                        Path = file.Path,
                        Content = file.Content,
                        IsExample = file.IsExample,
                    }).ToList(),
                }).ToList(),
                ModuleFolders = _form.ModuleFolders.Select((f, i) => new TemplateModuleFolder
                {
                    Ordering = i,
                    Path = f.Path,
                    Files = f.Files.Select((file, fi) => new TemplateModuleFile
                    {
                        Ordering = fi,
                        Path = file.Path,
                        Content = file.Content,
                        IsExample = file.IsExample,
                    }).ToList(),
                }).ToList(),
                DefaultModules = _form.DefaultModuleKeys
                    .Select((k, i) => new RuntimeTemplateDefaultModule
                    {
                        Ordering = i,
                        Module = new ALDevToolbox.Domain.Entities.Module { Key = k },
                    })
                    .ToList(),
                DefaultApplicationVersion = string.IsNullOrWhiteSpace(_form.DefaultApplicationVersionKey)
                    ? null
                    : new ApplicationVersion { Key = _form.DefaultApplicationVersionKey },
            };
            return TemplateTomlMapper.ToToml(stub);
        }
        catch (JsonException ex)
        {
            return $"# Could not render TOML — Defaults JSON is invalid:\n# {ex.Message}\n";
        }
    }

    /// <summary>
    /// Folder-tree preview for the right column. Reflects only what's declared
    /// in the template itself: Core uses the Core folder list; a representative
    /// <c>Module</c> entry is added only when module folders are declared. The
    /// generator's unconditional scaffolding (<c>libs</c>, <c>permissionsets</c>,
    /// <c>Translations</c>) is *not* drawn here — admins start from a non-empty
    /// template (see <see cref="TemplateTomlMapper.DefaultFolderPaths"/>), so
    /// those folders are visible because the template declares them, not
    /// because the preview synthesises them. The preview is always built from
    /// <c>_form</c>; in TOML mode it reflects the last validated form state
    /// rather than each keystroke (a switch back to Form parses and refreshes).
    /// </summary>
    private PreviewNode BuildPreview()
    {
        if (_form is null)
        {
            return PreviewNode.Folder("(no template)");
        }

        var rootName = string.IsNullOrWhiteSpace(_form.Key) ? "template" : _form.Key;

        var children = new List<PreviewNode>
        {
            BuildExtensionPreview("Core", _form.Folders),
        };
        if (_form.ModuleFolders.Count > 0)
        {
            children.Add(BuildExtensionPreview("Module", _form.ModuleFolders));
        }

        return PreviewTreeBuilder.SortForDisplay(
            new PreviewNode(rootName, PreviewNodeKind.Workspace, children));
    }

    private static PreviewNode BuildExtensionPreview(string name, IReadOnlyList<FolderRow> folders)
    {
        // app.json is always emitted (built from template metadata at
        // generation time). AppSourceCop.json no longer is — admins declare
        // it as a file under a folder with an empty path, the same way they
        // would any other root-level file. The preview surfaces those root
        // files alongside app.json so the layout matches the eventual ZIP.
        var contents = new List<PreviewNode>
        {
            PreviewNode.File("app.json"),
        };

        // Root-folder files land at the extension root, not in a subfolder.
        foreach (var rootFolder in folders.Where(f => string.IsNullOrEmpty(f.Path)))
        {
            foreach (var file in rootFolder.Files.Where(x => !string.IsNullOrWhiteSpace(x.Path)))
            {
                contents.Add(PreviewNode.File(file.Path));
            }
        }

        var entries = folders
            .Where(f => !string.IsNullOrWhiteSpace(f.Path))
            .Select(f =>
            {
                var leaves = f.Files.Count == 0
                    ? (IReadOnlyList<PreviewNode>)new[] { PreviewNode.File(".gitkeep") }
                    : f.Files
                        .Where(file => !string.IsNullOrWhiteSpace(file.Path))
                        .Select(file => PreviewNode.File(file.Path))
                        .ToList();
                return (f.Path, leaves);
            });
        contents.AddRange(PreviewTreeBuilder.BuildFolderChildren(entries));

        return PreviewNode.Extension(name, contents);
    }

    private async Task SaveTomlAsync()
    {
        if (_form is null || _saving) return;
        _saving = true;
        _saveError = null;
        _saveSuccess = null;
        _fieldErrors = new Dictionary<string, string>();
        _tomlIssues = new();

        // Pull the latest text from CodeMirror; the editor doesn't two-way
        // bind to _toml, so a stale value here would silently save the
        // pre-edit document.
        if (_editorId != 0 && _editorModule is not null)
        {
            try
            {
                _toml = await _editorModule.InvokeAsync<string>("getValue", _editorId);
                _editorMountedToml = _toml;
            }
            catch (Exception ex)
            {
                Log.LogError(ex, "Failed to read TOML value from editor before save.");
                _saveError = "Couldn't read the editor contents. Try again or refresh.";
                _saving = false;
                return;
            }
        }

        try
        {
            var payload = TemplateTomlMapper.FromToml(_toml, deprecated: _form.Deprecated);

            if (IsEdit && _existingId is not null)
            {
                await Templates.UpdateAsync(_existingId.Value, payload);
                var refreshed = await Templates.GetByKeyAsync(Key!);
                if (refreshed is not null)
                {
                    _form = FormState.From(refreshed);
                    _toml = TemplateTomlMapper.ToToml(refreshed);
                    _editorMountedToml = _toml;
                    if (_editorId != 0 && _editorModule is not null)
                    {
                        // setValue resets the editor's pristine baseline, so
                        // markPristine here is mostly belt-and-braces — but
                        // it also covers the case where the refreshed TOML
                        // matches the editor doc exactly (setValue early-outs
                        // and dirty would otherwise stay set).
                        await _editorModule.InvokeVoidAsync("setValue", _editorId, _toml);
                        await _editorModule.InvokeVoidAsync("markPristine", _editorId);
                    }
                }
                _saveSuccess = "Saved from TOML.";
            }
            else
            {
                await Templates.CreateAsync(payload);
                if (_editorId != 0 && _editorModule is not null)
                {
                    // The follow-up navigation is in-app and would trip the
                    // location-changing guard if the editor is still dirty.
                    await _editorModule.InvokeVoidAsync("markPristine", _editorId);
                }
                // Back to the list so the admin sees the new row in context.
                Nav.NavigateTo("/admin/templates");
                return;
            }
        }
        catch (TomlParseException ex)
        {
            _tomlIssues = ex.Issues.ToList();
            _editorIssueSyncPending = true;
            _saveError = _tomlIssues.Count == 1
                ? $"TOML parse error on line {_tomlIssues[0].Line}."
                : $"TOML parse error: {_tomlIssues.Count} issue(s). See gutter markers.";
        }
        catch (InvalidDataException ex)
        {
            _saveError = ex.Message;
        }
        catch (PlanValidationException ex)
        {
            _fieldErrors = ex.Errors;
            _saveError = $"Couldn't save: {ex.Errors.Count} validation error(s).";
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Unexpected error saving template from TOML.");
            _saveError = "An unexpected error occurred. The change was not saved.";
        }
        finally
        {
            _saving = false;
        }
    }

    /// <summary>
    /// Mutable form-state mirror of <see cref="TemplateInput"/>. Lives in the
    /// page so Razor's <c>@bind</c> can write into individual fields without
    /// the per-keystroke record allocations a record-based form would need.
    /// </summary>
    private sealed class FormState
    {
        public string Key { get; set; } = string.Empty;
        public string Runtime { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public string DefaultApplication { get; set; } = string.Empty;
        public string DefaultPlatform { get; set; } = "1.0.0.0";
        public string DefaultsJson { get; set; } = string.Empty;
        public int CoreIdRangeFrom { get; set; }
        public int CoreIdRangeTo { get; set; }
        public int ModuleIdRangeStart { get; set; }
        public int ModuleIdRangeSize { get; set; }
        public bool Deprecated { get; set; }
        public List<FolderRow> Folders { get; } = new();

        /// <summary>
        /// Folders emitted into every generated module extension. Empty by
        /// default — modules then ship with just app.json and the static
        /// fallback folders until an admin opts in to extra scaffolding.
        /// </summary>
        public List<FolderRow> ModuleFolders { get; } = new();

        /// <summary>
        /// Keys of modules pre-selected on the New Workspace form when this
        /// template is picked. Order matters; the multi-select renders rows
        /// in this order so admins can curate the visual hierarchy.
        /// </summary>
        public List<string> DefaultModuleKeys { get; } = new();

        /// <summary>
        /// Optional curated application-version key (Milestone P2.4). Empty
        /// string means "no curated entry"; the form's free-text
        /// DefaultApplication / runtime values are used at generation time.
        /// </summary>
        public string DefaultApplicationVersionKey { get; set; } = string.Empty;

        public static FormState Blank()
        {
            var state = new FormState
            {
                DefaultsJson = JsonSerializer.Serialize(new TemplateDefaults(), PrettyJson),
                CoreIdRangeFrom = 90000,
                CoreIdRangeTo = 90999,
                ModuleIdRangeStart = 91000,
                ModuleIdRangeSize = 200,
            };
            // Root folder (path = "") seeds an empty AppSourceCop.json
            // example file so new templates emit it by default. Admins can
            // delete the row for per-tenant extensions that don't need it.
            var rootCore = new FolderRow { Path = string.Empty, IsRoot = true };
            rootCore.Files.Add(new FileRow
            {
                Path = "AppSourceCop.json",
                Content = TemplateTomlMapper.DefaultAppSourceCopJson,
            });
            state.Folders.Add(rootCore);
            foreach (var path in TemplateTomlMapper.DefaultFolderPaths)
            {
                state.Folders.Add(new FolderRow { Path = path });
                state.ModuleFolders.Add(new FolderRow { Path = path });
            }
            return state;
        }

        public static FormState From(RuntimeTemplate template)
        {
            var state = new FormState
            {
                Key = template.Key,
                Runtime = template.Runtime,
                Name = template.Name,
                Description = template.Description,
                DefaultApplication = template.DefaultApplication,
                DefaultPlatform = template.DefaultPlatform,
                DefaultsJson = JsonSerializer.Serialize(template.Defaults, PrettyJson),
                CoreIdRangeFrom = template.CoreIdRangeFrom,
                CoreIdRangeTo = template.CoreIdRangeTo,
                ModuleIdRangeStart = template.ModuleIdRangeStart,
                ModuleIdRangeSize = template.ModuleIdRangeSize,
                Deprecated = template.Deprecated,
                DefaultApplicationVersionKey = template.DefaultApplicationVersion?.Key ?? string.Empty,
            };
            foreach (var f in template.Folders.OrderBy(f => f.Ordering))
            {
                var folderRow = new FolderRow { Path = f.Path, IsRoot = string.IsNullOrEmpty(f.Path) };
                foreach (var file in f.Files.OrderBy(x => x.Ordering))
                {
                    folderRow.Files.Add(new FileRow { Path = file.Path, Content = file.Content, IsExample = file.IsExample });
                }
                state.Folders.Add(folderRow);
            }
            foreach (var f in template.ModuleFolders.OrderBy(f => f.Ordering))
            {
                var folderRow = new FolderRow { Path = f.Path, IsRoot = string.IsNullOrEmpty(f.Path) };
                foreach (var file in f.Files.OrderBy(x => x.Ordering))
                {
                    folderRow.Files.Add(new FileRow { Path = file.Path, Content = file.Content, IsExample = file.IsExample });
                }
                state.ModuleFolders.Add(folderRow);
            }
            foreach (var d in template.DefaultModules.OrderBy(d => d.Ordering))
            {
                if (d.Module is not null)
                {
                    state.DefaultModuleKeys.Add(d.Module.Key);
                }
            }
            return state;
        }

        /// <summary>
        /// Mirror of <see cref="From"/> for the TOML → Form switch path:
        /// hydrates a fresh <see cref="FormState"/> directly from the parsed
        /// <see cref="TemplateInput"/>. The two builders converge on the same
        /// shape so a switch round-trip is lossless apart from anything the
        /// TOML schema deliberately omits (the Deprecated flag).
        /// </summary>
        public static FormState FromInput(TemplateInput input, bool currentDeprecated)
        {
            var state = new FormState
            {
                Key = input.Key,
                Runtime = input.Runtime,
                Name = input.Name,
                Description = input.Description,
                DefaultApplication = input.DefaultApplication,
                DefaultPlatform = input.DefaultPlatform,
                DefaultsJson = string.IsNullOrWhiteSpace(input.DefaultsJson)
                    ? JsonSerializer.Serialize(new TemplateDefaults(), PrettyJson)
                    : Reformat(input.DefaultsJson, JsonSerializer.Serialize(new TemplateDefaults(), PrettyJson)),
                CoreIdRangeFrom = input.CoreIdRangeFrom,
                CoreIdRangeTo = input.CoreIdRangeTo,
                ModuleIdRangeStart = input.ModuleIdRangeStart,
                ModuleIdRangeSize = input.ModuleIdRangeSize,
                // TOML doesn't carry Deprecated (see TemplateTomlMapper.ToToml);
                // preserve the structured form's value rather than zeroing it.
                Deprecated = currentDeprecated,
                DefaultApplicationVersionKey = input.DefaultApplicationVersionKey ?? string.Empty,
            };
            foreach (var f in input.Folders)
            {
                var folderRow = new FolderRow { Path = f.Path, IsRoot = string.IsNullOrEmpty(f.Path) };
                foreach (var file in f.Files)
                {
                    folderRow.Files.Add(new FileRow { Path = file.Path, Content = file.Content, IsExample = file.IsExample });
                }
                state.Folders.Add(folderRow);
            }
            foreach (var f in input.ModuleFolders)
            {
                var folderRow = new FolderRow { Path = f.Path, IsRoot = string.IsNullOrEmpty(f.Path) };
                foreach (var file in f.Files)
                {
                    folderRow.Files.Add(new FileRow { Path = file.Path, Content = file.Content, IsExample = file.IsExample });
                }
                state.ModuleFolders.Add(folderRow);
            }
            foreach (var key in input.DefaultModuleKeys)
            {
                state.DefaultModuleKeys.Add(key);
            }
            return state;
        }

        // Round-trip the JSON through the pretty-printer so the form's
        // textareas show the same indentation regardless of how the TOML
        // mapper serialised it. Falls back to the supplied default on
        // anything we can't re-parse, which is more useful to the user
        // than a stack trace at switch time.
        private static string Reformat(string json, string fallback)
        {
            try
            {
                using var doc = JsonDocument.Parse(json);
                return JsonSerializer.Serialize(doc.RootElement, PrettyJson);
            }
            catch (JsonException)
            {
                return fallback;
            }
        }

        public TemplateInput ToInput() => new(
            Key: Key,
            Runtime: Runtime,
            Name: Name,
            Description: Description,
            DefaultApplication: DefaultApplication,
            DefaultPlatform: DefaultPlatform,
            DefaultsJson: DefaultsJson,
            CoreIdRangeFrom: CoreIdRangeFrom,
            CoreIdRangeTo: CoreIdRangeTo,
            ModuleIdRangeStart: ModuleIdRangeStart,
            ModuleIdRangeSize: ModuleIdRangeSize,
            Deprecated: Deprecated,
            DefaultModuleKeys: DefaultModuleKeys.ToList(),
            Folders: Folders.Select(f => new TemplateFolderInput(
                f.Path,
                f.Files.Select(x => new TemplateFileInput(x.Path, x.Content, x.IsExample)).ToList())).ToList(),
            ModuleFolders: ModuleFolders.Select(f => new TemplateFolderInput(
                f.Path,
                f.Files.Select(x => new TemplateFileInput(x.Path, x.Content, x.IsExample)).ToList())).ToList(),
            DefaultApplicationVersionKey: string.IsNullOrWhiteSpace(DefaultApplicationVersionKey)
                ? null
                : DefaultApplicationVersionKey);
    }

    private sealed class FolderRow
    {
        public string Path { get; set; } = string.Empty;

        /// <summary>
        /// UI-only marker for "this row represents the extension root, not
        /// a subfolder". Set true by the "Add root folder" button and by the
        /// loader when an entity row's <see cref="TemplateFolder.Path"/> is
        /// empty; the path field is rendered as a static label rather than
        /// an editable input. Carries no state across save — on submit the
        /// row's Path is used as-is (empty for root rows).
        /// </summary>
        public bool IsRoot { get; set; }

        public List<FileRow> Files { get; } = new();
    }

    private sealed class FileRow
    {
        public string Path { get; set; } = string.Empty;
        public string Content { get; set; } = string.Empty;
        public bool IsExample { get; set; }
    }
}
