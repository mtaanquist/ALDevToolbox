@page "/admin/configuration/logo"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@inject OrganizationConfigService Config
@inject NavigationManager Nav
@inject ILogger<AdminConfigurationLogo> Log
@using ALDevToolbox.Domain.Entities
@using ALDevToolbox.Domain.ValueObjects
@using Microsoft.AspNetCore.Components.Forms

@*
    Logo sub-page (Issue #61). Upload, replace or remove the per-organisation
    logo bundled into every generated workspace. Pending uploads stay in memory
    until Save commits them, mirroring the original combined page.
*@

<PageTitle>Logo · Configuration · AL Dev Toolbox</PageTitle>

<div class="admin-page admin-configuration">
    <header class="admin-page__header">
        <div>
            <h1>Logo</h1>
            <p class="muted">
                Bundled into every generated workspace under
                <code>.assets/images/logo.&lt;ext&gt;</code>. SVG and PNG only;
                max @(OrganizationConfigService.MaxLogoBytes / 1024) KB. SVG
                uploads have <code>&lt;script&gt;</code> tags and
                <code>on*</code> attributes stripped on save.
            </p>
        </div>
        <div class="admin-page__header-actions">
            <a class="btn btn--sm" href="/admin">
                <Icon Name="arrow-left" Width="14" Height="14" />
                <span>Back to admin</span>
            </a>
            <button type="button" class="btn btn--sm btn--primary"
                    @onclick="SaveAsync"
                    disabled="@(_saving || !IsDirty)">
                <Icon Name="save" Width="14" Height="14" />
                <span>@(_saving ? "Saving…" : "Save changes")</span>
            </button>
        </div>
    </header>

    @if (_loading)
    {
        <p class="muted">Loading…</p>
    }
    else
    {
        @if (!string.IsNullOrEmpty(_okMessage))
        {
            <p class="form-success" role="status">@_okMessage</p>
        }
        @if (!string.IsNullOrEmpty(_errMessage))
        {
            <div class="form-error" role="alert"><p>@_errMessage</p></div>
        }

        <section class="admin-section">
            <div class="logo-preview">
                @if (_pendingLogoBytes is not null)
                {
                    <p class="muted">New logo selected (@_pendingLogoFileName). Click <strong>Save changes</strong> to apply.</p>
                }
                else if (_removeLogo)
                {
                    <p class="muted">Logo will be removed on save.</p>
                }
                else if (_logo is not null)
                {
                    <img src="/admin/configuration/logo/preview?t=@_logoCacheBust" alt="Current logo" class="logo-preview__img" />
                }
                else
                {
                    <p class="muted">No logo configured. Generated workspaces will ship without one.</p>
                }
            </div>

            <div class="form-grid form-grid--narrow">
                <section class="form-section">
                    <label class="section-label" for="cfg-logo">Replace logo</label>
                    <label class="btn btn--sm logo-upload__button">
                        <Icon Name="upload" Width="14" Height="14" />
                        <span>Choose file…</span>
                        <InputFile id="cfg-logo" OnChange="OnLogoChosen" accept="image/png,image/svg+xml" class="logo-upload__input" />
                    </label>
                </section>
                @if (_logo is not null || _pendingLogoBytes is not null)
                {
                    <div class="form-actions">
                        <button type="button" class="btn btn--sm" @onclick="MarkLogoForRemoval" disabled="@_removeLogo">
                            <Icon Name="trash-2" Width="14" Height="14" />
                            <span>Remove logo</span>
                        </button>
                        @if (_pendingLogoBytes is not null || _removeLogo)
                        {
                            <button type="button" class="btn btn--sm" @onclick="ResetLogoChanges">
                                <Icon Name="rotate-ccw" Width="14" Height="14" />
                                <span>Revert pending logo change</span>
                            </button>
                        }
                    </div>
                }
            </div>
        </section>
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "ok")] public string? OkParam { get; set; }

    private bool _loading = true;
    private bool _saving;
    private string? _okMessage;
    private string? _errMessage;
    private OrganizationAsset? _logo;

    private byte[]? _pendingLogoBytes;
    private string? _pendingLogoContentType;
    private string? _pendingLogoFileName;
    private bool _removeLogo;
    private long _logoCacheBust = DateTimeOffset.UtcNow.ToUnixTimeSeconds();

    private bool IsDirty => _pendingLogoBytes is not null || _removeLogo;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        _okMessage = OkParam == "saved" ? "Logo saved." : null;
    }

    private async Task LoadAsync()
    {
        var config = await Config.GetCurrentAsync();
        _logo = config.Logo;
        _pendingLogoBytes = null;
        _pendingLogoContentType = null;
        _pendingLogoFileName = null;
        _removeLogo = false;
        _logoCacheBust = DateTimeOffset.UtcNow.ToUnixTimeSeconds();
        _loading = false;
    }

    private async Task OnLogoChosen(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;
        if (file.Size > OrganizationConfigService.MaxLogoBytes)
        {
            _errMessage = $"Logo must be {OrganizationConfigService.MaxLogoBytes / 1024} KB or smaller.";
            return;
        }
        try
        {
            await using var stream = file.OpenReadStream(OrganizationConfigService.MaxLogoBytes);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            _pendingLogoBytes = ms.ToArray();
            _pendingLogoContentType = file.ContentType;
            _pendingLogoFileName = file.Name;
            _removeLogo = false;
            _errMessage = null;
        }
        catch (Exception ex)
        {
            Log.LogWarning(ex, "Failed to read uploaded logo '{Name}'.", file.Name);
            _errMessage = $"Could not read the file: {ex.Message}";
        }
    }

    private void MarkLogoForRemoval()
    {
        _removeLogo = true;
        _pendingLogoBytes = null;
        _pendingLogoContentType = null;
        _pendingLogoFileName = null;
    }

    private void ResetLogoChanges()
    {
        _pendingLogoBytes = null;
        _pendingLogoContentType = null;
        _pendingLogoFileName = null;
        _removeLogo = false;
    }

    private async Task SaveAsync()
    {
        if (_saving || !IsDirty) return;
        _saving = true;
        _errMessage = null;
        _okMessage = null;
        try
        {
            if (_removeLogo)
            {
                await Config.RevertLogoAsync();
            }
            else if (_pendingLogoBytes is not null)
            {
                await Config.UploadLogoAsync(_pendingLogoContentType ?? string.Empty, _pendingLogoBytes);
            }
            Nav.NavigateTo("/admin/configuration/logo?ok=saved", forceLoad: true);
        }
        catch (PlanValidationException ex)
        {
            _errMessage = ex.Errors.FirstOrDefault().Value ?? "Validation failed.";
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Failed to save organisation logo.");
            _errMessage = "An unexpected error occurred. The change was not saved.";
        }
        finally
        {
            _saving = false;
        }
    }
}
