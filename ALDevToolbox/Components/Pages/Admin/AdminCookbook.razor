@page "/admin/cookbook"
@attribute [Authorize(Roles = "Admin,Editor")]
@rendermode InteractiveServer
@inject RecipeService Recipes
@inject RecipeSuggestionService Suggestions
@inject OrganizationConfigService Config
@inject NavigationManager Nav
@inject ILogger<AdminCookbook> Log
@using ALDevToolbox.Domain.Entities
@using ALDevToolbox.Domain.ValueObjects
@using ALDevToolbox.Services
@using static ALDevToolbox.Components.Shared.AdminPageHelpers

<PageTitle>Cookbook · Admin · AL Dev Toolbox</PageTitle>

<div class="admin-page">
    <header class="admin-page__header">
        <div>
            <h1>Cookbook</h1>
            <p class="muted">
                Curate the recipe library for this organisation. End users see
                the published list at <code>/cookbook</code>; user-submitted
                suggestions appear in the queue below.
            </p>
        </div>
        <a class="btn btn--sm" href="/admin">
            <Icon Name="arrow-left" Width="14" Height="14" />
            <span>Back to admin</span>
        </a>
    </header>

    <div class="admin-page__toolbar">
        <label class="check-row">
            <input type="checkbox" @bind="_showDeleted" @bind:after="ReloadAsync" />
            <span>Show soft-deleted</span>
        </label>
    </div>

    @if (!string.IsNullOrEmpty(_lastError))
    {
        <p class="form-error" role="alert">@_lastError</p>
    }
    @if (!string.IsNullOrEmpty(_lastSuccess))
    {
        <p class="form-success" role="status">@_lastSuccess</p>
    }

    @if (_rows is null)
    {
        <p class="muted">Loading...</p>
    }
    else if (_rows.Count == 0)
    {
        <p class="muted">No recipes yet. Click <strong>New recipe</strong> below to create one.</p>
    }
    else
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Type</th>
                    <th>Files</th>
                    <th>Keywords</th>
                    <th>Status</th>
                    <th>Last updated (UTC)</th>
                    <th class="data-table__actions"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in _rows)
                {
                    <tr class="@(s.DeletedAt is not null ? "data-table__row--muted" : null)">
                        <td>@s.Title</td>
                        <td>@s.Type</td>
                        <td>@s.Files.Count</td>
                        <td class="muted">@s.Keywords</td>
                        <td>@SoftDeleteStatus(s.DeletedAt, s.Deprecated)</td>
                        <td><time datetime="@s.UpdatedAt.ToString("O")">@s.UpdatedAt.ToString("yyyy-MM-dd HH:mm:ss")</time></td>
                        <td class="data-table__actions">
                            <a class="btn btn--sm" href="@($"/admin/cookbook/{s.Id}")">
                                <Icon Name="pencil" Width="14" Height="14" />
                                <span>Edit</span>
                            </a>
                            @if (s.DeletedAt is null)
                            {
                                <button type="button" class="btn btn--sm" @onclick="() => SetDeprecatedAsync(s, !s.Deprecated)" disabled="@_busy">
                                    <Icon Name="@(s.Deprecated ? "archive-restore" : "archive")" Width="14" Height="14" />
                                    <span>@(s.Deprecated ? "Un-deprecate" : "Deprecate")</span>
                                </button>
                                <button type="button" class="btn btn--sm btn--danger" @onclick="() => DeleteClickAsync(s)" disabled="@_busy">
                                    <Icon Name="trash-2" Width="14" Height="14" />
                                    <span>@(_pendingDeleteId == s.Id ? "Confirm?" : "Delete")</span>
                                </button>
                            }
                            else
                            {
                                <button type="button" class="btn btn--sm" @onclick="() => RestoreAsync(s)" disabled="@_busy">
                                    <Icon Name="rotate-ccw" Width="14" Height="14" />
                                    <span>Restore</span>
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <div class="admin-page__footer-actions">
        <a class="btn btn--primary" href="/admin/cookbook/new">
            <Icon Name="plus" Width="16" Height="16" />
            <span>New recipe</span>
        </a>
    </div>

    <section class="admin-section">
        <h2>Cookbook authoring guidance</h2>
        <p class="muted">
            Shown to MCP agents by the <code>get_cookbook_guidance</code> tool
            before they call <code>suggest_recipe</code>. Document the
            conventions you want submitted recipes to follow - naming, prefixes,
            preferred event-subscriber style, anything specific to this
            organisation. Markdown. Built-in descriptions of each recipe Type
            are appended automatically.
        </p>
        <div class="form-grid form-grid--narrow">
            <section class="form-section">
                <textarea id="cookbook-guidance" rows="10" maxlength="@OrganizationConfigService.MaxCookbookGuidanceLength"
                          @bind="_guidance" @bind:event="oninput"
                          placeholder="Recipes in this organisation use the 'CRONUS' prefix on every object name. Pattern recipes should include a setup permission set. ..."></textarea>
                <FieldError Field="CookbookGuidance" Errors="_guidanceErrors" />
            </section>
        </div>
        <div class="form-actions">
            <button type="button" class="btn btn--primary"
                    @onclick="SaveGuidanceAsync"
                    disabled="@(_savingGuidance || _guidance == _guidanceBaseline)">
                <Icon Name="save" Width="14" Height="14" />
                <span>@(_savingGuidance ? "Saving..." : "Save guidance")</span>
            </button>
        </div>
    </section>

    <section class="admin-section">
        <h2>Suggestions</h2>
        <p class="muted">
            Drafts submitted by users awaiting review. Open one to approve or
            reject it.
        </p>
        @if (_suggestions is null)
        {
            <p class="muted">Loading...</p>
        }
        else if (_suggestions.Count == 0)
        {
            <p class="muted">No pending suggestions.</p>
        }
        else
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Type</th>
                        <th>Submitted by</th>
                        <th>Files</th>
                        <th>Submitted (UTC)</th>
                        <th class="data-table__actions"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in _suggestions)
                    {
                        <tr>
                            <td>@s.Title</td>
                            <td>@s.Type</td>
                            <td class="muted">@(s.SuggestedByUser?.DisplayName ?? "unknown user")</td>
                            <td>@s.Files.Count</td>
                            <td><time datetime="@s.RequestedAt.ToString("O")">@s.RequestedAt.ToString("yyyy-MM-dd HH:mm:ss")</time></td>
                            <td class="data-table__actions">
                                <a class="btn btn--sm" href="@($"/admin/cookbook/suggestions?focus={s.Id}")">
                                    <Icon Name="inbox" Width="14" Height="14" />
                                    <span>Review</span>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>
</div>

@code {
    private bool _showDeleted;
    private List<Recipe>? _rows;
    private List<RecipeSuggestion>? _suggestions;
    private bool _busy;
    private string? _lastError;
    private string? _lastSuccess;
    // First press arms the row; second press on the same row commits the
    // delete. Switching to a different row resets the arming.
    private int? _pendingDeleteId;

    private string _guidance = string.Empty;
    private string _guidanceBaseline = string.Empty;
    private bool _savingGuidance;
    private IReadOnlyDictionary<string, string>? _guidanceErrors;

    protected override async Task OnInitializedAsync()
    {
        var config = await Config.GetCurrentAsync();
        _guidance = _guidanceBaseline = config.Settings.CookbookGuidance ?? string.Empty;
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _rows = await Recipes.GetAllForAdminAsync(includeDeleted: _showDeleted);
        _suggestions = await Suggestions.GetPendingAsync();
    }

    private async Task DeleteClickAsync(Recipe s)
    {
        if (_pendingDeleteId != s.Id)
        {
            _pendingDeleteId = s.Id;
            return;
        }
        _pendingDeleteId = null;
        await RunActionAsync(() => Recipes.SoftDeleteAsync(s.Id), $"Recipe '{s.Title}' deleted.");
    }

    private async Task RestoreAsync(Recipe s)
    {
        await RunActionAsync(() => Recipes.RestoreAsync(s.Id), $"Recipe '{s.Title}' restored.");
    }

    private async Task SetDeprecatedAsync(Recipe s, bool deprecated)
    {
        var label = deprecated ? "deprecated" : "un-deprecated";
        await RunActionAsync(() => Recipes.SetDeprecatedAsync(s.Id, deprecated), $"Recipe '{s.Title}' {label}.");
    }

    private async Task RunActionAsync(Func<Task> action, string successMessage)
    {
        if (_busy) return;
        _busy = true;
        _lastError = null;
        _lastSuccess = null;
        _pendingDeleteId = null;
        try
        {
            await action();
            _lastSuccess = successMessage;
            await ReloadAsync();
        }
        catch (PlanValidationException ex)
        {
            _lastError = ex.Errors.FirstOrDefault().Value ?? "Validation failed.";
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Cookbook admin action failed.");
            _lastError = "An unexpected error occurred. The change was not saved.";
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task SaveGuidanceAsync()
    {
        if (_savingGuidance) return;
        _savingGuidance = true;
        _guidanceErrors = null;
        _lastError = null;
        _lastSuccess = null;
        try
        {
            await Config.SaveCookbookGuidanceAsync(_guidance);
            _guidanceBaseline = _guidance;
            _lastSuccess = "Cookbook guidance saved.";
        }
        catch (PlanValidationException ex)
        {
            _guidanceErrors = ex.Errors;
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Failed to save cookbook guidance.");
            _lastError = "An unexpected error occurred. Guidance was not saved.";
        }
        finally
        {
            _savingGuidance = false;
        }
    }
}
