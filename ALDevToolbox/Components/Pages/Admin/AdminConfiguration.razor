@page "/admin/configuration"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@inject OrganizationConfigService Config
@inject NavigationManager Nav
@inject ILogger<AdminConfiguration> Log
@using ALDevToolbox.Domain.Entities
@using ALDevToolbox.Domain.ValueObjects
@using Microsoft.AspNetCore.Components.Forms

@*
    Per-organisation configuration page. All three sections (defaults, logo,
    always-included files) commit through a single Save action at the top of
    the page so admins don't have to remember which sub-form persisted what.
    The TOML import/export lives on its own /admin/backup page; this page is
    the day-to-day editing surface.
*@

<PageTitle>Configuration · Admin · AL Dev Toolbox</PageTitle>

<div class="admin-page admin-configuration">
    <header class="admin-page__header">
        <div>
            <h1>Organisation configuration</h1>
            <p class="muted">
                Defaults that pre-fill the New Workspace and New Extension forms,
                the logo bundled into every generated workspace, and any always-
                included text files admins want emitted at the workspace root.
            </p>
        </div>
        <div class="admin-page__header-actions">
            <a class="btn btn--sm" href="/admin">
                <Icon Name="arrow-left" Width="14" Height="14" />
                <span>Back to admin</span>
            </a>
            <button type="button" class="btn btn--sm btn--primary"
                    @onclick="SaveAllAsync"
                    disabled="@(_saving || !IsDirty)">
                <Icon Name="save" Width="14" Height="14" />
                <span>@(_saving ? "Saving…" : "Save changes")</span>
            </button>
        </div>
    </header>

    @if (_config is null)
    {
        <p class="muted">Loading…</p>
    }
    else
    {
        @if (!string.IsNullOrEmpty(_okMessage))
        {
            <p class="form-success" role="status">@_okMessage</p>
        }
        @if (!string.IsNullOrEmpty(_errMessage))
        {
            <div class="form-error" role="alert">
                <p>@_errMessage</p>
            </div>
        }

        <section class="admin-section">
            <h2>Defaults</h2>
            <p class="muted">
                Pre-filled into the New Workspace and New Extension forms. Users
                can still edit on the form — these are defaults, not locks.
            </p>
            <div class="form-grid form-grid--narrow">
                <section class="form-section">
                    <label class="section-label" for="cfg-publisher">Publisher</label>
                    <input id="cfg-publisher" type="text" required
                           @bind="_publisher" @bind:event="oninput" />
                    <small class="muted">Used as the <code>publisher</code> for every generated <code>app.json</code>.</small>
                </section>

                <section class="form-section--row">
                    <div class="form-section form-section--id">
                        <label class="section-label" for="cfg-from">Default ID range — from</label>
                        <input id="cfg-from" type="number" required min="1"
                               @bind="_idFrom" @bind:event="oninput" />
                    </div>
                    <div class="form-section form-section--id">
                        <label class="section-label" for="cfg-to">Default ID range — to</label>
                        <input id="cfg-to" type="number" required min="1"
                               @bind="_idTo" @bind:event="oninput" />
                    </div>
                </section>

                <section class="form-section">
                    <label class="section-label" for="cfg-brief">Default brief</label>
                    <input id="cfg-brief" type="text"
                           placeholder="e.g. Customisations and reports for Acme."
                           @bind="_brief" @bind:event="oninput" />
                </section>

                <section class="form-section">
                    <label class="section-label" for="cfg-desc">Default core description</label>
                    <textarea id="cfg-desc" rows="3"
                              placeholder="Longer description prefilled into the New Workspace form."
                              @bind="_description" @bind:event="oninput"></textarea>
                </section>
            </div>
        </section>

        <section class="admin-section">
            <h2>Logo</h2>
            <p class="muted">
                Bundled into every generated workspace under
                <code>.assets/images/logo.&lt;ext&gt;</code>. SVG and PNG only;
                max @(OrganizationConfigService.MaxLogoBytes / 1024) KB. SVG
                uploads have <code>&lt;script&gt;</code> tags and <code>on*</code>
                attributes stripped on save.
            </p>

            <div class="logo-preview">
                @if (_pendingLogoBytes is not null)
                {
                    <p class="muted">New logo selected (@_pendingLogoFileName). Click <strong>Save changes</strong> to apply.</p>
                }
                else if (_removeLogo)
                {
                    <p class="muted">Logo will be removed on save.</p>
                }
                else if (_config.Logo is not null)
                {
                    <img src="/admin/configuration/logo/preview?t=@_logoCacheBust" alt="Current logo" class="logo-preview__img" />
                }
                else
                {
                    <p class="muted">No logo configured. Generated workspaces will ship without one.</p>
                }
            </div>

            <div class="form-grid form-grid--narrow">
                <section class="form-section">
                    <label class="section-label" for="cfg-logo">Replace logo</label>
                    <label class="btn btn--sm logo-upload__button">
                        <Icon Name="upload" Width="14" Height="14" />
                        <span>Choose file…</span>
                        <InputFile id="cfg-logo" OnChange="OnLogoChosen" accept="image/png,image/svg+xml" class="logo-upload__input" />
                    </label>
                </section>
                @if (_config.Logo is not null || _pendingLogoBytes is not null)
                {
                    <div class="form-actions">
                        <button type="button" class="btn btn--sm" @onclick="MarkLogoForRemoval" disabled="@_removeLogo">
                            <Icon Name="trash-2" Width="14" Height="14" />
                            <span>Remove logo</span>
                        </button>
                        @if (_pendingLogoBytes is not null || _removeLogo)
                        {
                            <button type="button" class="btn btn--sm" @onclick="ResetLogoChanges">
                                <Icon Name="rotate-ccw" Width="14" Height="14" />
                                <span>Revert pending logo change</span>
                            </button>
                        }
                    </div>
                }
            </div>
        </section>

        <section class="admin-section">
            <h2>Always-included files</h2>
            <p class="muted">
                Text files written into every generated workspace at the root.
                Mustache substitution applies the same context as per-template
                files when enabled.
            </p>
            @if (_files.Count == 0)
            {
                <p class="muted">No files configured. Add <code>.editorconfig</code>, a per-org <code>README.md</code>, or anything else admins want shipped on every generation.</p>
            }
            else
            {
                <ul class="org-file-list">
                    @foreach (var file in _files.OrderBy(f => f.Ordering))
                    {
                        <li class="org-file-row">
                            <div class="org-file-row__head">
                                <span><code>@file.Path</code></span>
                                <span class="muted">
                                    @(file.MustacheEnabled ? "mustache on" : "mustache off")
                                </span>
                            </div>
                            <div class="org-file-row__body">
                                <pre class="org-file-row__content">@TruncateForPreview(file.Content)</pre>
                            </div>
                            <div class="org-file-row__actions">
                                <button type="button" class="btn btn--sm" @onclick="() => StartEdit(file)">
                                    <Icon Name="pencil" Width="12" Height="12" />
                                    <span>Edit</span>
                                </button>
                                <button type="button" class="btn btn--sm" @onclick="() => RemoveFile(file)">
                                    <Icon Name="trash-2" Width="12" Height="12" />
                                    <span>Remove</span>
                                </button>
                            </div>
                        </li>
                    }
                </ul>
            }

            <h3>@(_editing is null ? "Add a file" : $"Editing {_editing.Path}")</h3>
            <div class="form-grid">
                <section class="form-section">
                    <label class="section-label" for="cfg-file-path">Path</label>
                    <input id="cfg-file-path" type="text" placeholder=".editorconfig"
                           @bind="_editPath" @bind:event="oninput" />
                </section>
                <section class="form-section">
                    <label class="section-label" for="cfg-file-content">Content</label>
                    <textarea id="cfg-file-content" rows="6" @bind="_editContent" @bind:event="oninput"></textarea>
                </section>
                <label class="check-row">
                    <input type="checkbox" @bind="_editMustache" />
                    <span>Substitute mustache variables when generating</span>
                </label>
                <div class="form-actions">
                    <button type="button" class="btn" @onclick="ApplyEdit">
                        <Icon Name="check" Width="12" Height="12" />
                        <span>@(_editing is null ? "Add to list" : "Apply changes")</span>
                    </button>
                    @if (_editing is not null)
                    {
                        <button type="button" class="btn btn--sm" @onclick="CancelEdit">Cancel</button>
                    }
                </div>
                @if (!string.IsNullOrEmpty(_localError))
                {
                    <span class="form-field-error" role="alert">@_localError</span>
                }
            </div>
        </section>
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "ok")] public string? OkParam { get; set; }
    [SupplyParameterFromQuery(Name = "err")] public string? ErrParam { get; set; }
    [SupplyParameterFromQuery(Name = "msg")] public string? MsgParam { get; set; }

    private OrganizationConfig? _config;

    // Settings (bound to the form, baseline kept for dirty detection).
    private string _publisher = string.Empty;
    private int _idFrom;
    private int _idTo;
    private string _brief = string.Empty;
    private string _description = string.Empty;
    private string _basePublisher = string.Empty;
    private int _baseIdFrom;
    private int _baseIdTo;
    private string _baseBrief = string.Empty;
    private string _baseDescription = string.Empty;

    // Files list — same FileRow shape as the previous implementation.
    private List<FileRow> _files = new();
    private List<FileRow> _baseFiles = new();

    // Logo: a pending upload OR a pending removal stays in memory until Save.
    private byte[]? _pendingLogoBytes;
    private string? _pendingLogoContentType;
    private string? _pendingLogoFileName;
    private bool _removeLogo;

    private FileRow? _editing;
    private string _editPath = string.Empty;
    private string _editContent = string.Empty;
    private bool _editMustache;
    private string? _localError;

    private bool _saving;
    private string? _okMessage;
    private string? _errMessage;
    private long _logoCacheBust = DateTimeOffset.UtcNow.ToUnixTimeSeconds();

    private sealed class FileRow
    {
        public int? Id { get; set; }
        public string Path { get; set; } = string.Empty;
        public string Content { get; set; } = string.Empty;
        public bool MustacheEnabled { get; set; }
        public int Ordering { get; set; }

        public FileRow Clone() => new()
        {
            Id = Id, Path = Path, Content = Content,
            MustacheEnabled = MustacheEnabled, Ordering = Ordering,
        };
    }

    private bool IsDirty
    {
        get
        {
            if (_publisher != _basePublisher) return true;
            if (_idFrom != _baseIdFrom) return true;
            if (_idTo != _baseIdTo) return true;
            if (_brief != _baseBrief) return true;
            if (_description != _baseDescription) return true;
            if (_pendingLogoBytes is not null || _removeLogo) return true;
            if (_files.Count != _baseFiles.Count) return true;
            for (var i = 0; i < _files.Count; i++)
            {
                var a = _files[i]; var b = _baseFiles[i];
                if (a.Id != b.Id || a.Path != b.Path || a.Content != b.Content
                    || a.MustacheEnabled != b.MustacheEnabled || a.Ordering != b.Ordering)
                {
                    return true;
                }
            }
            return false;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        _okMessage = OkParam switch
        {
            "saved" => "Configuration saved.",
            _ => null,
        };
        _errMessage = string.IsNullOrEmpty(ErrParam) ? null : (MsgParam ?? ErrParam);
    }

    private async Task LoadAsync()
    {
        _config = await Config.GetCurrentAsync();

        _publisher = _basePublisher = _config.Settings.DefaultPublisher;
        _idFrom = _baseIdFrom = _config.Settings.DefaultIdRangeFrom;
        _idTo = _baseIdTo = _config.Settings.DefaultIdRangeTo;
        _brief = _baseBrief = _config.Settings.DefaultBrief;
        _description = _baseDescription = _config.Settings.DefaultCoreDescription;

        _files = _config.Files
            .Select(f => new FileRow
            {
                Id = f.Id, Path = f.Path, Content = f.Content,
                MustacheEnabled = f.MustacheEnabled, Ordering = f.Ordering,
            })
            .ToList();
        _baseFiles = _files.Select(f => f.Clone()).ToList();

        _pendingLogoBytes = null;
        _pendingLogoContentType = null;
        _pendingLogoFileName = null;
        _removeLogo = false;
        _logoCacheBust = DateTimeOffset.UtcNow.ToUnixTimeSeconds();
    }

    private async Task OnLogoChosen(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;
        if (file.Size > OrganizationConfigService.MaxLogoBytes)
        {
            _errMessage = $"Logo must be {OrganizationConfigService.MaxLogoBytes / 1024} KB or smaller.";
            return;
        }
        try
        {
            await using var stream = file.OpenReadStream(OrganizationConfigService.MaxLogoBytes);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            _pendingLogoBytes = ms.ToArray();
            _pendingLogoContentType = file.ContentType;
            _pendingLogoFileName = file.Name;
            _removeLogo = false;
            _errMessage = null;
        }
        catch (Exception ex)
        {
            Log.LogWarning(ex, "Failed to read uploaded logo '{Name}'.", file.Name);
            _errMessage = $"Could not read the file: {ex.Message}";
        }
    }

    private void MarkLogoForRemoval()
    {
        _removeLogo = true;
        _pendingLogoBytes = null;
        _pendingLogoContentType = null;
        _pendingLogoFileName = null;
    }

    private void ResetLogoChanges()
    {
        _pendingLogoBytes = null;
        _pendingLogoContentType = null;
        _pendingLogoFileName = null;
        _removeLogo = false;
    }

    private void StartEdit(FileRow row)
    {
        _editing = row;
        _editPath = row.Path;
        _editContent = row.Content;
        _editMustache = row.MustacheEnabled;
        _localError = null;
    }

    private void CancelEdit()
    {
        _editing = null;
        _editPath = string.Empty;
        _editContent = string.Empty;
        _editMustache = false;
        _localError = null;
    }

    private void ApplyEdit()
    {
        var path = _editPath.Trim();
        if (string.IsNullOrEmpty(path))
        {
            _localError = "Path is required.";
            return;
        }
        if (path.Contains(".."))
        {
            _localError = "Path must not contain '..' segments.";
            return;
        }
        var conflict = _files.Any(f => f != _editing && string.Equals(f.Path, path, StringComparison.OrdinalIgnoreCase));
        if (conflict)
        {
            _localError = $"Another file already uses path '{path}'.";
            return;
        }

        if (_editing is null)
        {
            _files.Add(new FileRow
            {
                Path = path,
                Content = _editContent,
                MustacheEnabled = _editMustache,
                Ordering = _files.Count,
            });
        }
        else
        {
            _editing.Path = path;
            _editing.Content = _editContent;
            _editing.MustacheEnabled = _editMustache;
        }
        CancelEdit();
    }

    private void RemoveFile(FileRow row)
    {
        _files.Remove(row);
        for (var i = 0; i < _files.Count; i++) _files[i].Ordering = i;
        if (_editing == row) CancelEdit();
    }

    private async Task SaveAllAsync()
    {
        if (_saving || !IsDirty) return;
        _saving = true;
        _errMessage = null;
        _okMessage = null;
        try
        {
            var settingsDirty = _publisher != _basePublisher
                || _idFrom != _baseIdFrom || _idTo != _baseIdTo
                || _brief != _baseBrief || _description != _baseDescription;
            if (settingsDirty)
            {
                await Config.SaveSettingsAsync(new OrganizationSettingsInput(
                    DefaultPublisher: _publisher.Trim(),
                    DefaultIdRangeFrom: _idFrom,
                    DefaultIdRangeTo: _idTo,
                    DefaultBrief: _brief,
                    DefaultCoreDescription: _description));
            }

            if (_removeLogo)
            {
                await Config.RevertLogoAsync();
            }
            else if (_pendingLogoBytes is not null)
            {
                await Config.UploadLogoAsync(_pendingLogoContentType ?? string.Empty, _pendingLogoBytes);
            }

            for (var i = 0; i < _files.Count; i++) _files[i].Ordering = i;
            var filesDirty = _files.Count != _baseFiles.Count
                || _files.Zip(_baseFiles, (a, b) => a.Id != b.Id || a.Path != b.Path
                    || a.Content != b.Content || a.MustacheEnabled != b.MustacheEnabled
                    || a.Ordering != b.Ordering).Any(diff => diff);
            if (filesDirty)
            {
                var inputs = _files
                    .Select(f => new OrganizationFileInput(
                        Id: f.Id, Path: f.Path, Content: f.Content,
                        MustacheEnabled: f.MustacheEnabled))
                    .ToList();
                await Config.SaveFilesAsync(inputs);
            }

            Nav.NavigateTo("/admin/configuration?ok=saved", forceLoad: true);
        }
        catch (PlanValidationException ex)
        {
            _errMessage = ex.Errors.FirstOrDefault().Value ?? "Validation failed.";
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Failed to save organisation configuration.");
            _errMessage = "An unexpected error occurred. The change was not saved.";
        }
        finally
        {
            _saving = false;
        }
    }

    private static string TruncateForPreview(string content)
    {
        if (string.IsNullOrEmpty(content)) return string.Empty;
        const int max = 240;
        return content.Length <= max ? content : content.Substring(0, max) + "…";
    }
}
