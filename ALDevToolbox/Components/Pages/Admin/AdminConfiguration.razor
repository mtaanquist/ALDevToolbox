@page "/admin/configuration"
@attribute [Authorize(Roles = "Admin")]
@inject NavigationManager Nav

@*
    The configuration surface is split into four sub-pages under
    /admin/configuration/* (Issue #61). This page exists only so legacy
    bookmarks and the admin dashboard tile keep working — it redirects to
    the Defaults sub-page on load.
*@

@code {
    protected override void OnInitialized()
    {
        Nav.NavigateTo("/admin/configuration/defaults", replace: true);
    }
}
