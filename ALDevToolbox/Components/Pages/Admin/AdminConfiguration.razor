@page "/admin/configuration"
@attribute [Authorize(Roles = "Admin")]
@inject NavigationManager Nav

@*
    /admin/configuration is the org-level configuration surface (identity +
    MCP integration). The template-shaping pages (defaults / logo / files /
    workspace settings) moved under /admin/templates/* — this page redirects
    to the identity sub-page so the legacy bookmark still lands somewhere
    useful.
*@

@code {
    protected override void OnInitialized()
    {
        Nav.NavigateTo("/admin/configuration/identity", replace: true);
    }
}
