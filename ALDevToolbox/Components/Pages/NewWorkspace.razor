@page "/projects/new"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@inject TemplateService Templates
@inject FolderTreeHydrator FolderTree
@inject ApplicationVersionService Versions
@inject OrganizationConfigService OrgConfig
@using ALDevToolbox.Components.Shared
@using ALDevToolbox.Domain.Entities
@using ALDevToolbox.Domain.ValueObjects
@using ALDevToolbox.Services

<PageTitle>New workspace · AL Dev Toolbox</PageTitle>

<div class="workspace-page">
    @if (_templates is null || _modules is null || _applicationVersions is null)
    {
        @PageHeader
        <p class="muted">Loading…</p>
    }
    else if (_templates.Count == 0)
    {
        @PageHeader
        <p class="muted">
            No active workspace templates are available. Ask an admin to add
            one under <a href="/admin/templates">Templates</a> before
            generating a workspace.
        </p>
    }
    else
    {
        <form method="post" action="/generate/workspace" class="workspace-shell" data-loading-form>
            <AntiforgeryToken />
            <input type="hidden" name="GenToken" value="" />

            <div class="workspace-layout">
                <div class="form-grid workspace-layout__form">

                @PageHeader

                <section class="form-section">
                    <label class="section-label" for="ws-template">Workspace template</label>
                    <select id="ws-template" name="TemplateKey" required
                            @bind="_templateKey" @bind:after="OnTemplateChanged">
                        @foreach (var t in _templates)
                        {
                            <option value="@t.Key">@t.Name</option>
                        }
                    </select>
                    <p class="caption muted">
                        @_selected!.Description
                        <span> · Default application: <code>@_selected.Defaults.Application</code></span>
                    </p>
                </section>

                <section class="form-section">
                    <label class="section-label">Project</label>
                    <input type="text" name="WorkspaceName" placeholder="e.g. Acme Customer"
                           pattern="^[A-Za-z][A-Za-z0-9 ]*$" required
                           title="Letters, digits and spaces only; must start with a letter."
                           @bind="_workspaceName" @bind:event="oninput" />
                    <small class="muted">Workspace name. Letters, digits and spaces only; must start with a letter.</small>
                    <input type="text" name="ExtensionPrefix" placeholder="e.g. ACME"
                           @bind="_extensionPrefix" @bind:event="oninput" />
                    <small class="muted">
                        A short prefix added to the names of generated extensions
                        (e.g. <code>ACME Core</code>). Different from the AL object-name
                        affix set on the template itself.
                    </small>
                    <input type="text" name="Brief" placeholder="One-line description (optional)"
                           @bind="_brief" @bind:event="oninput" />
                    <textarea name="Description" rows="3" placeholder="Longer description (optional)"
                              @bind="_description" @bind:event="oninput"></textarea>
                </section>

                <section class="form-section">
                    <label class="section-label" for="ws-tenant">Tenant ID</label>
                    <input id="ws-tenant" type="text" name="TenantId"
                           pattern="^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
                           placeholder="e.g. 8a4f1c3e-1b2d-4e6f-9c1a-3d5b7e9f2a4c"
                           title="GUID in 8-4-4-4-12 hex form."
                           @bind="_tenantId" @bind:event="oninput" />
                    <small class="muted">
                        The customer's Microsoft Entra (Azure AD) tenant ID —
                        the GUID their tenant uses, typically pasted from
                        their Business Central environment so the generated
                        debug configs target the right tenant. Optional;
                        leave blank if you don't have it yet. Available in
                        templates and always-included files as
                        <code>&#123;&#123;tenant_id&#125;&#125;</code>.
                    </small>
                </section>

                <IdRangeEditor IdPrefix="ws-core"
                               FromName="CoreIdRangeFrom" ToName="CoreIdRangeTo"
                               FromLabel="Core ID range — from" ToLabel="Core ID range — to"
                               From="_coreIdRangeFrom" FromChanged="v => _coreIdRangeFrom = v"
                               To="_coreIdRangeTo" ToChanged="v => _coreIdRangeTo = v" />

                <section class="form-section">
                    <label class="section-label" for="ws-app-version">Application version</label>
                    @if (_applicationVersions is null || _applicationVersions.Count == 0)
                    {
                        @* Fallback when the catalogue is empty — keep the form
                           submittable using the free-text values lifted from
                           the picked template's defaults. Admins can curate the
                           list under /admin/application-versions. *@
                        <input id="ws-app-version" type="text" name="ApplicationVersion" required
                               @bind="_applicationVersion" @bind:event="oninput" />
                        <input type="hidden" name="RuntimeVersion" value="@_runtimeVersion" />
                        <small class="muted">
                            No application versions have been added for your organisation yet.
                            An admin can curate them under
                            <a href="/admin/application-versions">Application versions</a>.
                        </small>
                    }
                    else
                    {
                        <select id="ws-app-version" name="ApplicationVersion"
                                @bind="_applicationVersion" @bind:after="OnApplicationVersionChanged">
                            @* "Latest" sentinel: the endpoint resolves to
                               the highest-ordered active catalogue row at
                               submit time. Picking it sets the hidden
                               RuntimeVersion to the same sentinel so the
                               endpoint can swap both atomically. *@
                            <option value="@ApplicationVersionService.LatestSentinel">Latest (always highest)</option>
                            @* Orphan templates carry a free-text default
                               that doesn't necessarily appear in the curated
                               catalogue; render a synthetic option so the
                               browser keeps the orphan value selectable
                               until an admin assigns a real entry. Skip
                               this when the value is the Latest sentinel
                               since that already renders above. *@
                            @if (!string.Equals(_applicationVersion, ApplicationVersionService.LatestSentinel, StringComparison.Ordinal)
                                && !_applicationVersions.Any(v => v.Application == _applicationVersion))
                            {
                                <option value="@_applicationVersion">@_applicationVersion (template default — not in catalogue)</option>
                            }
                            @foreach (var v in _applicationVersions)
                            {
                                <option value="@v.Application">@v.Name</option>
                            }
                        </select>
                        @* The runtime is derived from the picked entry; ship
                           it as a hidden input so the existing endpoint shape
                           (separate ApplicationVersion + RuntimeVersion fields)
                           keeps working. *@
                        <input type="hidden" name="RuntimeVersion" value="@_runtimeVersion" />
                        <p class="caption muted">
                            application <code>@_applicationVersion</code> · runtime <code>@_runtimeVersion</code>
                        </p>
                    }
                </section>

                @if (_optionalExtensions.Count > 0)
                {
                    <section class="form-section">
                        <label class="section-label">Additional extensions</label>
                        <p class="caption muted">
                            Optional extensions declared by this template. Tick to include
                            them in the generated workspace alongside the required ones.
                        </p>
                        <div class="module-list">
                            @foreach (var ext in _optionalExtensions.OrderBy(e => e.Path, StringComparer.OrdinalIgnoreCase))
                            {
                                <label class="module-card">
                                    <input type="checkbox" name="SelectedExtensionPaths" value="@ext.Path"
                                           checked="@_selectedExtensionPaths.Contains(ext.Path)"
                                           @onchange="e => OnExtensionToggled(ext.Path, (bool)(e.Value ?? false))" />
                                    <span class="module-card__check"><Icon Name="check" Width="13" Height="13" /></span>
                                    <span class="module-card__body">
                                        <span class="module-card__name">@ext.Path</span>
                                        <span class="module-card__caption muted">@ext.NameTemplate</span>
                                    </span>
                                </label>
                            }
                        </div>
                    </section>
                }

                <section class="form-section">
                    <div class="module-head">
                        <label class="section-label">Modules</label>
                        @if (_modules.Count > 0)
                        {
                            <span class="selcount">
                                <b>@_selectedModuleKeys.Count</b> selected ·
                                <b>@CountDependencies()</b> dependencies pulled in
                            </span>
                        }
                    </div>
                    @if (_modules.Count == 0)
                    {
                        <p class="muted">No modules available.</p>
                    }
                    else
                    {
                        <div class="module-list">
                            @foreach (var m in _modules)
                            {
                                <label class="module-card">
                                    <input type="checkbox" name="SelectedModuleKeys" value="@m.Key"
                                           checked="@_selectedModuleKeys.Contains(m.Key)"
                                           @onchange="e => OnModuleToggled(m.Key, (bool)(e.Value ?? false))" />
                                    <span class="module-card__check"><Icon Name="check" Width="13" Height="13" /></span>
                                    <span class="module-card__body">
                                        <span class="module-card__name">@m.Name</span>
                                        <span class="module-card__caption">
                                            <Icon Name="link" Width="13" Height="13" />
                                            + @m.Dependencies.Count
                                            @(m.Dependencies.Count == 1 ? "dependency" : "dependencies")
                                        </span>
                                    </span>
                                </label>
                            }
                        </div>
                    }
                </section>

                <section class="form-section">
                    <label class="section-label">Options</label>
                    <label class="check-row">
                        <input type="checkbox" name="IncludeExamples" value="true"
                               @bind="_includeExamples" />
                        <span>Include example AL files</span>
                    </label>
                </section>

                </div>

                <aside class="workspace-layout__preview">
                    <section class="preview-card">
                        <div class="preview-card__head">
                            <span class="section-label">Preview</span>
                            <span class="status-pill status-pill--live"><span class="status-pill__dot"></span>Live</span>
                        </div>
                        <div class="preview-card__body preview-card__body--scroll">
                            <FolderTreePreview Root="BuildPreview()" />
                        </div>
                    </section>

                    <section class="preview-stats">
                        <div class="stat-card stat-card--accent">
                            <div class="stat-card__value">@CountExtensions()</div>
                            <div class="stat-card__label">Extensions</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-card__value">@CountDependencies()</div>
                            <div class="stat-card__label">Dependencies</div>
                        </div>
                    </section>
                </aside>
            </div>

            <div class="actionbar">
                <div class="actionbar__inner">
                    <div class="actionbar__info">
                        Generating <b>@CountExtensions() @(CountExtensions() == 1 ? "extension" : "extensions")</b>@if (_selected is not null)
                        {<text> from <b>@_selected.Name</b></text>}
                    </div>
                    <div class="actionbar__actions">
                        <button type="submit" class="btn btn--primary btn--lg" data-loading-button>
                            <span class="btn__spinner" aria-hidden="true"></span>
                            <span class="btn__label"><Icon Name="download" Width="15" Height="15" /> Download ZIP</span>
                            <span class="btn__label-busy">Generating…</span>
                        </button>
                    </div>
                </div>
            </div>
        </form>
    }
</div>

@code {
    // Rendered both in the loading/empty states and at the top of the left
    // column in the populated state, so the preview rail lines up with the
    // title row rather than sitting below a full-width header.
    private RenderFragment PageHeader =>@<header class="page-header">
        <h1>New workspace</h1>
        <p class="muted">
            Spin up a fresh AL workspace from one of your organisation's
            workspace templates. Pick the template, tweak the defaults that
            don't fit your project, and download the ZIP.
        </p>
    </header>;

    [SupplyParameterFromQuery(Name = "template")] public string? PreselectedTemplate { get; set; }

    private List<RuntimeTemplate>? _templates;
    private List<ALDevToolbox.Domain.Entities.Module>? _modules;
    private List<ApplicationVersion>? _applicationVersions;
    private RuntimeTemplate? _selected;

    // Form state. Mirrors what the form posts to /generate/workspace; the live
    // preview reads from these same fields so it always reflects the user's
    // current input.
    private string _templateKey = string.Empty;
    private string _workspaceName = string.Empty;
    private string _brief = string.Empty;
    private string _description = string.Empty;
    private int _coreIdRangeFrom;
    private int _coreIdRangeTo;
    private string _applicationVersion = string.Empty;
    private string _runtimeVersion = string.Empty;
    private string _extensionPrefix = string.Empty;
    private readonly HashSet<string> _selectedModuleKeys = new(StringComparer.Ordinal);
    /// <summary>
    /// Paths of optional template-declared extensions the user ticked. The
    /// required ones are emitted regardless and don't go through this set.
    /// </summary>
    private readonly HashSet<string> _selectedExtensionPaths = new(StringComparer.Ordinal);
    /// <summary>Cache of the picked template's optional extensions for rendering checkboxes.</summary>
    private List<WorkspaceExtension> _optionalExtensions = new();
    private bool _includeExamples = true;
    /// <summary>
    /// Microsoft Entra tenant ID surfaced via <c>{{tenant_id}}</c> mustache
    /// substitution. Optional — users who don't know it leave it blank;
    /// downstream substitutions then resolve to the empty string.
    /// </summary>
    private string _tenantId = string.Empty;

    private OrganizationConfig? _orgConfig;

    protected override async Task OnInitializedAsync()
    {
        _templates = await Templates.GetTemplatesAsync(includeDeprecated: false);
        _modules = await Templates.GetModulesAsync(includeDeprecated: false);
        // Folder/file trees aren't pulled by the default reads — load them on
        // top so the live preview can walk each extension's real layout
        // without an extra round-trip when the user picks a template or
        // toggles a module.
        await FolderTree.HydrateExtensionFolderTreeAsync(_templates);
        await FolderTree.HydrateModuleExtensionFolderTreeAsync(_modules);
        _applicationVersions = await Versions.GetActiveAsync(includeDeprecated: false);
        _orgConfig = await OrgConfig.GetCurrentAsync();
        // Pre-fill the brief / description from the org's defaults block
        // (Milestone P3.14). Users can still edit either field; the template's
        // own fields override the id range below if it specifies one, since
        // the ID range is a per-template concern.
        _brief = _orgConfig.Settings.DefaultBrief;
        _description = _orgConfig.Settings.DefaultCoreDescription;
        // Honour the ?template=<key> hint from the Templates browser when present
        // and the key matches an active template; otherwise fall back to the
        // per-org default flagged in admin, then the first row in the list.
        _selected = (!string.IsNullOrWhiteSpace(PreselectedTemplate)
            ? _templates.FirstOrDefault(t => t.Key == PreselectedTemplate)
            : null)
            ?? _templates.FirstOrDefault(t => t.IsDefault)
            ?? _templates.FirstOrDefault();
        if (_selected is not null)
        {
            ApplyTemplateDefaults(_selected);
        }
    }

    private void OnApplicationVersionChanged()
    {
        // Picking an entry on the select fills both ApplicationVersion and
        // RuntimeVersion atomically (Milestone P2.4). The select's value is
        // the four-part Application string; we look the row up to recover the
        // matching runtime so the hidden RuntimeVersion input stays correct.
        // "Latest" propagates the sentinel into RuntimeVersion so the
        // endpoint can swap both fields in lock-step at submit time.
        if (string.Equals(_applicationVersion, ApplicationVersionService.LatestSentinel, StringComparison.Ordinal))
        {
            _runtimeVersion = ApplicationVersionService.LatestSentinel;
            return;
        }
        if (_applicationVersions is null) return;
        var match = _applicationVersions.FirstOrDefault(v => v.Application == _applicationVersion);
        if (match is not null)
        {
            _runtimeVersion = match.Runtime;
        }
    }

    private void OnTemplateChanged()
    {
        var picked = _templates?.FirstOrDefault(t => t.Key == _templateKey);
        if (picked is null) return;
        _selected = picked;
        ApplyTemplateDefaults(picked);
    }

    private void ApplyTemplateDefaults(RuntimeTemplate template)
    {
        _templateKey = template.Key;
        _coreIdRangeFrom = template.CoreIdRangeFrom;
        _coreIdRangeTo = template.CoreIdRangeTo;
        // Pre-fill the friendly extension-name prefix from the template's
        // defaults. The user can override per workspace — this only seeds the
        // initial value when switching templates.
        _extensionPrefix = template.Defaults.ExtensionPrefix;
        // Populate the optional-extension checkbox list. Switching templates
        // wipes prior selections; required entries (Required = true) are
        // emitted unconditionally and don't surface here.
        _selectedExtensionPaths.Clear();
        _optionalExtensions = template.WorkspaceExtensions
            .Where(e => !e.Required)
            .OrderBy(e => e.Ordering)
            .ToList();
        (_applicationVersion, _runtimeVersion) =
            TemplateDefaultsResolver.ResolveApplicationAndRuntime(template, _applicationVersions);

        // Pre-select the modules this template ships with (Milestone P2.1).
        // Switching templates retunes the selection; the user's subsequent
        // toggles after that are honoured unchanged. We only consider modules
        // that are still in the active list — soft-deleted or filtered-out
        // entries silently drop off the default set.
        _selectedModuleKeys.Clear();
        if (_modules is null) return;
        var availableKeys = _modules.Select(m => m.Key).ToHashSet(StringComparer.Ordinal);
        foreach (var d in template.DefaultModules.OrderBy(d => d.Ordering))
        {
            var key = d.Module?.Key;
            if (!string.IsNullOrEmpty(key) && availableKeys.Contains(key))
            {
                _selectedModuleKeys.Add(key);
            }
        }
    }

    private void OnModuleToggled(string key, bool isChecked)
    {
        if (isChecked) _selectedModuleKeys.Add(key);
        else _selectedModuleKeys.Remove(key);
    }

    private void OnExtensionToggled(string path, bool isChecked)
    {
        if (isChecked) _selectedExtensionPaths.Add(path);
        else _selectedExtensionPaths.Remove(path);
    }

    private int CountExtensions()
    {
        var template = _selected;
        var fromTemplate = template is null
            ? 0
            : template.WorkspaceExtensions.Count(e => e.Required || _selectedExtensionPaths.Contains(e.Path));
        return fromTemplate + _selectedModuleKeys.Count;
    }

    private int CountDependencies()
    {
        if (_modules is null) return 0;
        // One self-reference to Core per module, plus each module's own
        // dependencies. Core itself has no dependencies unless ForNAV is on,
        // in which case we just call out a non-zero count without looking up
        // catalogue rows for the preview.
        var total = 0;
        foreach (var key in _selectedModuleKeys)
        {
            var module = _modules.FirstOrDefault(m => m.Key == key);
            if (module is null) continue;
            total += 1 + module.Dependencies.Count;
        }
        return total;
    }

    /// <summary>
    /// Builds the <see cref="PreviewNode"/> tree displayed in the right column.
    /// Mirrors the structure documented in <c>generation-engine.md</c>: the
    /// workspace root contains <c>.assets</c>, one extension folder per
    /// required template extension and per ticked optional extension, one
    /// folder per selected module (cloned from the module's extension tree),
    /// and three workspace-level files. The per-extension contents come from
    /// <see cref="ExtensionPreviewBuilder"/>, which walks the recursive folder
    /// tree the same way <c>GenerationService</c> does.
    /// </summary>
    private PreviewNode BuildPreview()
    {
        var rootName = string.IsNullOrWhiteSpace(_workspaceName)
            ? "Workspace"
            : StripWhitespace(_workspaceName);

        var children = new List<PreviewNode>();

        // The org logo lands at the path the admin set on
        // /admin/configuration/defaults' "Default logo path" (stripped of
        // any extension-relative ../ prefix). No logo uploaded means no
        // logo node at all — fresh orgs don't see a phantom .assets folder.
        if (_orgConfig?.Logo is not null)
        {
            var logoExt = _orgConfig.Logo.ContentType switch
            {
                "image/svg+xml" => "svg",
                _ => "png",
            };
            var logoPath = ALDevToolbox.Services.Generation.WorkspaceZipBuilder.NormaliseLogoPath(
                _orgConfig.Settings.DefaultLogo, logoExt);
            PreviewTreeBuilder.GraftFile(children, logoPath);
        }

        // Split the template's included files by scope once: workspace-root
        // grafts into the workspace tree; per-extension is duplicated inside
        // each extension folder by ExtensionPreviewBuilder. This is exactly
        // what WorkspaceZipBuilder does at emit time so the preview matches
        // the ZIP.
        var workspaceRootPaths = new List<string>();
        var perExtensionPaths = new List<string>();
        if (_selected is not null && _orgConfig is not null)
        {
            var byId = _orgConfig.Files.ToDictionary(f => f.Id);
            foreach (var joined in _selected.IncludedFiles.OrderBy(j => j.Ordering))
            {
                if (!byId.TryGetValue(joined.OrganizationFileId, out var file)) continue;
                if (file.Scope == OrganizationFileScope.EveryExtension)
                {
                    perExtensionPaths.Add(file.Path);
                }
                else
                {
                    workspaceRootPaths.Add(file.Path);
                }
            }
        }

        if (_selected is not null)
        {
            foreach (var ext in _selected.WorkspaceExtensions.OrderBy(e => e.Ordering))
            {
                if (!ext.Required && !_selectedExtensionPaths.Contains(ext.Path)) continue;
                children.Add(PreviewNode.Extension(
                    ext.Path,
                    ExtensionPreviewBuilder.BuildContents(ext.Folders, _includeExamples, perExtensionPaths)));
            }
        }

        if (_modules is not null)
        {
            foreach (var key in _selectedModuleKeys)
            {
                var module = _modules.FirstOrDefault(m => m.Key == key);
                if (module is null) continue;
                // Module-cloned extension folder name mirrors GenerationService:
                // the module's ExtensionName (PascalCase) is what lands in the
                // ZIP. Module.Key stays as the admin slug / dep ref target.
                children.Add(PreviewNode.Extension(
                    module.ExtensionName,
                    ExtensionPreviewBuilder.BuildContents(module.ExtensionFolders, _includeExamples, perExtensionPaths)));
            }
        }

        // Workspace-root files emitted unconditionally by the generator.
        children.Add(PreviewNode.File($"{rootName}.code-workspace"));
        children.Add(PreviewNode.File(WorkspaceConfigService.FileName));

        foreach (var path in workspaceRootPaths)
        {
            PreviewTreeBuilder.GraftFile(children, path);
        }

        return PreviewTreeBuilder.SortForDisplay(
            new PreviewNode(rootName, PreviewNodeKind.Workspace, children));
    }

    private static string StripWhitespace(string value) =>
        new(value.Where(c => !char.IsWhiteSpace(c)).ToArray());
}
