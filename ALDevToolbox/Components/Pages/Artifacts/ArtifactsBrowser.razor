@page "/artifacts"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject ALDevToolbox.Services.ObjectExplorer.ArtifactService Artifacts
@inject IHttpContextAccessor Http
@using ALDevToolbox.Services.ObjectExplorer

@*
    The Artifacts landing: every project's newest build at a glance, with a one-click
    download of its latest successful build's compiled .app files. Open a project to
    see its full build history, changelog, logs, and per-app downloads. Any signed-in
    user can browse and download. See .design/artifacts.md.

    Named user: a BC developer who needs the latest compiled .app for a customer.
    There is no create action here — projects are created in the Projects tool;
    this is a clean browse-and-download surface.
*@

<PageTitle>Artifacts · AL Dev Toolbox</PageTitle>

<div class="art-page">
    <div class="cb-head">
        <div>
            <h1>Artifacts</h1>
            <p class="sub">
                Download the compiled <code>.app</code> deliverables a project's builds produced.
                Open a project for its full build history, changelog, and logs.
            </p>
        </div>
    </div>

    @if (_rows is null)
    {
        <p class="muted">Loading...</p>
    }
    else if (_totalCount == 0)
    {
        <div class="rel-empty">
            <Icon Name="box" Width="30" Height="30" Css="rel-empty-ico" />
            <div class="rel-empty-h">Nothing built yet</div>
            <p class="rel-empty-p">
                Builds and their downloadable <code>.app</code> files show up here. Create a project and
                start a build in the <a href="/projects">Projects</a> tool.
            </p>
            <a class="btn btn--primary" href="/projects">
                <Icon Name="folder-git-2" Width="16" Height="16" />
                <span>Go to Projects</span>
            </a>
        </div>
    }
    else
    {
        <form method="get" class="cb-toolbar" role="search">
            <div class="cb-search">
                <Icon Name="search" Width="17" Height="17" />
                <input type="search" name="q" value="@_search" class="input"
                       placeholder="Search by name, owner, or repository..."
                       aria-label="Search projects" />
            </div>
            @if (!string.IsNullOrEmpty(_search))
            {
                <a class="btn btn--sm" href="/artifacts">Clear</a>
            }
        </form>

        @if (_rows.Count == 0)
        {
            <p class="muted">
                No projects match "<strong>@_search</strong>". <a href="/artifacts">Clear the search</a>.
            </p>
        }
        else
        {
            <table class="data-table data-table--card">
                <thead>
                    <tr>
                        <th scope="col">Project</th>
                        <th scope="col">Latest build</th>
                        <th scope="col">Built</th>
                        <th scope="col" class="data-table__actions"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in _rows)
                    {
                        <tr>
                            <td>
                                <a href="@($"/artifacts/{p.Id}")"><strong>@p.Name</strong></a>
                                <div class="muted art-app__meta">@p.RepoCount repo@(p.RepoCount == 1 ? "" : "s")@(p.OwnerName is { } o ? $" · {o}" : "")</div>
                            </td>
                            <td>
                                @if (p.Latest is { } b)
                                {
                                    <span class="art-latest">
                                        <BuildStatusPill Status="@b.Status" />
                                        @if (!string.IsNullOrEmpty(b.BcVersion))
                                        {
                                            <span class="muted mono">@b.BcVersion</span>
                                        }
                                    </span>
                                }
                                else
                                {
                                    <span class="muted">No builds yet</span>
                                }
                            </td>
                            <td class="art-history__when">
                                @(p.Latest?.FinishedAt?.ToString("yyyy-MM-dd") ?? p.Latest?.StartedAt.ToString("yyyy-MM-dd") ?? "—")
                            </td>
                            <td class="data-table__actions">
                                @if (p.LatestSuccessfulBuildId is { } sb)
                                {
                                    <a class="btn btn--sm" href="@($"/artifacts/build/{sb}/all")">
                                        <Icon Name="download" Width="14" Height="14" />
                                        <span>Download all</span>
                                    </a>
                                }
                                <a class="btn btn--sm" href="@($"/artifacts/{p.Id}")">
                                    <span>Open</span>
                                    <Icon Name="arrow-right" Width="14" Height="14" />
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    }
</div>

@code {
    private List<ProjectArtifactsRow>? _rows;
    private int _totalCount;
    private string _search = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        _search = Http.HttpContext?.Request.Query["q"].ToString().Trim() ?? string.Empty;
        var all = await Artifacts.ListProjectsAsync();
        _totalCount = all.Count;
        _rows = string.IsNullOrEmpty(_search) ? all : await Artifacts.ListProjectsAsync(_search);
    }
}
