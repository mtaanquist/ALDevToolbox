@page "/artifacts"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject ALDevToolbox.Services.ObjectExplorer.ArtifactService Artifacts
@inject IHttpContextAccessor Http
@using ALDevToolbox.Services.ObjectExplorer

@*
    The Artifacts landing: every project's newest build at a glance, with a one-click
    download of its latest successful build's compiled .app files. Open a project to
    see its full build history, changelog, logs, and per-app downloads. Any signed-in
    user can browse and download. See .design/artifacts.md.

    Named user: a BC developer who needs the latest compiled .app for a customer.
    Projects are created in the Projects tool; the "New project" button links there.
*@

<PageTitle>Artifacts · AL Dev Toolbox</PageTitle>

<div class="art-page">
    <div class="art-head">
        <div class="ah-text">
            <h1>Artifacts</h1>
            <p class="sub">
                Every solution your team builds. Open a project for its latest build,
                downloadable <code>.app</code> deliverables, changelog, and history.
            </p>
        </div>
        <a class="btn btn--primary" href="/projects/new">
            <Icon Name="plus" Width="16" Height="16" />
            <span>New project</span>
        </a>
    </div>

    @if (_rows is null)
    {
        <p class="muted">Loading...</p>
    }
    else if (_totalCount == 0)
    {
        <div class="rel-empty">
            <Icon Name="box" Width="30" Height="30" Css="rel-empty-ico" />
            <div class="rel-empty-h">Nothing built yet</div>
            <p class="rel-empty-p">
                Builds and their downloadable <code>.app</code> files show up here. Create a project and
                point it at the repositories that make up your solution.
            </p>
            <a class="btn btn--primary" href="/projects/new">
                <Icon Name="plus" Width="16" Height="16" />
                <span>New project</span>
            </a>
        </div>
    }
    else
    {
        <form method="get" class="art-toolbar" role="search">
            <div class="art-search">
                <Icon Name="search" Width="17" Height="17" />
                <input type="search" name="q" value="@_search" class="input"
                       placeholder="Search projects by name, owner, or repository..."
                       aria-label="Search projects" />
            </div>
            @if (!string.IsNullOrEmpty(_search))
            {
                <a class="btn btn--sm" href="/artifacts">Clear</a>
            }
            else
            {
                <span class="tb-sort">Sorted by <b>latest build</b></span>
            }
        </form>

        <div class="art-count">
            <b>@_totalCount</b> <span>project@(_totalCount == 1 ? "" : "s")</span>
            @if (_buildingCount > 0)
            {
                <span class="sep">·</span>
                <b>@_buildingCount</b> <span>building now</span>
            }
            @if (_failedCount > 0)
            {
                <span class="sep">·</span>
                <b>@_failedCount</b> <span>need@(_failedCount == 1 ? "s" : "") attention</span>
            }
            @if (!string.IsNullOrEmpty(_search))
            {
                <span class="sep">·</span>
                <span>showing</span> <b>@_rows.Count</b> <span>match@(_rows.Count == 1 ? "" : "es")</span>
            }
        </div>

        @if (_rows.Count == 0)
        {
            <p class="muted">
                No projects match "<strong>@_search</strong>". <a href="/artifacts">Clear the search</a>.
            </p>
        }
        else
        {
            <div class="art-list">
                <div class="alr lean head">
                    <div>Project</div>
                    <div>Latest build</div>
                    <div>Status</div>
                    <div>When</div>
                    <div class="h-blank"></div>
                </div>

                @foreach (var p in _rows)
                {
                    var sb = p.LatestSuccessfulBuildId;
                    var failedLatest = p.Latest?.Status == "failed";
                    <div class="alr lean proj">
                        <div class="al-proj">
                            <span class="al-pico"><Icon Name="package" Width="18" Height="18" /></span>
                            <div class="al-ptext">
                                <a class="al-pname al-rowlink" href="@($"/artifacts/{p.Id}")">@p.Name</a>
                                <div class="al-pmeta">
                                    @if (p.OwnerName is { } owner)
                                    {
                                        <span class="al-avatar">@Initials(owner)</span>
                                        <span>@owner</span>
                                        <span class="dotsep"></span>
                                    }
                                    <span class="reps"><Icon Name="git-branch" Width="12" Height="12" />@p.RepoCount repo@(p.RepoCount == 1 ? "" : "s")</span>
                                </div>
                            </div>
                        </div>

                        <div class="al-build">
                            @if (p.Latest is { } b)
                            {
                                @if (!string.IsNullOrEmpty(b.CommitShort))
                                {
                                    <span class="al-commit"><Icon Name="git-commit-vertical" Width="13" Height="13" />@b.CommitShort</span>
                                }
                                <span class="al-bmeta">
                                    @if (!string.IsNullOrEmpty(b.Branch))
                                    {
                                        <span class="br"><Icon Name="git-branch" Width="12" Height="12" />@b.Branch</span>
                                    }
                                    <span class="al-ver">@(string.IsNullOrEmpty(b.BcVersion) ? "BC —" : $"BC {b.BcVersion}")</span>
                                </span>
                            }
                            else
                            {
                                <span class="muted">No builds yet</span>
                            }
                        </div>

                        <div>
                            @if (p.Latest is { } st)
                            {
                                <BuildStatusPill Status="@st.Status" />
                            }
                            else
                            {
                                <span class="muted">—</span>
                            }
                        </div>

                        <div class="al-date">
                            @if (p.Latest is { } w)
                            {
                                <span title="@AbsoluteWhen(w)">@Verb(w.Status) @TimeAgo(w.FinishedAt ?? w.StartedAt)</span>
                            }
                            else
                            {
                                <span>—</span>
                            }
                        </div>

                        <div class="al-act">
                            <details class="ra__menu">
                                <summary class="ra__solo" title="More actions" aria-label="More actions" aria-haspopup="menu">
                                    <Icon Name="ellipsis-vertical" Width="17" Height="17" />
                                </summary>
                                <div class="ra__pop" role="menu">
                                    <a class="ra__item" href="@($"/artifacts/{p.Id}")" role="menuitem">
                                        <Icon Name="package" Width="15" Height="15" />
                                        <span>View builds</span>
                                    </a>
                                    @if (sb is { } good2)
                                    {
                                        <a class="ra__item" href="@($"/artifacts/build/{good2}/all")" role="menuitem">
                                            <Icon Name="archive" Width="15" Height="15" />
                                            <span>@(failedLatest ? "Download last good build" : "Download all deliverables")</span>
                                        </a>
                                    }
                                    <a class="ra__item" href="@($"/projects/{p.Id}")" role="menuitem">
                                        <Icon Name="settings" Width="15" Height="15" />
                                        <span>Project settings</span>
                                    </a>
                                    <div class="ra__divider"></div>
                                    <button type="button" class="ra__item" data-copy-url="@($"/artifacts/{p.Id}")" role="menuitem">
                                        <Icon Name="copy" Width="15" Height="15" />
                                        <span data-copy-label>Copy link</span>
                                    </button>
                                </div>
                            </details>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    private List<ProjectArtifactsRow>? _rows;
    private int _totalCount;
    private int _buildingCount;
    private int _failedCount;
    private string _search = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        _search = Http.HttpContext?.Request.Query["q"].ToString().Trim() ?? string.Empty;
        var all = await Artifacts.ListProjectsAsync();
        _totalCount = all.Count;
        _buildingCount = all.Count(p => p.Latest?.Status is "building" or "queued");
        _failedCount = all.Count(p => p.Latest?.Status == "failed");
        _rows = string.IsNullOrEmpty(_search) ? all : await Artifacts.ListProjectsAsync(_search);
    }

    private static string Verb(string status) => status switch
    {
        "ready" => "Built",
        "failed" => "Failed",
        "building" => "Started",
        _ => "Queued",
    };

    /// <summary>The full local timestamp, shown as a hover title behind the relative "when".</summary>
    private static string AbsoluteWhen(BuildSummary b) =>
        (b.FinishedAt ?? b.StartedAt).ToString("yyyy-MM-dd HH:mm");

    /// <summary>A compact relative time ("2 days ago", "4 minutes ago") matching the build history.</summary>
    private static string TimeAgo(DateTime utc)
    {
        var span = DateTime.UtcNow - utc;
        if (span < TimeSpan.Zero) span = TimeSpan.Zero;
        return span switch
        {
            { TotalSeconds: < 60 } => "just now",
            { TotalMinutes: < 60 } => Plural((int)span.TotalMinutes, "minute"),
            { TotalHours: < 24 } => Plural((int)span.TotalHours, "hour"),
            { TotalDays: < 7 } => Plural((int)span.TotalDays, "day"),
            { TotalDays: < 30 } => Plural((int)(span.TotalDays / 7), "week"),
            { TotalDays: < 365 } => Plural((int)(span.TotalDays / 30), "month"),
            _ => Plural((int)(span.TotalDays / 365), "year"),
        };

        static string Plural(int n, string unit) => $"{n} {unit}{(n == 1 ? "" : "s")} ago";
    }

    /// <summary>Two-letter avatar initials from an owner's display name.</summary>
    private static string Initials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length == 0) return "?";
        var first = char.ToUpperInvariant(parts[0][0]);
        return parts.Length > 1 ? $"{first}{char.ToUpperInvariant(parts[^1][0])}" : first.ToString();
    }
}
